{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@layouts/*": ["src/layouts/*"],
      "@components/*": ["src/components/*"],
      "@themes/*": ["src/themes/*"],
      "@core/*": ["src/core/*"],
      "@libs/*": ["src/lib/*"],
      "@styles/*": ["src/styles/*"],
      "@store/*": ["src/store/*"],
      "@websites/*": ["src/websites/*"],
      "@data/*": ["src/data/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.astro"]
}