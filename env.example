# Site Configuration
SITE_URL=https://streamvista.com
THEME=iptv
NODE_ENV=development

# Analytics
GOOGLE_ANALYTICS_ID=your-google-analytics-id
HOTJAR_ID=your-hotjar-id

# API Keys (if needed)
API_KEY=your-api-key
DATABASE_URL=your-database-url

# Email Configuration (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Social Media Links
FACEBOOK_URL=https://facebook.com/streamvista
TWITTER_URL=https://twitter.com/streamvista
INSTAGRAM_URL=https://instagram.com/streamvista
YOUTUBE_URL=https://youtube.com/streamvista

# Payment Configuration (if needed)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# CDN Configuration (if needed)
CDN_URL=https://cdn.streamvista.com 