# Copy to .env and fill in values. Used by scripts (e.g. upload-image-to-r2).

# AI (Shopify product enhance: scripts/shopify-gemini-enhance.mjs, shopify-enhance-all.mjs)
# Put keys in root .env and/or .env.<StoreName> (same name you pass to shopify-enhance-all).
OPENAI_API_KEY=
# Comma- or newline-separated Google AI (Gemini) API keys
GEMINI_API_KEYS=
# Optional: single Gemini key instead of GEMINI_API_KEYS
# GEMINI_API_KEY=

# Cloudflare R2 (for homepage-graphics CDN uploads)
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=atlagia
R2_PUBLIC_URL=https://cdn.atlagia.com
