---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

// Get PROJECT_TYPE from environment
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';

// Only show for physical products (hide for IPTV, digital, etc.)
const isPhysical = !['iptv', 'digital', 'streaming'].includes(PROJECT_TYPE.toLowerCase());

if (!isPhysical) {
  return null;
}

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';
const defaultStyles = {
  wrapper: 'bg-neutral-50 rounded-2xl p-8 border border-neutral-200',
  headerWrap: 'mb-6',
  title: 'text-sm font-medium uppercase tracking-widest text-neutral-500 flex items-center gap-2',
  titleIconWrap: 'w-8 h-8 bg-neutral-200 flex items-center justify-center',
  titleIcon: 'w-4 h-4 text-neutral-600',
  titleDivider: 'w-12 h-px bg-neutral-300 mt-2',
  grid: 'grid grid-cols-1 md:grid-cols-2 gap-6',
  column: 'space-y-3',
  heading: 'font-semibold text-neutral-900 text-sm',
  list: 'space-y-2 text-sm text-neutral-600',
  listItem: 'flex items-start',
  bullet: 'w-1.5 h-1.5 bg-neutral-400 rounded-full mt-2 mr-3 flex-shrink-0'
};

let styles = defaultStyles;
try {
  const { luxuryComponentStyle } = await import(`@websites/${siteName}/themes/${theme}/styles/components/luxury.mjs`);
  if (luxuryComponentStyle?.careInstructions) styles = { ...defaultStyles, ...luxuryComponentStyle.careInstructions };
} catch {
  try {
    const { luxuryComponentStyle } = await import(`@themes/${theme}/styles/components/luxury.mjs`);
    if (luxuryComponentStyle?.careInstructions) styles = { ...defaultStyles, ...luxuryComponentStyle.careInstructions };
  } catch (err) {
    console.error('Failed to load CareInstructions styles:', err);
  }
}
---

<div class={`${styles.wrapper} ${className}`}>
  <div class={styles.headerWrap}>
    <h2 class={styles.title}>
      <span class={styles.titleIconWrap}>
        <svg class={styles.titleIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </span>
      Care Instructions
    </h2>
    <div class={styles.titleDivider}></div>
  </div>

  <div class={styles.grid}>
    <div class={styles.column}>
      <h3 class={styles.heading}>Washing</h3>
      <ul class={styles.list}>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Machine wash cold (30°C max)</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Use gentle cycle</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Turn inside out before washing</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Do not bleach</span>
        </li>
      </ul>
    </div>

    <div class={styles.column}>
      <h3 class={styles.heading}>Drying</h3>
      <ul class={styles.list}>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Air dry recommended</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Low heat tumble dry if needed</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Avoid direct sunlight</span>
        </li>
        <li class={styles.listItem}>
          <span class={styles.bullet}></span>
          <span>Remove while slightly damp</span>
        </li>
      </ul>
    </div>
  </div>
</div>
