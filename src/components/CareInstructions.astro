---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

// Get PROJECT_TYPE from environment
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';

// Only show for physical products (hide for IPTV, digital, etc.)
const isPhysical = !['iptv', 'digital', 'streaming'].includes(PROJECT_TYPE.toLowerCase());

if (!isPhysical) {
  return null;
}
---

<div class={`bg-gradient-to-br from-gray-50 to-white rounded-xl p-6 shadow-sm ${className}`}>
  <h2 class="text-2xl font-bold mb-4 text-gray-900 flex items-center gap-2">
    <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
    </svg>
    Care Instructions
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-3">
      <h3 class="font-semibold text-gray-900">Washing</h3>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Machine wash cold (30°C max)</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Use gentle cycle</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Turn inside out before washing</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Do not bleach</span>
        </li>
      </ul>
    </div>
    
    <div class="space-y-3">
      <h3 class="font-semibold text-gray-900">Drying</h3>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Air dry recommended</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Low heat tumble dry if needed</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Avoid direct sunlight</span>
        </li>
        <li class="flex items-start">
          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3 flex-shrink-0"></span>
          <span>Remove while slightly damp</span>
        </li>
      </ul>
    </div>
  </div>
</div>
