---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

// Get PROJECT_TYPE from environment
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';

// Only show for physical products (hide for IPTV, digital, etc.)
const isPhysical = !['iptv', 'digital', 'streaming'].includes(PROJECT_TYPE.toLowerCase());

if (!isPhysical) {
  return null;
}

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';
const defaultStyles = {
  wrapper: 'bg-neutral-50 rounded-2xl p-8 border border-neutral-200',
  title: 'text-sm font-medium uppercase tracking-widest text-neutral-500 mb-4 flex items-center gap-2',
  titleIconWrap: 'w-8 h-8 bg-neutral-200 flex items-center justify-center',
  titleIcon: 'w-4 h-4 text-neutral-600',
  titleDivider: 'w-12 h-px bg-neutral-300 mb-6',
  methodsGrid: 'grid grid-cols-1 md:grid-cols-3 gap-4 mb-6',
  methodCard: 'text-center p-4 bg-white border border-neutral-200 rounded-xl',
  methodTitle: 'text-sm font-medium text-neutral-900 mb-1',
  methodPrice: 'text-xs text-neutral-600',
  methodEta: 'text-xs text-neutral-500 mt-1',
  footnoteWrap: 'text-center text-sm text-neutral-500'
};

let styles = defaultStyles;
try {
  const { luxuryComponentStyle } = await import(`@websites/${siteName}/themes/${theme}/styles/components/luxury.mjs`);
  if (luxuryComponentStyle?.shipping) styles = { ...defaultStyles, ...luxuryComponentStyle.shipping };
} catch {
  try {
    const { luxuryComponentStyle } = await import(`@themes/${theme}/styles/components/luxury.mjs`);
    if (luxuryComponentStyle?.shipping) styles = { ...defaultStyles, ...luxuryComponentStyle.shipping };
  } catch (err) {
    console.error('Failed to load component styles:', err);
  }
}
---

<div class={`${styles.wrapper} ${className}`}>
  <h2 class={styles.title}>
    <span class={styles.titleIconWrap}>
      <svg class={styles.titleIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
    </svg>
    </span>
    Shipping & Delivery
  </h2>
  <div class={styles.titleDivider}></div>

  <div class={styles.methodsGrid}>
    <div class={styles.methodCard}>
      <div class={styles.methodTitle}>Free Shipping</div>
      <div class={styles.methodPrice}>Orders over $75</div>
      <div class={styles.methodEta}>5-7 business days</div>
    </div>
    
    <div class={styles.methodCard}>
      <div class={styles.methodTitle}>Express Delivery</div>
      <div class={styles.methodPrice}>$9.99</div>
      <div class={styles.methodEta}>1-2 business days</div>
    </div>
    
    <div class={styles.methodCard}>
      <div class={styles.methodTitle}>International</div>
      <div class={styles.methodPrice}>From $15.99</div>
      <div class={styles.methodEta}>10-14 business days</div>
    </div>
  </div>

  <div class={styles.footnoteWrap}>
    <p>Processing time: 1-2 business days • Free returns within 30 days</p>
  </div>
</div>
