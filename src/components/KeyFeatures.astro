---
import featuresContent from './content/key-features.json';

interface Props {
  productTitle: string;
  language: string;
}

const { productTitle, language = 'en' } = Astro.props;

// Get PROJECT_TYPE from environment variables
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';

function getProductCategory(title: string): string {
  // First priority: Check PROJECT_TYPE for rep products
  const PROJECT_TYPE_LOWER = PROJECT_TYPE.toLowerCase();
  const title_lower = title.toLowerCase();
  
  if (PROJECT_TYPE_LOWER === 'repbag') {
    return 'bag';
  }
  if (PROJECT_TYPE_LOWER === 'repshoes') {
    return 'shoes';
  }
  if (PROJECT_TYPE_LOWER === 'repwatch') {
    return 'watch';
  }
  
  // IPTV-specific detection
  if (PROJECT_TYPE_LOWER === 'iptv') {
    if (title_lower.includes('iptv') || 
        title_lower.includes('subscription') || 
        title_lower.includes('smart tv') || 
        title_lower.includes('streaming')) {
      return 'iptv';
    }
  }
  
  // Second priority: Check if it's a watch
  if (title_lower.includes('watch') ||
      title_lower.includes('timepiece') ||
      title_lower.includes('chronograph') ||
      title_lower.includes('wristwatch') ||
      title_lower.includes('smartwatch') ||
      title_lower.includes('clock')) {
    return 'watch';
  }

  // Third priority: Check if it's a digital product
  if (PROJECT_TYPE_LOWER === 'degital') {
    if (title_lower.includes('template') || title_lower.includes('theme')) {
      return 'template';
    }
    if (title_lower.includes('plugin') || title_lower.includes('extension')) {
      return 'plugin';
    }
    if (title_lower.includes('script') || title_lower.includes('code')) {
      return 'script';
    }
    return 'digital'; // default digital fallback
  }
  
  // Third priority: Check title for shoe-related terms
  if (title_lower.includes('shoes') || 
      title_lower.includes('boot') ||
      title_lower.includes('sneaker') ||
      title_lower.includes('trainer') ||
      title_lower.includes('footwear') ||
      title_lower.includes('sandal') ||
      title_lower.includes('slipper') ||
      title_lower.includes('loafer') ||
      title_lower.includes('heel') ||
      title_lower.includes('oxford') ||
      title_lower.includes('moccasin') ||
      title_lower.includes('espadrille') ||
      title_lower.includes('pump') ||
      title_lower.includes('flat') ||
      title_lower.includes('derby') ||
      title_lower.includes('brogue') ||
      title_lower.includes('mule') ||
      title_lower.includes('clog')) {
    return 'shoes';
  }
  
  // Original physical product categories
  if (title_lower.includes('jacket') || 
      title_lower.includes('coat') ||
      title_lower.includes('blazer') ||
      title_lower.includes('parka') ||
      title_lower.includes('windbreaker') ||
      title_lower.includes('bomber') ||
      title_lower.includes('cardigan') ||
      title_lower.includes('hoodie') ||
      title_lower.includes('sweater') ||
      title_lower.includes('pullover') ||
      title_lower.includes('vest') ||
      title_lower.includes('gilet') ||
      title_lower.includes('anorak') ||
      title_lower.includes('raincoat') ||
      title_lower.includes('overcoat') ||
      title_lower.includes('peacoat') ||
      title_lower.includes('trench') ||
      title_lower.includes('duster') ||
      title_lower.includes('puffer') ||
      title_lower.includes('down jacket')) {
    return 'jacket';
  }
  
  return PROJECT_TYPE_LOWER === 'shoes' ? 'shoes' : 
         PROJECT_TYPE_LOWER === 'iptv' ? 'iptv' : 
         'jacket'; // default fallback
}

// Get content for current language or fallback to English
const content = featuresContent[language] || featuresContent.en;
const category = getProductCategory(productTitle);

// Get features for the category, fallback to English if not available in current language
const features = content.categories[category]?.features || 
                featuresContent.en.categories[category]?.features || 
                featuresContent.en.categories[PROJECT_TYPE_LOWER === 'degital' ? 'digital' : 
                                               PROJECT_TYPE_LOWER === 'iptv' ? 'iptv' : 
                                               'jacket'].features; // ultimate fallback

const theme = import.meta.env.THEME || 'default';
let styles = {};

try {
  const { luxuryComponentStyle } = await import(`../themes/${theme}/styles/components/luxury.mjs`);
  styles = luxuryComponentStyle.keyFeatures;
} catch (error) {
  console.error('Failed to load component styles:', error);
}
---

<div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-8 shadow-lg border border-blue-100">
  <div class="text-center mb-8">
    <h3 class="text-3xl font-bold text-gray-900 mb-3 flex items-center justify-center gap-3">
      <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      {content.title}
    </h3>
    <div class="w-24 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 mx-auto rounded-full"></div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {features.map((feature, index) => (
      <div class="group relative bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-200 transition-all duration-300 hover:-translate-y-1">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-gray-800 font-medium leading-relaxed group-hover:text-gray-900 transition-colors duration-300">
              {feature}
            </p>
          </div>
        </div>
        
        <!-- Decorative element -->
        <div class="absolute top-4 right-4 w-2 h-2 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
    ))}
  </div>
  
  <!-- Bottom accent -->
  <div class="mt-8 text-center">
    <div class="inline-flex items-center gap-2 text-sm text-gray-600 bg-white/60 px-4 py-2 rounded-full border border-gray-200">
      <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>All features included</span>
    </div>
  </div>
</div> 