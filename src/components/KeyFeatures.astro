---
import featuresContent from './content/key-features.json';

interface Props {
  productTitle: string;
  language: string;
}

const { productTitle, language = 'en' } = Astro.props;

// Get PROJECT_TYPE and site name from environment variables
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';
const SITE_NAME = (import.meta.env.PUBLIC_SITE_NAME || '').toLowerCase();

function getProductCategory(title: string): string {
  const PROJECT_TYPE_LOWER = PROJECT_TYPE.toLowerCase();
  const title_lower = title.toLowerCase();

  // 1) MAP VIA TITLE FIRST — so backpack/handbag shows bag content, jacket shows jacket content
  if (title_lower.includes('watch') || title_lower.includes('timepiece') || title_lower.includes('chronograph') ||
      title_lower.includes('wristwatch') || title_lower.includes('smartwatch') || title_lower.includes('clock')) {
    return 'watch';
  }
  if (title_lower.includes('backpack') || title_lower.includes('handbag') || title_lower.includes(' shoulder bag') ||
      title_lower.includes('clutch') || title_lower.includes('wallet') || title_lower.includes('pouch') ||
      title_lower.includes('tote') || title_lower.includes('satchel') || title_lower.includes('crossbody') ||
      title_lower.includes('hobo') || title_lower.includes('pochette') || title_lower.includes('messenger') ||
      (title_lower.includes('bag') && !title_lower.includes('sleeping bag')) || title_lower.includes('purse')) {
    return 'bag';
  }
  if (title_lower.includes('jacket') || title_lower.includes('coat') || title_lower.includes('blazer') ||
      title_lower.includes('parka') || title_lower.includes('windbreaker') || title_lower.includes('bomber') ||
      title_lower.includes('cardigan') || title_lower.includes('hoodie') || title_lower.includes('sweater') ||
      title_lower.includes('pullover') || title_lower.includes('vest') || title_lower.includes('gilet') ||
      title_lower.includes('anorak') || title_lower.includes('raincoat') || title_lower.includes('overcoat') ||
      title_lower.includes('peacoat') || title_lower.includes('trench') || title_lower.includes('duster') ||
      title_lower.includes('puffer') || title_lower.includes('down jacket')) {
    return 'jacket';
  }
  if (title_lower.includes('shoe') || title_lower.includes('boot') || title_lower.includes('sneaker') ||
      title_lower.includes('trainer') || title_lower.includes('footwear') || title_lower.includes('sandal') ||
      title_lower.includes('slipper') || title_lower.includes('loafer') || title_lower.includes('heel') ||
      title_lower.includes('oxford') || title_lower.includes('moccasin') || title_lower.includes('espadrille') ||
      title_lower.includes('pump') || title_lower.includes('flat') || title_lower.includes('derby') ||
      title_lower.includes('brogue') || title_lower.includes('mule') || title_lower.includes('clog')) {
    return 'shoes';
  }
  if (title_lower.includes('helmet')) return 'helmet';

  // 2) PROJECT_TYPE / site-level override
  if (PROJECT_TYPE_LOWER === 'repbag' || SITE_NAME === 'repbag') return 'bag';
  if (PROJECT_TYPE_LOWER === 'repshoes') return 'shoes';
  if (PROJECT_TYPE_LOWER === 'repwatch') return 'watch';
  if (PROJECT_TYPE_LOWER === 'iptv' && (title_lower.includes('iptv') || title_lower.includes('subscription') || title_lower.includes('streaming'))) return 'iptv';
  if (PROJECT_TYPE_LOWER === 'degital') {
    if (title_lower.includes('template') || title_lower.includes('theme')) return 'template';
    if (title_lower.includes('plugin') || title_lower.includes('extension')) return 'plugin';
    if (title_lower.includes('script') || title_lower.includes('code')) return 'script';
    return 'digital';
  }

  // 3) Default: RepBag site → bag; otherwise jacket for physical
  if (PROJECT_TYPE_LOWER === 'shoes') return 'shoes';
  if (PROJECT_TYPE_LOWER === 'iptv') return 'iptv';
  if (SITE_NAME === 'repbag' || PROJECT_TYPE_LOWER === 'repbag') return 'bag';
  return 'jacket';
}

// Get content for current language or fallback to English
const content = featuresContent[language] || featuresContent.en;
const category = getProductCategory(productTitle);

// Get features for the category, fallback to English if not available in current language
const PROJECT_TYPE_LOWER = (import.meta.env.PROJECT_TYPE || 'default').toLowerCase();
const fallbackCategory = PROJECT_TYPE_LOWER === 'degital' ? 'digital' : PROJECT_TYPE_LOWER === 'iptv' ? 'iptv' : (SITE_NAME === 'repbag' ? 'bag' : 'jacket');
const features = content.categories[category]?.features || 
                featuresContent.en.categories[category]?.features || 
                featuresContent.en.categories[fallbackCategory]?.features || 
                featuresContent.en.categories.bag?.features;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';
const defaultKeyFeatures = {
  wrapper: 'bg-neutral-50 rounded-2xl p-8 border border-neutral-200',
  headerWrap: 'mb-8',
  title: 'text-sm font-medium uppercase tracking-widest text-neutral-500 mb-2 flex items-center gap-2',
  titleIconWrap: 'w-8 h-8 bg-neutral-200 flex items-center justify-center',
  titleIcon: 'w-4 h-4 text-neutral-600',
  titleDivider: 'w-12 h-px bg-neutral-300',
  list: 'grid grid-cols-1 md:grid-cols-2 gap-5',
  item: 'group relative bg-white rounded-xl p-5 border border-neutral-200 hover:border-neutral-300 transition-all duration-200',
  itemContent: 'flex items-start gap-4',
  itemIconWrap: 'flex-shrink-0 w-8 h-8 bg-neutral-200 rounded-full flex items-center justify-center',
  itemIcon: 'w-4 h-4 text-neutral-600',
  textWrap: 'flex-1',
  text: 'text-neutral-700 font-medium leading-relaxed text-sm',
  footerWrap: 'mt-6 text-center',
  footerInner: 'inline-flex items-center gap-2 text-sm text-neutral-500 bg-white px-4 py-2 border border-neutral-200',
  footerIcon: 'w-4 h-4 text-neutral-400'
};
let styles = defaultKeyFeatures;
try {
  const { luxuryComponentStyle } = await import(`@websites/${siteName}/themes/${theme}/styles/components/luxury.mjs`);
  if (luxuryComponentStyle?.keyFeatures) styles = { ...defaultKeyFeatures, ...luxuryComponentStyle.keyFeatures };
} catch {
  try {
    const { luxuryComponentStyle } = await import(`@themes/${theme}/styles/components/luxury.mjs`);
    if (luxuryComponentStyle?.keyFeatures) styles = { ...defaultKeyFeatures, ...luxuryComponentStyle.keyFeatures };
  } catch (err) {
    console.error('Failed to load component styles:', err);
  }
}
---

<div class={styles.wrapper}>
  <div class={styles.headerWrap}>
    <h3 class={styles.title}>
      <span class={styles.titleIconWrap}>
        <svg class={styles.titleIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </span>
      {content.title}
    </h3>
    <div class={styles.titleDivider}></div>
  </div>
  
  <div class={styles.list}>
    {features.map((feature, index) => (
      <div class={styles.item}>
        <div class={styles.itemContent}>
          <div class={styles.itemIconWrap}>
            <svg class={styles.itemIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div class={styles.textWrap}>
            <p class={styles.text}>
              {feature}
            </p>
          </div>
        </div>
      </div>
    ))}
  </div>
  
  <div class={styles.footerWrap}>
    <div class={styles.footerInner}>
      <svg class={styles.footerIcon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>All features included</span>
    </div>
  </div>
</div> 