---
import sizeChartContent from './content/sizeCharts.json';

interface Props {
  productTitle: string;
  language: string;
  handle?: string;
}

const { productTitle, language = 'en', handle } = Astro.props;

// Common size data across all languages
const commonSizes = {
  clothing: [
    ['S', '26.5 inch', '20 inch', '23.98 inch'],
    ['M', '27.48 inch', '21.97 inch', '24.29 inch'],
    ['L', '28.46 inch', '23.98 inch', '24.37 inch'],
    ['XL', '29.53 inch', '24.99 inch', '24.80 inch'],
    ['2XL', '30 inch', '27.95 inch', '25 inch'],
  ],
  shoes: [
    ['6', '5', '38', '23.5'],
    ['7', '6', '39', '24.1'],
    ['8', '7', '40', '24.8'],
    ['9', '8', '41', '25.4'],
    ['10', '9', '42', '26'],
  ],
  // ... other size arrays
};

// Function to determine if product should have size chart
function shouldShowSizeChart(handle: string, productType: string): boolean {
  // Add specific handle checks if needed
  if (handle) {
    const excludedHandles = ['accessory', 'bag', 'wallet'];
    if (excludedHandles.some(excluded => handle.includes(excluded))) {
      return false;
    }
  }

  // Return true if product type has size data
  return !!commonSizes[productType];
}

function getProductType(title: string): string {
  const title_lower = title.toLowerCase();
  
  // First priority: Check PROJECT_TYPE
  if (PROJECT_TYPE === 'repshoes') {
    return 'shoes';
  }
  
  // Second priority: Check title for shoe-related terms
  if (title_lower.includes('shoe') ||
      title_lower.includes('sneaker') ||
      title_lower.includes('trainer') ||
      title_lower.includes('footwear') ||
      title_lower.includes('boot') ||
      title_lower.includes('sandal') ||
      title_lower.includes('slipper') ||
      title_lower.includes('loafer') ||
      title_lower.includes('heel') ||
      title_lower.includes('oxford') ||
      title_lower.includes('moccasin') ||
      title_lower.includes('espadrille') ||
      title_lower.includes('pump') ||
      title_lower.includes('flat') ||
      title_lower.includes('derby') ||
      title_lower.includes('brogue') ||
      title_lower.includes('mule') ||
      title_lower.includes('clog')) {
    return 'shoes';
  }
  
  // Third priority: Check for clothing terms
  if (title_lower.includes('shirt') || 
      title_lower.includes('hoodie') || 
      title_lower.includes('jacket') || 
      title_lower.includes('sweater') ||
      title_lower.includes('vest')) {
    return 'clothing';
  }
  
  return PROJECT_TYPE === 'shoes' ? 'shoes' : null;
}

const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';
const content = sizeChartContent[language] || sizeChartContent['en'];
const productType = getProductType(productTitle);

// Determine if we should show the size chart
const hasChartData = shouldShowSizeChart(handle || '', productType);

// Only proceed if we have content for this product type
const chartContent = productType && content.charts[productType];

// Export hasChartData for use in parent components
Astro.props.hasChartData = hasChartData;
---

{chartContent && hasChartData && (
  <div id="size-chart" class="bg-gradient-to-br from-slate-50 to-gray-50 rounded-2xl p-8 shadow-lg border border-gray-200">
    <!-- Header Section -->
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-3 flex items-center justify-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        {content.title} {productType.charAt(0).toUpperCase() + productType.slice(1)}
      </h2>
      <div class="w-24 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 mx-auto rounded-full"></div>
    </div>
    
    <!-- Size Chart Table -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full">
          <thead class="bg-gradient-to-r from-gray-50 to-slate-50">
            <tr>
              {chartContent.headers.map((header, index) => (
                <th scope="col" class={`px-6 py-4 text-left text-sm font-semibold text-gray-700 uppercase tracking-wider ${
                  index === 0 ? 'bg-gradient-to-r from-blue-50 to-indigo-50' : ''
                }`}>
                  {header}
                </th>
              ))}
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-100">
            {commonSizes[productType].map((sizeRow, rowIndex) => (
              <tr class={`group hover:bg-gradient-to-r hover:from-blue-50 hover:to-indigo-50 transition-all duration-300 ${
                rowIndex % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'
              }`}>
                {sizeRow.map((cell, cellIndex) => (
                  <td class={`px-6 py-4 whitespace-nowrap text-sm transition-colors duration-300 ${
                    cellIndex === 0 
                      ? 'font-semibold text-gray-900 bg-gradient-to-r from-blue-50 to-indigo-50 group-hover:from-blue-100 group-hover:to-indigo-100' 
                      : 'text-gray-600 group-hover:text-gray-800'
                  }`}>
                    {cell}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    
    <!-- Measurement Tips Section -->
    <div class="mt-8 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border border-blue-100 shadow-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">{content.measurementTips}</h3>
          <div class="space-y-3">
            {chartContent.tips.map((tip, index) => (
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-5 h-5 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full flex items-center justify-center mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed">{tip}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom accent -->
    <div class="mt-6 text-center">
      <div class="inline-flex items-center gap-2 text-sm text-gray-600 bg-white/60 px-4 py-2 rounded-full border border-gray-200">
        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Find your perfect fit</span>
      </div>
    </div>
  </div>
)} 