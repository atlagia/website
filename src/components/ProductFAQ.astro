---
import faqContent from './content/faqs.json';

interface Props {
  productTitle: string;
  language: string;
}

const { productTitle, language = 'en' } = Astro.props;

// Get PROJECT_TYPE from environment variables
const PROJECT_TYPE = import.meta.env.PROJECT_TYPE || 'default';

function getProductCategory(title: string): string {
  // First priority: Check PROJECT_TYPE for rep products
  const PROJECT_TYPE_LOWER = PROJECT_TYPE.toLowerCase();
  const title_lower = title.toLowerCase();
  
  if (PROJECT_TYPE_LOWER === 'repbag') {
    return 'bag';
  }
  if (PROJECT_TYPE_LOWER === 'repshoes') {
    return 'shoes';
  }
  if (PROJECT_TYPE_LOWER === 'repwatch') {
    return 'watch';
  }
  
  // IPTV-specific detection
  if (PROJECT_TYPE_LOWER === 'iptv') {
    if (title_lower.includes('iptv') || 
        title_lower.includes('subscription') || 
        title_lower.includes('smart tv') || 
        title_lower.includes('streaming')) {
      return 'iptv';
    }
  }
  
  // Existing category detection logic with case-insensitive checks
  // Second priority: Check if it's a watch
  if (title_lower.includes('watch') ||
      title_lower.includes('timepiece') ||
      title_lower.includes('chronograph') ||
      title_lower.includes('wristwatch') ||
      title_lower.includes('smartwatch') ||
      title_lower.includes('clock')) {
    return 'watch';
  }

  // Third priority: Check if it's a digital product
  if (PROJECT_TYPE_LOWER === 'degital') {
    if (title_lower.includes('template') || title_lower.includes('theme')) {
      return 'template';
    }
    if (title_lower.includes('plugin') || title_lower.includes('extension')) {
      return 'plugin';
    }
    if (title_lower.includes('script') || title_lower.includes('code')) {
      return 'script';
    }
    return 'digital'; // default digital fallback
  }
  
  // Fourth priority: Check other categories
  // Original physical product categories
  if (title_lower.includes('jacket') || title_lower.includes('coat')) {
    return 'jacket';
  }
  if (title_lower.includes('shoe') || title_lower.includes('boot')) {
    return 'shoes';
  }
  if (title_lower.includes('helmet')) {
    return 'helmet';
  }
  
  return PROJECT_TYPE_LOWER === 'degital' ? 'digital' : 
         PROJECT_TYPE_LOWER === 'iptv' ? 'iptv' : 
         'jacket'; // default fallback
}

// Get content for current language or fallback to English
const content = faqContent[language] || faqContent.en;
const category = getProductCategory(productTitle);

// Get FAQs for the category, fallback to English if not available in current language
const faqs = content.categories[category]?.questions || 
            faqContent.en.categories[category]?.questions || 
            faqContent.en.categories[PROJECT_TYPE === 'degital' ? 'digital' : 
                                      PROJECT_TYPE === 'iptv' ? 'iptv' : 
                                      'jacket'].questions; // ultimate fallback

const theme = import.meta.env.THEME || 'default';
let styles = {};

try {
  const { luxuryComponentStyle } = await import(`../themes/${theme}/styles/components/luxury.mjs`);
  styles = luxuryComponentStyle.faq;
} catch (error) {
  console.error('Failed to load component styles:', error);
}
---

<div class="bg-gradient-to-br from-gray-50 to-slate-50 rounded-2xl p-8 shadow-lg border border-gray-200">
  <div class="text-center mb-8">
    <h3 class="text-3xl font-bold text-gray-900 mb-3 flex items-center justify-center gap-3">
      <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      {content.title}
    </h3>
    <div class="w-24 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 mx-auto rounded-full"></div>
  </div>
  
  <div class="space-y-4">
    {faqs.map((faq, index) => (
      <div class="group bg-white rounded-xl border border-gray-200 hover:border-blue-200 hover:shadow-md transition-all duration-300 overflow-hidden">
        <div class="p-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <span class="text-white font-bold text-sm">Q</span>
            </div>
            <div class="flex-1">
              <h4 class="text-lg font-semibold text-gray-900 mb-3 group-hover:text-blue-900 transition-colors duration-300">
                {faq.q}
              </h4>
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-gradient-to-r from-green-400 to-emerald-500 rounded-full flex items-center justify-center mt-0.5">
                  <span class="text-white font-bold text-xs">A</span>
                </div>
                <p class="text-gray-700 leading-relaxed group-hover:text-gray-800 transition-colors duration-300">
                  {faq.a}
                </p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Decorative border -->
        <div class="h-1 bg-gradient-to-r from-blue-400 via-indigo-400 to-blue-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      </div>
    ))}
  </div>
  
  <!-- Bottom accent -->
  <div class="mt-8 text-center">
    <div class="inline-flex items-center gap-2 text-sm text-gray-600 bg-white/60 px-4 py-2 rounded-full border border-gray-200">
      <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 100 19.5 9.75 9.75 0 000-19.5z"></path>
      </svg>
      <span>Still have questions? Contact us!</span>
    </div>
  </div>
</div>