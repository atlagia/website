---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`bg-gradient-to-br from-gray-50 to-white rounded-xl p-6 shadow-sm ${className}`}>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
      <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
      Recently Viewed
    </h2>
    <button 
      id="clearHistory" 
      class="text-sm text-gray-500 hover:text-gray-700 underline transition-colors"
    >
      Clear History
    </button>
  </div>

  <!-- Recently Viewed Products Container -->
  <div id="recentlyViewedContainer" class="hidden">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="recentlyViewedGrid">
      <!-- Products will be inserted here by JavaScript -->
    </div>
  </div>

  <!-- Empty State -->
  <div id="emptyState" class="text-center py-8">
    <div class="text-gray-400 mb-3">
      <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
    </div>
    <p class="text-gray-600 text-sm">No recently viewed items</p>
  </div>
</div>

<script>
  class RecentlyViewed {
    constructor() {
      this.storageKey = 'recentlyViewed';
      this.maxItems = 10;
      this.container = document.getElementById('recentlyViewedContainer');
      this.grid = document.getElementById('recentlyViewedGrid');
      this.emptyState = document.getElementById('emptyState');
      this.clearButton = document.getElementById('clearHistory');
      
      this.init();
    }

    init() {
      // Add current product to recently viewed (if on product page)
      this.addCurrentProduct();
      
      // Display recently viewed products
      this.displayProducts();
      
      // Setup clear history button
      this.clearButton?.addEventListener('click', () => {
        this.clearHistory();
      });
    }

    addCurrentProduct() {
      // Check if we're on a product page
      const productData = this.getCurrentProductData();
      if (productData) {
        this.addProduct(productData);
      }
    }

    getCurrentProductData() {
      // Try to extract product data from the current page
      const title = document.querySelector('h1')?.textContent?.trim();
      const image = document.querySelector('#mainImage')?.src;
      const price = document.querySelector('[data-price]')?.textContent?.trim();
      const handle = window.location.pathname.split('/').pop();

      if (title && image && handle && window.location.pathname.includes('/products/')) {
        return {
          id: handle,
          title: title,
          image: image,
          price: price || 'Price not available',
          handle: handle,
          url: window.location.pathname,
          timestamp: Date.now()
        };
      }
      return null;
    }

    addProduct(productData) {
      let recentlyViewed = this.getRecentlyViewed();
      
      // Remove if already exists
      recentlyViewed = recentlyViewed.filter(item => item.id !== productData.id);
      
      // Add to beginning
      recentlyViewed.unshift(productData);
      
      // Limit to maxItems
      if (recentlyViewed.length > this.maxItems) {
        recentlyViewed = recentlyViewed.slice(0, this.maxItems);
      }
      
      // Save to localStorage
      localStorage.setItem(this.storageKey, JSON.stringify(recentlyViewed));
    }

    getRecentlyViewed() {
      try {
        const stored = localStorage.getItem(this.storageKey);
        return stored ? JSON.parse(stored) : [];
      } catch (error) {
        console.error('Error parsing recently viewed data:', error);
        return [];
      }
    }

    displayProducts() {
      const products = this.getRecentlyViewed();
      
      if (products.length === 0) {
        this.showEmptyState();
        return;
      }

      // Filter out current product if on product page
      const currentHandle = window.location.pathname.split('/').pop();
      const filteredProducts = products.filter(product => product.handle !== currentHandle);
      
      if (filteredProducts.length === 0) {
        this.showEmptyState();
        return;
      }

      this.showProducts(filteredProducts);
    }

    showEmptyState() {
      if (this.container) this.container.classList.add('hidden');
      if (this.emptyState) this.emptyState.classList.remove('hidden');
    }

    showProducts(products) {
      if (this.emptyState) this.emptyState.classList.add('hidden');
      if (this.container) this.container.classList.remove('hidden');
      
      if (!this.grid) return;

      this.grid.innerHTML = products.map(product => `
        <div class="bg-white rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
          <a href="${product.url}" class="block">
            <div class="aspect-square overflow-hidden bg-gray-50">
              <img 
                src="${product.image}" 
                alt="${product.title}"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-3">
              <h3 class="font-medium text-gray-900 text-sm line-clamp-2 mb-1">
                ${product.title}
              </h3>
              <div class="flex items-center justify-between">
                <span class="text-sm text-gray-900">${product.price}</span>
                <button 
                  onclick="recentlyViewedInstance.removeProduct('${product.id}')"
                  class="text-xs text-gray-400 hover:text-gray-600"
                >
                  ×
                </button>
              </div>
            </div>
          </a>
        </div>
      `).join('');
    }

    removeProduct(productId) {
      let recentlyViewed = this.getRecentlyViewed();
      recentlyViewed = recentlyViewed.filter(item => item.id !== productId);
      localStorage.setItem(this.storageKey, JSON.stringify(recentlyViewed));
      this.displayProducts();
    }

    clearHistory() {
      localStorage.removeItem(this.storageKey);
      this.displayProducts();
    }

    getTimeAgo(timestamp) {
      const now = Date.now();
      const diff = now - timestamp;
      const minutes = Math.floor(diff / 60000);
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);

      if (days > 0) return `${days}d ago`;
      if (hours > 0) return `${hours}h ago`;
      if (minutes > 0) return `${minutes}m ago`;
      return 'Just now';
    }
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    window.recentlyViewedInstance = new RecentlyViewed();
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
