---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { RefreshCw, AlertCircle, Package, CreditCard, Clock, Building, Mail, Phone } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const { default: BaseHead } = await import(`../themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../themes/${theme}/components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  },
  support: {
    hours: import.meta.env.PUBLIC_SUPPORT_HOURS || 'Monday - Friday, 9 AM - 6 PM (GMT+3)',
    email: import.meta.env.PUBLIC_SUPPORT_EMAIL || 'returns@glamorfoot.com'
  }
};

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Returns & Refunds | ${businessInfo.name}`}
      description={`Returns and refund policy information for ${businessInfo.name} orders`}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-bold text-center mb-8">Returns & Refunds Policy</h1>
      
      <div class="prose max-w-none mb-12">
        <p class="text-lg text-gray-700 mb-8">
          At {businessInfo.name}, we want you to be completely satisfied with your purchase. If you're not entirely happy with your order, we're here to help with an easy returns process.
        </p>

        <!-- Return Policy Overview -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <RefreshCw class="w-6 h-6" /> Return Policy Overview
          </h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3 flex items-center gap-2">
                <Clock class="w-5 h-5" /> Return Window
              </h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>30 days from delivery date</li>
                <li>Items must be unworn</li>
                <li>Original tags attached</li>
                <li>In original packaging</li>
              </ul>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3 flex items-center gap-2">
                <Package class="w-5 h-5" /> Return Shipping
              </h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Free returns in Turkey</li>
                <li>Customer pays international return shipping</li>
                <li>Return label provided for domestic returns</li>
                <li>Tracked shipping required</li>
              </ul>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3 flex items-center gap-2">
                <CreditCard class="w-5 h-5" /> Refund Process
              </h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Processed within 5-7 business days</li>
                <li>Original payment method</li>
                <li>Full refund including initial shipping</li>
                <li>Email confirmation when processed</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Return Process -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <Package class="w-6 h-6" /> Return Process
          </h2>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <ol class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="bg-gray-100 rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 mt-1">1</span>
                <div>
                  <h3 class="font-semibold">Initiate Your Return</h3>
                  <p class="text-gray-600">Log into your account and select the order you wish to return. Fill out the return form indicating your reason for return.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="bg-gray-100 rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 mt-1">2</span>
                <div>
                  <h3 class="font-semibold">Package Your Return</h3>
                  <p class="text-gray-600">Ensure all items are unworn, undamaged, and in their original packaging with all tags attached.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="bg-gray-100 rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 mt-1">3</span>
                <div>
                  <h3 class="font-semibold">Ship Your Return</h3>
                  <p class="text-gray-600">Use the provided return label (domestic) or ship to our returns address using a tracked service (international).</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="bg-gray-100 rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0 mt-1">4</span>
                <div>
                  <h3 class="font-semibold">Refund Processing</h3>
                  <p class="text-gray-600">Once we receive and inspect your return, we'll process your refund within 5-7 business days.</p>
                </div>
              </li>
            </ol>
          </div>
        </section>

        <!-- Non-Returnable Items -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <AlertCircle class="w-6 h-6" /> Non-Returnable Items
          </h2>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <ul class="list-disc pl-5 space-y-2 text-gray-700">
              <li>Items marked as "Final Sale"</li>
              <li>Personal items (for hygiene reasons)</li>
              <li>Damaged or worn items</li>
              <li>Items without original tags</li>
              <li>Items not in original packaging</li>
              <li>Gift cards</li>
            </ul>
          </div>
        </section>

        <!-- Contact Information -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6">Need Help?</h2>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <div class="grid gap-4 md:grid-cols-2">
              <div class="flex items-start gap-3">
                <Building class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Returns Address</h3>
                  <p>{businessInfo.address.street}, {businessInfo.address.postalCode} {businessInfo.address.city}/{businessInfo.address.region}, {businessInfo.address.country}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Mail class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Email Support</h3>
                  <a href={`mailto:${businessInfo.support.email}`} class="text-blue-600 hover:underline">
                    {businessInfo.support.email}
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Phone class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Customer Service</h3>
                  <a href={`tel:${businessInfo.phone}`} class="text-blue-600 hover:underline">
                    {businessInfo.phone}
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Clock class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Support Hours</h3>
                  <p>{businessInfo.support.hours}</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html> 