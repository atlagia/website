---
import Layout from '@layouts/Layoutp.astro';
import { useCartStore } from '../../store/cart';

const { lang } = Astro.params;
const searchParams = Astro.url.searchParams;
const total = searchParams.get('total');

// Get payment config from layout
const paymentConfig = {
  method: import.meta.env.PUBLIC_PAYMENT_METHOD,
  hoodpay: {
    apiUrl: import.meta.env.HOODPAY_API_URL,
    businessId: import.meta.env.HOODPAY_BUSINESS_ID,
    authToken: import.meta.env.HOODPAY_AUTH_TOKEN,
    redirectUrl: `${import.meta.env.DOMAINE}${import.meta.env.HOODPAY_REDIRECT_URL}`
  }
};

// Translations
const translations = {
  en: {
    title: 'Checkout',
    shipping: 'Shipping Information',
    firstName: 'First Name',
    lastName: 'Last Name',
    email: 'Email',
    phone: 'Phone',
    address: 'Address',
    city: 'City',
    country: 'Country',
    postalCode: 'Postal Code',
    payButton: 'Pay Now',
    total: 'Total',
  },
  // Add other languages as needed
};

const t = translations[lang] || translations.en;
---

<Layout title={t.title}>
  <div class="max-w-2xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">{t.title}</h1>
    
    <div class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">{t.shipping}</h2>
      
      <form id="checkoutForm" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">{t.firstName}</label>
            <input type="text" name="firstName" required
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">{t.lastName}</label>
            <input type="text" name="lastName" required
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">{t.email}</label>
          <input type="email" name="email" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">{t.phone}</label>
          <input type="tel" name="phone" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">{t.address}</label>
          <input type="text" name="address" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
          />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">{t.city}</label>
            <input type="text" name="city" required
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">{t.postalCode}</label>
            <input type="text" name="postalCode" required
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700">{t.country}</label>
          <select name="country" required
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500"
          >
            <option value="US">United States</option>
            <option value="CA">Canada</option>
            <option value="GB">United Kingdom</option>
            <!-- Add more countries as needed -->
          </select>
        </div>

        <div class="border-t pt-4 mt-6">
          <div class="flex justify-between items-center text-xl font-semibold">
            <span>{t.total}:</span>
            <span>${total}</span>
          </div>
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors duration-200 flex items-center justify-center gap-2"
        >
          <span>{t.payButton}</span>
          <span id="processingIndicator" class="hidden">
            <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </span>
        </button>
      </form>
    </div>
  </div>
</Layout>

<script define:vars={{ paymentConfig, total }}>
  document.getElementById('checkoutForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const form = e.target;
    const button = form.querySelector('button[type="submit"]');
    const processingIndicator = document.getElementById('processingIndicator');
    
    try {
      button.disabled = true;
      processingIndicator.classList.remove('hidden');

      const formData = new FormData(form);
      const shippingInfo = Object.fromEntries(formData.entries());

      const paymentData = {
        currency: 'USD',
        amount: Math.round(parseFloat(total)),
        customerEmail: shippingInfo.email,
        metadata: {
          shipping: JSON.stringify(shippingInfo)
        }
      };

      const response = await fetch(`${paymentConfig.hoodpay.apiUrl}/businesses/${paymentConfig.hoodpay.businessId}/payments`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${paymentConfig.hoodpay.authToken}`,
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          ...paymentData,
          redirectUrl: paymentConfig.hoodpay.redirectUrl
        })
      });

      if (!response.ok) {
        throw new Error(`Payment creation failed: ${response.statusText}`);
      }

      const data = await response.json();
      window.location.href = data.data.url;
      
    } catch (error) {
      console.error('Checkout error:', error);
      alert('An error occurred during checkout. Please try again.');
      
      button.disabled = false;
      processingIndicator.classList.add('hidden');
    }
  });
</script> 