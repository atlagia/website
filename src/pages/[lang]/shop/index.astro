---
import Layout from '@layouts/Layoutc.astro';
import ProductCard from '@themes/default/components/ProductCard';
import { getPaginatedTranslatedProducts, getAllCollections } from '@libs/shopify';
import { getPaginatedProducts } from '@libs/woocommerce';
import { generateCacheKey, getCachedPage, cachePageContent } from '@libs/cache';
import { Grid, List, Tag, Star, TrendingUp, Award, Zap } from 'lucide-react';
import FilterSidebar from '@components/FilterSidebar.astro';
import SortDropdown from '@components/SortDropdown.astro';
import ReactiveProductCard from '@components/ReactiveProductCard.tsx';
// Dynamic imports based on environment
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || 'RidWear';
const THEME = import.meta.env.THEME || 'default';

// Get page and locale
const page = Number(Astro.url.searchParams.get('page')) || 1;
const PRODUCTS_PER_PAGE = 20;
const { lang = 'en' } = Astro.params;

let contentData;
let filterData;

try {
  // Try to load from current website theme path
  contentData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/shop/shop_${lang}.json`);
  filterData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-filters.json`);
} catch (error) {
  try {
    // Fallback to English
    contentData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/shop/shop_en.json`);
    filterData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-filters.json`);
  } catch (fallbackError) {
    // Final fallback to default data
    contentData = await import('@data/shop-content.json');
    filterData = await import('@data/shop-filters.json');
  }
}

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME;
const dataType = import.meta.env.DATA_TYPE?.toLowerCase() || 'shopify';

// Get content for current language
const content = contentData.default || contentData;

// Parse current filters from URL
const url = Astro.url;
const currentFilters: Record<string, string[]> = {};
url.searchParams.forEach((value, key) => {
  if (key === 'color' || key === 'size' || key === 'availability') {
    if (!currentFilters[key]) currentFilters[key] = [];
    currentFilters[key].push(value);
  }
});

// Get current sort parameter
const currentSort = url.searchParams.get('sort') || '';

// Add this helper function that doesn't use document
function stripHtml(html: string) {
  if (!html) return '';
  
  // First, remove script and style tags and their contents
  let text = html.replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '');
  text = text.replace(/<style\b[^<]*(?:(?!<\/style>)<[^<]*)*<\/style>/gi, '');
  
  // Then remove all remaining HTML tags
  text = text.replace(/<[^>]+>/g, ' ');
  
  // Replace multiple spaces, newlines, and tabs with a single space
  text = text.replace(/\s+/g, ' ');
  
  // Decode HTML entities
  text = text.replace(/&nbsp;/g, ' ')
             .replace(/&amp;/g, '&')
             .replace(/&lt;/g, '<')
             .replace(/&gt;/g, '>')
             .replace(/&quot;/g, '"')
             .replace(/&#039;/g, "'");
  
  // Trim whitespace
  return text.trim();
}

// Generate cache key for this page
const cacheKey = generateCacheKey(`/shop?page=${page}`, lang);
const cachedContent = await getCachedPage(cacheKey);

if (cachedContent) {
  console.log('✅ Serving cached shop page:', cacheKey);
  return new Response(cachedContent, {
    headers: {
      'Content-Type': 'text/html;charset=UTF-8',
      'X-Cache': 'HIT',
    },
  });
}

// Fetch products based on data source
let products = [];
let pagination = {
  currentPage: page,
  totalPages: 0,
  totalProducts: 0,
  hasNextPage: false,
  hasPreviousPage: false
};

try {
  if (dataType === 'shopify') {
    console.log('🛍️ Fetching from Shopify');
    const shopifyData = await getPaginatedTranslatedProducts(page, PRODUCTS_PER_PAGE, lang);
    products = shopifyData.products;
    pagination = shopifyData.pagination;
  } else if (dataType === 'woocommerce') {
    console.log('🛍️ Fetching from WooCommerce');
    const wooData = await getPaginatedProducts(page, PRODUCTS_PER_PAGE);
    
    // Transform WooCommerce data to match Shopify structure
    products = wooData.products.map(product => ({
      node: {
        id: product.id.toString(),
        title: product.name,
        handle: product.slug,
        description: stripHtml(product.description || ''),
        variants: {
          edges: [{
            node: {
              price: {
                amount: product.price,
                currencyCode: 'USD'
              },
              compareAtPrice: product.regular_price ? {
                amount: product.regular_price,
                currencyCode: 'USD'
              } : null
            }
          }]
        },
        images: {
          edges: product.images.map(image => ({
            node: {
              url: image.src,
              altText: image.alt || product.name
            }
          }))
        }
      }
    }));
    
    pagination = wooData.pagination;
  } else {
    throw new Error(`Unsupported data type: ${dataType}`);
  }
} catch (error) {
  console.error(`❌ Error fetching products:`, error);
  return new Response('Error fetching products', { status: 500 });
}

// Fetch collections
let collections = [];
try {
  if (dataType === 'shopify') {
    console.log('📚 Fetching collections from Shopify');
    collections = await getAllCollections(lang);
  } else {
    // For WooCommerce, create mock collections
    collections = [
      {
        node: {
          id: '1',
          title: 'Featured Products',
          handle: 'featured',
          description: 'Our most popular products',
          image: { url: 'https://via.placeholder.com/400x300/1f2937/ffffff?text=Featured', altText: 'Featured Products' }
        }
      },
      {
        node: {
          id: '2',
          title: 'New Arrivals',
          handle: 'new-arrivals',
          description: 'Latest products in our store',
          image: { url: 'https://via.placeholder.com/400x300/1f2937/ffffff?text=New+Arrivals', altText: 'New Arrivals' }
        }
      },
      {
        node: {
          id: '3',
          title: 'Best Sellers',
          handle: 'best-sellers',
          description: 'Our top-selling products',
          image: { url: 'https://via.placeholder.com/400x300/1f2937/ffffff?text=Best+Sellers', altText: 'Best Sellers' }
        }
      }
    ];
  }
} catch (error) {
  console.error(`❌ Error fetching collections:`, error);
  collections = [];
}
---

<Layout title={content.pageTitle || siteName} description={content.pageDescription || content.pageTitle || ''} lang={lang}>
  <main class="max-w-7xl mx-auto px-4 pb-8 pt-[100px]">
    {/* Breadcrumbs */}
    <nav class="mb-8">
      <ol class="flex items-center space-x-2 text-sm">
        <li>
          <a href={`/${lang}`} class="text-gray-500 hover:text-gray-700">{content.breadcrumbs?.home || 'Home'}</a>
        </li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">{content.breadcrumbs?.shop || 'Shop'}</li>
      </ol>
    </nav>

    {/* Page Header */}
    <header class="text-center mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{content.pageTitle || 'Shop'}</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        {content.pageDescription || content.pageTitle || ''}
      </p>
    </header>

    {/* Mobile Filter Toggle */}
    <div class="lg:hidden mb-6">
      <button 
        id="mobile-filter-toggle"
        class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
{content.filters?.title || 'Filters'} & Sort
      </button>
    </div>

    {/* Main Content with Sidebar */}
    <div class="flex flex-col lg:flex-row gap-8">
      {/* Mobile Filter Overlay */}
      <div 
        id="mobile-filter-overlay"
        class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden lg:hidden"
      ></div>

      {/* Sidebar Filters */}
      <aside 
        id="filter-sidebar"
        class="w-full lg:w-80 flex-shrink-0 fixed lg:relative top-0 left-0 h-full lg:h-auto bg-white z-40 lg:z-auto transform -translate-x-full lg:translate-x-0 lg:top-auto lg:left-auto lg:transform-none transition-transform duration-300 ease-in-out lg:block"
      >
        <div class="p-4 lg:p-0">
          <div class="flex items-center justify-between mb-4 lg:hidden">
            <h3 class="text-lg font-semibold">{content.filters?.title || 'Filters'}</h3>
            <button 
              id="close-mobile-filters"
              class="p-2 hover:bg-gray-100 rounded-full"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <FilterSidebar language={lang} currentFilters={currentFilters} filterData={filterData?.default || {}} />
        </div>
      </aside>

      {/* Main Content Area */}
      <div class="flex-1 w-full">
        {/* Top Controls */}
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
          <!-- View Toggle -->
          <div class="flex items-center space-x-2">
            <button class="p-2 rounded-md bg-white border border-gray-300 hover:bg-gray-50 transition-colors">
              <Grid className="w-5 h-5 text-gray-600" />
            </button>
            <button class="p-2 rounded-md bg-gray-50 border border-gray-300 hover:bg-gray-100 transition-colors">
              <List className="w-5 h-5 text-gray-600" />
            </button>
          </div>

          <!-- Sort Dropdown and Product Count -->
          <div class="flex items-center gap-4">
            <SortDropdown language={lang} currentSort={currentSort} />
            <div class="text-sm text-gray-600 hidden sm:block">
              {pagination.totalProducts} {content.collections?.count || 'products'}
            </div>
          </div>
        </div>

        {/* Mobile Product Count */}
        <div class="text-sm text-gray-600 mb-4 sm:hidden">
          {pagination.totalProducts} {content.collections?.count || 'products'}
        </div>

        {/* Products Grid */}
        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 sm:gap-4 lg:gap-6 mb-16">
          {products.map((product) => {
            // Handle both Shopify and WooCommerce data structures
            const node = product.node;
            const price = dataType === 'shopify' 
              ? (node.variants?.edges?.[0]?.node?.price?.amount || 
                 node.priceRange?.minVariantPrice?.amount || 
                 '0')
              : node.variants.edges[0].node.price.amount;
              
            const compareAtPrice = dataType === 'shopify'
              ? node.variants?.edges?.[0]?.node?.compareAtPrice?.amount
              : node.variants.edges[0].node.compareAtPrice?.amount;
              
            const imageUrl = dataType === 'shopify'
              ? node.images?.edges?.[0]?.node?.url
              : node.images.edges[0].node.url;

            const currencyCode = dataType === 'shopify'
              ? (node.variants?.edges?.[0]?.node?.price?.currencyCode || 'USD')
              : 'USD';
            
            return (
              <ReactiveProductCard 
                client:load
                product={{
                  id: node.id,
                  title: node.title,
                  handle: node.handle,
                  price: { amount: price, currencyCode: currencyCode },
                  compareAtPrice: compareAtPrice ? { amount: compareAtPrice, currencyCode: currencyCode } : undefined,
                  image: imageUrl ? { url: imageUrl, altText: node.title } : undefined
                }}
                lang={lang}
                content={content}
              />
            );
          })}
        </div>

        <!-- Pagination -->
        <div class="flex justify-center items-center gap-4 mt-12">
          {pagination.hasPreviousPage && (
            <a
              href={`/${lang}/shop?page=${page - 1}`}
              class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition-colors"
            >
{content.pagination?.previous || 'Previous'}
            </a>
          )}
          
          <span class="text-gray-600">
            Page {pagination.currentPage} of {pagination.totalPages}
          </span>
          
          {pagination.hasNextPage && (
            <a
              href={`/${lang}/shop?page=${page + 1}`}
              class="px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition-colors"
            >
{content.pagination?.next || 'Next'}
            </a>
          )}
        </div>

        <div class="text-center text-sm text-gray-500 mt-4">
          Showing {(page - 1) * PRODUCTS_PER_PAGE + 1} - {Math.min(page * PRODUCTS_PER_PAGE, pagination.totalProducts)} 
          of {pagination.totalProducts} products
        </div>
      </div>
    </div>

    {/* Collections Section */}
    <section class="mt-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.collections?.title || 'Collections'}</h2>
        <p class="text-lg text-gray-600">{content.collections?.description || 'Browse our curated collections'}</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {collections.map((collection) => {
          const node = collection.node;
          return (
            <a 
              href={`/${lang}/collections/${node.handle}`}
              class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100"
            >
              <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
                {node.image?.url ? (
                  <img 
                    src={node.image.url} 
                    alt={node.image.altText || node.title}
                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-blue-50 to-purple-50">
                    <Tag className="w-12 h-12 text-blue-400" />
                  </div>
                )}
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-20 transition-all duration-300"></div>
                <div class="absolute top-4 right-4 bg-white bg-opacity-90 backdrop-blur-sm rounded-full px-3 py-1 text-xs font-medium text-gray-700">
                  Collection
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                  {node.title}
                </h3>
                {node.description && (
                  <p class="text-gray-600 text-sm line-clamp-2">
                    {node.description}
                  </p>
                )}
                  <div class="mt-4 flex items-center text-blue-600 group-hover:translate-x-1 transition-transform duration-300">
                    <span class="text-sm font-medium">{content.collections?.exploreCollection || 'Explore Collection'}</span>
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    {/* Why Choose Us Section */}
    <section class="mt-20 bg-gradient-to-r from-gray-50 to-blue-50 rounded-2xl p-8 md:p-12">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.whyChooseUs?.title || 'Why Choose Us'}</h2>
        <p class="text-lg text-gray-600">{content.whyChooseUs?.description || 'We provide the best products and service'}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <Zap className="w-8 h-8 text-blue-600" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{content.whyChooseUs?.instantAccess?.title || 'Instant Access'}</h3>
          <p class="text-gray-600">{content.whyChooseUs?.instantAccess?.description || 'Get immediate access to all products'}</p>
        </div>
        
        <div class="text-center">
          <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <Award className="w-8 h-8 text-green-600" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{content.whyChooseUs?.premiumQuality?.title || 'Premium Quality'}</h3>
          <p class="text-gray-600">{content.whyChooseUs?.premiumQuality?.description || 'High-quality products you can trust'}</p>
        </div>
        
        <div class="text-center">
          <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <Star className="w-8 h-8 text-purple-600" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">{content.whyChooseUs?.support?.title || '24/7 Support'}</h3>
          <p class="text-gray-600">{content.whyChooseUs?.support?.description || 'Round-the-clock customer support'}</p>
        </div>
      </div>
    </section>

    {/* Featured Stats */}
    <section class="mt-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.stats?.title || "Our Stats"}</h2>
        <p class="text-lg text-gray-600">{content.stats?.description || "Numbers that speak for themselves"}</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white p-6 rounded-xl text-center hover:scale-105 transition-transform duration-300">
          <Star className="w-8 h-8 mx-auto mb-2" />
          <div class="text-2xl font-bold">4.9</div>
          <div class="text-sm opacity-90">{content.stats?.customerRating || "Customer Rating"}</div>
        </div>
        <div class="bg-gradient-to-r from-green-500 to-green-600 text-white p-6 rounded-xl text-center hover:scale-105 transition-transform duration-300">
          <TrendingUp className="w-8 h-8 mx-auto mb-2" />
          <div class="text-2xl font-bold">12K+</div>
          <div class="text-sm opacity-90">{content.stats?.happyCustomers || "Happy Customers"}</div>
        </div>
        <div class="bg-gradient-to-r from-purple-500 to-purple-600 text-white p-6 rounded-xl text-center hover:scale-105 transition-transform duration-300">
          <Award className="w-8 h-8 mx-auto mb-2" />
          <div class="text-2xl font-bold">24/7</div>
          <div class="text-sm opacity-90">{content.stats?.support || "Support"}</div>
        </div>
        <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-white p-6 rounded-xl text-center hover:scale-105 transition-transform duration-300">
          <Zap className="w-8 h-8 mx-auto mb-2" />
          <div class="text-2xl font-bold">HD</div>
          <div class="text-sm opacity-90">{content.stats?.quality || "Quality"}</div>
        </div>
      </div>
    </section>

    {/* Newsletter Signup */}
    <section class="mt-20 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 md:p-12 text-white text-center">
      <h2 class="text-3xl font-bold mb-4">{content.newsletter?.title || "Stay Updated"}</h2>
      <p class="text-lg opacity-90 mb-8 max-w-2xl mx-auto">
        {content.newsletter?.description || "Get the latest updates and offers"}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input 
          type="email" 
          placeholder={content.newsletter?.emailPlaceholder || "Enter your email"}
          class="flex-1 px-4 py-3 rounded-lg text-gray-900 focus:outline-none focus:ring-2 focus:ring-white"
        />
        <button class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors">
          {content.newsletter?.subscribeButton || "Subscribe"}
        </button>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Handle dynamic loading states
  document.addEventListener('astro:page-load', () => {
    const grid = document.querySelector('.grid');
    if (grid) {
      grid.classList.add('fade-in');
    }
    
    // Initialize mobile filter functionality
    initializeMobileFilters();
  });

  function initializeMobileFilters() {
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle');
    const mobileFilterOverlay = document.getElementById('mobile-filter-overlay');
    const filterSidebar = document.getElementById('filter-sidebar');
    const closeMobileFilters = document.getElementById('close-mobile-filters');

    if (!mobileFilterToggle || !filterSidebar) return;

    // Open mobile filters
    mobileFilterToggle.addEventListener('click', () => {
      filterSidebar.classList.remove('-translate-x-full');
      mobileFilterOverlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    // Close mobile filters
    const closeFilters = () => {
      filterSidebar.classList.add('-translate-x-full');
      mobileFilterOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    };

    closeMobileFilters?.addEventListener('click', closeFilters);
    mobileFilterOverlay?.addEventListener('click', closeFilters);

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeFilters();
      }
    });
  }
</script>

<style>
  .fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>