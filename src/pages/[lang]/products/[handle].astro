<script>
  function initializeShowMore() {
    const content = document.getElementById('description-content');
    const overlay = document.getElementById('description-overlay');
    const button = document.getElementById('show-more-btn');
    const buttonText = document.getElementById('show-more-text');
    const buttonIcon = document.getElementById('show-more-icon');
    
    if (!content || !overlay || !button || !buttonText || !buttonIcon) return;

    // Check if content needs show more button
    const needsShowMore = content.scrollHeight > 200;
    
    if (!needsShowMore) {
      overlay.style.display = 'none';
      button.style.display = 'none';
      content.style.maxHeight = 'none';
      return;
    }

    let isExpanded = false;

    button.addEventListener('click', () => {
      isExpanded = !isExpanded;
      
      if (isExpanded) {
        // Expand
        content.style.maxHeight = content.scrollHeight + 'px';
        overlay.style.opacity = '0';
        buttonText.textContent = 'Show Less';
        buttonIcon.style.transform = 'rotate(180deg)';
        button.setAttribute('aria-expanded', 'true');
      } else {
        // Collapse
        content.style.maxHeight = '200px';
        overlay.style.opacity = '1';
        buttonText.textContent = 'Show More';
        buttonIcon.style.transform = 'rotate(0)';
        button.setAttribute('aria-expanded', 'false');
      }
    });

    // Set initial state
    content.style.maxHeight = '200px';
    overlay.style.opacity = '1';
    button.style.display = needsShowMore ? 'flex' : 'none';

    // Add intersection observer for animation
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            content.style.opacity = '1';
            content.style.transform = 'translateY(0)';
          }
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(content);
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initializeShowMore);

  // Re-initialize on view transitions
  document.addEventListener('astro:page-load', initializeShowMore);
</script>

