---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';
const { lang, slug = 'index' } = Astro.params;

// Validate language and redirect to /en if invalid
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

// Try to dynamically import the page component from theme
let ThemePage;
let name;
let is404 = false;

const slugParts = slug.split('/');
console.log('Full slug:', slug);
console.log('slugParts:', slugParts);

try {
  if (slugParts.length > 1) {
    const pageType = slugParts[0];
    name = slugParts.slice(1).join('/');
    
    // Try to import from website-specific theme first
    try {
      const module = await import(`@websites/${siteName}/themes/${theme}/page/${pageType}/[...${pageType}].astro`);
      ThemePage = module.default;
    } catch (error) {
      // Fallback to default theme
      const module = await import(`@themes/${theme}/page/${pageType}/[...${pageType}].astro`);
      ThemePage = module.default;
    }
  } else {
    // Try to import from website-specific theme first
    try {
      const module = await import(`@websites/${siteName}/themes/${theme}/page/${slug}.astro`);
      ThemePage = module.default;
    } catch (error) {
      // Fallback to default theme
      const module = await import(`@themes/${theme}/page/${slug}.astro`);
      ThemePage = module.default;
    }
  }
} catch (error) {
  console.error('Error loading page:', error);
  // Try to load 404 page component from website-specific theme first
  try {
    const module = await import(`@websites/${siteName}/themes/${theme}/page/404.astro`);
    ThemePage = module.default;
  } catch (error404) {
    // Fallback to default theme 404
    try {
      const module = await import(`@themes/${theme}/page/404.astro`);
      ThemePage = module.default;
    } catch (errorDefault) {
      // Final fallback to root 404
      const module = await import('../../pages/404.astro');
      ThemePage = module.default;
    }
  }
  is404 = true;
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

let posts: any[] = [];
try {
  const { fetchBlogPosts } = await import('@libs/db');
  posts = await fetchBlogPosts(lang) || [];
} catch (error) {
  console.error('Error fetching blog posts:', error);
  posts = [];
}

// Generate static paths for all supported languages and any page
export async function getStaticPaths() {
  // Get allowed languages from environment variable
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  // Generate paths for common pages and let dynamic imports handle the rest
  const commonPages = ['index', 'about', 'contact', 'services', 'pricing', 'support', 'documentation', 'blog', 'story', 'press', 'sports', 'news', 'status', 'careers', 'shop', 'login', 'signup'];
  
  return languages.flatMap(lang => 
    commonPages.map(page => ({
      params: { 
        lang,
        slug: page === 'index' ? undefined : page
      }
    }))
  );
}

// Set status code to 404 if page not found
if (is404) {
  Astro.response.status = 404;
}
---

<ThemePage {lang} {jsonData} {posts} {name} /> 