---
import Layout from '@layouts/Layoutc.astro';
import ProductCard from '@themes/default/components/ProductCard';
import { getPaginatedTranslatedProducts, filterProducts } from '@libs/shopify';
import { getPaginatedProducts } from '@libs/woocommerce';
import { generateCacheKey, getCachedPage, cachePageContent } from '@libs/cache';
import { Grid, List } from 'lucide-react';
import FilterSidebar from '@components/FilterSidebar.astro';
import SortDropdown from '@components/SortDropdown.astro';
import ReactiveProductCard from '@components/ReactiveProductCard.tsx';
// Dynamic imports based on environment
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || 'RidWear';
const THEME = import.meta.env.THEME || 'default';

let contentData;
let filterData;

try {
  // Try to load from current website theme path
  contentData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-content.json`);
  filterData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-filters.json`);
} catch (error) {
  // Fallback to default data
  contentData = await import('@data/collection-content.json');
  filterData = await import('@data/collection-filters.json');
}

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME;
const dataType = import.meta.env.DATA_TYPE?.toLowerCase() || 'shopify';

// Load collection page styles (website theme first, then default) for consistent dark/light theme
function deepMerge<T extends Record<string, unknown>>(target: T, source: Record<string, unknown> | null | undefined): T {
  if (!source || typeof source !== 'object') return target;
  const out = { ...target };
  for (const key of Object.keys(source)) {
    const src = source[key];
    const cur = (out as Record<string, unknown>)[key];
    if (src != null && typeof src === 'object' && !Array.isArray(src) && typeof (src as object).constructor === 'function' && (src as object).constructor?.name === 'Object') {
      (out as Record<string, unknown>)[key] = deepMerge((cur != null && typeof cur === 'object' && !Array.isArray(cur)) ? (cur as Record<string, unknown>) : {}, src as Record<string, unknown>);
    } else if (src !== undefined) {
      (out as Record<string, unknown>)[key] = src;
    }
  }
  return out;
}
let styleData: { default?: { page?: Record<string, string>; card?: Record<string, unknown> } } = {};
try {
  styleData = await import(`@websites/${SITE_NAME}/themes/${THEME}/styles/collections/collections.json`);
} catch {
  styleData = { default: {} };
}
const defaultStyleData = await import('../../styles/default/collections.json');
const defaultPage = (defaultStyleData.default?.page || {}) as Record<string, string>;
const websitePage = (styleData.default?.page || {}) as Record<string, string>;
const pageStyle = deepMerge({ ...defaultPage }, websitePage);
// Build cardStyles for ReactiveProductCard from style JSON (dark theme when wrapper is dark)
const cardData = deepMerge(
  (defaultStyleData.default?.card || {}) as Record<string, unknown>,
  (styleData.default?.card || {}) as Record<string, unknown>
) as Record<string, unknown>;
const pc = (cardData.productCard || {}) as Record<string, string>;
const imgCont = (cardData.imageContainer || {}) as Record<string, string>;
const titleObj = (cardData.title || {}) as Record<string, string>;
const priceObj = (cardData.price || {}) as Record<string, string>;
const isDark = pageStyle.wrapper?.includes('bg-[#0a0a0a]') ?? false;
const cardStyles = {
  root: [pc.background, pc.border, pc.shadow, pc.transition].filter(Boolean).join(' ') + ' group product-card flex flex-col h-full overflow-hidden',
  media: [imgCont.aspectRatio, imgCont.background, imgCont.overflow, 'relative min-h-[200px] flex items-center justify-center'].filter(Boolean).join(' ') || 'relative aspect-[3/4] min-h-[200px] overflow-hidden flex items-center justify-center bg-white/5',
  noImageWrap: (cardData.noImagePlaceholder as string) || 'w-full h-full flex items-center justify-center bg-white/5',
  noImageText: 'text-gray-500 text-sm',
  saleBadge: 'absolute top-2 left-2 bg-red-500 text-white text-xs font-semibold px-2 py-1 rounded-sm',
  content: (cardData.content as string) || 'flex flex-col flex-grow p-4',
  title: [titleObj.fontSize, titleObj.fontWeight, titleObj.color, titleObj.truncate || 'line-clamp-3 leading-snug mb-2'].filter(Boolean).join(' ') || (isDark ? 'text-lg font-medium text-gray-100 line-clamp-3 leading-snug mb-2' : 'text-sm font-medium text-neutral-900 line-clamp-3 leading-snug mb-2'),
  price: [priceObj.fontSize, priceObj.fontWeight, priceObj.color].filter(Boolean).join(' ') || (isDark ? 'text-sm font-semibold text-gray-200' : 'text-base font-semibold text-neutral-900'),
  comparePrice: isDark ? 'text-sm text-gray-500 line-through' : 'text-sm text-neutral-400 line-through',
  arrow: isDark ? 'text-gray-500 group-hover:text-purple-400 transition-all duration-200 flex-shrink-0' : 'text-neutral-400 group-hover:text-neutral-900 group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0'
};

// Get page and locale (root route has no [lang] param, default to 'en')
const page = Number(Astro.url.searchParams.get('page')) || 1;
const PRODUCTS_PER_PAGE = 20;
const lang = Astro.params?.lang ?? 'en';

// Get content for current language (handle dynamic import: contentData.default or contentData)
const data = contentData.default ?? contentData;
const content = data[lang] ?? data.en;

// Parse current filters from URL
const url = Astro.url;
const currentFilters: Record<string, string[]> = {};
const filters: any = {};

// Parse filter parameters
url.searchParams.forEach((value, key) => {
  if (key === 'color' || key === 'size' || key === 'availability') {
    if (!currentFilters[key]) currentFilters[key] = [];
    currentFilters[key].push(value);
    if (!filters[key]) filters[key] = [];
    filters[key].push(value);
  }
});

// Parse price filter
const priceFilter = url.searchParams.get('price');
if (priceFilter) {
  filters.price = priceFilter;
}

// Get current sort parameter
const currentSort = url.searchParams.get('sort') || '';

// Check if any filters are applied
const hasFilters = Object.keys(filters).length > 0;

// Add this helper function that doesn't use document
function stripHtml(html: string) {
  if (!html) return '';
  
  // First, remove script and style tags and their contents
  let text = html.replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '');
  text = text.replace(/<style\b[^<]*(?:(?!<\/style>)<[^<]*)*<\/style>/gi, '');
  
  // Then remove all remaining HTML tags
  text = text.replace(/<[^>]+>/g, ' ');
  
  // Replace multiple spaces, newlines, and tabs with a single space
  text = text.replace(/\s+/g, ' ');
  
  // Decode HTML entities
  text = text.replace(/&nbsp;/g, ' ')
             .replace(/&amp;/g, '&')
             .replace(/&lt;/g, '<')
             .replace(/&gt;/g, '>')
             .replace(/&quot;/g, '"')
             .replace(/&#039;/g, "'");
  
  // Trim whitespace
  return text.trim();
}

// Generate cache key for this page
const cacheKey = generateCacheKey(`/collections?page=${page}`, lang);
const cachedContent = await getCachedPage(cacheKey);

if (cachedContent) {
  console.log('✅ Serving cached collections page:', cacheKey);
  return new Response(cachedContent, {
    headers: {
      'Content-Type': 'text/html;charset=UTF-8',
      'X-Cache': 'HIT',
    },
  });
}

// Fetch products based on data source
let products = [];
let pagination = {
  currentPage: page,
  totalPages: 0,
  totalProducts: 0,
  hasNextPage: false,
  hasPreviousPage: false
};

try {
  if (dataType === 'shopify') {
    console.log('🛍️ Fetching from Shopify');
    
    if (hasFilters) {
      console.log('🔍 Applying filters:', filters);
      const filteredData = await filterProducts(filters, lang, page, PRODUCTS_PER_PAGE);
      products = filteredData.products;
      pagination = filteredData.pagination;
    } else {
      const shopifyData = await getPaginatedTranslatedProducts(page, PRODUCTS_PER_PAGE, lang);
      products = shopifyData.products;
      pagination = shopifyData.pagination;
    }
  } else if (dataType === 'woocommerce') {
    console.log('🛍️ Fetching from WooCommerce');
    const wooData = await getPaginatedProducts(page, PRODUCTS_PER_PAGE);
    
    // Transform WooCommerce data to match Shopify structure
    products = wooData.products.map(product => ({
      node: {
        id: product.id.toString(),
        title: product.name,
        handle: product.slug,
        description: stripHtml(product.description || ''),
        variants: {
          edges: [{
            node: {
              price: {
                amount: product.price,
                currencyCode: 'USD'
              },
              compareAtPrice: product.regular_price ? {
                amount: product.regular_price,
                currencyCode: 'USD'
              } : null
            }
          }]
        },
        images: {
          edges: product.images.map(image => ({
            node: {
              url: image.src,
              altText: image.alt || product.name
            }
          }))
        }
      }
    }));
    
    pagination = wooData.pagination;
  } else {
    throw new Error(`Unsupported data type: ${dataType}`);
  }
} catch (error) {
  console.error(`❌ Error fetching products:`, error);
  return new Response('Error fetching products', { status: 500 });
}
---

<Layout title={`Collections | ${siteName}`} lang={lang}>
  <div class={pageStyle.wrapper}>
    <main class={pageStyle.main}>
      {/* Breadcrumbs */}
      <nav class={pageStyle.breadcrumbNav} aria-label="Breadcrumb">
        <ol class={pageStyle.breadcrumbList}>
          <li><a href={`/${lang}`} class={pageStyle.breadcrumbLink}>{content.breadcrumbs.home}</a></li>
          <li aria-hidden="true">/</li>
          <li class={pageStyle.breadcrumbCurrent}>{content.breadcrumbs.collections}</li>
        </ol>
      </nav>

      {/* Page Header */}
      <header class={pageStyle.header}>
        <h1 class={pageStyle.headerTitleNoImage}>{content.breadcrumbs.collections}</h1>
        <p class={pageStyle.headerDescription}>
          Discover our complete collection of products
        </p>
      </header>

      {/* Mobile Filter Toggle */}
      <div class={pageStyle.mobileFilterWrap}>
        <button
          id="mobile-filter-toggle"
          class={pageStyle.mobileFilterBtn}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          Filters & Sort
        </button>
      </div>

      {/* Main Content with Sidebar */}
      <div class={`collection-layout ${pageStyle.contentWrap}`}>
        {/* Mobile Filter Overlay */}
        <div
          id="mobile-filter-overlay"
          class={pageStyle.overlay}
        ></div>

        {/* Sidebar Filters */}
        <aside
          id="filter-sidebar"
          class={pageStyle.sidebar}
        >
          <div class={pageStyle.sidebarInner}>
            <div class={pageStyle.sidebarTitleRow}>
              <h3 class={pageStyle.sidebarTitle}>Filters</h3>
              <button id="close-mobile-filters" class={pageStyle.closeBtn} aria-label="Close filters">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <FilterSidebar
              language={lang}
              currentFilters={currentFilters}
              filterData={filterData.default}
              wrapperClass={pageStyle.filterSidebarRoot}
              theme={isDark ? 'dark' : 'light'}
            />
          </div>
        </aside>

        {/* Main Content Area */}
        <div class={`collection-main ${pageStyle.mainContent}`}>
          {/* Top Controls */}
          <div class={pageStyle.topBar}>
            <div class={pageStyle.countText}>
              {pagination.totalProducts} {content?.collections?.count ?? content?.products?.count ?? 'products'}
            </div>
            <div class={pageStyle.viewToggleWrap}>
              <div class={pageStyle.viewToggleGroup}>
                <button class={pageStyle.gridBtnActive} aria-label="Grid view">
                  <Grid className="w-4 h-4" />
                </button>
                <button class={pageStyle.listBtn} aria-label="List view">
                  <List className="w-4 h-4" />
                </button>
              </div>
              <SortDropdown
                language={lang}
                currentSort={currentSort}
                selectClass={pageStyle.sortDropdownSelect}
                labelClass={pageStyle.sortDropdownLabel}
              />
            </div>
          </div>

          {/* Mobile Product Count */}
          <div class={pageStyle.mobileCount}>
            {pagination.totalProducts} {content?.collections?.count ?? content?.products?.count ?? 'products'}
          </div>

          {/* Products Grid */}
          <div class={`${pageStyle.productGrid} collection-product-grid-fix`}>
          {products.map((product) => {
            // Handle both Shopify and WooCommerce data structures
            const node = product.node;
            const price = dataType === 'shopify' 
              ? (node.variants?.edges?.[0]?.node?.price?.amount || 
                 node.priceRange?.minVariantPrice?.amount || 
                 '0')
              : node.variants.edges[0].node.price.amount;
              
            const compareAtPrice = dataType === 'shopify'
              ? node.variants?.edges?.[0]?.node?.compareAtPrice?.amount
              : node.variants.edges[0].node.compareAtPrice?.amount;
              
            const imageUrl = dataType === 'shopify'
              ? node.images?.edges?.[0]?.node?.url
              : node.images.edges[0].node.url;

            const currencyCode = dataType === 'shopify'
              ? (node.variants?.edges?.[0]?.node?.price?.currencyCode || 'USD')
              : 'USD';
            
            return (
              <ReactiveProductCard 
                client:load
                product={{
                  id: node.id,
                  title: node.title,
                  handle: node.handle,
                  price: { amount: price, currencyCode: currencyCode },
                  compareAtPrice: compareAtPrice ? { amount: compareAtPrice, currencyCode: currencyCode } : undefined,
                  image: imageUrl ? { url: imageUrl, altText: node.title } : undefined
                }}
                lang={lang}
                content={content}
                containImage={true}
                cardStyles={cardStyles}
              />
            );
          })}
        </div>

        <!-- Pagination -->
          {pagination.totalPages > 1 && (
            <div class="flex justify-center items-center gap-4 mt-12">
              {pagination.hasPreviousPage && (
                <a
                  href={`/${lang}/collections?page=${page - 1}`}
                  class="px-4 py-2 rounded-lg transition-colors bg-white/10 border border-white/20 text-gray-300 hover:text-white hover:bg-white/15"
                >
                  Previous
                </a>
              )}
              <span class="text-sm font-medium text-gray-400">
                Page {pagination.currentPage} of {pagination.totalPages}
              </span>
              {pagination.hasNextPage && (
                <a
                  href={`/${lang}/collections?page=${page + 1}`}
                  class="px-4 py-2 rounded-lg transition-colors bg-white/10 border border-white/20 text-gray-300 hover:text-white hover:bg-white/15"
                >
                  Next
                </a>
              )}
            </div>
          )}

          <div class="text-center text-sm text-gray-400 mt-4">
            Showing {(page - 1) * PRODUCTS_PER_PAGE + 1} - {Math.min(page * PRODUCTS_PER_PAGE, pagination.totalProducts)} 
            of {pagination.totalProducts} products
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  // Handle dynamic loading states
  document.addEventListener('astro:page-load', () => {
    const grid = document.querySelector('.collection-product-grid, .grid');
    if (grid) grid.classList.add('fade-in');
    
    // Initialize mobile filter functionality
    initializeMobileFilters();
  });

  function initializeMobileFilters() {
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle');
    const mobileFilterOverlay = document.getElementById('mobile-filter-overlay');
    const filterSidebar = document.getElementById('filter-sidebar');
    const closeMobileFilters = document.getElementById('close-mobile-filters');

    if (!mobileFilterToggle || !filterSidebar) return;

    // Open mobile filters
    mobileFilterToggle.addEventListener('click', () => {
      filterSidebar.classList.remove('-translate-x-full');
      mobileFilterOverlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    // Close mobile filters
    const closeFilters = () => {
      filterSidebar.classList.add('-translate-x-full');
      mobileFilterOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    };

    closeMobileFilters?.addEventListener('click', closeFilters);
    mobileFilterOverlay?.addEventListener('click', closeFilters);

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeFilters();
      }
    });
  }
</script>

<style>
  .fade-in {
    animation: fadeIn 0.5s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  /* Collection layout: desktop = sidebar + main with product grid visible */
  .collection-layout {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .collection-layout {
      display: grid !important;
      grid-template-columns: 18rem minmax(0, 1fr);
      grid-template-areas: "sidebar main";
      align-items: start;
      gap: 2rem;
    }
    .collection-layout #mobile-filter-overlay {
      display: none !important;
    }
    .collection-layout #filter-sidebar {
      grid-area: sidebar;
      width: 18rem;
      max-width: 18rem;
    }
    .collection-main {
      grid-area: main;
      min-width: 0;
      overflow: visible;
    }
    .collection-product-grid-fix {
      display: grid !important;
      align-items: start;
      width: 100%;
    }
  }
</style>