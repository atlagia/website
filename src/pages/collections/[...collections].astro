---
import Layoutc from '@layouts/Layoutc.astro';
import { getCollectionByHandle, getAllCollections } from '@libs/controller';
import { filterProducts } from '@libs/shopify';
import { ArrowRight, Grid, List, Filter } from 'lucide-react';
import FilterSidebar from '@components/FilterSidebar.astro';
import SortDropdown from '@components/SortDropdown.astro';
import ReactiveProductCard from '@components/ReactiveProductCard.tsx';
// Dynamic imports based on environment
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME || 'RidWear';
const THEME = import.meta.env.THEME || 'default';

let contentData;
let filterData;

try {
  // Try to load from current website theme path
  contentData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-content.json`);
  filterData = await import(`@websites/${SITE_NAME}/themes/${THEME}/data/collection-filters.json`);
} catch (error) {
  // Fallback to default data
  contentData = await import('@data/collection-content.json');
  filterData = await import('@data/collection-filters.json');
}

// Load collection page styles: website theme first, then fallback to default (multi-tenant dynamic styling)
function deepMerge<T extends Record<string, unknown>>(target: T, source: Record<string, unknown> | null | undefined): T {
  if (!source || typeof source !== 'object') return target;
  const out = { ...target };
  for (const key of Object.keys(source)) {
    const src = source[key];
    const cur = (out as Record<string, unknown>)[key];
    if (src != null && typeof src === 'object' && !Array.isArray(src) && typeof (src as object).constructor === 'function' && (src as object).constructor?.name === 'Object') {
      (out as Record<string, unknown>)[key] = deepMerge((cur != null && typeof cur === 'object' && !Array.isArray(cur)) ? (cur as Record<string, unknown>) : {}, src as Record<string, unknown>);
    } else if (src !== undefined) {
      (out as Record<string, unknown>)[key] = src;
    }
  }
  return out;
}

let styleData: { default?: { page?: Record<string, string>; card?: Record<string, unknown> } };
try {
  styleData = await import(`@websites/${SITE_NAME}/themes/${THEME}/styles/collections/collections.json`);
} catch {
  styleData = { default: {} };
}
const defaultStyleData = await import('../../styles/default/collections.json');
const defaultPage = (defaultStyleData.default?.page || {}) as Record<string, string>;
const websitePage = (styleData.default?.page || {}) as Record<string, string>;
const pageStyle = deepMerge({ ...defaultPage }, websitePage);

// Build cardStyles for ReactiveProductCard from style JSON
const cardData = deepMerge(
  (defaultStyleData.default?.card || {}) as Record<string, unknown>,
  (styleData.default?.card || {}) as Record<string, unknown>
) as Record<string, unknown>;
const pc = (cardData.productCard || {}) as Record<string, string>;
const imgCont = (cardData.imageContainer || {}) as Record<string, string>;
const titleObj = (cardData.title || {}) as Record<string, string>;
const priceObj = (cardData.price || {}) as Record<string, string>;
const isDark = pageStyle.wrapper?.includes('bg-[#0a0a0a]') ?? false;
const cardStyles = {
  root: [pc.background, pc.border, pc.shadow, pc.transition].filter(Boolean).join(' ') + ' group product-card flex flex-col h-full overflow-hidden',
  media: [imgCont.aspectRatio, imgCont.background, imgCont.overflow, 'relative min-h-[200px] flex items-center justify-center'].filter(Boolean).join(' ') || 'relative aspect-[3/4] min-h-[200px] overflow-hidden flex items-center justify-center bg-white/5',
  noImageWrap: (cardData.noImagePlaceholder as string) || 'w-full h-full flex items-center justify-center bg-white/5',
  noImageText: 'text-gray-500 text-sm',
  saleBadge: 'absolute top-2 left-2 bg-red-500 text-white text-xs font-semibold px-2 py-1 rounded-sm',
  content: (cardData.content as string) || 'flex flex-col flex-grow p-4',
  title: [titleObj.fontSize, titleObj.fontWeight, titleObj.color, titleObj.truncate || 'line-clamp-3 leading-snug mb-2'].filter(Boolean).join(' ') || (isDark ? 'text-lg font-medium text-gray-100 line-clamp-3 leading-snug mb-2' : 'text-sm font-medium text-neutral-900 line-clamp-3 leading-snug mb-2'),
  price: [priceObj.fontSize, priceObj.fontWeight, priceObj.color].filter(Boolean).join(' ') || (isDark ? 'text-sm font-semibold text-gray-200' : 'text-base font-semibold text-neutral-900'),
  comparePrice: isDark ? 'text-sm text-gray-500 line-through' : 'text-sm text-neutral-400 line-through',
  arrow: isDark ? 'text-gray-500 group-hover:text-purple-400 transition-all duration-200 flex-shrink-0' : 'text-neutral-400 group-hover:text-neutral-900 group-hover:translate-x-0.5 transition-all duration-200 flex-shrink-0'
};

const { lang = 'en', collections: handle } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://ridwear.com';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'RidWear';
// Get allowed languages from environment variable
const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);

// Get content for current language
const content = contentData.default[lang] || contentData.default.en;

// Parse current filters from URL (use Astro.url - Astro.request.url can be undefined in some SSR contexts)
const url = Astro.url;
const currentFilters: Record<string, string[]> = {};
const filters: any = {};

// Parse filter parameters
url.searchParams.forEach((value, key) => {
  if (key === 'color' || key === 'size' || key === 'availability') {
    if (!currentFilters[key]) currentFilters[key] = [];
    currentFilters[key].push(value);
    if (!filters[key]) filters[key] = [];
    filters[key].push(value);
  }
});

// Parse price filter
const priceFilter = url.searchParams.get('price');
if (priceFilter) {
  filters.price = priceFilter;
}

// Get current sort parameter
const currentSort = url.searchParams.get('sort') || '';

// Check if any filters are applied
const hasFilters = Object.keys(filters).length > 0;

// Get collection data
let collection = await getCollectionByHandle(handle, lang?.toUpperCase());

// Apply filters if any are present
if (hasFilters) {
  console.log('🔍 Applying filters to collection:', filters);
  
  // Get all products from the collection
  const allProducts = collection.products.edges;
  
  // Apply filters to the products
  let filteredProducts = allProducts;

  // Apply color filter
  if (filters.color && filters.color.length > 0) {
    filteredProducts = filteredProducts.filter(({ node: product }) => {
      const productColors = product.options?.find(opt => 
        opt.name?.toLowerCase() === 'color'
      )?.values || [];
      
      return filters.color.some(filterColor => 
        productColors.some(productColor => 
          productColor.toLowerCase().includes(filterColor.toLowerCase())
        )
      );
    });
  }

  // Apply size filter
  if (filters.size && filters.size.length > 0) {
    filteredProducts = filteredProducts.filter(({ node: product }) => {
      const productSizes = product.options?.find(opt => 
        opt.name?.toLowerCase() === 'size'
      )?.values || [];
      
      return filters.size.some(filterSize => 
        productSizes.some(productSize => 
          productSize.toLowerCase() === filterSize.toLowerCase()
        )
      );
    });
  }

  // Apply price filter
  if (filters.price) {
    const [minPrice, maxPrice] = filters.price.split('-').map(p => parseFloat(p));
    filteredProducts = filteredProducts.filter(({ node: product }) => {
      const price = parseFloat(product.variants.edges[0]?.node?.price?.amount || '0');
      return price >= minPrice && (isNaN(maxPrice) || price <= maxPrice);
    });
  }

  // Update collection with filtered products
  collection = {
    ...collection,
    products: {
      edges: filteredProducts
    }
  };
}

// SEO Helpers
const generateSEOTitle = (collection) => {
  if (collection.seo?.title) return collection.seo.title;
  
  const templates = {
    en: `Shop ${collection.title} | ${storeName}`,
    fr: `Achetez ${collection.title} | ${storeName}`,
    de: `${collection.title} kaufen | ${storeName}`,
    es: `Compra ${collection.title} | ${storeName}`,
    it: `Acquista ${collection.title} | ${storeName}`
  };
  
  return templates[lang] || templates.en;
};

const generateSEODescription = (collection) => {
  if (collection.seo?.description) return collection.seo.description;
  
  const templates = {
    en: `Discover our premium ${collection.title.toLowerCase()} collection.`,
    fr: `Découvrez notre collection premium ${collection.title.toLowerCase()}.`,
    de: `Entdecken Sie unsere Premium ${collection.title.toLowerCase()} Kollektion.`,
    es: `Descubre nuestra colección premium de ${collection.title.toLowerCase()}.`,
    it: `Scopri la nostra collezione premium ${collection.title.toLowerCase()}.`
  };
  
  return templates[lang] || templates.en;
};

const seoTitle = generateSEOTitle(collection);
const seoDescription = generateSEODescription(collection);

// Schema Generation
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `${baseUrl}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Collections",
      "item": `${baseUrl}/${lang}/catalog`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": collection.title,
      "item": `${baseUrl}/${lang}/collections/${handle}`
    }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": collection.title,
  "description": seoDescription,
  "image": collection.image?.url,
  "url": `${baseUrl}/${lang}/collections/${handle}`,
  "numberOfItems": collection.products.edges.length,
  "hasPart": collection.products.edges.map(({ node: product }) => ({
    "@type": "Product",
    "name": product.title,
    "description": product.description,
    "image": product.images?.edges[0]?.node?.url,
    "url": `${baseUrl}/${lang}/products/${product.handle}`,
    "offers": {
      "@type": "Offer",
      "price": product.variants.edges[0]?.node?.price?.amount,
      "priceCurrency": product.variants.edges[0]?.node?.price?.currencyCode,
      "availability": "https://schema.org/InStock"
    }
  }))
};

// Static paths generation
export async function getStaticPaths() {
  const paths = [];
  for (const lang of languages) {
    const collections = await getAllCollections(lang);
    paths.push(...collections.map(({ node }) => ({
      params: { lang, collections: node.handle },
      props: { collection: node }
    })));
  }
  return paths;
}

// Price formatter
const formatPrice = (amount: string, currencyCode: string) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: currencyCode,
  }).format(parseFloat(amount));
};
---

<Layoutc 
  title={seoTitle}
  description={seoDescription}
  image={collection.image?.url}
  schemas={[breadcrumbSchema, collectionSchema]}
  alternateUrls={languages
    .filter(language => language !== lang) // Remove current language to avoid self-reference
    .map(language => ({
      lang: language,
      url: `/${language}/collections/${handle}`
    }))}
  lang={lang}
>
  <div class={pageStyle.wrapper}>
    <main class={pageStyle.main}>
      {/* Breadcrumbs */}
      <nav class={pageStyle.breadcrumbNav} aria-label="Breadcrumb">
        <ol class={pageStyle.breadcrumbList}>
          <li><a href={`/${lang}`} class={pageStyle.breadcrumbLink}>{content.breadcrumbs.home}</a></li>
          <li aria-hidden="true">/</li>
          <li><a href={`/${lang}/collections`} class={pageStyle.breadcrumbLink}>{content.breadcrumbs.collections}</a></li>
          <li aria-hidden="true">/</li>
          <li class={pageStyle.breadcrumbCurrent}>{collection.title}</li>
        </ol>
      </nav>

      {/* Collection Header / Top banner — styles from F1 collections.json page.header* */}
      <header class={`collection-banner-header ${pageStyle.header}`}>
        {collection.image && (
          <div class={`collection-banner-image-wrap ${pageStyle.headerImageWrap}`}>
            <img
              src={collection.image.url}
              alt={collection.image.altText || collection.title}
              class={pageStyle.headerImage}
            />
            <div class={pageStyle.headerOverlay} />
            <h1 class={pageStyle.headerTitleOnImage}>
              {collection.title}
            </h1>
          </div>
        )}
        {!collection.image && (
          <h1 class={pageStyle.headerTitleNoImage}>{collection.title}</h1>
        )}
        {collection.description && (
          <p class={pageStyle.headerDescription}>
            {collection.description}
          </p>
        )}
      </header>

      {/* Mobile Filter Toggle */}
      <div class={pageStyle.mobileFilterWrap}>
        <button
          id="mobile-filter-toggle"
          class={pageStyle.mobileFilterBtn}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          Filters & Sort
        </button>
      </div>

      {/* Main Content with Sidebar — desktop: side-by-side; mobile: overlay sidebar */}
      <div class={`collection-layout ${pageStyle.contentWrap}`}>
        {/* Mobile Filter Overlay */}
        <div
          id="mobile-filter-overlay"
          class={pageStyle.overlay}
        ></div>

        {/* Sidebar Filters */}
        <aside
          id="filter-sidebar"
          class={pageStyle.sidebar}
        >
          <div class={pageStyle.sidebarInner}>
            <div class={pageStyle.sidebarTitleRow}>
              <h3 class={pageStyle.sidebarTitle}>Filters</h3>
              <button id="close-mobile-filters" class={pageStyle.closeBtn} aria-label="Close filters">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <FilterSidebar
              language={lang}
              currentFilters={currentFilters}
              filterData={filterData.default}
              currentSort={currentSort}
              priceFilter={priceFilter}
              wrapperClass={pageStyle.filterSidebarRoot}
              theme={isDark ? 'dark' : 'light'}
            />
          </div>
        </aside>

        {/* Main Content Area — flex-1 min-w-0 so grid doesn't overflow on desktop */}
        <div class={`collection-main ${pageStyle.mainContent}`}>
          {/* Top bar: count + sort */}
          <div class={pageStyle.topBar}>
            <div class={pageStyle.countText}>
              {collection.products.edges.length} {content.collections?.count || content.products?.count || 'products'}
            </div>
            <div class={pageStyle.viewToggleWrap}>
              <div class={pageStyle.viewToggleGroup}>
                <button class={pageStyle.gridBtnActive} aria-label="Grid view">
                  <Grid className="w-4 h-4" />
                </button>
                <button class={pageStyle.listBtn} aria-label="List view">
                  <List className="w-4 h-4" />
                </button>
              </div>
              <SortDropdown 
                language={lang} 
                currentSort={currentSort} 
                selectClass={pageStyle.sortDropdownSelect}
                labelClass={pageStyle.sortDropdownLabel}
              />
            </div>
          </div>

          {/* Mobile Product Count */}
          <div class={pageStyle.mobileCount}>
            {collection.products.edges.length} {content.collections?.count || content.products?.count || 'products'}
          </div>

          {/* Products Grid — items-start so cards align at top on desktop (no stepped layout) */}
          <div class={`${pageStyle.productGrid} collection-product-grid-fix`}>
            {collection.products.edges.map(({ node: product }) => {
              const firstVariant = product.variants.edges[0]?.node;
              const price = firstVariant?.price;
              const compareAtPrice = firstVariant?.compareAtPrice;
              return (
                <ReactiveProductCard
                  client:load
                  product={{
                    id: product.id,
                    title: product.title,
                    handle: product.handle,
                    price: price || { amount: '0', currencyCode: 'USD' },
                    compareAtPrice: compareAtPrice,
                    image: product.images?.edges[0]?.node
                  }}
                  lang={lang}
                  content={content}
                  containImage={true}
                  cardStyles={cardStyles}
                />
              );
            })}
          </div>

          {/* Load More Section */}
          {collection.products.edges.length > 0 && (
            <div class={pageStyle.loadMoreWrap}>
              <div class={pageStyle.loadMoreText}>
                {content.collections?.viewed || content.products?.viewed || 'You have viewed'} {Math.min(12, collection.products.edges.length)} {content.collections?.of || content.products?.of || 'of'} {collection.products.edges.length} {content.collections?.products || content.products?.products || 'products'}
              </div>
              <button class={pageStyle.loadMoreBtn}>
                {content.collections?.loadMore || content.products?.loadMore || 'Load More'}
              </button>
            </div>
          )}

          {/* Empty State */}
          {collection.products.edges.length === 0 && (
            <div class={pageStyle.emptyWrap}>
              <div class={pageStyle.emptyContent}>
                <h2 class={pageStyle.emptyTitle}>{content.collections?.noProducts || content.products?.noProducts || 'No products found'}</h2>
                <p class={pageStyle.emptyDescription}>
                  {content.collections?.noProductsDescription || content.products?.noProductsDescription || 'Try adjusting your filters or search terms'}
                </p>
              </div>
            </div>
          )}
        </div>
      </div>
    </main>
  </div>
</Layoutc>

<script>
  // Handle dynamic loading states
  document.addEventListener('astro:page-load', () => {
    const grid = document.querySelector('.grid');
    if (grid) {
      grid.classList.add('fade-in');
    }
    
    // Initialize mobile filter functionality
    initializeMobileFilters();
  });

  function initializeMobileFilters() {
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle');
    const mobileFilterOverlay = document.getElementById('mobile-filter-overlay');
    const filterSidebar = document.getElementById('filter-sidebar');
    const closeMobileFilters = document.getElementById('close-mobile-filters');

    if (!mobileFilterToggle || !filterSidebar) return;

    // Open mobile filters
    mobileFilterToggle.addEventListener('click', () => {
      filterSidebar.classList.remove('-translate-x-full');
      mobileFilterOverlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    // Close mobile filters
    const closeFilters = () => {
      filterSidebar.classList.add('-translate-x-full');
      mobileFilterOverlay.classList.add('hidden');
      document.body.style.overflow = '';
    };

    closeMobileFilters?.addEventListener('click', closeFilters);
    mobileFilterOverlay?.addEventListener('click', closeFilters);

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeFilters();
      }
    });
  }
</script>

<style is:global>
  .fade-in {
    animation: fadeIn 0.5s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Top banner: cap height so grid + filters visible above fold; F1 styles from collections.json apply via pageStyle */
  .collection-banner-header {
    margin-bottom: 1rem;
  }
  .collection-banner-header .collection-banner-image-wrap {
    height: 180px !important;
    max-height: 200px !important;
    min-height: 180px !important;
  }
  @media (min-width: 640px) {
    .collection-banner-header .collection-banner-image-wrap {
      height: 200px !important;
      max-height: 220px !important;
      min-height: 200px !important;
    }
  }

  /* Collection layout: mobile = stack, desktop = sidebar + main with product grid visible */
  .collection-layout {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .collection-layout {
      display: grid !important;
      grid-template-columns: 18rem minmax(0, 1fr);
      grid-template-areas: "sidebar main";
      align-items: start;
      gap: 2rem;
    }
    .collection-layout #mobile-filter-overlay {
      display: none !important;
    }
    .collection-layout #filter-sidebar {
      grid-area: sidebar;
      width: 18rem;
      max-width: 18rem;
    }
    .collection-main {
      grid-area: main;
      min-width: 0;
      overflow: visible;
    }
    .collection-product-grid-fix {
      display: grid !important;
      align-items: start;
      width: 100%;
    }
  }
</style> 