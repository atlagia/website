---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { Truck, Clock, Globe, Phone, Mail, Building } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const { default: BaseHead } = await import(`../themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../themes/${theme}/components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  }
};

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Shipping Policy | ${businessInfo.name}`}
      description={`Shipping information and delivery details for ${businessInfo.name} orders`}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-bold text-center mb-8">Shipping Policy for {businessInfo.name}</h1>
      
      <div class="prose max-w-none mb-12">
        <p class="text-lg text-gray-700 mb-8">
          At {businessInfo.name}, we are dedicated to ensuring that your orders are delivered timely and reliably. Please review our comprehensive shipping policy for detailed information on our shipping methods, costs, delivery times, and other essential aspects.
        </p>

        <!-- Shipping Methods Section -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <Truck class="w-6 h-6" /> 1. Shipping Methods and Costs
          </h2>
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse border border-gray-200">
              <thead class="bg-gray-100">
                <tr>
                  <th class="border p-3 text-left">Shipping Type</th>
                  <th class="border p-3 text-left">Delivery Time</th>
                  <th class="border p-3 text-left">Cost</th>
                  <th class="border p-3 text-left">Carrier</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="border p-3">Domestic Shipping (Turkey)</td>
                  <td class="border p-3">1-2 business days</td>
                  <td class="border p-3">Free</td>
                  <td class="border p-3">FedEx Express</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border p-3">Standard International Shipping</td>
                  <td class="border p-3">5-14 business days</td>
                  <td class="border p-3">Varies by destination</td>
                  <td class="border p-3">FedEx Standard</td>
                </tr>
                <tr>
                  <td class="border p-3">Expedited International Shipping</td>
                  <td class="border p-3">3-7 business days</td>
                  <td class="border p-3">Varies by destination</td>
                  <td class="border p-3">FedEx Express</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Delivery Times Section -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <Clock class="w-6 h-6" /> 2. Delivery Times
          </h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3">Domestic Shipping (Turkey)</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Standard Delivery Time: 1-2 business days</li>
                <li>Major cities: Often 1 day</li>
                <li>Remote areas: May extend to 2 days</li>
                <li>Processing Time: 1-2 business days</li>
              </ul>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3">Standard International</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Europe: 5-7 business days</li>
                <li>North America: 5-14 business days</li>
                <li>Asia-Pacific: 8-12 business days</li>
                <li>Other regions: Up to 14 business days</li>
              </ul>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-md">
              <h3 class="font-semibold mb-3">Expedited International</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Europe: 3-5 business days</li>
                <li>North America: 3-7 business days</li>
                <li>Asia-Pacific: 4-7 business days</li>
                <li>Priority Handling included</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Store Information -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6">Store Information</h2>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <div class="grid gap-4 md:grid-cols-2">
              <div class="flex items-start gap-3">
                <Building class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Address</h3>
                  <p>{businessInfo.address.street}, {businessInfo.address.postalCode} {businessInfo.address.city}/{businessInfo.address.region}, {businessInfo.address.country}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Mail class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Email</h3>
                  <a href={`mailto:${businessInfo.email}`} class="text-blue-600 hover:underline">
                    {businessInfo.email}
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Phone class="w-5 h-5 mt-1 text-gray-600" />
                <div>
                  <h3 class="font-semibold">Phone</h3>
                  <a href={`tel:${businessInfo.phone}`} class="text-blue-600 hover:underline">
                    {businessInfo.phone}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html> 