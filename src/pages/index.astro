export const prerender = true;
---
import { getLangFromUrl, isValidLanguage } from '../utils/i18n';

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';

// Root (/) uses same page as /<lang>: default lang from URL (path or subdomain) or 'en'
const lang = getLangFromUrl(Astro.url);
const validLang = isValidLanguage(lang) ? lang : 'en';

// Same theme index as [lang]/[...slug].astro so root and /en are identical (no redirect, no client inject)
const { default: ThemePage } = await import(`../websites/${siteName}/themes/${theme}/page/index.astro`);
---
<ThemePage lang={validLang} />
