export const prerender = true;
---
import { fetchBlogPosts } from '../utils/shopifyAPI';
import { getLangFromUrl, useTranslations, isValidLanguage } from '../utils/i18n';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import Assistant from '@components/Assistant.astro';

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'default';

// Get the user's language
const lang = getLangFromUrl(Astro.url);
const validLang = isValidLanguage(lang) ? lang : 'en';

// Import only the top-level components needed for the shell
const { default: BaseHead } = await import(`../websites/${siteName}/themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../websites/${siteName}/themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../websites/${siteName}/themes/${theme}/components/Footer.astro`);

// Get translations for basic page elements
const translations = await useTranslations(validLang);
const jsonData = translations.default;

// Get site title and description from language-specific data
const SITE_TITLE = jsonData.siteTitle || siteName;
const SITE_DESCRIPTION = jsonData.siteDescription || 'Welcome to our site';

// Fetch blog posts
let posts = [];
try {
  posts = await fetchBlogPosts();
} catch (error) {
  console.error('Error fetching blog posts:', error);
}

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}
---
<!doctype html>
<html lang={validLang} dir={validLang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      isHomePage={true}
    />
    <noscript>
      <meta http-equiv="refresh" content={`0;url=/${validLang}`}>
    </noscript>
  </head>
  <body class={validLang === 'ar' ? 'rtl' : 'ltr'}>
    <Header />
    
    <!-- Loading placeholder -->
    <div id="main-content-placeholder" class="p-4 text-center">
      <div class="animate-pulse flex flex-col items-center justify-center min-h-[50vh] gap-4">
        <div class="h-8 bg-gray-200 rounded w-1/3"></div>
        <div class="h-4 bg-gray-200 rounded w-1/2"></div>
        <div class="h-4 bg-gray-200 rounded w-1/4"></div>
        <div class="mt-4 h-10 bg-gray-200 rounded w-1/4"></div>
      </div>
    </div>
    
    <!-- Main content will be loaded here -->
    <main id="main-content" style="display: none;">
      <!-- Content will be inserted here via JavaScript -->
    </main>
    
    <Footer />
    
    <!-- Client-side script to fetch and render the language page -->
    <script define:vars={{ validLang, theme, siteName }}>
      (async function loadMainContent() {
        try {
          // Fetch the language-specific page
          const response = await fetch(`/${validLang}`);
          
          if (!response.ok) {
            throw new Error(`Failed to fetch /${validLang} page: ${response.status}`);
          }
          
          const html = await response.text();
          
          // Parse the full HTML document
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          
          // Copy ALL style tags from head (including Astro scoped styles)
          const styles = doc.querySelectorAll('style');
          styles.forEach(style => {
            if (!document.querySelector(`style[data-astro-cid="${style.getAttribute('data-astro-cid')}"]`)) {
              const newStyle = document.createElement('style');
              Array.from(style.attributes).forEach(attr => {
                newStyle.setAttribute(attr.name, attr.value);
              });
              newStyle.textContent = style.textContent;
              document.head.appendChild(newStyle);
            }
          });
          
          // Extract main content
          const mainContent = doc.querySelector('main');
          
          if (mainContent) {
            const targetMain = document.getElementById('main-content');
            
            // Copy all attributes from source main (including classes and data attributes)
            Array.from(mainContent.attributes).forEach(attr => {
              if (attr.name !== 'id') {
                targetMain.setAttribute(attr.name, attr.value);
              }
            });
            
            // Replace placeholder with actual content
            targetMain.innerHTML = mainContent.innerHTML;
            targetMain.style.display = 'block';
            document.getElementById('main-content-placeholder').style.display = 'none';
            
            // Execute any scripts that were in the loaded content
            const scripts = document.getElementById('main-content').querySelectorAll('script');
            scripts.forEach(script => {
              const newScript = document.createElement('script');
              if (script.src) {
                newScript.src = script.src;
              } else {
                newScript.textContent = script.textContent;
              }
              document.head.appendChild(newScript);
            });
            
            // Initialize any components that need client-side hydration
            if (window.htmx) {
              window.htmx.process(document.getElementById('main-content'));
            }
            
            // Trigger custom events for component initialization
            window.dispatchEvent(new Event('contentLoaded'));
            
            // Initialize any Astro components that have client:load
            const clientComponents = document.querySelectorAll('[data-astro-cid]');
            clientComponents.forEach(component => {
              // Re-trigger component initialization if needed
              if (component.hasAttribute('data-hydrate')) {
                const event = new CustomEvent('astro:hydrate', { 
                  detail: { component } 
                });
                component.dispatchEvent(event);
              }
            });
            
          } else {
            throw new Error('Could not find main content in the response');
          }
        } catch (error) {
          console.error('Error loading content:', error);
          
          // Show error message to user
          document.getElementById('main-content-placeholder').innerHTML = `
            <div class="py-12 text-center">
              <h2 class="text-xl font-semibold text-red-600 mb-2">Error Loading Content</h2>
              <p class="mb-4">Sorry, we couldn't load the page content.</p>
              <a href="/${validLang}" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                Go to ${validLang.toUpperCase()} site directly
              </a>
            </div>
          `;
        }
      })();
    </script>
  </body>
</html>

