---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { Ruler, RefreshCw, Info } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const projectType = import.meta.env.PROJECT_TYPE || 'repshoes';

const { default: BaseHead } = await import(`../themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../themes/${theme}/components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  }
};

const lang = getLangFromUrl(Astro.url);

// Enhanced size conversion data with more precise mappings
const shoeSizes = {
  US: [5, 5.5, 6, 6.5, 7, 7.5, 8, 8.5, 9, 9.5, 10, 10.5, 11, 11.5, 12, 13],
  EU: [35, 36, 36.5, 37, 38, 38.5, 39, 40, 41, 41.5, 42, 42.5, 43, 44, 45, 46],
  UK: [3, 3.5, 4, 4.5, 5, 5.5, 6, 6.5, 7, 7.5, 8, 8.5, 9, 9.5, 10, 11],
  CM: [22.5, 23, 23.5, 24, 24.5, 25, 25.5, 26, 26.5, 27, 27.5, 28, 28.5, 29, 29.5, 30]
};

const clothingSizes = {
  tops: {
    International: ['XXS', 'XS', 'S', 'M', 'L', 'XL', 'XXL', '3XL'],
    US: [2, 4, 6, 8, 10, 12, 14, 16],
    EU: [32, 34, 36, 38, 40, 42, 44, 46],
    UK: [4, 6, 8, 10, 12, 14, 16, 18],
    Chest_cm: [76, 81, 86, 91, 96, 101, 106, 111],
    Waist_cm: [58, 63, 68, 73, 78, 83, 88, 93]
  },
  bottoms: {
    International: ['XXS', 'XS', 'S', 'M', 'L', 'XL', 'XXL', '3XL'],
    US: [0, 2, 4, 6, 8, 10, 12, 14],
    EU: [32, 34, 36, 38, 40, 42, 44, 46],
    UK: [4, 6, 8, 10, 12, 14, 16, 18],
    Waist_cm: [61, 66, 71, 76, 81, 86, 91, 96],
    Hip_cm: [86, 91, 96, 101, 106, 111, 116, 121]
  }
};

// Function to interpolate sizes for values not in the chart
function interpolateSize(value: number, fromArray: number[], toArray: number[]): number {
  // Find the closest indices
  let lowerIndex = 0;
  while (lowerIndex < fromArray.length && fromArray[lowerIndex] < value) {
    lowerIndex++;
  }
  
  if (lowerIndex === 0) return toArray[0];
  if (lowerIndex >= fromArray.length) return toArray[toArray.length - 1];
  
  const lowerValue = fromArray[lowerIndex - 1];
  const upperValue = fromArray[lowerIndex];
  
  // Calculate the interpolation ratio
  const ratio = (value - lowerValue) / (upperValue - lowerValue);
  
  // Interpolate between the two closest sizes
  return toArray[lowerIndex - 1] + ratio * (toArray[lowerIndex] - toArray[lowerIndex - 1]);
}

// Enhanced conversion function
function convertSize(fromSystem: string, toSystem: string, value: number) {
  if (fromSystem === toSystem) return value;

  const fromArray = shoeSizes[fromSystem];
  const toArray = shoeSizes[toSystem];
  
  if (!fromArray || !toArray) return null;

  // Try exact match first
  const exactIndex = fromArray.indexOf(value);
  if (exactIndex !== -1) {
    return toArray[exactIndex];
  }

  // If no exact match, interpolate
  return interpolateSize(value, fromArray, toArray);
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Size Guide | ${businessInfo.name}`}
      description={`Complete size guide and conversion charts for ${businessInfo.name}`}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-6xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-bold text-center mb-8">Size Guide</h1>

      <!-- Quick Size Converter (New Section) -->
      <section class="mb-12 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2 justify-center">
            <RefreshCw class="w-6 h-6" /> Quick Size Converter
          </h2>
          <div class="grid md:grid-cols-4 gap-4" id="quickConverter">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Your Size</label>
              <input 
                type="number" 
                class="w-full border rounded-md p-2" 
                id="quickSizeInput" 
                placeholder="Enter size"
                step="0.5"
              >
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">From</label>
              <select class="w-full border rounded-md p-2" id="quickFromSystem">
                <option value="US">US</option>
                <option value="EU">EU</option>
                <option value="UK">UK</option>
                <option value="CM">CM</option>
              </select>
            </div>
            <div class="flex items-center justify-center pt-8">
              <button 
                id="swapButton"
                class="p-2 rounded-full hover:bg-gray-100 transition-colors"
                aria-label="Swap conversion direction"
              >
                <RefreshCw class="w-5 h-5" />
              </button>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">To</label>
              <select class="w-full border rounded-md p-2" id="quickToSystem">
                <option value="EU">EU</option>
                <option value="US">US</option>
                <option value="UK">UK</option>
                <option value="CM">CM</option>
              </select>
            </div>
          </div>
          <div class="mt-6 text-center" id="quickResult">
            <div class="text-2xl font-bold text-gray-800 conversion-result"></div>
            <div class="text-sm text-gray-500 mt-1 closest-size"></div>
          </div>
        </div>
      </section>

      {projectType === 'repshoes' ? (
        <div class="space-y-12">
          <!-- Shoe Size Conversion Chart -->
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
              <Ruler class="w-6 h-6" /> Shoe Size Conversion Chart
            </h2>
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse border border-gray-200">
                <thead class="bg-gray-100">
                  <tr>
                    {Object.keys(shoeSizes).map((system) => (
                      <th class="border p-3 text-left">{system}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {shoeSizes.US.map((_, index) => (
                    <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                      {Object.keys(shoeSizes).map((system) => (
                        <td class="border p-3">{shoeSizes[system][index]}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- How to Measure -->
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
              <Info class="w-6 h-6" /> How to Measure Your Feet
            </h2>
            <div class="bg-white p-6 rounded-lg shadow-md space-y-4">
              <ol class="list-decimal pl-5 space-y-4">
                <li>Stand on a piece of paper with your heel against the wall</li>
                <li>Mark the longest part of your foot on the paper</li>
                <li>Measure the distance from the wall to the mark in centimeters</li>
                <li>Use the CM column in our size chart to find your size</li>
              </ol>
            </div>
          </section>
        </div>
      ) : (
        <div class="space-y-12">
          <!-- Tops Size Chart -->
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
              <Ruler class="w-6 h-6" /> Tops Size Chart
            </h2>
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse border border-gray-200">
                <thead class="bg-gray-100">
                  <tr>
                    {Object.keys(clothingSizes.tops).map((system) => (
                      <th class="border p-3 text-left">{system.replace('_', ' ')}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {clothingSizes.tops.International.map((_, index) => (
                    <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                      {Object.keys(clothingSizes.tops).map((system) => (
                        <td class="border p-3">{clothingSizes.tops[system][index]}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- Bottoms Size Chart -->
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
              <Ruler class="w-6 h-6" /> Bottoms Size Chart
            </h2>
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse border border-gray-200">
                <thead class="bg-gray-100">
                  <tr>
                    {Object.keys(clothingSizes.bottoms).map((system) => (
                      <th class="border p-3 text-left">{system.replace('_', ' ')}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {clothingSizes.bottoms.International.map((_, index) => (
                    <tr class={index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                      {Object.keys(clothingSizes.bottoms).map((system) => (
                        <td class="border p-3">{clothingSizes.bottoms[system][index]}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <!-- How to Measure -->
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
              <Info class="w-6 h-6" /> How to Measure
            </h2>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="font-semibold mb-3">For Tops:</h3>
                <ul class="list-disc pl-5 space-y-2">
                  <li><strong>Chest:</strong> Measure around the fullest part of your chest</li>
                  <li><strong>Waist:</strong> Measure around your natural waistline</li>
                  <li><strong>Shoulders:</strong> Measure across the back from shoulder to shoulder</li>
                </ul>
              </div>
              <div class="bg-white p-6 rounded-lg shadow-md">
                <h3 class="font-semibold mb-3">For Bottoms:</h3>
                <ul class="list-disc pl-5 space-y-2">
                  <li><strong>Waist:</strong> Measure around your natural waistline</li>
                  <li><strong>Hips:</strong> Measure around the fullest part of your hips</li>
                  <li><strong>Inseam:</strong> Measure from crotch to desired length</li>
                </ul>
              </div>
            </div>
          </section>
        </div>
      )}

      <!-- Enhanced Size Converter Tool -->
      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
          <RefreshCw class="w-6 h-6" /> Size Converter
        </h2>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <div class="grid md:grid-cols-3 gap-4" id="converter">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">From</label>
              <select class="w-full border rounded-md p-2" id="fromSystem">
                <option value="US">US</option>
                <option value="EU">EU</option>
                <option value="UK">UK</option>
                <option value="CM">CM</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">To</label>
              <select class="w-full border rounded-md p-2" id="toSystem">
                <option value="EU">EU</option>
                <option value="US">US</option>
                <option value="UK">UK</option>
                <option value="CM">CM</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Size</label>
              <input 
                type="number" 
                class="w-full border rounded-md p-2" 
                id="sizeInput" 
                placeholder="Enter size"
                step="0.5"
              >
            </div>
          </div>
          <div class="mt-4 text-center" id="result"></div>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      // Size conversion data (copy from above for client-side use)
      const shoeSizes = {
        US: [5, 5.5, 6, 6.5, 7, 7.5, 8, 8.5, 9, 9.5, 10, 10.5, 11, 11.5, 12, 13],
        EU: [35, 36, 36.5, 37, 38, 38.5, 39, 40, 41, 41.5, 42, 42.5, 43, 44, 45, 46],
        UK: [3, 3.5, 4, 4.5, 5, 5.5, 6, 6.5, 7, 7.5, 8, 8.5, 9, 9.5, 10, 11],
        CM: [22.5, 23, 23.5, 24, 24.5, 25, 25.5, 26, 26.5, 27, 27.5, 28, 28.5, 29, 29.5, 30]
      };

      // Interpolation function for client-side
      function interpolateSize(value, fromArray, toArray) {
        let lowerIndex = 0;
        while (lowerIndex < fromArray.length && fromArray[lowerIndex] < value) {
          lowerIndex++;
        }
        
        if (lowerIndex === 0) return toArray[0];
        if (lowerIndex >= fromArray.length) return toArray[toArray.length - 1];
        
        const lowerValue = fromArray[lowerIndex - 1];
        const upperValue = fromArray[lowerIndex];
        const ratio = (value - lowerValue) / (upperValue - lowerValue);
        
        return toArray[lowerIndex - 1] + ratio * (toArray[lowerIndex] - toArray[lowerIndex - 1]);
      }

      // Enhanced client-side conversion function
      function convertSize(fromSystem, toSystem, value) {
        if (fromSystem === toSystem) return value;

        const fromArray = shoeSizes[fromSystem];
        const toArray = shoeSizes[toSystem];
        
        if (!fromArray || !toArray) return null;

        // Try exact match first
        const exactIndex = fromArray.indexOf(value);
        if (exactIndex !== -1) {
          return toArray[exactIndex];
        }

        // If no exact match, interpolate
        return interpolateSize(value, fromArray, toArray);
      }

      // Setup event listeners
      const converter = document.getElementById('converter');
      const fromSystem = document.getElementById('fromSystem');
      const toSystem = document.getElementById('toSystem');
      const sizeInput = document.getElementById('sizeInput');
      const result = document.getElementById('result');

      function updateResult() {
        const from = fromSystem.value;
        const to = toSystem.value;
        const size = parseFloat(sizeInput.value);

        if (!isNaN(size)) {
          const convertedSize = convertSize(from, to, size);
          if (convertedSize !== null) {
            // Round to one decimal place for cleaner display
            const roundedSize = Math.round(convertedSize * 10) / 10;
            result.innerHTML = `
              <div class="text-lg font-semibold text-gray-800">
                ${size} ${from} = ${roundedSize} ${to}
              </div>
              <div class="text-sm text-gray-500 mt-1">
                Closest available size in ${to}: ${findClosestStandardSize(roundedSize, to)}
              </div>
            `;
          } else {
            result.innerHTML = '<div class="text-red-500">Size not found in conversion chart</div>';
          }
        } else {
          result.textContent = '';
        }
      }

      // Helper function to find the closest standard size
      function findClosestStandardSize(value, system) {
        const sizes = shoeSizes[system];
        return sizes.reduce((prev, curr) => 
          Math.abs(curr - value) < Math.abs(prev - value) ? curr : prev
        );
      }

      // Add input validation
      sizeInput.addEventListener('input', function(e) {
        const value = parseFloat(e.target.value);
        if (value < 0) {
          e.target.value = 0;
        }
      });

      fromSystem.addEventListener('change', updateResult);
      toSystem.addEventListener('change', updateResult);
      sizeInput.addEventListener('input', updateResult);

      // Initialize with default values
      updateResult();

      function setupQuickConverter() {
        const quickSizeInput = document.getElementById('quickSizeInput');
        const quickFromSystem = document.getElementById('quickFromSystem');
        const quickToSystem = document.getElementById('quickToSystem');
        const quickResult = document.getElementById('quickResult');
        const swapButton = document.getElementById('swapButton');

        function updateQuickResult() {
          const from = quickFromSystem.value;
          const to = quickToSystem.value;
          const size = parseFloat(quickSizeInput.value);

          if (!isNaN(size)) {
            const convertedSize = convertSize(from, to, size);
            if (convertedSize !== null) {
              const roundedSize = Math.round(convertedSize * 10) / 10;
              const closestSize = findClosestStandardSize(roundedSize, to);
              
              quickResult.querySelector('.conversion-result').textContent = 
                `${size} ${from} = ${roundedSize} ${to}`;
              
              quickResult.querySelector('.closest-size').textContent = 
                `Closest standard size: ${closestSize} ${to}`;
              
              // Add animation class
              quickResult.classList.add('animate-fade-in');
              setTimeout(() => quickResult.classList.remove('animate-fade-in'), 500);
            } else {
              quickResult.querySelector('.conversion-result').textContent = 'Size not found';
              quickResult.querySelector('.closest-size').textContent = '';
            }
          } else {
            quickResult.querySelector('.conversion-result').textContent = '';
            quickResult.querySelector('.closest-size').textContent = '';
          }
        }

        function swapSystems() {
          const tempValue = quickFromSystem.value;
          quickFromSystem.value = quickToSystem.value;
          quickToSystem.value = tempValue;
          updateQuickResult();
        }

        quickSizeInput.addEventListener('input', updateQuickResult);
        quickFromSystem.addEventListener('change', updateQuickResult);
        quickToSystem.addEventListener('change', updateQuickResult);
        swapButton.addEventListener('click', swapSystems);

        // Initialize
        updateQuickResult();
      }

      // Call setup function when DOM is loaded
      document.addEventListener('DOMContentLoaded', () => {
        setupQuickConverter();
      });

      // Add this to your existing styles
      const style = document.createElement('style');
      style.textContent = `
        .animate-fade-in {
          animation: fadeIn 0.5s ease-in-out;
        }

        @keyframes fadeIn {
          from {
            opacity: 0;
            transform: translateY(-10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
      `;
      document.head.appendChild(style);
    </script>
  </body>
</html> 