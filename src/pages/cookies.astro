---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { Cookie, Shield, Settings, Clock, AlertTriangle, HelpCircle } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const { default: BaseHead } = await import(`../themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../themes/${theme}/components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  }
};

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Cookies Policy | ${businessInfo.name}`}
      description={`Information about how we use cookies and similar technologies on ${businessInfo.name}`}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-4xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-bold text-center mb-8 pt-16">Cookies Policy</h1>
      
      <div class="prose max-w-none">
        <!-- Introduction -->
        <section class="mb-12">
          <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-8">
            <p class="text-blue-700">
              Last updated: {new Date().toLocaleDateString()}. This policy explains how we use cookies and similar tracking technologies on our website.
            </p>
          </div>

          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Cookie class="w-6 h-6" /> What Are Cookies?
          </h2>
          <p class="text-gray-600 mb-4">
            Cookies are small text files that are stored on your device when you visit our website. They help us provide you with a better browsing experience and allow us to improve our site.
          </p>
        </section>

        <!-- Types of Cookies -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Settings class="w-6 h-6" /> Types of Cookies We Use
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <div class="space-y-6">
              <div>
                <h3 class="font-semibold mb-2">Essential Cookies</h3>
                <p class="text-gray-600 mb-2">Required for the website to function properly. These cannot be disabled.</p>
                <ul class="list-disc pl-5 space-y-1 text-gray-600">
                  <li>Authentication and security</li>
                  <li>Shopping cart functionality</li>
                  <li>Basic site operations</li>
                </ul>
              </div>

              <div>
                <h3 class="font-semibold mb-2">Performance Cookies</h3>
                <p class="text-gray-600 mb-2">Help us understand how visitors interact with our website.</p>
                <ul class="list-disc pl-5 space-y-1 text-gray-600">
                  <li>Analytics and statistics</li>
                  <li>Site usage patterns</li>
                  <li>Performance monitoring</li>
                </ul>
              </div>

              <div>
                <h3 class="font-semibold mb-2">Functional Cookies</h3>
                <p class="text-gray-600 mb-2">Enable enhanced functionality and personalization.</p>
                <ul class="list-disc pl-5 space-y-1 text-gray-600">
                  <li>Language preferences</li>
                  <li>User preferences</li>
                  <li>Remember user choices</li>
                </ul>
              </div>

              <div>
                <h3 class="font-semibold mb-2">Marketing Cookies</h3>
                <p class="text-gray-600 mb-2">Used to track visitors across websites to display relevant advertisements.</p>
                <ul class="list-disc pl-5 space-y-1 text-gray-600">
                  <li>Targeted advertising</li>
                  <li>Social media features</li>
                  <li>Marketing analytics</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Cookie Duration -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Clock class="w-6 h-6" /> Cookie Duration
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <ul class="space-y-4">
              <li>
                <h3 class="font-semibold">Session Cookies</h3>
                <p class="text-gray-600">Temporary cookies that expire when you close your browser</p>
              </li>
              <li>
                <h3 class="font-semibold">Persistent Cookies</h3>
                <p class="text-gray-600">Remain on your device for a set period or until manually deleted</p>
              </li>
            </ul>
          </div>
        </section>

        <!-- Managing Cookies -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Shield class="w-6 h-6" /> Managing Cookies
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <p class="text-gray-600 mb-4">
              You can control and/or delete cookies as you wish. You can delete all cookies that are already on your computer and you can set most browsers to prevent them from being placed.
            </p>
            <div class="space-y-3">
              <p class="font-semibold">How to manage cookies in your browser:</p>
              <ul class="list-disc pl-5 space-y-2 text-gray-600">
                <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Google Chrome</a></li>
                <li><a href="https://support.mozilla.org/en-US/kb/enhanced-tracking-protection-firefox-desktop" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Mozilla Firefox</a></li>
                <li><a href="https://support.microsoft.com/en-us/microsoft-edge/delete-cookies-in-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Microsoft Edge</a></li>
                <li><a href="https://support.apple.com/guide/safari/manage-cookies-and-website-data-sfri11471/mac" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Safari</a></li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Warning -->
        <section class="mb-12">
          <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
            <h2 class="font-semibold mb-2 flex items-center gap-2">
              <AlertTriangle class="w-5 h-5 text-yellow-500" /> Important Notice
            </h2>
            <p class="text-gray-700">
              Please be aware that restricting cookies may impact the functionality of our website. Some features may not work properly if cookies are disabled.
            </p>
          </div>
        </section>

        <!-- Contact Information -->
        <section class="mb-12">
          <div class="bg-gray-50 rounded-lg p-6">
            <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
              <HelpCircle class="w-6 h-6" /> Questions About Cookies?
            </h2>
            <p class="text-gray-600 mb-4">
              If you have any questions about our use of cookies, please contact us:
            </p>
            <ul class="mt-4 space-y-2">
              <li>Email: <a href={`mailto:${businessInfo.email}`} class="text-blue-600 hover:underline">{businessInfo.email}</a></li>
              <li>Phone: <a href={`tel:${businessInfo.phone}`} class="text-blue-600 hover:underline">{businessInfo.phone}</a></li>
              <li>Address: {businessInfo.address.street}, {businessInfo.address.postalCode} {businessInfo.address.city}/{businessInfo.address.region}, {businessInfo.address.country}</li>
            </ul>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html> 