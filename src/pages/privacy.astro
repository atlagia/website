---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import { Shield, Lock, Eye, Database, Share2, Bell, MessageCircle, HelpCircle } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const { default: BaseHead } = await import(`../themes/${theme}/components/BaseHead.astro`);
const { default: Header } = await import(`../themes/${theme}/components/Header.astro`);
const { default: Footer } = await import(`../themes/${theme}/components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  }
};

const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Privacy Policy | ${businessInfo.name}`}
      description={`Privacy policy and data protection information for ${businessInfo.name} users`}
    />
  </head>
  <body>
    <Header />
    <main class="max-w-4xl mx-auto px-4 py-8">
      <h1 class="text-4xl font-bold text-center mb-8 pt-16">Privacy Policy</h1>
      
      <div class="prose max-w-none">
        <!-- Introduction -->
        <section class="mb-12">
          <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-8">
            <p class="text-blue-700">
              Last updated: {new Date().toLocaleDateString()}. This privacy policy explains how we collect, use, and protect your personal information.
            </p>
          </div>

          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Shield class="w-6 h-6" /> Our Commitment to Privacy
          </h2>
          <p class="text-gray-600 mb-4">
            At {businessInfo.name}, we take your privacy seriously. We are committed to protecting your personal information and being transparent about how we use it.
          </p>
        </section>

        <!-- Information We Collect -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Database class="w-6 h-6" /> Information We Collect
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h3 class="font-semibold mb-3">Personal Information</h3>
            <ul class="list-disc pl-5 space-y-2 mb-6">
              <li>Name and contact information</li>
              <li>Shipping and billing addresses</li>
              <li>Payment information</li>
              <li>Email address</li>
              <li>Phone number</li>
            </ul>

            <h3 class="font-semibold mb-3">Usage Information</h3>
            <ul class="list-disc pl-5 space-y-2">
              <li>Browser type and version</li>
              <li>IP address</li>
              <li>Pages visited and time spent</li>
              <li>Device information</li>
              <li>Cookies and similar technologies</li>
            </ul>
          </div>
        </section>

        <!-- How We Use Your Information -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Eye class="w-6 h-6" /> How We Use Your Information
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <Bell class="w-5 h-5 mt-1 text-blue-500 flex-shrink-0" />
                <div>
                  <h3 class="font-semibold">Order Processing and Delivery</h3>
                  <p class="text-gray-600">To process your orders, send confirmations, and provide shipping updates</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <MessageCircle class="w-5 h-5 mt-1 text-blue-500 flex-shrink-0" />
                <div>
                  <h3 class="font-semibold">Customer Support</h3>
                  <p class="text-gray-600">To provide customer service and respond to your inquiries</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <Share2 class="w-5 h-5 mt-1 text-blue-500 flex-shrink-0" />
                <div>
                  <h3 class="font-semibold">Marketing Communications</h3>
                  <p class="text-gray-600">To send you promotional offers and updates (with your consent)</p>
                </div>
              </li>
            </ul>
          </div>
        </section>

        <!-- Data Protection -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Lock class="w-6 h-6" /> Data Protection
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <p class="text-gray-600 mb-4">
              We implement appropriate technical and organizational measures to protect your personal data against unauthorized or unlawful processing, accidental loss, destruction, or damage.
            </p>
            <ul class="list-disc pl-5 space-y-2">
              <li>SSL encryption for all data transmission</li>
              <li>Regular security assessments</li>
              <li>Limited access to personal information</li>
              <li>Employee confidentiality agreements</li>
            </ul>
          </div>
        </section>

        <!-- Your Rights -->
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
            <Shield class="w-6 h-6" /> Your Rights
          </h2>
          <div class="bg-white rounded-lg shadow-md p-6">
            <p class="text-gray-600 mb-4">You have the right to:</p>
            <ul class="list-disc pl-5 space-y-2">
              <li>Access your personal data</li>
              <li>Correct inaccurate data</li>
              <li>Request deletion of your data</li>
              <li>Object to data processing</li>
              <li>Data portability</li>
              <li>Withdraw consent at any time</li>
            </ul>
          </div>
        </section>

        <!-- Cookies -->
        <section class="mb-12">
          <div class="bg-yellow-50 border-l-4 border-yellow-500 p-4">
            <h2 class="font-semibold mb-2">Cookies Policy</h2>
            <p class="text-gray-700">
              We use cookies and similar tracking technologies to improve your browsing experience on our website. 
              You can control cookies through your browser settings. For more information, please visit our Cookies Policy page.
            </p>
          </div>
        </section>

        <!-- Contact Information -->
        <section class="mb-12">
          <div class="bg-gray-50 rounded-lg p-6">
            <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
              <HelpCircle class="w-6 h-6" /> Privacy Questions or Concerns?
            </h2>
            <p class="text-gray-600 mb-4">
              If you have any questions about this Privacy Policy or how we handle your personal information, please contact our Data Protection Officer:
            </p>
            <ul class="mt-4 space-y-2">
              <li>Email: <a href={`mailto:${businessInfo.email}`} class="text-blue-600 hover:underline">{businessInfo.email}</a></li>
              <li>Phone: <a href={`tel:${businessInfo.phone}`} class="text-blue-600 hover:underline">{businessInfo.phone}</a></li>
              <li>Address: {businessInfo.address.street}, {businessInfo.address.postalCode} {businessInfo.address.city}/{businessInfo.address.region}, {businessInfo.address.country}</li>
            </ul>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html> 