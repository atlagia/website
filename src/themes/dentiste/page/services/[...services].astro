---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { Shield, Search, Activity, PiggyBank, ChevronRight, Clock, Check } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

// Fix the service path extraction
const servicePath = Astro.url.pathname.split('/').pop() || 'check-ups';

// Validate if the service exists
const validServices = [
  'check-ups',
  'cleaning',
  'fillings',
  'root-canal',
  'teeth-whitening',
  'veneers',
  'bonding',
  'smile-makeover',
  'orthodontics',
  'implants',
  'periodontics',
  'emergency'
];

if (!validServices.includes(servicePath)) {
  return Astro.redirect('/404');
}

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific service data with proper path construction
const serviceData = await import(`../../data/services/${servicePath}/${servicePath}_${lang}.json`);

// Generate static paths for all services
export async function getStaticPaths() {
  const languages = ['en', 'fr', 'es', 'it', 'de'];
  const services = [
    'check-ups',
    'cleaning',
    'fillings',
    'root-canal',
    'teeth-whitening',
    'veneers',
    'bonding',
    'smile-makeover',
    'orthodontics',
    'implants',
    'periodontics',
    'emergency'
  ];
  
  return languages.flatMap(lang => 
    services.map(service => ({
      params: { 
        lang,
        services: service 
      }
    }))
  );
}

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  tooth: `<path d="M12 2.5c-1.7 0-3 1.3-3 3 0 1.7-1.3 3-3 3h-2v2c0 2.2 1.8 4 4 4h8c2.2 0 4-1.8 4-4v-2h-2c-1.7 0-3-1.3-3-3 0-1.7-1.3-3-3-3z"/>`,
  scan: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><path d="M9 9h.01"/><path d="M15 9h.01"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  search: `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>`,
  activity: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  'piggy-bank': `<path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2V5z"/><path d="M2 9v1c0 1.1.9 2 2 2h1"/><path d="M16 11h0"/>`,
  'shield-check': `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  brush: `<path d="M9.06 11.9l8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.07"/><path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"/>`,
  sparkles: `<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>`,
  wind: `<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>`,
  heart: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
  'list-check': `<path d="m16 6 2 2 4-4"/><path d="m16 12 2 2 4-4"/><path d="m16 18 2 2 4-4"/><path d="M4 6h8"/><path d="M4 12h8"/><path d="M4 18h8"/>`,
  'message-circle': `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${serviceData.hero.title} | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
              {serviceData.hero.subtitle}
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{serviceData.hero.title}</h1>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">
              {serviceData.hero.description}
            </p>
          </div>
        </div>
      </section>

      <!-- Overview Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.overview.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.overview.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {serviceData.overview.features.map(feature => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[feature.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Rest of the sections remain the same as in the previous check-ups.astro -->
      <!-- Process Section -->
      <!-- Benefits Section -->
      <!-- FAQ Section -->
      <!-- CTA Section -->
      
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 