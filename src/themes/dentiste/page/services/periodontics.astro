---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { 
  Activity,
  Shield,
  Target,
  Heart,
  AlertCircle,
  AlertTriangle,
  ArrowDown,
  Scissors,
  Maximize,
  Layers,
  Camera,
  Zap,
  Box,
  Waves
} = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific service data
const serviceData = await import(`../../data/services/periodontics/periodontics_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  activity: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  target: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  heart: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  "alert-circle": `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  "alert-triangle": `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  "arrow-down": `<line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>`,
  scissors: `<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>`,
  maximize: `<path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  camera: `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  box: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>`,
  waves: `<path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${serviceData.hero.title} | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
            {serviceData.hero.subtitle}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{serviceData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {serviceData.hero.description}
          </p>
        </div>
      </section>

      <!-- Services Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.services.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.services.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {serviceData.services.treatments.map(treatment => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{treatment.name}</h3>
                <p class="text-gray-600 mb-4">{treatment.description}</p>
                <div class="space-y-4">
                  <div class="flex items-center text-[#0a91b1] font-semibold">
                    <span class="mr-2">Starting at:</span>
                    <span class="text-xl">{treatment.price}</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span>Duration: {treatment.duration}</span>
                  </div>
                </div>
                <ul class="mt-6 space-y-3">
                  {treatment.features.map(feature => (
                    <li class="flex items-center">
                      <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span class="text-gray-600">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Conditions Section -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.conditions.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.conditions.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {serviceData.conditions.issues.map(issue => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[issue.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{issue.title}</h3>
                <p class="text-gray-600">{issue.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Technology Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.technology.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.technology.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {serviceData.technology.features.map(feature => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[feature.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Prevention Section -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.prevention.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.prevention.description}</p>
          </div>
          <div class="max-w-3xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {serviceData.prevention.tips.map(tip => (
                <div class="flex items-center p-4 bg-white rounded-xl shadow-sm">
                  <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-gray-700">{tip}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="relative py-16 px-4 bg-[#0a91b1]">
        <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">{serviceData.cta.title}</h2>
          <p class="text-xl text-white/90 max-w-3xl mx-auto mb-8">{serviceData.cta.description}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={serviceData.cta.primaryButton.href}
              class="inline-block px-8 py-3 bg-white text-[#0a91b1] font-semibold rounded-full hover:bg-gray-100 transition-colors duration-300"
            >
              {serviceData.cta.primaryButton.text}
            </a>
            <a
              href={serviceData.cta.secondaryButton.href}
              class="inline-block px-8 py-3 bg-transparent text-white font-semibold rounded-full border-2 border-white hover:bg-white/10 transition-colors duration-300"
            >
              {serviceData.cta.secondaryButton.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 