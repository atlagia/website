---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { Shield, Star, Clock, Smile, Sun, Wand, Palette, MoveHorizontal, Puzzle, ArrowRight, Zap } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific service data
const serviceData = await import(`../../data/services/veneers/veneers_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  palette: `<circle cx="13.5" cy="6.5" r="3.5"/><path d="M7 14c-1.5 1-3 3.5-3 5.5a5.5 5.5 0 0 0 11 0c0-2-1.5-4.5-3-5.5"/><path d="M14 6.5v10"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  wand: `<path d="M15 4V2"/><path d="M15 16v-2"/><path d="M8 9h2"/><path d="M20 9h2"/><path d="M17.8 11.8 19 13"/><path d="M15 9h0"/><path d="M17.8 6.2 19 5"/><path d="m3 21 9-9"/><path d="M12.2 6.2 11 5"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  sun: `<circle cx="12" cy="12" r="5"/><path d="M12 1v2"/><path d="M12 21v2"/><path d="M4.22 4.22l1.42 1.42"/><path d="M18.36 18.36l1.42 1.42"/><path d="M1 12h2"/><path d="M21 12h2"/><path d="M4.22 19.78l1.42-1.42"/><path d="M18.36 5.64l1.42-1.42"/>`,
  "move-horizontal": `<polyline points="18 8 22 12 18 16"/><polyline points="6 8 2 12 6 16"/><line x1="2" y1="12" x2="22" y2="12"/>`,
  puzzle: `<path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.611 1.611a2.404 2.404 0 0 1-1.704.706 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.23 8.77c.24-.24.867-.676 1.915-.866-.18-.464-.527-.894-1.02-.967a2.5 2.5 0 1 1 3.237-3.237c.18.464.527.894.967 1.02.323.049.649-.059.879-.289L11.776 2.9c.47-.47 1.087-.706 1.704-.706s1.233.236 1.704.706l1.568 1.568c.23.23.556.338.879.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02z"/>`,
  "arrow-right": `<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>`,
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  smile: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${serviceData.hero.title} | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
            {serviceData.hero.subtitle}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{serviceData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {serviceData.hero.description}
          </p>
        </div>
      </section>

      <!-- Solutions Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.solutions.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.solutions.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {serviceData.solutions.problems.map(problem => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[problem.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{problem.title}</h3>
                <p class="text-gray-600">{problem.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Types of Veneers -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.types.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.types.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {serviceData.types.options.map(option => (
              <div class={`p-8 bg-white rounded-2xl border-2 ${option.recommended ? 'border-[#0a91b1]' : 'border-gray-100'} shadow-lg hover:shadow-xl transition-all duration-300 relative`}>
                {option.recommended && (
                  <span class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-[#0a91b1] text-white px-4 py-1 rounded-full text-sm font-medium">
                    Recommended
                  </span>
                )}
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{option.name}</h3>
                <p class="text-3xl font-bold text-[#0a91b1] mb-4">{option.price}</p>
                <p class="text-gray-600 mb-6">{option.description}</p>
                <ul class="space-y-3">
                  {option.features.map(feature => (
                    <li class="flex items-center">
                      <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span class="text-gray-600">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Process Steps -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.process.title}</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-8">
            {serviceData.process.steps.map((step, index) => (
              <div class="relative">
                {index < serviceData.process.steps.length - 1 && (
                  <div class="hidden lg:block absolute top-1/2 right-0 transform translate-x-1/2 -translate-y-1/2">
                    <svg class="w-6 h-6 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </div>
                )}
                <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                  <span class="inline-block text-3xl font-bold text-[#0a91b1] mb-4">{step.number}</span>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">{step.title}</h3>
                  <p class="text-gray-600">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.testimonials.title}</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {serviceData.testimonials.reviews.map(review => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg">
                <div class="flex items-center mb-4">
                  {Array.from({ length: review.rating }).map(() => (
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                <p class="text-gray-600 mb-4">{review.comment}</p>
                <div class="flex justify-between items-center">
                  <span class="font-semibold text-gray-900">{review.name}</span>
                  <span class="text-sm text-gray-500">{review.date}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="relative py-16 px-4 bg-[#0a91b1]">
        <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">{serviceData.cta.title}</h2>
          <p class="text-xl text-white/90 max-w-3xl mx-auto mb-8">{serviceData.cta.description}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={serviceData.cta.primaryButton.href}
              class="inline-block px-8 py-3 bg-white text-[#0a91b1] font-semibold rounded-full hover:bg-gray-100 transition-colors duration-300"
            >
              {serviceData.cta.primaryButton.text}
            </a>
            <a
              href={serviceData.cta.secondaryButton.href}
              class="inline-block px-8 py-3 bg-transparent text-white font-semibold rounded-full border-2 border-white hover:bg-white/10 transition-colors duration-300"
            >
              {serviceData.cta.secondaryButton.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 