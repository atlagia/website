---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { 
  CheckCircle, 
  Smile, 
  Zap, 
  Shield, 
  Scan, 
  Cpu, 
  Camera, 
  Layers,
  Clock,
  Utensils,
  Activity,
  Star
} = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific service data
const serviceData = await import(`../../data/services/implants/implants_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  "check-circle": `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
  smile: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  scan: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/>`,
  cpu: `<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
  camera: `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  utensils: `<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M17 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><line x1="12" y1="17" x2="12" y2="22"/><line x1="10" y1="22" x2="14" y2="22"/>`,
  activity: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  star: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${serviceData.hero.title} | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
            {serviceData.hero.subtitle}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{serviceData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {serviceData.hero.description}
          </p>
        </div>
      </section>

      <!-- Implant Solutions -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.types.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.types.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {serviceData.types.options.map(option => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="aspect-video rounded-xl overflow-hidden mb-6">
                  <img src={option.image} alt={option.name} class="w-full h-full object-cover"/>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{option.name}</h3>
                <p class="text-gray-600 mb-4">{option.description}</p>
                <div class="space-y-4">
                  <div class="flex items-center text-[#0a91b1] font-semibold">
                    <span class="mr-2">Starting at:</span>
                    <span class="text-xl">{option.price}</span>
                  </div>
                  <div class="flex items-center text-gray-600">
                    <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span>Treatment time: {option.duration}</span>
                  </div>
                </div>
                <ul class="mt-6 space-y-3">
                  {option.features.map(feature => (
                    <li class="flex items-center">
                      <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span class="text-gray-600">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Technology Section -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.technology.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.technology.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {serviceData.technology.features.map(feature => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[feature.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Process Steps -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.process.title}</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-8">
            {serviceData.process.steps.map((step, index) => (
              <div class="relative">
                {index < serviceData.process.steps.length - 1 && (
                  <div class="hidden lg:block absolute top-1/2 right-0 transform translate-x-1/2 -translate-y-1/2">
                    <svg class="w-6 h-6 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </div>
                )}
                <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                  <span class="inline-block text-3xl font-bold text-[#0a91b1] mb-4">{step.number}</span>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">{step.title}</h3>
                  <p class="text-gray-600">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Candidacy Section -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.candidacy.title}</h2>
          </div>
          <div class="max-w-3xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {serviceData.candidacy.requirements.map(requirement => (
                <div class="flex items-center p-4 bg-white rounded-xl shadow-sm">
                  <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-gray-700">{requirement}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Financing Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.financing.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.financing.description}</p>
          </div>
          <div class="max-w-3xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {serviceData.financing.options.map(option => (
                <div class="flex items-center p-4 bg-white rounded-xl shadow-sm">
                  <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-gray-700">{option}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="relative py-16 px-4 bg-[#0a91b1]">
        <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">{serviceData.cta.title}</h2>
          <p class="text-xl text-white/90 max-w-3xl mx-auto mb-8">{serviceData.cta.description}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={serviceData.cta.primaryButton.href}
              class="inline-block px-8 py-3 bg-white text-[#0a91b1] font-semibold rounded-full hover:bg-gray-100 transition-colors duration-300"
            >
              {serviceData.cta.primaryButton.text}
            </a>
            <a
              href={serviceData.cta.secondaryButton.href}
              class="inline-block px-8 py-3 bg-transparent text-white font-semibold rounded-full border-2 border-white hover:bg-white/10 transition-colors duration-300"
            >
              {serviceData.cta.secondaryButton.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 