---
interface Props {
  title: string;
  description: string;
  services: {
    icon: string;
    title: string;
    description: string;
  }[];
}

const { title, description, services } = Astro.props;
---

<section class="py-20 bg-white" id="content-servicesSection">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" id="content-title">{title}</h2>
      <p class="text-gray-600" id="content-description">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service, index) => (
          <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6 text-blue-600">
              <i class={service.icon} id={`content-serviceIcon-${index}`}></i>
            </div>
            <h3 class="text-xl font-semibold mb-3" id={`content-serviceTitle-${index}`}>{service.title}</h3>
            <p class="text-gray-600" id={`content-serviceDescription-${index}`}>{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section> 