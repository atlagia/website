---
import { Button } from './ui/Button';
import { Mail } from 'lucide-react';

// Import form configuration
const { config, form } = await import('../forms/emailsignup/config.json');

interface Props {
  subtitle?: string;
  title?: string;
  description?: string;
  buttonText?: string;
  placeholder?: string;
  features?: string[];
}

const {
  subtitle = form.subtitle,
  title = form.title,
  description = form.description,
  buttonText = form.buttonText,
  placeholder = form.placeholder,
  features = form.features
} = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-white to-gray-50">
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-blue-500/10 to-purple-500/10 rounded-full blur-3xl animate-blob"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        {subtitle && (
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold bg-blue-50 text-blue-600 rounded-full border border-blue-100">
            {subtitle}
          </span>
        )}
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 tracking-tight">
          {title}
        </h2>
        <p class="text-xl text-gray-600 leading-relaxed">
          {description}
        </p>
      </div>

      <form 
        id="newsletter-form" 
        class="max-w-2xl mx-auto mb-12 space-y-4"
      >
        <div class="flex flex-col sm:flex-row gap-4">
          {form.fields.map(field => (
            <div class="flex-1">
              <input 
                type={field.type}
                name={field.id}
                placeholder={field.placeholder}
                class="w-full px-6 py-4 bg-white border border-gray-200 rounded-full focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 transition-all"
                required={field.required}
              />
            </div>
          ))}
        </div>

        <div class="flex justify-center">
          <button
            type="submit"
            class="px-8 py-4 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/25 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
          >
            {buttonText}
          </button>
        </div>
      </form>

      {features.length > 0 && (
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
          {features.map((feature) => (
            <div class="flex items-center text-gray-600">
              <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>{feature}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<script define:vars={{ config }}>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('newsletter-form');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const today = new Date().toISOString().split('T')[0];
    
    // Prepare the data according to the schema
    const subscriberData = {
      name: formData.get('name'),
      email: formData.get('email'),
      subscriptionDate: today,
      subscriptionStatus: 'Subscribed'
    };

    try {
      const response = await fetch(
        `${config.apiBaseUrl}/builder/entities/${config.schemaId}/entries/create/`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Schema-Key-Token': config.keyToken
          },
          body: JSON.stringify({
            data: subscriberData,
            key_token: config.keyToken
          })
        }
      );

      const result = await response.json();
      
      if (result.id) {
        // Success
        form.reset();
        alert('Thank you for subscribing to our newsletter!');
      } else {
        throw new Error(result.error || 'Failed to subscribe');
      }
    } catch (error) {
      console.error('Subscription error:', error);
      alert('Sorry, there was an error processing your subscription. Please try again.');
    }
  });
});
</script>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>