---
import { SITE_TITLE } from '../consts';
import { BarChart, Zap, ArrowRight } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific about data
const aboutData = await import(`../data/about/about_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// Map icon strings to actual components
const iconMap = {
  BarChart,
  Zap
};

// Map features with actual icon components
const features = aboutData.welcome.features.map(feature => ({
  ...feature,
  icon: iconMap[feature.icon]
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`About Us | ${businessInfo.name}`}
      description={aboutData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-pink-50 text-pink-600">{aboutData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{aboutData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {aboutData.hero.description}
          </p>
        </div>
      </section>

      <!-- Welcome Section -->
      <section class="relative py-20 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <span class="text-sm font-semibold text-gray-600 mb-4 block">{aboutData.welcome.subtitle}</span>
              <h2 class="text-3xl md:text-4xl font-bold mb-6">{aboutData.welcome.title}</h2>
              <p class="text-gray-600 mb-12">{aboutData.welcome.description}</p>
              <div class="space-y-8">
                {features.map(feature => (
                  <div class="flex gap-4">
                    <div class={`w-12 h-12 rounded-xl bg-${feature.color}-50 flex items-center justify-center flex-shrink-0`}>
                      <feature.icon className={`w-6 h-6 text-${feature.color}-600`} />
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
                      <p class="text-gray-600">{feature.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <img 
                src={aboutData.welcome.image}
                alt="E-commerce Dashboard"
                class="w-full h-auto rounded-2xl shadow-lg"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Platform Integration -->
      <section class="relative py-16 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="flex flex-wrap justify-center items-center gap-12 opacity-60">
            {aboutData.platforms.map(platform => (
              <img 
                src={platform.logo}
                alt={platform.name}
                class="h-8 w-auto"
              />
            ))}
          </div>
        </div>
      </section>

      <!-- Innovation Section -->
      <section class="relative py-20 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <img 
                src={aboutData.innovation.image}
                alt="Innovation"
                class="w-full h-auto rounded-2xl"
              />
            </div>
            <div>
              <span class="text-sm font-semibold text-gray-600 mb-4 block">{aboutData.innovation.subtitle}</span>
              <h2 class="text-3xl md:text-4xl font-bold mb-6">{aboutData.innovation.title}</h2>
              <p class="text-gray-600 mb-8">{aboutData.innovation.description}</p>
              <div class="grid grid-cols-2 gap-8 mb-8">
                {aboutData.innovation.milestones.map(milestone => (
                  <div>
                    <div class="text-4xl font-bold text-pink-600 mb-2">{milestone.number}</div>
                    <div class="font-semibold">{milestone.title}</div>
                  </div>
                ))}
              </div>
              <a 
                href={aboutData.innovation.cta.link}
                class="inline-flex items-center gap-2 text-navy-900 font-semibold hover:text-pink-600 transition-colors"
              >
                {aboutData.innovation.cta.text}
                <ArrowRight className="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section class="relative py-20 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold mb-4">{aboutData.testimonials.title}</h2>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto">
              {aboutData.testimonials.description}
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {aboutData.testimonials.items.map(testimonial => (
              <div class="bg-white p-8 rounded-2xl">
                <p class="text-gray-600 mb-6">{testimonial.content}</p>
                <div class="flex items-center gap-4">
                  <img 
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="w-12 h-12 rounded-full"
                  />
                  <div>
                    <div class="font-semibold">{testimonial.name}</div>
                    <div class="text-sm text-gray-600">{testimonial.position}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="text-center mt-12">
            <a
              href={aboutData.testimonials.cta.link}
              class="inline-flex items-center px-6 py-3 rounded-lg bg-navy-900 text-white font-semibold hover:bg-navy-800 transition-colors"
            >
              {aboutData.testimonials.cta.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>