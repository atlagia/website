---
import { SITE_TITLE } from '../consts';
import { Brain, Target, Wand, LineChart, Check, ArrowRight, Star } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific service data
const serviceData = await import(`../data/services/email-marketing-ai/email_marketing_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// Map icon strings to actual components
const iconMap = {
  Brain: Brain,
  Target: Target,
  Wand: Wand,
  LineChart: LineChart
};

// Map benefits with actual icon components
const benefits = serviceData.benefits.items.map(benefit => ({
  ...benefit,
  icon: iconMap[benefit.icon] || Brain
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Email Marketing AI | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-pink-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/10 to-green-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
              <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-purple-50 text-purple-600">{serviceData.hero.subtitle}</span>
              <h1 class="text-4xl md:text-5xl font-bold mb-6">{serviceData.hero.title}</h1>
              <p class="text-xl text-gray-600 mb-8">{serviceData.hero.description}</p>
              <div class="flex flex-wrap gap-4">
                {serviceData.cta.buttons.map(button => (
                  <a
                    href={button.link}
                    class={`px-6 py-3 rounded-lg font-semibold transition-colors ${
                      button.primary
                        ? 'bg-navy-900 text-white hover:bg-navy-800'
                        : 'bg-white text-navy-900 hover:bg-gray-50'
                    }`}
                  >
                    {button.text}
                  </a>
                ))}
              </div>
            </div>
            <div>
              <img
                src={serviceData.hero.image}
                alt="Email Marketing AI"
                class="w-full h-auto"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Benefits Section -->
      <section class="py-20 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl font-bold text-center mb-12">{serviceData.benefits.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {benefits.map(benefit => (
              <div class="p-6 bg-[#f9faff] rounded-2xl">
                <div class={`w-12 h-12 rounded-xl bg-${benefit.color}-50 flex items-center justify-center mb-6`}>
                  <benefit.icon className={`w-6 h-6 text-${benefit.color}-600`} />
                </div>
                <h3 class="text-xl font-semibold mb-3">{benefit.title}</h3>
                <p class="text-gray-600">{benefit.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="py-20 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{serviceData.features.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.features.description}</p>
          </div>
          <div class="space-y-16">
            {serviceData.features.items.map((feature, index) => (
              <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${
                index % 2 === 1 ? 'lg:flex-row-reverse' : ''
              }`}>
                <div>
                  <h3 class="text-2xl font-bold mb-4">{feature.title}</h3>
                  <p class="text-gray-600 mb-6">{feature.description}</p>
                  <ul class="space-y-3">
                    {feature.features.map(item => (
                      <li class="flex items-center gap-3">
                        <Check className="w-5 h-5 text-green-500" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <img
                    src={feature.image}
                    alt={feature.title}
                    class="w-full h-auto rounded-2xl shadow-lg"
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- How It Works -->
      <section class="py-20 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{serviceData.howItWorks.title}</h2>
            <p class="text-xl text-gray-600">{serviceData.howItWorks.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {serviceData.howItWorks.steps.map(step => (
              <div class="relative">
                <div class="text-4xl font-bold text-purple-600 mb-4">{step.number}</div>
                <h3 class="text-xl font-semibold mb-3">{step.title}</h3>
                <p class="text-gray-600">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Pricing Section -->
      <section class="py-20 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{serviceData.pricing.title}</h2>
            <p class="text-xl text-gray-600">{serviceData.pricing.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {serviceData.pricing.plans.map(plan => (
              <div class={`relative p-8 bg-white rounded-2xl ${
                plan.popular ? 'ring-2 ring-purple-600' : ''
              }`}>
                {plan.popular && (
                  <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                    <div class="flex items-center gap-1 px-3 py-1 bg-purple-600 text-white text-sm rounded-full">
                      <Star className="w-4 h-4" />
                      Popular
                    </div>
                  </div>
                )}
                <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
                <p class="text-gray-600 mb-6">{plan.description}</p>
                <div class="flex items-baseline mb-6">
                  <span class="text-4xl font-bold">${plan.price}</span>
                  <span class="text-gray-600">{plan.period}</span>
                </div>
                <ul class="space-y-3 mb-8">
                  {plan.features.map(feature => (
                    <li class="flex items-center gap-3">
                      <Check className="w-5 h-5 text-green-500" />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={plan.cta.link}
                  class={`block w-full py-3 text-center rounded-lg font-semibold transition-colors ${
                    plan.popular
                      ? 'bg-navy-900 text-white hover:bg-navy-800'
                      : 'bg-[#f9faff] text-navy-900 hover:bg-gray-100'
                  }`}
                >
                  {plan.cta.text}
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section class="py-20 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl font-bold text-center mb-12">{serviceData.testimonials.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {serviceData.testimonials.items.map(testimonial => (
              <div class="p-8 bg-[#f9faff] rounded-2xl">
                <p class="text-gray-600 mb-6">{testimonial.content}</p>
                <div class="flex items-center gap-4">
                  <img
                    src={testimonial.image}
                    alt={testimonial.author}
                    class="w-12 h-12 rounded-full"
                  />
                  <div>
                    <div class="font-semibold">{testimonial.author}</div>
                    <div class="text-sm text-gray-600">{testimonial.position}</div>
                    <div class="text-sm text-gray-600">{testimonial.company}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="relative py-20 px-4 bg-navy-900 text-white overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/20 to-pink-500/20 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">{serviceData.cta.title}</h2>
          <p class="text-xl text-gray-300 mb-8">{serviceData.cta.description}</p>
          <div class="flex flex-wrap justify-center gap-4">
            {serviceData.cta.buttons.map(button => (
              <a
                href={button.link}
                class={`px-6 py-3 rounded-lg font-semibold transition-colors ${
                  button.primary
                    ? 'bg-white text-navy-900 hover:bg-gray-100'
                    : 'bg-navy-800 text-white hover:bg-navy-700'
                }`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }
  .bg-navy-700 {
    background-color: #1a1b35;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 