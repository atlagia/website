---
interface Feature {
  icon: string;
  title: string;
  description: string;
  bullets?: string[];
  backgroundSvg?: string;
  keywords?: string[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  features?: Array<{
    title: string;
    description: string;
  }>;
  stats?: Array<{
    value: string;
    label: string;
  }>;
}

const { 
  subtitle, 
  title, 
  description, 
  image,
  features = [],
  stats = []
} = Astro.props;

// Simplified position function for single keyword
function getKeywordPosition(): string {
  return 'absolute -top-2 right-0 translate-x-1/3 -translate-y-full'; // Position above and slightly to the right
}
---

<section class="relative py-24 px-4 overflow-hidden bg-gray-900">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-cyan-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Image Section -->
      <div class="flex-1 order-2 lg:order-1">
        <div class="relative">
          <!-- Image Container -->
          <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl h-[500px]">
            {image && (
              <img 
                src={image} 
                alt="Our Dental Practice"
                class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            )}
          </div>

          <!-- Decorative Elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-cyan-500/10 rounded-full blur-lg"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-blue-500/10 rounded-full blur-lg"></div>

          <!-- Experience Badge -->
          <div class="absolute top-4 right-4 bg-gray-800/80 backdrop-blur-sm px-6 py-4 rounded-lg shadow-lg border border-gray-700">
            <div class="text-3xl font-bold text-cyan-400">15+</div>
            <div class="text-sm text-gray-300">Years Experience</div>
          </div>
        </div>
      </div>

      <!-- Content Section -->
      <div class="flex-1 order-1 lg:order-2">
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-gray-800/50 text-cyan-400 backdrop-blur-sm border border-gray-700">
          {subtitle}
        </span>
        
        <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
          {title}
        </h2>
        
        <p class="text-lg text-gray-300 leading-relaxed mb-8">
          {description}
        </p>

        <!-- Features List -->
        <div class="space-y-6 mb-8">
          {features.map((feature) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gray-800/50 flex items-center justify-center border border-gray-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white mb-1">{feature.title}</h3>
                <p class="text-gray-300">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Stats Grid -->
        {stats && stats.length > 0 && (
          <div class="grid grid-cols-2 gap-8 mt-12">
            {stats.map((stat) => (
              <div class="text-center p-4 bg-gray-800/50 backdrop-blur-sm rounded-xl border border-gray-700 hover:bg-gray-800/80 transition-all duration-300">
                <div class="text-3xl font-bold text-cyan-400 mb-1">{stat.value}</div>
                <div class="text-gray-300 font-medium">{stat.label}</div>
              </div>
            ))}
          </div>
        )}

        <!-- CTA Button -->
        <div class="mt-12">
          <a 
            href="/contact" 
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-cyan-600 hover:bg-cyan-700 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-cyan-500/25 hover:-translate-y-0.5"
          >
            Schedule Consultation
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 