---
import { Button } from './ui/Button';
import { ArrowRight } from 'lucide-react';

interface Logo {
  src: string;
  alt: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  blogLink: string;
  blogLinkText: string;
  heroImage: string;
  partnerLogos: Logo[];
  getStartedText?: string;
}

const { 
  badge, 
  title, 
  description, 
  blogLink, 
  blogLinkText, 
  heroImage, 
  partnerLogos,
  getStartedText = 'Book Appointment'
} = Astro.props;
const isRTL = Astro.url.pathname.includes('/ar/');
---

<section class="relative min-h-[85vh] flex items-center justify-center px-4 pt-20 pb-0 overflow-hidden bg-gradient-to-b from-[#f0f9ff] via-white to-transparent">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Blobs -->
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-blue-500/5 to-teal-500/5 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-teal-500/5 to-blue-500/5 rounded-full blur-3xl animate-blob"></div>
  </div>



  <div class={`relative z-10 max-w-7xl mx-auto flex flex-col ${isRTL ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-center gap-12`}>
    <div class="flex-1 flex flex-col">
      <div class={`mb-6 flex ${isRTL ? 'justify-end' : 'justify-start'}`}>
        <span class="px-4 py-1.5 rounded-full text-sm font-medium bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
          {badge}
        </span>
      </div>
      <h1 
        class="text-4xl lg:text-6xl font-bold mb-6 leading-tight text-gray-900"
        set:html={title}
      />
      <!-- Mobile Image -->
      <div class="block lg:hidden relative mb-8">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-teal-500/10 rounded-3xl blur-2xl transform rotate-6 scale-110"></div>
        <img 
          src={heroImage}
          alt="Dental Care Illustration"
          class="relative w-full max-w-[600px] mx-auto drop-shadow-xl transform hover:scale-105 transition-transform duration-300"
        />
      </div>
      <p class="text-xl text-gray-600 mb-8">
        {description}
      </p>
      <div class={`flex flex-col sm:flex-row gap-4 ${isRTL ? 'justify-end' : 'justify-start'}`}>
        <a 
          href="https://app.dentiste.com/booking"
          class="inline-flex items-center justify-center gap-2 bg-[#0a91b1] hover:bg-[#097d99] text-white px-8 py-4 rounded-lg transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          {getStartedText}
          <ArrowRight className={`w-5 h-5 ${isRTL ? 'rtl-rotate-180' : ''}`} />
        </a>
        <a 
          href={blogLink}
          class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-900 px-8 py-4 rounded-lg font-semibold transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 border border-gray-200"
        >
          {blogLinkText}
          <ArrowRight className={`w-5 h-5 ${isRTL ? 'rtl-rotate-180' : ''}`} />
        </a>
      </div>
      <div class={`mt-12 flex items-center ${isRTL ? 'justify-end' : 'justify-start'} gap-8`}>
        {partnerLogos.map((logo) => (
          <img 
            src={logo.src} 
            alt={logo.alt} 
            class="h-12 opacity-60 hover:opacity-100 transition-opacity duration-300" 
          />
        ))}
      </div>
    </div>
    <!-- Desktop Image -->
    <div class="flex-1 relative hidden lg:block">
      <!-- Background Effect -->
      <div class="absolute inset-0 bg-gradient-to-r from-blue-500/10 to-teal-500/10 rounded-3xl blur-2xl transform rotate-6 scale-110"></div>
      
      <!-- Dental-themed Decorative Shapes -->
      <div class="absolute -bottom-4 -left-8 w-24 h-24 border-4 border-cyan-200 rounded-full transform rotate-12"></div>
      <div class="absolute -bottom-6 left-20 w-16 h-16 bg-blue-50 rounded-lg transform rotate-45"></div>
      <div class="absolute -bottom-4 right-12 w-20 h-20">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M50 0C55 0 60 5 65 15C70 25 75 30 80 30C90 30 95 25 95 20C95 15 90 10 85 10C80 10 75 15 75 20C75 40 65 50 50 50C35 50 25 40 25 20C25 15 20 10 15 10C10 10 5 15 5 20C5 25 10 30 20 30C25 30 30 25 35 15C40 5 45 0 50 0Z" fill="#E0F2FE"/>
        </svg>
      </div>
      
      <!-- Main Image -->
      <img 
        src={heroImage}
        alt="Dental Care Illustration"
        class="relative w-full max-w-[800px] mx-auto drop-shadow-xl transform hover:scale-105 transition-transform duration-300"
      />

      <!-- Additional Dental Shapes -->
      <div class="absolute bottom-0 right-24 w-12 h-12 border-2 border-blue-200 rounded-full"></div>
      <div class="absolute bottom-2 right-40 w-8 h-8">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 4C18 4 20 8 22 12C24 16 26 18 28 18C30 18 32 16 32 14C32 12 30 10 28 10C26 10 24 12 24 14C24 22 20 26 16 26C12 26 8 22 8 14C8 12 6 10 4 10C2 10 0 12 0 14C0 16 2 18 4 18C6 18 8 16 10 12C12 8 14 4 16 4Z" fill="#93C5FD"/>
        </svg>
      </div>

      <!-- Bottom Pattern -->
      <div class="absolute bottom-0 left-0 right-0 h-16">
        <div class="absolute bottom-0 left-1/4 w-2 h-8 bg-cyan-100 rounded-full transform -rotate-12"></div>
        <div class="absolute bottom-2 left-1/3 w-2 h-12 bg-blue-100 rounded-full transform rotate-12"></div>
        <div class="absolute bottom-1 right-1/4 w-2 h-10 bg-cyan-100 rounded-full transform -rotate-6"></div>
        <div class="absolute bottom-3 right-1/3 w-2 h-8 bg-blue-100 rounded-full transform rotate-6"></div>
      </div>
    </div>
  </div>

  <!-- Bottom Wave Pattern -->
  <div class="absolute bottom-0 left-0 right-0 h-12 overflow-hidden z-1">
    <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path 
        fill-rule="evenodd" 
        clip-rule="evenodd" 
        d="M0 0L60 10C120 20 240 40 360 46.7C480 53 600 47 720 40C840 33 960 27 1080 30C1200 33 1320 47 1380 53.3L1440 60V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0V0Z" 
        fill="white" 
        fill-opacity="0.4"
      />
      <path 
        fill-rule="evenodd" 
        clip-rule="evenodd" 
        d="M0 60L60 56.7C120 53 240 47 360 50C480 53 600 67 720 70C840 73 960 67 1080 63.3C1200 60 1320 60 1380 60H1440V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0V60Z" 
        fill="white" 
        fill-opacity="0.8"
      />
    </svg>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
    will-change: transform;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .font-arabic {
    font-family: 'Cairo', sans-serif;
  }

  /* Add smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Add transition for shape movements */
  .transition-transform {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.dental-highlight) {
    color: #0a91b1;
  }
</style>