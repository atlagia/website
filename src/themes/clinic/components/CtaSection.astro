---
interface Props {
  subtitle?: string;
  title: string;
  description: string;
  primaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonText: string;
  secondaryButtonLink: string;
  stats?: Array<{
    value: string;
    label: string;
  }>;
  emergencyContact?: {
    phone: string;
    hours: string;
  };
}

const {
  subtitle,
  title,
  description,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  stats,
  emergencyContact
} = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gray-900">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-cyan-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Main Content -->
    <div class="text-center max-w-3xl mx-auto mb-12">
      {subtitle && (
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-gray-800/50 text-cyan-400 backdrop-blur-sm border border-gray-700">
          {subtitle}
        </span>
      )}
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">
        {title}
      </h2>
      <p class="text-xl text-gray-300 leading-relaxed mb-8">
        {description}
      </p>
      
      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={primaryButtonLink}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-cyan-600 hover:bg-cyan-700 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-cyan-500/25 hover:-translate-y-0.5"
        >
          {primaryButtonText}
        </a>
        <a
          href={secondaryButtonLink}
          class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-gray-300 border-2 border-gray-700 hover:bg-gray-800 rounded-lg backdrop-blur-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          {secondaryButtonText}
        </a>
      </div>
    </div>

    <!-- Stats Section -->
    {stats && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto mb-12">
        {stats.map((stat) => (
          <div class="text-center bg-gray-800/50 backdrop-blur-sm p-6 rounded-xl border border-gray-700">
            <div class="text-3xl md:text-4xl font-bold text-cyan-400 mb-2">
              {stat.value}
            </div>
            <div class="text-gray-300 text-sm md:text-base">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Emergency Contact -->
    {emergencyContact && (
      <div class="mt-12 text-center">
        <div class="inline-block bg-gray-800/50 backdrop-blur-sm rounded-2xl p-8 border border-gray-700">
          <div class="text-cyan-400 text-lg font-medium mb-2">24/7 Emergency Dental Care</div>
          <div class="text-3xl font-bold text-white mb-2">
            {emergencyContact.phone}
          </div>
          <div class="text-gray-300">
            {emergencyContact.hours}
          </div>
        </div>
      </div>
    )}

    <!-- Trust Indicators -->
    <div class="flex flex-wrap justify-center gap-8 mt-12">
      {[
        'Same-Day Appointments',
        'Experienced Dentists',
        'Modern Facilities',
        'Insurance Accepted'
      ].map((feature) => (
        <div class="flex items-center gap-2 text-gray-300">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>{feature}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 