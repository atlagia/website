---
interface PricingFeature {
  text: string;
  included: boolean;
}

interface PricingPlan {
  name: string;
  price: string;
  period: string;
  features: PricingFeature[];
  buttonText: string;
  buttonLink: string;
  isPopular?: boolean;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  plans: PricingPlan[];
}

const { subtitle, title, description, plans } = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
        {subtitle}
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
        {title}
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {plans.map((plan) => (
        <div class={`relative bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 ${plan.isPopular ? 'shadow-xl ring-2 ring-[#0a91b1]' : 'shadow-lg'}`}>
          {plan.isPopular && (
            <div class="absolute top-0 right-0 bg-[#0a91b1] text-white px-4 py-1 text-sm font-medium rounded-bl-lg">
              Most Popular
            </div>
          )}
          
          <div class="p-8">
            <!-- Plan Header -->
            <div class="text-center pb-8 mb-8 border-b border-gray-100">
              <h3 class="text-2xl font-bold text-gray-900 mb-4">{plan.name}</h3>
              <div class="flex items-center justify-center mb-4">
                <span class="text-4xl font-bold text-[#0a91b1]">{plan.price}</span>
                <span class="text-gray-500 ml-2">{plan.period}</span>
              </div>
            </div>

            <!-- Features List -->
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-center text-gray-600">
                  <svg 
                    class={`w-5 h-5 mr-3 ${feature.included ? 'text-[#0a91b1]' : 'text-gray-400'}`}
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d={feature.included ? "M5 13l4 4L19 7" : "M6 18L18 6M6 6l12 12"}
                    />
                  </svg>
                  <span class={feature.included ? 'text-gray-700' : 'text-gray-400'}>
                    {feature.text}
                  </span>
                </li>
              ))}
            </ul>

            <!-- Action Button -->
            <a
              href={plan.buttonLink}
              class={`block w-full text-center px-6 py-3 rounded-lg transition-all duration-300 ${
                plan.isPopular
                  ? 'bg-[#0a91b1] text-white hover:bg-[#097d99]'
                  : 'bg-gray-100 text-gray-900 hover:bg-gray-200'
              }`}
            >
              {plan.buttonText}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Insurance Info -->
    <div class="mt-16 text-center">
      <p class="text-gray-600 mb-4">We accept most dental insurance plans</p>
      <div class="flex flex-wrap justify-center gap-6">
        {['Delta Dental', 'Cigna', 'Aetna', 'MetLife'].map((provider) => (
          <span class="px-4 py-2 bg-white rounded-lg shadow-sm text-gray-600">
            {provider}
          </span>
        ))}
      </div>
    </div>
  </div>
</section> 