---
interface Testimonial {
  id: string;
  author: string;
  role: string;
  content: string;
  avatar?: string;
}

interface Props {
  title: string;
  testimonials: Testimonial[];
}

const { title, testimonials } = Astro.props;

function getInitials(name: string): string {
  return name
    .split(' ')
    .map(word => word[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
}

function getRandomPastelColor(name: string): string {
  const hash = name.split('').reduce((acc, char) => char.charCodeAt(0) + acc, 0);
  const hue = hash % 360;
  return `hsl(${hue}, 30%, 25%)`; // Darker version for dark theme
}
---

<section class="py-24 bg-black">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-4xl font-['Montserrat'] uppercase tracking-wider mb-16 text-center text-white">
      {title}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-zinc-900/50 backdrop-blur-sm p-8 rounded-sm">
          <blockquote class="relative">
            <div class="text-xl font-light text-gray-300 mb-6 leading-relaxed">
              "{testimonial.content}"
            </div>
            
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-sm overflow-hidden flex-shrink-0">
                {testimonial.avatar ? (
                  <img
                    src={testimonial.avatar}
                    alt={testimonial.author}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="w-full h-full flex items-center justify-center text-white/90 font-medium"
                    style={`background-color: ${getRandomPastelColor(testimonial.author)}`}
                  >
                    {getInitials(testimonial.author)}
                  </div>
                )}
              </div>
              <div>
                <div class="font-['Montserrat'] uppercase tracking-wide text-white">
                  {testimonial.author}
                </div>
                <div class="text-sm text-gray-400 mt-0.5">
                  {testimonial.role}
                </div>
              </div>
            </div>
          </blockquote>
        </div>
      ))}
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="max-w-7xl mx-auto px-4 mt-16">
    <div class="h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
  </div>
</section>

<style>
  section {
    background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.8) 100%),
                      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23333333' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
</style>