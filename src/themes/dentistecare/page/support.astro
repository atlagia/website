---
import { SITE_TITLE } from '../consts';
import { Book, Video, MessageCircle, LifeBuoy, Mail, MessageSquare, FileText, BookOpen, Calendar, ChevronDown } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific support data
const supportData = await import(`../data/support/support_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// Map icon strings to actual components
const iconMap = {
  Book,
  Video,
  MessageCircle,
  LifeBuoy,
  Mail,
  MessageSquare,
  FileText,
  BookOpen,
  Calendar
};

// Map categories with actual icon components
const categories = supportData.categories.map(category => ({
  ...category,
  icon: iconMap[category.icon]
}));

// Map contact options with actual icon components
const contactOptions = supportData.contact.options.map(option => ({
  ...option,
  icon: iconMap[option.icon]
}));

// Map resources with actual icon components
const resources = supportData.resources.items.map(item => ({
  ...item,
  icon: iconMap[item.icon]
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Support | ${businessInfo.name}`}
      description={supportData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-pink-50 text-pink-600">{supportData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{supportData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {supportData.hero.description}
          </p>
        </div>
      </section>

      <!-- Support Categories -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {categories.map(category => (
              <a
                href={category.link}
                class="group p-8 bg-[#f9faff] rounded-2xl hover:bg-navy-900 transition-all duration-300"
              >
                <div class="flex flex-col items-center text-center">
                  <div class={`w-14 h-14 mb-6 rounded-xl bg-${category.color}-50 group-hover:bg-${category.color}-500/20 flex items-center justify-center transition-colors`}>
                    <category.icon className={`w-7 h-7 text-${category.color}-600 group-hover:text-white`} />
                  </div>
                  <h3 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-white">{category.title}</h3>
                  <p class="text-gray-600 group-hover:text-gray-300">{category.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="relative py-16 px-4 bg-[#f9faff]">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{supportData.faq.title}</h2>
            <p class="text-gray-600">{supportData.faq.description}</p>
          </div>
          <div class="space-y-8">
            {supportData.faq.categories.map(category => (
              <div class="bg-white rounded-2xl p-6 shadow-sm">
                <h3 class="text-xl font-bold mb-4">{category.title}</h3>
                <div class="space-y-4">
                  {category.questions.map(item => (
                    <details class="group">
                      <summary class="flex justify-between items-center cursor-pointer list-none">
                        <span class="font-medium">{item.question}</span>
                        <ChevronDown className="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform" />
                      </summary>
                      <p class="mt-4 text-gray-600">{item.answer}</p>
                    </details>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Contact Options -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{supportData.contact.title}</h2>
            <p class="text-gray-600">{supportData.contact.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            {contactOptions.map(option => (
              <a
                href={option.link}
                class="flex flex-col items-center p-8 bg-[#f9faff] rounded-2xl hover:bg-navy-900 group transition-all duration-300"
              >
                <div class="w-14 h-14 mb-6 rounded-xl bg-pink-50 group-hover:bg-pink-500/20 flex items-center justify-center transition-colors">
                  <option.icon className="w-7 h-7 text-pink-600 group-hover:text-white" />
                </div>
                <h3 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-white">{option.title}</h3>
                <p class="text-gray-600 group-hover:text-gray-300 mb-4 text-center">{option.description}</p>
                <span class="font-medium text-pink-600 group-hover:text-white">{option.action}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Additional Resources -->
      <section class="relative py-16 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <h2 class="text-3xl font-bold mb-12 text-center">{supportData.resources.title}</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {resources.map(resource => (
              <a
                href={resource.link}
                class="flex items-start p-6 bg-white rounded-xl hover:shadow-md transition-shadow"
              >
                <div class="w-12 h-12 rounded-xl bg-pink-50 flex items-center justify-center mr-4">
                  <resource.icon className="w-6 h-6 text-pink-600" />
                </div>
                <div>
                  <h3 class="font-semibold mb-1">{resource.title}</h3>
                  <p class="text-sm text-gray-600">{resource.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 