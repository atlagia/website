---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { Shield, Search, Activity, PiggyBank, ChevronRight, Clock, Check } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

// Fix the solution path extraction
const solutionPath = Astro.url.pathname.split('/').pop() || 'scheduling';

// Validate if the solution exists
const validSolutions = [
  'scheduling',
  'patient-records',
  'billing',
  'inventory',
  'online-booking',
  'patient-portal',
  'reminders',
  'virtual-consults',
  'imaging',
  'treatment-planning',
  'cad-cam',
  'ai-diagnostics',
  'marketing',
  'analytics',
  'reputation',
  'multi-location',
  'sleep-dentistry-module'
];

if (!validSolutions.includes(solutionPath)) {
  return Astro.redirect('/404');
}

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific solution data with proper path construction
const solutionData = await import(`../../data/solutions/${solutionPath}/${solutionPath}_${lang}.json`);

// Generate static paths for all solutions
export async function getStaticPaths() {
  const languages = ['en', 'fr', 'es', 'it', 'de'];
  const solutions = [
    'scheduling',
    'patient-records',
    'billing',
    'inventory',
    'online-booking',
    'patient-portal',
    'reminders',
    'virtual-consults',
    'imaging',
    'treatment-planning',
    'cad-cam',
    'ai-diagnostics',
    'marketing',
    'analytics',
    'reputation',
    'multi-location',
    'sleep-dentistry-module'
  ];
  
  return languages.flatMap(lang => 
    solutions.map(solution => ({
      params: { 
        lang,
        solutions: solution 
      }
    }))
  );
}

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atlagia'
};

// Define icon paths
const iconPaths = {
  // Original icons
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  'shield-check': `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  search: `<path d="M11 3a8 8 0 1 0 0 16 8 8 0 0 0 0-16z"/><path d="m21 21-4.35-4.35"/>`,
  activity: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  heart: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
  
  // Software-specific icons
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  users: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  bell: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>`,
  user: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  stethoscope: `<path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>`,
  building: `<rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M8 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M16 14h.01"/>`,
  'alert-circle': `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  monitor: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  'trending-up': `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  'check-circle': `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  cpu: `<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`,
  settings: `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>`,
  list: `<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>`,
  repeat: `<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  refresh: `<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>`,
  'bar-chart': `<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>`,
  'file-text': `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
  tablet: `<rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>`,
  clipboard: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>`,
  'edit-3': `<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>`,
  image: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`,
  'message-circle': `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`,
  umbrella: `<path d="M23 12a11.05 11.05 0 0 0-22 0zm-5 7a3 3 0 0 1-6 0v-7"/>`,
  file: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
  'fast-forward': `<polygon points="13 19 22 12 13 5 13 19"/><polygon points="2 19 11 12 2 5 2 19"/>`,
  cloud: `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
  award: `<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>`,
  camera: `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>`,
  edit: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`,
  'message-square': `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  'credit-card': `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
  'dollar-sign': `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  'bar-chart-2': `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  'check-square': `<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
  'pie-chart': `<path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/>`,
  calculator: `<rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="16" y1="14" x2="16" y2="18"/><line x1="8" y1="14" x2="8" y2="18"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/>`,
  send: `<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>`,
  filter: `<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${solutionData.hero.title} | ${businessInfo.name}`}
      description={solutionData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
          
          <!-- Software Grid Pattern -->
          <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20 backdrop-blur-sm">
              {solutionData.hero.subtitle}
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{solutionData.hero.title}</h1>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">
              {solutionData.hero.description}
            </p>
          </div>
        </div>
      </section>

      <!-- Overview Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.overview.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.overview.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {solutionData.overview.features.map(feature => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                  <svg 
                    class="w-6 h-6 text-[#0a91b1]"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={iconPaths[feature.icon]}
                  />
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Applications Section (if exists) -->
      {solutionData.applications && (
        <section class="relative py-16 px-4 bg-gray-50">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.applications.title}</h2>
              <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.applications.description}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {solutionData.applications.problems.map(problem => (
                <div class="p-6 bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100">
                  <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                    <svg 
                      class="w-6 h-6 text-[#0a91b1]"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={iconPaths[problem.icon]}
                    />
                  </div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">{problem.title}</h3>
                  <p class="text-gray-600">{problem.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Process Section -->
      {solutionData.process && (
        <section class="relative py-16 px-4 bg-white">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.process.title}</h2>
              {solutionData.process.description && (
                <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.process.description}</p>
              )}
            </div>
            <div class="relative">
              <!-- Process Line -->
              <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-[#0a91b1]/20 rounded-full hidden md:block"></div>
              
              <div class="space-y-12 relative">
                {solutionData.process.steps.map((step, index) => (
                  <div class={`flex flex-col md:flex-row gap-8 md:gap-16 items-center ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
                    <div class="w-full md:w-1/2 order-2 md:order-none">
                      <div class="p-6 bg-white rounded-2xl shadow-lg border border-gray-100">
                        <div class="flex items-start">
                          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mr-4">
                            <span class="text-xl font-bold text-[#0a91b1]">{step.number}</span>
                          </div>
                          <div>
                            <h3 class="text-xl font-semibold text-gray-900 mb-2">{step.title}</h3>
                            <p class="text-gray-600">{step.description}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Process Circle for Desktop -->
                    <div class="absolute left-1/2 transform -translate-x-1/2 w-6 h-6 bg-[#0a91b1] rounded-full border-4 border-white hidden md:block"></div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Features Section -->
      {solutionData.features && (
        <section class="relative py-16 px-4 bg-gray-50">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.features.title}</h2>
              <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.features.description}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              {solutionData.features.featureList.map(feature => (
                <div class="p-5 bg-white rounded-xl shadow-md hover:shadow-lg transition-all duration-300 border border-gray-100">
                  <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#0a91b1]/10 flex items-center justify-center mr-4">
                      <svg 
                        class="w-5 h-5 text-[#0a91b1]"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={iconPaths[feature.icon]}
                      />
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-gray-900 mb-1">{feature.title}</h3>
                      <p class="text-sm text-gray-600">{feature.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Advantages/Benefits Section -->
      {solutionData.advantages && (
        <section class="relative py-16 px-4 bg-white">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.advantages.title}</h2>
              <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.advantages.description}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
              {solutionData.advantages.benefits.map(benefit => (
                <div class="p-6 bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100">
                  <div class="w-12 h-12 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                    <svg 
                      class="w-6 h-6 text-[#0a91b1]"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={iconPaths[benefit.icon]}
                    />
                  </div>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2">{benefit.title}</h3>
                  <p class="text-gray-600">{benefit.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Integration Section -->
      {solutionData.integration && (
        <section class="relative py-16 px-4 bg-gray-50">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.integration.title}</h2>
              <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.integration.description}</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
              {solutionData.integration.partners.map(partner => (
                <div class="flex items-center justify-center bg-white p-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300">
                  <img src={partner.logo} alt={partner.name} class="max-h-12 object-contain" />
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Pricing Section -->
      {solutionData.pricing && (
        <section class="relative py-16 px-4 bg-white">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.pricing.title}</h2>
              <p class="text-xl text-gray-600 max-w-3xl mx-auto">{solutionData.pricing.description}</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {solutionData.pricing.options.map((option, index) => (
                <div class={`p-8 bg-white rounded-2xl shadow-lg border ${index === 1 ? 'border-[#0a91b1]/30 ring-1 ring-[#0a91b1]/20' : 'border-gray-100'} hover:border-[#0a91b1]/30 hover:shadow-xl transition-all duration-300 flex flex-col h-full`}>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">{option.name}</h3>
                  <div class="mb-6">
                    <span class="text-3xl font-bold text-[#0a91b1]">{option.price}</span>
                    {option.duration && (
                      <span class="text-gray-500 ml-2">{option.duration}</span>
                    )}
                  </div>
                  <ul class="space-y-3 mb-8 flex-grow">
                    {option.includes.map(item => (
                      <li class="flex items-start">
                        <svg class="w-5 h-5 text-[#0a91b1] mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  <a href="/request-demo" class={`w-full py-3 px-6 ${index === 1 ? 'bg-[#0a91b1] text-white hover:bg-[#097d99]' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'} font-medium rounded-lg text-center transition-colors duration-300`}>
                    {index === 1 ? 'Get Started' : 'Request Demo'}
                  </a>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- FAQ Section -->
      {solutionData.faq && (
        <section class="relative py-16 px-4 bg-gray-50">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.faq.title}</h2>
            </div>
            <div class="max-w-4xl mx-auto divide-y divide-gray-200">
              {solutionData.faq.questions.map((faq, index) => (
                <div class="py-6">
                  <details class="group">
                    <summary class="flex justify-between items-center cursor-pointer list-none">
                      <h3 class="text-xl font-semibold text-gray-900 group-open:text-[#0a91b1]">{faq.question}</h3>
                      <span class="text-[#0a91b1] group-open:rotate-180 transition-transform duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </span>
                    </summary>
                    <div class="mt-4 text-gray-600">
                      <p>{faq.answer}</p>
                    </div>
                  </details>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- Testimonials -->
      {solutionData.testimonials && (
        <section class="relative py-16 px-4 bg-white">
          <div class="max-w-7xl mx-auto">
            <div class="text-center mb-12">
              <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.testimonials.title}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {solutionData.testimonials.reviews.map(review => (
                <div class="bg-white p-6 rounded-2xl shadow-md border border-gray-100 h-full flex flex-col">
                  <div class="flex items-center mb-4">
                    <div class="flex text-yellow-400">
                      {Array.from({ length: review.rating }).map(() => (
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                        </svg>
                      ))}
                    </div>
                    <span class="text-gray-500 text-sm ml-4">{review.date}</span>
                  </div>
                  <p class="text-gray-700 mb-4 italic flex-grow">"{review.comment}"</p>
                  <div>
                    <p class="font-semibold text-gray-900">{review.name}</p>
                    {review.practice && (
                      <p class="text-sm text-gray-500">{review.practice}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- CTA Section -->
      {solutionData.cta && (
        <section class="relative py-16 px-4 bg-[#0a91b1]/5">
          <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{solutionData.cta.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">{solutionData.cta.description}</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a 
                href={solutionData.cta.primaryButton.href} 
                class="py-3 px-8 bg-[#0a91b1] hover:bg-[#097d99] text-white font-medium rounded-lg transition-colors duration-300"
              >
                {solutionData.cta.primaryButton.text}
              </a>
              <a 
                href={solutionData.cta.secondaryButton.href} 
                class="py-3 px-8 bg-white hover:bg-gray-100 text-gray-900 font-medium rounded-lg border border-gray-300 transition-colors duration-300"
              >
                {solutionData.cta.secondaryButton.text}
              </a>
            </div>
          </div>
        </section>
      )}
      
    </main>
    <Footer />
  </body>
</html>

