---
import { fetchBlogPosts } from '@utils/shopifyAPI';
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const theme = import.meta.env.THEME || 'default';

// Properly handle dynamic imports with default exports
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);
const { default: Welcome } = await import(`../components/Welcome.astro`);
const { default: Banner } = await import(`../components/Banner.astro`);
const { default: FeaturedPosts } = await import(`../components/FeaturedPosts.astro`);
const { default: EmailSignup } = await import(`../components/EmailSignup.astro`);
const { default: CategoryGrid } = await import(`../components/CategoryGrid.astro`);
const { default: ProductShowcase } = await import(`../components/ProductShowcase.astro`);
const { default: TestimonialSlider } = await import(`../components/TestimonialSlider.astro`);
const { default: FAQ } = await import(`../components/FaqSection.astro`);
const { default: Video } = await import(`../components/Video.astro`);
const { default: About } = await import(`../components/About.astro`);
const { default: WhoWeAre } = await import(`../components/WhoWeAre.astro`);
const { default: Benefits } = await import(`../components/Benefits.astro`);
const { default: Reviews } = await import(`../components/Reviews.astro`);
const { default: CtaSection } = await import(`../components/CtaSection.astro`);
const { default: Blogger } = await import(`../components/Blogger.astro`);
const { default: Pricing } = await import(`../components/Pricing.astro`);
const { default: AiAgent } = await import(`../components/AiAgent.astro`);
const { default: VisionSection } = await import(`../components/VisionSection.astro`);

// Get the language parameter from the URL
const { lang } = Astro.params;

// Validate language and redirect to /en if invalid
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

// Get site title and description from language-specific data
const SITE_TITLE = jsonData.siteTitle || 'DigiVast';
const SITE_DESCRIPTION = jsonData.siteDescription || 'Your ultimate cosplay destination';

const blogId = '82152357935';
let posts = [];

try {
  posts = await fetchBlogPosts();
} catch (error) {
  console.error('Error fetching blog posts:', error);
}

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      isHomePage={true}
    />
  </head>
  <body class={lang === 'ar' ? 'rtl' : 'ltr'}>
    <Header />
    <main>
      {jsonData.sections?.map((section) => {
        return (
          <>
            {section.type === 'welcomeSection' && (
              <Welcome
                badge={section.badge}
                title={section.title}
                description={section.description}
                blogLink={`/${lang}${section.blogLink}`}
                blogLinkText={section.blogLinkText}
                getStartedText={section.getStartedText}
                getStartedLink={section.getStartedLink}
                heroImage={section.heroImage}
                partnerLogos={section.partnerLogos}
              />
            )}
            
            {section.type === 'bannerSection' && (
              <Banner
                subtitle={section.subtitle}
                headline={section.headline}
                description={section.description}
                backgroundImage={section.backgroundImage}
                button1Text={section.button1Text}
                button1Link={`/${lang}${section.button1Link}`}
                button2Text={section.button2Text}
                button2Link={`/${lang}${section.button2Link}`}
                cards={section.cards}
                trustBadges={section.trustBadges}
              />
            )}
            
            {section.type === 'categoryGrid' && (
              <CategoryGrid
                title={section.title}
                description={section.description}
                categories={section.categories}
              />
            )}
            
            {section.type === 'productShowcase' && (
              <ProductShowcase
                title={section.title}
                description={section.description}
                products={section.products}
                viewAllLink={`/${lang}${section.viewAllLink}`}
                collectionHandle={section.collectionHandle}
                lang={lang}
              />
            )}
            
            {section.type === 'testimonialSlider' && (
              <TestimonialSlider
                title={section.title}
                testimonials={section.testimonials}
              />
            )}
            
            {section.type === 'featuredPostsSection' && (
              <FeaturedPosts
                title={section.title}
                posts={posts}
                exploreMoreLink={`/${lang}${section.exploreMoreLink}`}
                exploreMoreText={section.exploreMoreText}
              />
            )}
            
            {section.type === 'emailSignupSection' && (
              <EmailSignup
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                buttonText={section.buttonText}
                placeholder={section.placeholder}
                features={section.features}
                formType={section.formType}
                trustBadge={section.trustBadge}
              />
            )}

            {section.type === 'faqSection' && (
              <FAQ
                title={section.title}
                description={section.description}
                faqs={section.faqs}
              />
            )}

            {section.type === 'videoSection' && (
              <Video
                headline={section.headline}
                description={section.description}
                videoUrl={section.videoUrl}
                buttonText={section.buttonText}
                buttonLink={`/${lang}${section.buttonLink}`}
                headlinePosition={section.headlinePosition}
                textPosition={section.textPosition}
              />
            )}

            {section.type === 'aboutSection' && (
              <About
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                image={section.image}
                features={section.features}
                stats={section.stats}
                experienceBadge={section.experienceBadge}
                ctaButton={section.ctaButton}
              />
            )}

            {section.type === 'whoWeAreSection' && (
              <WhoWeAre
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                image={section.image}
                stats={section.stats}
                trustIndicators={section.trustIndicators}
                ctaButton={section.ctaButton}
              />
            )}

            {section.type === 'aiAgentSection' && (
              <AiAgent
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                features={section.features}
                ctaButton={section.ctaButton}
              />
            )}

            {section.type === 'visionSection' && (
              <VisionSection
                headline={section.headline}
                description={section.description}
                illustration={section.illustration}
                cards={section.cards}
              />
            )}

            {section.type === 'benefitsSection' && (
              <Benefits
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                benefits={section.benefits}
                stats={section.stats}
              />
            )}

            {section.type === 'bloggerSection' && (
              <Blogger
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                buttonText={section.buttonText}
                buttonLink={`/${lang}${section.buttonLink}`}
                image={section.image}
              />
            )}

            {section.type === 'reviewsSection' && (
              <Reviews
                reviews={section.reviews}
              />
            )}

            {section.type === 'pricingSection' && (
              <Pricing
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                plans={section.plans}
                insuranceInfo={section.insuranceInfo}
              />
            )}

            {section.type === 'ctaSection' && (
              <CtaSection
                subtitle={section.subtitle}
                title={section.title}
                description={section.description}
                primaryButtonText={section.primaryButtonText}
                primaryButtonLink={`/${lang}${section.primaryButtonLink}`}
                secondaryButtonText={section.secondaryButtonText}
                secondaryButtonLink={`/${lang}${section.secondaryButtonLink}`}
                stats={section.stats}
                emergencyContact={section.emergencyContact}
                trustIndicators={section.trustIndicators}
              />
            )}
          </>
        );
      })}
    </main>
    <Footer />
  </body>
</html>