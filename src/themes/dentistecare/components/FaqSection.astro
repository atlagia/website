---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  faqs: FaqItem[];
}

const { title, description, faqs } = Astro.props;
---

<section class="py-20 px-4 bg-gray-50" id="content-faqSection">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" id="content-title">{title}</h2>
      <p class="text-lg text-gray-600" id="content-description">{description}</p>
    </div>
    
    <div class="space-y-6">
      {faqs.map((faq, index) => (
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-xl font-semibold mb-2" id={`content-faqQuestion-${index}`}>{faq.question}</h3>
          <p class="text-gray-600" id={`content-faqAnswer-${index}`}>{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section> 