---
// Header.astro
import { Menu, Globe } from 'lucide-react';
import { getLangFromUrl, getLocalizedPath } from '@utils/i18n';
import styles from '../style/component/headerSection.json';

const currentPath = Astro.url.pathname;
const currentLang = getLangFromUrl(Astro.url);
const siteName = currentLang === 'ar' ? 'أَتلاَّسيَا' : (import.meta.env.PUBLIC_SITE_NAME || 'Atlagia');
const isRTL = currentLang === 'ar';

// Import the language-specific header content
const headerData = await import(`../data/header/header_${currentLang}.json`).catch(() => {
  return import('../data/header/header_en.json');
});

const { navigation, auth, languages } = headerData;
---

<header class={styles.header.container}>
  <nav class={styles.nav.container} aria-label="Top">
    <div class={styles.wrapper.container}>
      <!-- Logo -->
      <div class={styles.logo.container}>
        <a href={`/${currentLang}`} class={styles.logo.container}>
          <span class:list={[
            styles.logo.text,
            isRTL && "font-arabic-primary"
          ]}>
            {siteName}
          </span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class:list={[styles.desktopNav.container, isRTL && "space-x-reverse"]}>
        <!-- Solutions Mega Menu -->
        <div class="relative group">
          <button class={styles.desktopNav.megaMenu.button}>
            {navigation[0].name}
            <svg class:list={[styles.desktopNav.megaMenu.icon, isRTL ? "mr-1" : "ml-1"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Mega Menu Dropdown -->
          <div class:list={[
            styles.desktopNav.megaMenu.dropdown,
            isRTL ? "right-0 translate-x-1/4" : "left-0 -translate-x-1/4"
          ]}>
            <!-- Categories Grid -->
            <div class={styles.desktopNav.megaMenu.grid}>
              {navigation[0].megaMenu.categories.map((category) => (
                <div class="space-y-4">
                  <div class="flex items-center gap-2">
                    <span class:list={[
                      styles.desktopNav.megaMenu.categoryIcon.container,
                      {
                        [styles.desktopNav.megaMenu.categoryIcon.practice]: category.title === 'Practice Management',
                        [styles.desktopNav.megaMenu.categoryIcon.patient]: category.title === 'Patient Experience',
                        [styles.desktopNav.megaMenu.categoryIcon.clinical]: category.title === 'Clinical Tools',
                        [styles.desktopNav.megaMenu.categoryIcon.business]: category.title === 'Business Growth'
                      }
                    ]}>
                      {/* Icons based on category */}
                      {category.icon === 'laptop' && (
                        <svg class={styles.desktopNav.megaMenu.categoryIcon.icon.practice} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                          <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                          <line x1="8" y1="21" x2="16" y2="21" />
                          <line x1="12" y1="17" x2="12" y2="21" />
                        </svg>
                      )}
                      {category.icon === 'users' && (
                        <svg class={styles.desktopNav.megaMenu.categoryIcon.icon.patient} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                      )}
                      {category.icon === 'stethoscope' && (
                        <svg class={styles.desktopNav.megaMenu.categoryIcon.icon.clinical} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                        </svg>
                      )}
                      {category.icon === 'trending-up' && (
                        <svg class={styles.desktopNav.megaMenu.categoryIcon.icon.business} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                      )}
                    </span>
                    <h3 class={styles.desktopNav.megaMenu.categoryTitle}>{category.title}</h3>
                  </div>
                  <ul class:list={[styles.desktopNav.megaMenu.categoryList, isRTL ? "border-r pr-4" : "border-l pl-4"]}>
                    {category.items.map((item) => (
                      <li>
                        <a href={`/${currentLang}${item.href}`} class={styles.desktopNav.megaMenu.categoryItem.container}>
                          <span class:list={[styles.desktopNav.megaMenu.categoryItem.dot, isRTL ? "ml-2" : "mr-2"]}></span>
                          {item.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <!-- Featured Section -->
            <div class={styles.desktopNav.megaMenu.featured.container}>
              <div class={styles.desktopNav.megaMenu.featured.wrapper}>
                <div>
                  <span class={styles.desktopNav.megaMenu.featured.badge}>
                    {navigation[0].megaMenu.featured.badge}
                  </span>
                  <h4 class={styles.desktopNav.megaMenu.featured.title}>{navigation[0].megaMenu.featured.title}</h4>
                  <p class={styles.desktopNav.megaMenu.featured.description}>{navigation[0].megaMenu.featured.description}</p>
                </div>
                <a href={`/${currentLang}${navigation[0].megaMenu.featured.link.href}`} 
                   class={styles.desktopNav.megaMenu.featured.link}>
                  {navigation[0].megaMenu.featured.link.text}
                  <svg class:list={[styles.desktopNav.megaMenu.featured.linkIcon, isRTL ? 'mr-1 rotate-180' : 'ml-1']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Rest of navigation items -->
        {navigation.slice(1).map((item) => (
          <a
            href={`/${currentLang}${item.href}`}
            class={styles.desktopNav.item}
          >
            {item.name}
          </a>
        ))}
      </div>

      <!-- Right Section -->
      <div class:list={[styles.rightSection.container, isRTL ? 'mr-4' : 'ml-4']}>
        <!-- Language Selector -->
        <div class={styles.rightSection.languageSelector.container}>
          <div class="relative group">
            <button class={styles.rightSection.languageSelector.button}>
              <Globe className={styles.rightSection.languageSelector.icon} />
              <span>{languages.find(lang => lang.code === currentLang)?.name}</span>
            </button>
            <div class:list={[
              styles.rightSection.languageSelector.dropdown,
              isRTL ? 'left-0' : 'right-0'
            ]}>
              <div class="py-1" role="menu">
                {languages.map((lang) => (
                  <a
                    href={getLocalizedPath(currentPath, lang.code)}
                    class={styles.rightSection.languageSelector.item}
                    role="menuitem"
                  >
                    {lang.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Sign In Button -->
        <a
          href={auth.signIn.href}
          class={styles.rightSection.signIn}
        >
          {auth.signIn.text}
        </a>

        <!-- Get Started Button -->
        <a
          href={auth.getStarted.href}
          class={styles.rightSection.getStarted}
        >
          {auth.getStarted.text}
        </a>

        <!-- Mobile Menu Button -->
        <div class="relative md:hidden">
          <button
            type="button"
            id="mobile-menu-button"
            class={styles.mobileMenu.button}
            aria-expanded="false"
          >
            <span class="sr-only">Open menu</span>
            <Menu className={styles.mobileMenu.icon} aria-hidden="true" />
          </button>

          <!-- Mobile Menu Dropdown -->
          <div 
            id="mobile-menu-dropdown"
            class:list={[
              styles.mobileMenu.dropdown,
              isRTL ? 'left-0' : 'right-0'
            ]}
          >
            <div class="py-2" role="menu">
              <!-- Products Dropdown -->
              <div class="relative">
                <button
                  type="button"
                  class={styles.mobileMenu.productsButton}
                  id="mobile-products-button"
                  aria-expanded="false"
                >
                  {navigation[0].name}
                  <svg class:list={[styles.mobileMenu.productsIcon, isRTL ? 'rotate-180' : '']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
                <div
                  id="mobile-products-dropdown"
                  class={styles.mobileMenu.productsDropdown}
                >
                  {navigation[0].megaMenu.categories.map((category) => (
                    <div class="px-4 py-2">
                      <div class={styles.mobileMenu.categoryTitle}>{category.title}</div>
                      {category.items.map((item) => (
                        <a
                          href={`/${currentLang}${item.href}`}
                          class={styles.mobileMenu.categoryItem}
                        >
                          {item.name}
                        </a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>

              <!-- Rest of navigation items -->
              {navigation.slice(1).map((item) => (
                <a
                  href={`/${currentLang}${item.href}`}
                  class={styles.mobileMenu.item}
                  role="menuitem"
                >
                  {item.name}
                </a>
              ))}

              <div class={styles.mobileMenu.divider}></div>

              <!-- Language Selector -->
              <div class="relative px-4 py-2">
                <button
                  type="button"
                  class={styles.mobileMenu.languageButton}
                  id="mobile-language-button"
                  aria-expanded="false"
                >
                  <Globe className={styles.mobileMenu.languageIcon} />
                  <span>{languages.find(lang => lang.code === currentLang)?.name}</span>
                </button>
                <div
                  id="mobile-language-dropdown"
                  class={styles.mobileMenu.languageDropdown}
                >
                  {languages.map((lang) => (
                    <a
                      href={getLocalizedPath(currentPath, lang.code)}
                      class={styles.mobileMenu.languageItem}
                    >
                      {lang.name}
                    </a>
                  ))}
                </div>
              </div>

              <!-- Auth Buttons -->
              <div class={styles.mobileMenu.divider}></div>
              <a
                href={auth.signIn.href}
                class={styles.mobileMenu.signIn}
                role="menuitem"
              >
                {auth.signIn.text}
              </a>
              <a
                href={auth.getStarted.href}
                class={styles.mobileMenu.getStarted}
                role="menuitem"
              >
                {auth.getStarted.text}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu functionality
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenuDropdown = document.getElementById('mobile-menu-dropdown');
  const mobileProductsButton = document.getElementById('mobile-products-button');
  const mobileProductsDropdown = document.getElementById('mobile-products-dropdown');
  const mobileLanguageButton = document.getElementById('mobile-language-button');
  const mobileLanguageDropdown = document.getElementById('mobile-language-dropdown');

  // Main mobile menu toggle
  mobileMenuButton?.addEventListener('click', () => {
    const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    mobileMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());
    
    if (!isExpanded) {
      mobileMenuDropdown?.classList.remove('opacity-0', 'invisible', 'scale-95');
      mobileMenuDropdown?.classList.add('opacity-100', 'visible', 'scale-100');
    } else {
      mobileMenuDropdown?.classList.add('opacity-0', 'invisible', 'scale-95');
      mobileMenuDropdown?.classList.remove('opacity-100', 'visible', 'scale-100');
    }
  });

  // Products submenu toggle
  mobileProductsButton?.addEventListener('click', () => {
    const isExpanded = mobileProductsButton.getAttribute('aria-expanded') === 'true';
    mobileProductsButton.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileProductsDropdown?.classList.toggle('hidden');
  });

  // Language submenu toggle
  mobileLanguageButton?.addEventListener('click', () => {
    const isExpanded = mobileLanguageButton.getAttribute('aria-expanded') === 'true';
    mobileLanguageButton.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileLanguageDropdown?.classList.toggle('hidden');
  });

  // Close menu when clicking outside
  document.addEventListener('click', (event) => {
    if (!mobileMenuButton?.contains(event.target as Node) && 
        !mobileMenuDropdown?.contains(event.target as Node)) {
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      mobileMenuDropdown?.classList.add('opacity-0', 'invisible', 'scale-95');
      mobileMenuDropdown?.classList.remove('opacity-100', 'visible', 'scale-100');
    }
  });
</script>

<style define:vars={{ 
  primaryColor: styles.colors.primary,
  primaryHoverColor: styles.colors.primaryHover,
  primaryLightColor: styles.colors.primaryLight,
  textPrimary: styles.colors.text.primary,
  textSecondary: styles.colors.text.secondary,
  textHover: styles.colors.text.hover,
  bgPrimary: styles.colors.background.primary,
  bgSecondary: styles.colors.background.secondary,
  bgTertiary: styles.colors.background.tertiary,
  shadowPrimary: styles.colors.shadow.primary,
  shadowHover: styles.colors.shadow.hover
}}>
  /* Add RTL support */
  :global([dir="rtl"]) .space-x-8 > :not([hidden]) ~ :not([hidden]) {
    --tw-space-x-reverse: 1;
  }

  :global([dir="rtl"]) .translate-x-1\/4 {
    --tw-translate-x: 25%;
  }

  :global([dir="rtl"]) .border-l {
    border-left: none;
    border-right: 1px solid;
  }

  :global([dir="rtl"]) .pl-4 {
    padding-left: 0;
    padding-right: 1rem;
  }

  /* Add smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }
</style>
