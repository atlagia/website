---
interface Props {
  title: string;
  description: string;
  images: {
    src: string;
    alt: string;
    category: string;
  }[];
}

const { title, description, images } = Astro.props;

// Get unique categories for filter
const categories = ['All', ...new Set(images.map(image => image.category))];
---

<section class="py-20 bg-white" id="content-gallerySection">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" id="content-title">{title}</h2>
      <p class="text-gray-600" id="content-description">{description}</p>
    </div>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      {categories.map((category, index) => (
        <button 
          class="px-6 py-2 rounded-full border border-gray-300 hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-colors gallery-filter"
          data-filter={category === 'All' ? '*' : `.${category.toLowerCase().replace(/\s+/g, '-')}`}
          id={`content-filterButton-${index}`}
        >
          {category}
        </button>
      ))}
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 gallery-container">
      {images.map((image, index) => (
        <div class={`gallery-item ${image.category.toLowerCase().replace(/\s+/g, '-')}`}>
          <div class="relative overflow-hidden rounded-lg group">
            <img 
              src={image.src} 
              alt={image.alt} 
              class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-110"
              id={`content-galleryImage-${index}`}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
              <h3 class="text-white text-xl font-semibold mb-2" id={`content-galleryImageTitle-${index}`}>{image.alt}</h3>
              <p class="text-blue-200" id={`content-galleryImageCategory-${index}`}>{image.category}</p>
              <div class="mt-4">
                <a 
                  href={image.src} 
                  class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white text-blue-600 hover:bg-blue-600 hover:text-white transition-colors"
                  id={`content-galleryImageLink-${index}`}
                >
                  <i class="fas fa-search-plus"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Simple gallery filtering
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.gallery-filter');
    const galleryItems = document.querySelectorAll('.gallery-item');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        filterButtons.forEach(btn => btn.classList.remove('bg-blue-600', 'text-white', 'border-blue-600'));
        
        // Add active class to clicked button
        button.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
        
        const filterValue = button.getAttribute('data-filter');
        
        galleryItems.forEach(item => {
          if (filterValue === '*') {
            item.style.display = 'block';
          } else if (item.classList.contains(filterValue.substring(1))) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
    
    // Set 'All' as active by default
    filterButtons[0].click();
  });
</script> 