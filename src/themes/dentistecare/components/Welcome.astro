---
import { Button } from './ui/Button';
import { ArrowRight } from 'lucide-react';
import styles from '../style/component/welcomeSection.json';

interface Logo {
  src: string;
  alt: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  blogLink: string;
  blogLinkText: string;
  heroImage: string;
  partnerLogos: Logo[];
  getStartedText?: string;
  getStartedLink?: string;
}

const { 
  badge, 
  title, 
  description, 
  blogLink, 
  blogLinkText, 
  heroImage, 
  partnerLogos,
  getStartedText = 'Free Demo',
  getStartedLink = '/demo'
} = Astro.props;
const isRTL = Astro.url.pathname.includes('/ar/');
---

<section class={`${styles.section.base} pb-20`}>
  <!-- Animated Background Elements -->
  <div class={styles.backgroundElements.container}>
    <!-- Animated Gradient Blobs -->
    <div class={styles.backgroundElements.blob1}></div>
    <div class={styles.backgroundElements.blob2}></div>
  </div>

  <div class={isRTL ? styles.content.containerRTL : styles.content.container}>
    <div class={styles.textContent.container}>
      <div class={isRTL ? styles.textContent.badgeContainerRTL : styles.textContent.badgeContainer}>
        <span class={styles.textContent.badge} id="content-badge">
          {badge}
        </span>
      </div>
      <h1 
        class={styles.textContent.title}
        id="content-title"
        set:html={title}
      />
      <!-- Mobile Image -->
      <div class={styles.mobileImage.container}>
        <div class={styles.mobileImage.background}></div>
        <video 
          src="https://cdn.atlagia.com/Atlagia_DentalCare_Pro_Video_Request_upscaled_1920_1080.mp4"
          controls
          autoplay
          loop
          muted
          class={styles.mobileImage.image}
          id="content-heroImage-mobile"
        >Your browser does not support the video tag.</video>
      </div>
      <p class={styles.textContent.description} id="content-description">
        {description}
      </p>
      <div class={isRTL ? styles.textContent.buttonsContainerRTL : styles.textContent.buttonsContainer}>
        <a 
          href={getStartedLink}
          class={styles.textContent.primaryButton}
          id="content-getStartedLink"
        >
          <span id="content-getStartedText">{getStartedText}</span>
          <ArrowRight className={isRTL ? styles.textContent.arrowIconRTL : styles.textContent.arrowIcon} />
        </a>
        <a 
          href={blogLink}
          class={styles.textContent.secondaryButton}
          id="content-blogLink"
        >
          <span id="content-blogLinkText">{blogLinkText}</span>
          <ArrowRight className={isRTL ? styles.textContent.arrowIconRTL : styles.textContent.arrowIcon} />
        </a>
      </div>
      
      <!-- Feature Badges -->
      <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="flex items-center p-2 bg-white/80 backdrop-blur-sm rounded-lg border border-gray-100 shadow-sm">
          <div class="flex-shrink-0 bg-[#0a91b1]/10 p-2 rounded-md mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="text-sm font-medium">Appointment Management</div>
        </div>
        <div class="flex items-center p-2 bg-white/80 backdrop-blur-sm rounded-lg border border-gray-100 shadow-sm">
          <div class="flex-shrink-0 bg-[#0a91b1]/10 p-2 rounded-md mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100-8 4 4 0 000 8z" />
            </svg>
          </div>
          <div class="text-sm font-medium">Patient Records</div>
        </div>
        <div class="flex items-center p-2 bg-white/80 backdrop-blur-sm rounded-lg border border-gray-100 shadow-sm">
          <div class="flex-shrink-0 bg-[#0a91b1]/10 p-2 rounded-md mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div class="text-sm font-medium">Analytics & Reports</div>
        </div>
        <div class="flex items-center p-2 bg-white/80 backdrop-blur-sm rounded-lg border border-gray-100 shadow-sm">
          <div class="flex-shrink-0 bg-[#0a91b1]/10 p-2 rounded-md mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0a91b1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M8 9l3 3-3 3M13 15h3M5 3h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2z" />
            </svg>
          </div>
          <div class="text-sm font-medium">AI Assistant</div>
        </div>
      </div>
      
      <div class={isRTL ? styles.textContent.logosContainerRTL : styles.textContent.logosContainer}>
        {partnerLogos.map((logo, index) => (
          <img 
            src={logo.src} 
            alt={logo.alt} 
            class={styles.textContent.logo} 
            id={`content-partnerLogo-${index}`}
            data-content-key={`partnerLogos.${index}.src`}
            data-alt-key={`partnerLogos.${index}.alt`}
          />
        ))}
      </div>
    </div>
    <!-- Desktop Image -->
    <div class={styles.desktopImage.container}>
      <!-- Background Effect -->
      <div class={styles.desktopImage.background}></div>
      
      <!-- Dashboard Frame -->
      <div class="absolute inset-0 bg-white/40 backdrop-blur-sm rounded-xl border border-gray-200 shadow-2xl transform rotate-3 scale-90"></div>
      
      <!-- Main Dashboard Video -->
      <video 
        src="https://cdn.atlagia.com/Atlagia_DentalCare_Pro_Video_Request.mp4"
        controls
        autoplay
        loop
        muted
        class={styles.desktopImage.image}
        id="content-heroImage-desktop"
      >Your browser does not support the video tag.</video>

      <!-- Dashboard Elements Overlay -->
      <div class="absolute top-4 left-4 right-4 flex items-center justify-between">
        <div class="bg-white/80 px-3 py-1.5 rounded-lg shadow-sm flex items-center">
          <div class="w-3 h-3 bg-red-500 rounded-full mr-1.5"></div>
          <div class="w-3 h-3 bg-yellow-500 rounded-full mr-1.5"></div>
          <div class="w-3 h-3 bg-green-500 rounded-full"></div>
        </div>
        <div class="bg-white/80 px-3 py-1.5 rounded-lg shadow-sm text-xs font-medium">
          Atlagia DentalCare Pro
        </div>
      </div>
      
      <!-- Animated Notification Badge -->
      <div class="absolute top-16 right-12 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full animate-pulse">
        3
      </div>
      
      <!-- Bottom Wave Pattern -->
      <div class={styles.bottomWave.container}>
        <svg class={styles.bottomWave.svg} viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path 
            fill-rule="evenodd" 
            clip-rule="evenodd" 
            d="M0 0L60 10C120 20 240 40 360 46.7C480 53 600 47 720 40C840 33 960 27 1080 30C1200 33 1320 47 1380 53.3L1440 60V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0V0Z" 
            fill="white" 
            fill-opacity="0.4"
          />
          <path 
            fill-rule="evenodd" 
            clip-rule="evenodd" 
            d="M0 60L60 56.7C120 53 240 47 360 50C480 53 600 67 720 70C840 73 960 67 1080 63.3C1200 60 1320 60 1380 60H1440V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0V60Z" 
            fill="white" 
            fill-opacity="0.8"
          />
        </svg>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ 
  highlightColor: styles.highlight.color,
  blobDuration: styles.animations.blob.duration
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob var(--blobDuration) infinite linear;
    will-change: transform;
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
    }
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .font-arabic {
    font-family: 'Cairo', sans-serif;
  }

  /* Add smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Add transition for shape movements */
  .transition-transform {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.dental-highlight) {
    color: var(--highlightColor);
  }
</style>