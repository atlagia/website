---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  faqs: FaqItem[];
}

const { title, description, faqs } = Astro.props;
---

<section class="py-20 px-4 bg-gradient-to-b from-orange-50/50 to-white">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-orange-100 text-orange-600">
        Common Questions
      </span>
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4 text-gray-900">{title}</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto font-light">{description}</p>
    </div>
    
    <div class="space-y-6">
      {faqs.map((faq) => (
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-all duration-300 border border-orange-100/50">
          <h3 class="text-xl font-display font-semibold mb-3 text-gray-900">{faq.question}</h3>
          <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section> 