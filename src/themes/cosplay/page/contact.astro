---
import { SITE_TITLE } from '../consts';
import { Mail, Phone, MapPin } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'GlamorFoot',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'privacy@glamorfoot.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+905417874673',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || 'Osmanağa, Kuşdili Cd. 48A',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Kadıköy',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'İstanbul',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'Turkey',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '34714'
  },
  support: {
    hours: import.meta.env.PUBLIC_SUPPORT_HOURS || 'Monday - Friday, 9 AM - 6 PM (GMT+3)',
    email: import.meta.env.PUBLIC_SUPPORT_EMAIL || 'returns@glamorfoot.com'
  }
};

const contactInfo = [
  {
    icon: Mail,
    title: 'Email',
    content: businessInfo.support.email,
    link: `mailto:${businessInfo.support.email}`
  },
  {
    icon: Phone,
    title: 'Phone',
    content: businessInfo.phone,
    link: `tel:${businessInfo.phone}`
  },
  {
    icon: MapPin,
    title: 'Address',
    content: `${businessInfo.address.street}, ${businessInfo.address.city}`,
    link: `https://maps.google.com/maps?q=${encodeURIComponent(
      `${businessInfo.address.street}, ${businessInfo.address.city}, ${businessInfo.address.country}`
    )}`
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead 
      title={`Contact Us | ${businessInfo.name}`}
      description={`Get in touch with ${businessInfo.name} for any questions about our products, orders, or partnerships.`}
    />
  </head>
  <body>
    <Header />
    <main class="pt-20">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gray-900 text-white">
        <div class="max-w-7xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Contact Us</h1>
          <p class="text-xl text-gray-300 max-w-2xl">
            Have questions? We're here to help. Reach out to our team for assistance with orders, product information, or anything else.
          </p>
        </div>
      </section>

      <!-- Contact Form & Info -->
      <section class="py-16 px-4">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Information -->
          <div>
            <h2 class="text-2xl font-bold mb-8">Get in Touch</h2>
            <div class="grid gap-8">
              {contactInfo.map(item => (
                <a
                  href={item.link}
                  class="flex items-center gap-4 p-6 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors"
                >
                  <div class="bg-gray-900 text-white p-3 rounded-full">
                    <item.icon className="w-6 h-6" />
                  </div>
                  <div>
                    <h3 class="font-semibold">{item.title}</h3>
                    <p class="text-gray-600">{item.content}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl font-bold mb-8">Send Us a Message</h2>
            <form class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                  Subject
                </label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-gray-900 text-white py-3 px-6 rounded-lg font-semibold hover:bg-gray-800 transition-colors"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>