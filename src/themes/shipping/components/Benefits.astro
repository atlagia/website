---
import { 
  Stethoscope, 
  Clock, 
  Shield, 
  Users, 
  Sparkles, 
  HeartPulse 
} from 'lucide-react';
import styles from '../style/component/benefitsSection.json';

interface Benefit {
  title: string;
  description: string;
  icon?: string;
}

interface Stat {
  value: string;
  label: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  benefits: Benefit[];
  stats?: Stat[];
}

const { subtitle, title, description, benefits, stats } = Astro.props;

// Dental-specific SVG paths
const benefitIcons = [
  // Stethoscope
  `<path d="M19 15V18C19 19.6569 17.6569 21 16 21H8C6.34315 21 5 19.6569 5 18V15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M16 3V11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M8 3V11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M19.5 11C20.8807 11 22 9.88071 22 8.5C22 7.11929 20.8807 6 19.5 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M16 11H8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,

  // Clock
  `<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
   <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,

  // Shield Check
  `<path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,

  // Users
  `<path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15H6C4.93913 15 3.92172 15.4214 3.17157 16.1716C2.42143 16.9217 2 17.9391 2 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M22 21V19C21.9993 18.1137 21.7044 17.2528 21.1614 16.5523C20.6184 15.8519 19.8581 15.3516 19 15.13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M16 3.13C16.8604 3.35031 17.623 3.85071 18.1676 4.55232C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89318 18.7122 8.75608 18.1676 9.45769C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,

  // Sparkles
  `<path d="M12 3L13.9389 8.95492H20.0111L15.0361 12.5951L16.9749 18.5501L12 14.9099L7.02513 18.5501L8.96394 12.5951L3.98894 8.95492H10.0611L12 3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,

  // Heart Pulse
  `<path d="M22 12L15.5355 5.53553C13.5829 3.58291 10.4171 3.58291 8.46447 5.53553C6.51184 7.48816 6.51184 10.6539 8.46447 12.6066L12 16.1421L15.5355 12.6066C17.4882 10.6539 17.4882 7.48816 15.5355 5.53553C13.5829 3.58291 10.4171 3.58291 8.46447 5.53553" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M12 16L7 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M17 21L12 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`
];
---

<section class={styles.section.container}>
  <div class={styles.content.container}>
    <!-- Header -->
    <div class={styles.header.container}>
      <span class={styles.header.subtitle}>
        {subtitle}
      </span>
      <h2 class={styles.header.title}>
        {title}
      </h2>
      <p class={styles.header.description}>
        {description}
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class={styles.benefitsGrid.container}>
      {benefits.map((benefit, index) => (
        <div class={styles.benefitCard.container}>
          <!-- Subtle Gradient Background -->
          <div class={styles.benefitCard.gradientBackground}></div>
          
          <div class={styles.benefitCard.content.container}>
            <!-- Icon -->
            <div class={styles.benefitCard.content.iconContainer}>
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class={styles.benefitCard.content.icon} 
                fill="none" 
                viewBox="0 0 24 24" 
                set:html={benefit.icon ? benefit.icon : benefitIcons[index % benefitIcons.length]}
              />
            </div>

            <!-- Content -->
            <h3 class={styles.benefitCard.content.title}>
              {benefit.title}
            </h3>
            <p class={styles.benefitCard.content.description}>
              {benefit.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Indicators -->
    {stats && stats.length > 0 && (
      <div class={styles.trustIndicators.container}>
        {stats.map((stat) => (
          <div class={styles.trustIndicators.stat.container}>
            <div class={styles.trustIndicators.stat.value}>
              {stat.value}
            </div>
            <div class={styles.trustIndicators.stat.label}>
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style define:vars={{ 
  primaryColor: styles.colors.primary,
  primaryLight: styles.colors.primaryLight,
  primaryLighter: styles.colors.primaryLighter,
  transitionDuration: styles.transitions.all.duration,
  transitionTiming: styles.transitions.all.timing,
  hoverShadow: styles.transitions.hover.shadow,
  hoverScale: styles.transitions.hover.scale
}}>
  /* Smooth Transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: var(--transitionTiming);
    transition-duration: var(--transitionDuration);
  }

  /* Card Hover Effect */
  .hover\:shadow-xl:hover {
    box-shadow: var(--hoverShadow);
  }

  /* Group Hover Animations */
  .group:hover .group-hover\:scale-110 {
    transform: var(--hoverScale);
  }
</style> 