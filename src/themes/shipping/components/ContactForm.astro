---
interface Props {
  title: string;
  description: string;
  address: string;
  phone: string;
  email: string;
  hours: string;
  formTitle: string;
  formDescription: string;
}

const { 
  title, 
  description, 
  address, 
  phone, 
  email, 
  hours, 
  formTitle, 
  formDescription 
} = Astro.props;
---

<section class="py-20 bg-white" id="content-contactSection">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" id="content-title">{title}</h2>
      <p class="text-gray-600" id="content-description">{description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Information -->
      <div class="bg-gray-50 p-8 rounded-lg">
        <div class="space-y-8">
          <div>
            <h3 class="text-2xl font-semibold mb-6" id="content-contactInfoTitle">Contact Information</h3>
            <div class="space-y-4">
              <div class="flex items-start">
                <div class="text-blue-600 mt-1 mr-4">
                  <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1" id="content-addressLabel">Address</h4>
                  <p class="text-gray-600" id="content-address">{address}</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="text-blue-600 mt-1 mr-4">
                  <i class="fas fa-phone-alt"></i>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1" id="content-phoneLabel">Phone</h4>
                  <p class="text-gray-600" id="content-phone">{phone}</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="text-blue-600 mt-1 mr-4">
                  <i class="fas fa-envelope"></i>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1" id="content-emailLabel">Email</h4>
                  <p class="text-gray-600" id="content-email">{email}</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <div class="text-blue-600 mt-1 mr-4">
                  <i class="fas fa-clock"></i>
                </div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1" id="content-hoursLabel">Working Hours</h4>
                  <p class="text-gray-600" id="content-hours">{hours}</p>
                </div>
              </div>
            </div>
          </div>
          
          <div>
            <h3 class="text-2xl font-semibold mb-6" id="content-socialTitle">Follow Us</h3>
            <div class="flex space-x-4">
              <a href="#" class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors" id="content-facebookLink">
                <i class="fab fa-facebook-f"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-blue-400 text-white rounded-full flex items-center justify-center hover:bg-blue-500 transition-colors" id="content-twitterLink">
                <i class="fab fa-twitter"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-pink-600 text-white rounded-full flex items-center justify-center hover:bg-pink-700 transition-colors" id="content-instagramLink">
                <i class="fab fa-instagram"></i>
              </a>
              <a href="#" class="w-10 h-10 bg-blue-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition-colors" id="content-linkedinLink">
                <i class="fab fa-linkedin-in"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Contact Form -->
      <div class="bg-white p-8 rounded-lg shadow-md">
        <h3 class="text-2xl font-semibold mb-2" id="content-formTitle">{formTitle}</h3>
        <p class="text-gray-600 mb-6" id="content-formDescription">{formDescription}</p>
        
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1" id="content-nameLabel">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                placeholder="John Doe"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1" id="content-emailInputLabel">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                placeholder="john@example.com"
              />
            </div>
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1" id="content-subjectLabel">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
              placeholder="How can we help you?"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1" id="content-messageLabel">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
              placeholder="Your message here..."
            ></textarea>
          </div>
          
          <div>
            <button
              type="submit"
              class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              id="content-submitButton"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section> 