---
import styles from '../style/component/whoWeAreSection.json';

interface Stat {
  value: string;
  label: string;
}

interface TrustIndicator {
  icon: string;
  text: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  stats: Stat[];
  trustIndicators?: TrustIndicator[];
  ctaButton?: {
    text: string;
    link: string;
  };
}

const { 
  subtitle, 
  title, 
  description, 
  image, 
  stats,
  trustIndicators,
  ctaButton
} = Astro.props;
---

<section class={styles.section.container} id="content-whoWeAreSection">
  <!-- Subtle Grid Pattern -->
  <div class={styles.backgroundElements.gridPattern}></div>

  <!-- Animated Background Elements -->
  <div class={styles.backgroundElements.container}>
    <div class={styles.backgroundElements.blob1}></div>
    <div class={styles.backgroundElements.blob2}></div>
  </div>

  <div class={styles.content.container}>
    <div class={styles.content.flexContainer}>
      <!-- Image Section -->
      <div class={styles.imageSection.container}>
        <div class={styles.imageSection.background}></div>
        <div class={styles.imageSection.imageWrapper}>
          <img 
            src={image}
            alt="Our Dental Practice"
            class={styles.imageSection.image}
            id="content-whoWeAreImage"
          />
          <!-- Decorative Elements -->
          <div class={styles.imageSection.decorativeElement.container}>
            <svg xmlns="http://www.w3.org/2000/svg" class={styles.imageSection.decorativeElement.icon} fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Content Section -->
      <div class={styles.textContent.container}>
        <span class={styles.textContent.subtitle} id="content-subtitle">
          {subtitle}
        </span>
        <h2 class={styles.textContent.title} id="content-title">
          {title}
        </h2>
        <p class={styles.textContent.description} id="content-description">
          {description}
        </p>

        <!-- Stats Grid -->
        <div class={styles.textContent.statsGrid}>
          {stats.map((stat, index) => (
            <div class={styles.textContent.statCard.container}>
              <div class={styles.textContent.statCard.value} id={`content-statValue-${index}`}>
                {stat.value}
              </div>
              <div class={styles.textContent.statCard.label} id={`content-statLabel-${index}`}>
                {stat.label}
              </div>
            </div>
          ))}
        </div>

        <!-- Trust Indicators -->
        {trustIndicators && trustIndicators.length > 0 && (
          <div class={styles.textContent.trustIndicators.container}>
            {trustIndicators.map((indicator, index) => (
              <div class={styles.textContent.trustIndicators.indicator}>
                <svg class={styles.textContent.trustIndicators.icon} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={indicator.icon}/>
                </svg>
                <span id={`content-trustIndicator-${index}`}>{indicator.text}</span>
              </div>
            ))}
          </div>
        )}

        <!-- CTA Button -->
        {ctaButton && (
          <div class="mt-8">
            <a 
              href={ctaButton.link} 
              class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-cyan-600 hover:bg-cyan-700 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-cyan-500/25 hover:-translate-y-0.5"
              id="content-ctaButton"
            >
              {ctaButton.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style define:vars={{ 
  blobDuration: styles.animations.blob.duration,
  gridBackgroundImage: styles.gridPattern.backgroundImage,
  gridBackgroundSize: styles.gridPattern.backgroundSize
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob var(--blobDuration, 20s) infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  /* Subtle grid pattern */
  .bg-grid-blue-100 {
    background-image: var(--gridBackgroundImage);
    background-size: var(--gridBackgroundSize);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 