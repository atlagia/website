---
import { ShoppingCart, Stethoscope, Briefcase, Rocket, ArrowRight, Package, Users, MessageSquare, CreditCard, Calendar, FileText, Stethoscope as StethoscopeAlt, PenTool, BarChart, Code, Zap, Brain, Bot, Target } from 'lucide-react';

interface Industry {
  icon: string;
  title: string;
  description: string;
  features: string[];
  processIcons: string[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  industries: Industry[];
}

const { subtitle, title, description, industries } = Astro.props;

// Map icon names to Lucide components
const iconMap = {
  'ShoppingCart': ShoppingCart,
  'Stethoscope': Stethoscope,
  'Briefcase': Briefcase,
  'Rocket': Rocket,
  'Package': Package,
  'Users': Users,
  'MessageSquare': MessageSquare,
  'CreditCard': CreditCard,
  'Calendar': Calendar,
  'FileText': FileText,
  'StethoscopeAlt': StethoscopeAlt,
  'PenTool': PenTool,
  'BarChart': BarChart,
  'Code': Code,
  'Zap': Zap,
  'Brain': Brain,
  'Bot': Bot,
  'Target': Target
};
---

<section class="relative py-32 overflow-hidden bg-gradient-to-b from-white to-gray-50">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-purple-500/5 via-pink-500/5 to-blue-500/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/5 via-purple-500/5 to-pink-500/5 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-5"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-purple-500/20 backdrop-blur-sm shadow-lg shadow-purple-500/5 hover:shadow-purple-500/10 transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-600 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-purple-600 to-pink-600"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-purple-600 to-pink-600 text-transparent bg-clip-text">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        {title}
      </h2>
      
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Industry Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {industries.map((industry, index) => {
        const IconComponent = iconMap[industry.icon as keyof typeof iconMap];
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 bg-white rounded-2xl shadow-lg border border-gray-100 transition-all duration-500 group-hover:border-purple-500/20 group-hover:shadow-xl"></div>
            
            <div class="relative p-8">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-gradient-to-br from-purple-50 to-pink-50 group-hover:from-purple-100 group-hover:to-pink-100 transition-colors duration-300">
                  <IconComponent className="w-8 h-8 text-purple-600" />
                </div>
                <h3 class="text-2xl font-bold text-gray-900">
                  {industry.title}
                </h3>
              </div>

              <p class="text-gray-600 mb-6">
                {industry.description}
              </p>

              <ul class="space-y-3 mb-8">
                {industry.features.map((feature) => (
                  <li class="flex items-center gap-2">
                    <div class="w-5 h-5 rounded-full bg-gradient-to-br from-purple-500/10 to-pink-500/10 flex items-center justify-center">
                      <svg class="w-3 h-3 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="text-gray-600">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- Process Flow -->
              <div class="relative h-24 mt-6 bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-4">
                <div class="flex items-center justify-between">
                  {industry.processIcons.map((iconName, iconIndex) => {
                    const ProcessIcon = iconMap[iconName as keyof typeof iconMap];
                    return (
                      <div class="flex items-center">
                        <div class={`w-12 h-12 rounded-full bg-white shadow-md flex items-center justify-center ${iconIndex === 0 ? 'animate-pulse-first' : iconIndex === 1 ? 'animate-pulse-second' : iconIndex === 2 ? 'animate-pulse-third' : 'animate-pulse-fourth'}`}>
                          <ProcessIcon className="w-6 h-6 text-purple-600" />
                        </div>
                        {iconIndex < industry.processIcons.length - 1 && (
                          <ArrowRight className="w-6 h-6 text-purple-400 mx-2" />
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes pulse-scale {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
  }

  .animate-pulse-first {
    animation: pulse-scale 2s infinite;
  }

  .animate-pulse-second {
    animation: pulse-scale 2s infinite;
    animation-delay: 0.5s;
  }

  .animate-pulse-third {
    animation: pulse-scale 2s infinite;
    animation-delay: 1s;
  }

  .animate-pulse-fourth {
    animation: pulse-scale 2s infinite;
    animation-delay: 1.5s;
  }
</style> 