---
import { SITE_TITLE } from '../consts';
import pkg from 'lucide-react';
const { Check } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific pricing data
const pricingData = await import(`../data/pricing/pricing_${lang}.json`);

// Import styles
const styles = await import(`../style/page/pricingpage.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// State for billing period (can be enhanced with client-side JS)
const billingPeriod = 'monthly';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Pricing | ${businessInfo.name}`}
      description={pricingData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <span class={styles.hero.subtitle}>
            {pricingData.hero.subtitle}
          </span>
          <h1 class={styles.hero.title}>
            {pricingData.hero.title}
          </h1>
          <p class={styles.hero.description}>
            {pricingData.hero.description}
          </p>
        </div>
      </section>

      <!-- Pricing Toggle -->
      <section class={styles.toggle.section}>
        <div class={styles.toggle.container}>
          <div class={styles.toggle.wrapper}>
            <span class={styles.toggle.monthlyText}>{pricingData.billing.monthly}</span>
            <button class={styles.toggle.toggleButton}>
              <span class={styles.toggle.toggleCircle}></span>
            </button>
            <span class={styles.toggle.yearlyText}>
              {pricingData.billing.yearly} 
              <span class={styles.toggle.discountText}>({pricingData.billing.discount})</span>
            </span>
          </div>
        </div>
      </section>

      <!-- Pricing Cards -->
      <section class={styles.pricing.section}>
        <div class={styles.pricing.container}>
          <div class={styles.pricing.grid}>
            {pricingData.plans.map(plan => (
              <div class={`${styles.pricing.card.base} ${plan.featured ? styles.pricing.card.featured : styles.pricing.card.normal}`}>
                {plan.featured && (
                  <span class={styles.pricing.badge}>
                    {plan.badge}
                  </span>
                )}
                <div class={styles.pricing.cardHeader}>
                  <h3 class={styles.pricing.cardTitle}>{plan.name}</h3>
                  <p class={styles.pricing.cardDescription}>{plan.description}</p>
                  <div class={styles.pricing.priceContainer}>
                    <span class={styles.pricing.priceAmount}>${plan.price[billingPeriod]}</span>
                    <span class={styles.pricing.pricePeriod}>/{pricingData.billing[billingPeriod].toLowerCase()}</span>
                  </div>
                </div>
                <ul class={styles.pricing.featuresList}>
                  {plan.features.map(feature => (
                    <li class={styles.pricing.featureItem}>
                      <svg class={styles.pricing.featureIcon} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 13l4 4L19 7"></path>
                      </svg>
                      <span class={styles.pricing.featureText}>{feature}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={plan.cta.link}
                  class={`${styles.pricing.ctaButton.base} ${
                    plan.featured
                      ? styles.pricing.ctaButton.featured
                      : styles.pricing.ctaButton.normal
                  }`}
                >
                  {plan.cta.text}
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class={styles.faq.section}>
        <div class={styles.faq.container}>
          <div class={styles.faq.header}>
            <span class={styles.faq.subtitle}>
              FAQ
            </span>
            <h2 class={styles.faq.title}>Frequently Asked Questions</h2>
            <p class={styles.faq.description}>Find answers to common questions about our dental plans.</p>
          </div>
          <div class={styles.faq.questionsContainer}>
            {pricingData.faqs.map(faq => (
              <div class={styles.faq.questionCard}>
                <h3 class={styles.faq.questionTitle}>{faq.question}</h3>
                <p class={styles.faq.questionAnswer}>{faq.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class={styles.cta.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.cta.blob1}></div>
          <div class={styles.cta.blob2}></div>
        </div>
        <div class={styles.cta.container}>
          <span class={styles.cta.subtitle}>
            GET STARTED
          </span>
          <h2 class={styles.cta.title}>{pricingData.cta.title}</h2>
          <p class={styles.cta.description}>
            {pricingData.cta.description}
          </p>
          <div class={styles.cta.buttonsContainer}>
            {pricingData.cta.buttons.map(button => (
              <a
                href={button.link}
                class={`${styles.cta.button.base} ${
                  button.primary
                    ? styles.cta.button.primary
                    : styles.cta.button.secondary
                }`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style define:vars={{ 
  blobAnimation: styles.animations.blob 
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 