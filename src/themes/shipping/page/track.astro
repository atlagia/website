---
import trackingData from '../data/tracking_data.json';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

let trackingNumber = '';
let trackingInfo = null;
let trackingSteps = null;
let destination = null;
let notFound = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  trackingNumber = formData.get('trackingNumber')?.trim();
  trackingInfo = trackingData[trackingNumber];
  trackingSteps = trackingInfo?.steps;
  destination = trackingInfo?.destination;
  notFound = !trackingInfo;
} else if (Astro.url.searchParams.has('trackingNumber')) {
  trackingNumber = Astro.url.searchParams.get('trackingNumber')?.trim();
  trackingInfo = trackingData[trackingNumber];
  trackingSteps = trackingInfo?.steps;
  destination = trackingInfo?.destination;
  notFound = !trackingInfo;
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Track Your Package" description="Enter your tracking number to see your package status." />
  </head>
  <body>
    <Header />
    <main class="pt-10 min-h-screen bg-gradient-to-b from-blue-50 via-cyan-50 to-white">
      <section class="max-w-4xl mx-auto bg-white rounded-xl shadow-lg p-8 mt-12">
        <h1 class="text-3xl font-bold mb-6 text-blue-900 text-center">Track Your Package</h1>
        <form method="POST" class="flex flex-col sm:flex-row gap-4 mb-8 justify-center">
          <input
            type="text"
            name="trackingNumber"
            placeholder="Enter tracking number"
            class="flex-1 px-4 py-3 border border-blue-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400"
            value={trackingNumber}
            required
          />
          <button type="submit" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-cyan-600 transition">Track</button>
        </form>
        <div class="flex flex-col md:flex-row gap-8">
          <!-- Left: Tracking Progress -->
          <div class="flex-1">
            {trackingSteps && (
              <div>
                <h2 class="text-xl font-semibold mb-4 text-blue-800">Tracking Progress</h2>
                <ol class="relative border-l-2 border-blue-200 ml-4">
                  {trackingSteps.map((step, idx) => (
                    <li class="mb-8 ml-6">
                      <span class="absolute -left-4 flex items-center justify-center w-8 h-8 bg-blue-100 rounded-full ring-4 ring-white">
                        <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      </span>
                      <div class="flex flex-col gap-1">
                        <span class="text-lg font-medium text-blue-900">{step.status}</span>
                        <span class="text-sm text-gray-500">{step.timestamp}</span>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            )}
            {notFound && (
              <div class="text-center text-red-600 font-semibold mt-6">Tracking number not found. Please check and try again.</div>
            )}
          </div>
          <!-- Right: Destination Info -->
          <div class="flex-1">
            {destination && (
              <div class="p-6 bg-blue-50 rounded-lg border border-blue-100 h-full flex flex-col justify-center gap-2">
                <div class="font-semibold text-blue-800 mb-2 text-lg">Destination Info</div>
                <div class="mb-1 text-blue-900 font-medium">{destination.name}</div>
                <div class="text-blue-700 text-sm break-words">{destination.address}</div>
                {destination.phone && (
                  <div class="text-blue-700 text-sm"><span class="font-semibold">Phone:</span> {destination.phone}</div>
                )}
                {destination.email && (
                  <div class="text-blue-700 text-sm"><span class="font-semibold">Email:</span> <a href={`mailto:${destination.email}`} class="underline text-blue-800">{destination.email}</a></div>
                )}
                {destination.expectedDelivery && (
                  <div class="text-blue-700 text-sm"><span class="font-semibold">Expected Delivery:</span> {destination.expectedDelivery}</div>
                )}
                {destination.instructions && (
                  <div class="text-blue-700 text-sm"><span class="font-semibold">Instructions:</span> {destination.instructions}</div>
                )}
              </div>
            )}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html> 