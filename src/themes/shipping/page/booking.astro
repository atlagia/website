---
import { SITE_TITLE } from '../consts';
import pkg from 'lucide-react';
const { Calendar, Clock, User, CreditCard, CheckCircle, ChevronRight } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific booking data
const bookingData = await import(`../data/booking/booking_${lang}.json`);

// Import styles
const styles = await import(`../style/page/bookingpage.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  Calendar: `<path d="M8 2v3M16 2v3M3.5 9.09h17M21 8.5V17c0 3-1.5 5-5 5H8c-3.5 0-5-2-5-5V8.5c0-3 1.5-5 5-5h8c3.5 0 5 2 5 5Z"/>`,
  Clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  User: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  CheckCircle: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
  ChevronRight: `<polyline points="9 18 15 12 9 6"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Online Booking | ${businessInfo.name}`}
      description={bookingData.hero.description}
    />
    <script is:inline src="/panel/src/utils/DataVaultFormEmbed.js"></script>
    
    <!-- Make DataVaultForm configuration available to client-side scripts -->
    <script is:inline define:vars={{ dataVaultFormConfig: styles.dataVaultForm }}>
      // Define global variable for DataVaultForm configuration
      window.dataVaultFormConfig = {
        config: {
          apiBaseUrl: dataVaultFormConfig.config.apiBaseUrl,
          schemaId: dataVaultFormConfig.config.schemaId,
          targetElement: dataVaultFormConfig.config.targetElement,
          styleMode: dataVaultFormConfig.config.styleMode
        },
        hideFields: dataVaultFormConfig.hideFields,
        tailwindConfig: {
          formContainer: dataVaultFormConfig.tailwindConfig.formContainer,
          formGroup: dataVaultFormConfig.tailwindConfig.formGroup,
          label: dataVaultFormConfig.tailwindConfig.label,
          input: dataVaultFormConfig.tailwindConfig.input,
          select: dataVaultFormConfig.tailwindConfig.select,
          textarea: dataVaultFormConfig.tailwindConfig.textarea,
          checkbox: dataVaultFormConfig.tailwindConfig.checkbox,
          submitButton: dataVaultFormConfig.tailwindConfig.submitButton,
          errorMessage: dataVaultFormConfig.tailwindConfig.errorMessage,
          successMessage: dataVaultFormConfig.tailwindConfig.successMessage
        }
      };
    </script>
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <span class={styles.hero.subtitle}>
            {bookingData.hero.subtitle}
          </span>
          <h1 class={styles.hero.title}>{bookingData.hero.title}</h1>
          <p class={styles.hero.description}>
            {bookingData.hero.description}
          </p>
        </div>
      </section>

      <!-- Booking Process -->
      <div class={styles.bookingProcess.section}>
        <div class={styles.bookingProcess.container}>
          <!-- Progress Steps -->
          <div class={styles.progressSteps.container}>
            <div class={styles.progressSteps.stepsWrapper}>
              {bookingData.steps.map((step, index) => (
                <div class={styles.progressSteps.step.container}>
                  <div class={`flex items-center ${index < bookingData.steps.length - 1 ? styles.progressSteps.step.lineConnector : ''}`}>
                    <div class={styles.progressSteps.step.circleWrapper}>
                      <div class={styles.progressSteps.step.circle.inactive} id={`step-${index + 1}`}>
                        <span class={styles.progressSteps.step.number.inactive}>{step.number}</span>
                      </div>
                      <span class={styles.progressSteps.step.title}>
                        {step.title}
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Step Content -->
          <div id="booking-steps" class={styles.bookingSteps.container}>
            <!-- Step 1: Service Selection -->
            <div id="step-1-content" class={styles.bookingSteps.step.active}>
              <div class={styles.bookingSteps.card}>
                <h2 class={styles.bookingSteps.title}>{bookingData.services.title}</h2>
                <div class={styles.serviceSelection.grid}>
                  {bookingData.services.categories.map(category => (
                    <div class="space-y-4">
                      <h3 class={styles.serviceSelection.categoryTitle}>{category.title}</h3>
                      {category.services.map(service => (
                        <label class={styles.serviceSelection.serviceOption}>
                          <input
                            type="radio"
                            name="selected-service"
                            value={service.id}
                            class={styles.serviceSelection.serviceRadio}
                          />
                          <div class={styles.serviceSelection.serviceCard}>
                            <div class={styles.serviceSelection.serviceHeader}>
                              <h4 class={styles.serviceSelection.serviceName}>{service.name}</h4>
                              <span class={styles.serviceSelection.servicePrice}>{service.price}</span>
                            </div>
                            <p class={styles.serviceSelection.serviceDescription}>{service.description}</p>
                            <div class={styles.serviceSelection.serviceDuration}>
                              <svg class={styles.serviceSelection.durationIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" set:html={iconPaths.Clock} />
                              <span>{service.duration}</span>
                            </div>
                          </div>
                        </label>
                      ))}
                    </div>
                  ))}
                </div>
                <div class={styles.buttons.container}>
                  <div></div> <!-- Empty div for flex spacing -->
                  <button
                    id="next-to-step-2"
                    class={styles.buttons.next}
                    disabled
                  >
                    Next Step
                  </button>
                </div>
              </div>
            </div>

            <!-- Step 2: Date & Time Selection -->
            <div id="step-2-content" class={styles.bookingSteps.step.hidden}>
              <div class={styles.bookingSteps.card}>
                <h2 class={styles.bookingSteps.title}>Select Date & Time</h2>
                <div class={styles.dateTimeSelection.grid}>
                  <div>
                    <label class={styles.dateTimeSelection.label}>Select Date</label>
                    <input
                      type="date"
                      class={styles.dateTimeSelection.input}
                      required
                    />
                  </div>
                  <div>
                    <label class={styles.dateTimeSelection.label}>Select Time</label>
                    <select
                      class={styles.dateTimeSelection.input}
                      required
                    >
                      <option value="">Choose a time slot</option>
                      <option value="09:00">09:00 AM</option>
                      <option value="10:00">10:00 AM</option>
                      <option value="11:00">11:00 AM</option>
                      <option value="14:00">02:00 PM</option>
                      <option value="15:00">03:00 PM</option>
                      <option value="16:00">04:00 PM</option>
                    </select>
                  </div>
                </div>
                <div class={styles.buttons.container}>
                  <button
                    id="back-to-step-1"
                    class={styles.buttons.back}
                  >
                    Previous Step
                  </button>
                  <button
                    id="next-to-step-3"
                    class={styles.buttons.next}
                    disabled
                  >
                    Next Step
                  </button>
                </div>
              </div>
            </div>

            <!-- Step 3: Personal Information -->
            <div id="step-3-content" class={styles.bookingSteps.step.hidden}>
              <div class={styles.bookingSteps.card}>
                <h2 class={styles.bookingSteps.title}>{bookingData.form.personalInfo.title}</h2>
                
                <!-- DataVault Form Embed Code for Customer Management -->
                <div id="datavault-form"></div>
                
                <div class={styles.buttons.container}>
                  <button
                    id="back-to-step-2"
                    class={styles.buttons.back}
                  >
                    Previous Step
                  </button>
                  <button
                    id="next-to-step-4"
                    class={styles.buttons.next}
                  >
                    Next Step
                  </button>
                </div>
              </div>
            </div>

            <!-- Step 4: Confirmation -->
            <div id="step-4-content" class={styles.bookingSteps.step.hidden}>
              <div class={styles.bookingSteps.card}>
                <h2 class={styles.bookingSteps.title}>Confirm Your Appointment</h2>
                <div class="space-y-6">
                  <div id="booking-summary" class={styles.confirmation.summary}>
                    <!-- Summary will be populated by JavaScript -->
                  </div>
                  <div class="space-y-4">
                    <h3 class={styles.confirmation.sectionTitle}>Important Information:</h3>
                    <ul class={styles.confirmation.stepsList}>
                      {bookingData.confirmation.nextSteps.map(step => (
                        <li class={styles.confirmation.stepItem}>
                          <svg class={styles.confirmation.stepIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" set:html={iconPaths.CheckCircle} />
                          <span class={styles.confirmation.stepText}>{step}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
                <div class={styles.buttons.container}>
                  <button
                    id="back-to-step-3"
                    class={styles.buttons.back}
                  >
                    Previous Step
                  </button>
                  <button
                    id="confirm-booking"
                    class={styles.buttons.confirm}
                  >
                    Confirm Booking
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <Footer />

    <script is:inline>
      // Function to initialize the booking process
      function initBookingProcess() {
        console.log('Initializing booking process...');
        const steps = document.querySelectorAll('.booking-step');
        const progressSteps = document.querySelectorAll('[id^="step-"]');
        let currentStep = 1;
        
        // Store booking data that will be passed to the DataVault form
        window.bookingData = {
          service: null,
          date: null,
          time: null
        };

        // Service selection
        const serviceCards = document.querySelectorAll('.service-card');
        const serviceRadios = document.querySelectorAll('.service-radio');
        const nextToStep2Button = document.getElementById('next-to-step-2');

        if (!nextToStep2Button) {
          console.error('Next to step 2 button not found');
          return;
        }

        serviceRadios.forEach((radio) => {
          radio.addEventListener('change', (e) => {
            console.log('Service selected');
            // Enable next button
            nextToStep2Button.disabled = false;
            
            // Update selected service styling
            serviceCards.forEach(card => {
              card.classList.remove('selected');
            });
            
            // Store selected service info
            const selectedCard = e.target.closest('.service-option').querySelector('.service-card');
            const serviceName = selectedCard.querySelector('h4').textContent;
            const servicePrice = selectedCard.querySelector('span').textContent;
            const serviceDuration = selectedCard.querySelector('.text-gray-500 span').textContent;
            
            // Save selection for confirmation step and DataVault form
            window.selectedService = {
              name: serviceName,
              price: servicePrice,
              duration: serviceDuration
            };
            
            // Store in bookingData for the DataVault form
            window.bookingData.service = {
              name: serviceName,
              price: servicePrice,
              duration: serviceDuration,
              id: e.target.value
            };
          });
        });

        // Date and time selection
        const dateInput = document.querySelector('input[type="date"]');
        const timeSelect = document.querySelector('select');
        const nextToStep3Button = document.getElementById('next-to-step-3');

        if (dateInput && timeSelect && nextToStep3Button) {
          function checkDateTime() {
            nextToStep3Button.disabled = !(dateInput.value && timeSelect.value);
            
            // Store date and time for DataVault form
            if (dateInput.value) {
              window.bookingData.date = dateInput.value;
            }
            
            if (timeSelect.value) {
              window.bookingData.time = timeSelect.value;
            }
          }

          dateInput.addEventListener('change', checkDateTime);
          timeSelect.addEventListener('change', checkDateTime);
        }

        // Navigation buttons
        document.querySelectorAll('[id^="next-to-step-"]').forEach(button => {
          button.addEventListener('click', () => {
            const nextStep = parseInt(button.id.split('-')[3]);
            showStep(nextStep);
            
            // Initialize DataVault form with selected values when moving to step 3
            if (nextStep === 3) {
              initDataVaultForm();
            }
          });
        });

        document.querySelectorAll('[id^="back-to-step-"]').forEach(button => {
          button.addEventListener('click', () => {
            const prevStep = parseInt(button.id.split('-')[3]);
            showStep(prevStep);
          });
        });

        // Confirm booking
        const confirmButton = document.getElementById('confirm-booking');
        if (confirmButton) {
          confirmButton.addEventListener('click', () => {
            // Add your booking confirmation logic here
            alert('Booking confirmed! You will receive a confirmation email shortly.');
          });
        }

        function showStep(stepNumber) {
          steps.forEach(step => step.classList.add('hidden'));
          const nextStepContent = document.getElementById(`step-${stepNumber}-content`);
          if (nextStepContent) {
            nextStepContent.classList.remove('hidden');
          }
          
          // Update progress indicators
          progressSteps.forEach((step, index) => {
            if (index + 1 <= stepNumber) {
              step.classList.add('bg-[#0a91b1]');
              step.classList.remove('bg-[#0a91b1]/10');
              const span = step.querySelector('span');
              if (span) {
                span.classList.add('text-white');
                span.classList.remove('text-[#0a91b1]');
              }
            } else {
              step.classList.remove('bg-[#0a91b1]');
              step.classList.add('bg-[#0a91b1]/10');
              const span = step.querySelector('span');
              if (span) {
                span.classList.remove('text-white');
                span.classList.add('text-[#0a91b1]');
              }
            }
          });

          currentStep = stepNumber;
        }
        
        // Function to initialize the DataVault form with selected values
        function initDataVaultForm() {
          if (window.DataVaultForm && window.bookingData) {
            // Create a mapping of DataVault form fields to booking data
            const fieldMapping = {
              'service': window.bookingData.service?.name || '',
              'serviceId': window.bookingData.service?.id || '',
              'appointmentDate': window.bookingData.date || '',
              'appointmentTime': window.bookingData.time || ''
            };
            
            console.log('Initializing DataVault form with data:', fieldMapping);
            
            // Initialize the form with pre-filled values
            new DataVaultForm({
              apiBaseUrl: window.dataVaultFormConfig.config.apiBaseUrl,
              schemaId: window.dataVaultFormConfig.config.schemaId,
              targetElement: window.dataVaultFormConfig.config.targetElement,
              styleMode: window.dataVaultFormConfig.config.styleMode,
              prefillData: fieldMapping, // Pass the mapping to prefill the form
              hideFields: window.dataVaultFormConfig.hideFields,
              tailwindConfig: window.dataVaultFormConfig.tailwindConfig,
              onSuccess: function(result) {
                // Move to the confirmation step
                showStep(4);
                
                // Update the booking summary in step 4
                updateBookingSummary();
              },
              onError: function(error) {
                alert('Error: ' + (error.message || 'Failed to submit form'));
              }
            });
          }
        }
        
        // Function to update the booking summary in step 4
        function updateBookingSummary() {
          const summaryElement = document.getElementById('booking-summary');
          if (summaryElement && window.bookingData) {
            const service = window.bookingData.service;
            const date = window.bookingData.date ? new Date(window.bookingData.date).toLocaleDateString() : '';
            const time = window.bookingData.time || '';
            
            summaryElement.innerHTML = `
              <div class="space-y-3">
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="font-medium">Service:</span>
                  <span>${service?.name || ''}</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="font-medium">Price:</span>
                  <span>${service?.price || ''}</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="font-medium">Duration:</span>
                  <span>${service?.duration || ''}</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="font-medium">Date:</span>
                  <span>${date}</span>
                </div>
                <div class="flex justify-between items-center pb-2 border-b border-gray-200">
                  <span class="font-medium">Time:</span>
                  <span>${time}</span>
                </div>
              </div>
            `;
          }
        }
      }

      // Run initialization on page load
      document.addEventListener('DOMContentLoaded', initBookingProcess);

      // Also run initialization when the page is loaded via client-side navigation
      // This is the key part that fixes the issue
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        setTimeout(initBookingProcess, 100);
      }
    </script>

    <script is:inline src="http://localhost:8000/api/datavault/embed/datavault-form.js"></script>
    
    <div id="datavault-booking-form"></div>
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .booking-step {
    transition: all 0.3s ease-in-out;
  }

  .booking-step.hidden {
    display: none;
  }

  .booking-step.active {
    display: block;
  }

  .service-option input[type="radio"]:checked + .service-card {
    background-color: rgba(10, 145, 177, 0.1);
    border: 2px solid #0a91b1;
    transform: translateY(-2px);
    box-shadow: 0 4px 6px -1px rgb(10 145 177 / 0.1), 0 2px 4px -2px rgb(10 145 177 / 0.1);
  }

  .service-card {
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .service-card:hover {
    background-color: rgba(10, 145, 177, 0.05);
    transform: translateY(-1px);
    box-shadow: 0 2px 4px -1px rgb(10 145 177 / 0.1);
  }
</style> 