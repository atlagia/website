---
import { SITE_TITLE } from '../consts';
import pkg from 'lucide-react';
// Import all icons dynamically
const LucideIcons = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific data
const servicesData = await import(`../data/services/services_${lang}.json`);

// Import styles
const styles = await import(`../style/page/servicespage.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Global Shipping Solutions'
};

// Helper function to get icon from Lucide package dynamically
function getIconComponent(iconName) {
  return LucideIcons[iconName] || LucideIcons.Package; // Default to Package icon if not found
}

// Process services to ensure all fields exist
const services = servicesData.services.map(service => {
  // Get the icon component
  const IconComponent = getIconComponent(service.icon);
  
  // Set defaults for any missing fields
  return {
    ...service,
    image: service.image || '/images/services/default.jpg',
    link: service.link || `/${lang}/services/${service.id || 'default'}`,
    IconComponent
  };
});

// Define fallback data for awards and platforms if they're not in servicesData
const awardsData = [
  {
    title: 'Best Logistics Provider',
    description: 'Recognized for excellence in logistics and shipping solutions that help businesses optimize their supply chain.',
    year: '2023',
    icon: 'Award'
  },
  {
    title: 'Innovation in Shipping',
    description: 'Award-winning shipping technologies that streamline delivery workflows and improve transit times.',
    year: '2023',
    icon: 'Lightbulb'
  },
  {
    title: 'Global Shipping Excellence',
    description: 'Recognized for outstanding international shipping services and customs management.',
    year: '2023',
    icon: 'Globe'
  },
  {
    title: 'Customer Service Award',
    description: 'Awarded for exceptional customer service and support in the logistics industry.',
    year: '2023',
    icon: 'HeartHandshake'
  }
];

// Define shipping carrier partners with corresponding icons
const platformsData = [
  { name: 'FedEx', icon: 'Package' },
  { name: 'DHL', icon: 'Truck' },
  { name: 'UPS', icon: 'BoxPackage' },
  { name: 'TNT', icon: 'Plane' },
  { name: 'USPS', icon: 'MailBox' },
  { name: 'Amazon Logistics', icon: 'ShoppingBag' }
];

// Use awards data from servicesData if available, otherwise use the fallback
const awards = servicesData.awards || awardsData;

// Use platforms data from servicesData if available, otherwise use the fallback
const platforms = servicesData.platforms || platformsData;

// Get hero section icon
const HeroIcon = getIconComponent(servicesData.hero.icon || 'TruckLoading');

// Get workflow section icon
const WorkflowIcon = getIconComponent(servicesData.workflow.icon || 'GitBranch');
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Services | ${businessInfo.name}`}
      description={servicesData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <div class={styles.hero.grid}>
            <!-- Left Content -->
            <div>
              <span class={styles.hero.subtitle}>
                {servicesData.hero.subtitle}
              </span>
              <h1 class={styles.hero.title}>{servicesData.hero.title}</h1>
              <p class={styles.hero.description}>{servicesData.hero.description}</p>
              
              <!-- Stats -->
              <div class={styles.hero.statsContainer}>
                {servicesData.stats.map(stat => (
                  <div>
                    <div class={styles.hero.statValue}>{stat.value}</div>
                    <div class={styles.hero.statLabel}>{stat.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Right Icon Instead of Image -->
            <div class={styles.hero.imageContainer}>
              <div class={styles.hero.imageBlob1}></div>
              <div class={styles.hero.imageBlob2}></div>
              <div class="flex items-center justify-center w-full h-full">
                <HeroIcon className="w-64 h-64 text-primary-600 opacity-90" strokeWidth={1.5} />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Services Grid -->
      <section class={styles.services.section}>
        <div class={styles.services.container}>
          <div class={styles.services.grid}>
            {services.map(service => {
              const Icon = service.IconComponent;
              return (
                <div class={styles.services.card}>
                  <div class={styles.services.iconContainer}>
                    <Icon className={styles.services.icon} strokeWidth={2} />
                  </div>
                  <h3 class={styles.services.cardTitle}>{service.title}</h3>
                  <p class={styles.services.cardDescription}>{service.description}</p>
                  <div class="mt-4 flex justify-center">
                    <Icon className="w-24 h-24 text-primary-200 opacity-50" strokeWidth={1} />
                  </div>
                  <a href={service.link} class={styles.services.cardLink}>
                    {service.linkText || "Learn More"}
                    <svg class={styles.services.cardLinkIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14"></path>
                      <path d="m12 5 7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Awards Section -->
      <section class={styles.awards.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.awards.blob1}></div>
          <div class={styles.awards.blob2}></div>
        </div>
        <div class={styles.awards.container}>
          <div class={styles.awards.header}>
            <span class={styles.awards.subtitle}>
              RECOGNITION
            </span>
            <h2 class={styles.awards.title}>Our Awards & Recognition</h2>
            <p class={styles.awards.description}>
              We're proud to be recognized for our commitment to excellence in shipping and logistics.
            </p>
          </div>
          <div class={styles.awards.grid}>
            {awards.map((award) => {
              const AwardIcon = getIconComponent(award.icon || 'Award');
              return (
                <div class={styles.awards.card}>
                  <div class="flex justify-center mb-4">
                    <AwardIcon className="w-16 h-16 text-primary-500" strokeWidth={1.5} />
                  </div>
                  <span class={styles.awards.cardYear}>
                    {award.year}
                  </span>
                  <h3 class={styles.awards.cardTitle}>{award.title}</h3>
                  <p class={styles.awards.cardDescription}>{award.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Approach Section -->
      <section class={styles.workflow.section}>
        <div class={styles.workflow.container}>
          <div class={styles.workflow.grid}>
            <div>
              <span class={styles.workflow.subtitle}>
                {servicesData.workflow.subtitle}
              </span>
              <h2 class={styles.workflow.title}>{servicesData.workflow.title}</h2>
              <p class={styles.workflow.description}>{servicesData.workflow.description}</p>
              <a 
                href={servicesData.workflow.cta.link} 
                class={styles.workflow.cta}
              >
                {servicesData.workflow.cta.text}
                <svg class={styles.workflow.ctaIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"></path>
                  <path d="m12 5 7 7-7 7"></path>
                </svg>
              </a>
            </div>
            <div class={styles.workflow.imageContainer}>
              <div class={styles.workflow.imageBlob}></div>
              <div class="flex items-center justify-center w-full h-full">
                <WorkflowIcon className="w-56 h-56 text-primary-600 opacity-80" strokeWidth={1.5} />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Partner Platforms - Now using Icons instead of static images -->
      <section class={styles.platforms.section}>
        <div class={styles.platforms.container}>
          <h2 class="text-2xl font-bold text-center mb-8">Our Shipping Partners</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 mt-8">
            {platforms.map(platform => {
              const PartnerIcon = getIconComponent(platform.icon);
              return (
                <div class="flex flex-col items-center justify-center p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow">
                  <PartnerIcon className="w-16 h-16 text-gray-700 mb-3" strokeWidth={1.5} />
                  <span class="text-sm font-medium text-gray-800">{platform.name}</span>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style define:vars={{ 
  blobAnimation: styles.animations.blob 
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style> 