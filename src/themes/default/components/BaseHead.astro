---
import { ViewTransitions } from 'astro:transitions';
import { generateCanonicalURL, generateSchema, type SEOProps } from '../../../utils/seo';
import GoogleAnalytics from '@components/GoogleAnalytics.astro';
import Hotjar from '@components/Hotjar.astro';



interface Props extends SEOProps {
  isProduct?: boolean;
  price?: {
    amount: string;
    currency: string;
  };
  availability?: boolean;
  alternateUrls?: Array<{lang: string, url: string}>;
  productSchema?: any;
  breadcrumbSchema?: any;
  projectType?: string;
}

const { 
  title, 
  description, 
  image = '/images/social-card.jpg',
  article = false,
  publishedTime,
  modifiedTime,
  isProduct = false,
  price,
  availability,
  alternateUrls = [],
  productSchema,
  breadcrumbSchema,
  projectType
} = Astro.props;

// Get current language from URL
const currentPath = Astro.url.pathname;
const currentLang = currentPath.split('/')[1];

// Get allowed languages from environment
const getAllowedLanguages = () => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const supportedLanguages = getAllowedLanguages();

// Generate hreflang URLs - Use provided alternateUrls or generate them
const hrefLangURLs = alternateUrls.length > 0 ? [...alternateUrls] : [];

// If no alternateUrls provided, generate them
if (alternateUrls.length === 0) {
  // Determine the base path (without language prefix)
  let basePath = currentPath;
  if (currentLang && supportedLanguages.includes(currentLang)) {
    // Remove language prefix from path
    basePath = currentPath.substring(currentLang.length + 1) || '/';
  }

  // Generate hreflang URLs for each supported language
  const uniqueLangs = new Set();
  supportedLanguages.forEach(lang => {
    let url;
    
    if (basePath === '/') {
      // For home pages, each language gets its own home page
      url = `${Astro.url.origin}/${lang}`;
    } else {
      // For other pages, add language prefix to the base path
      url = `${Astro.url.origin}/${lang}${basePath}`;
    }
    
    // Add all language variants
    if (!uniqueLangs.has(lang)) {
      uniqueLangs.add(lang);
      hrefLangURLs.push({ lang, url });
    }
  });

  // Add x-default pointing to English version (always)
  const xDefaultUrl = basePath === '/' 
    ? `${Astro.url.origin}/en` 
    : `${Astro.url.origin}/en${basePath}`;
  hrefLangURLs.push({ lang: 'x-default', url: xDefaultUrl });
}

// Always add self-referential hreflang tag (required by Google) - ensure it's not duplicated
if (currentLang && supportedLanguages.includes(currentLang)) {
  const selfUrl = Astro.url.href;
  const existingSelf = hrefLangURLs.find(h => h.lang === currentLang && h.url === selfUrl);
  if (!existingSelf) {
    hrefLangURLs.push({ lang: currentLang, url: selfUrl });
  }
}

// Set canonical URL - each language should have its own canonical URL
let canonicalURL;
if (currentPath === '/') {
  // Root path should redirect to English version
  canonicalURL = `${Astro.url.origin}/en`;
} else if (currentLang && supportedLanguages.includes(currentLang)) {
  // Language-specific pages have their own canonical URL
  canonicalURL = Astro.url.href;
} else {
  // Non-language pages should point to English version
  canonicalURL = `${Astro.url.origin}/en${currentPath}`;
}

const schema = generateSchema(Astro.props, Astro.url.pathname);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={`/${import.meta.env.THEME || 'favicon'}.svg`} />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Language Alternates (hreflang) -->
{hrefLangURLs.map(({ lang, url }) => (
  <link rel="alternate" hreflang={lang} href={url} />
))}

<!-- Robots Meta Tag - Allow indexing of all language versions -->
<meta name="robots" content="index, follow" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : isProduct ? 'product' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, canonicalURL)} />

{isProduct && price && (
  <>
    <meta property="og:price:amount" content={price.amount} />
    <meta property="og:price:currency" content={price.currency} />
    <meta property="product:availability" content={availability ? 'in stock' : 'out of stock'} />
  </>
)}

{article && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{article && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, canonicalURL)} />

<!-- Schema.org -->
<script type="application/ld+json" set:html={schema} />

<!-- Additional Schema Markup -->
{productSchema && <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}


<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<ViewTransitions />

<style is:global>
  :root {
    --font-fallback: -apple-system, BlinkMacSystemFont, Segoe UI, Helvetica, Arial, sans-serif, Apple Color Emoji, Segoe UI Emoji;
    --font-body: 'Inter', var(--font-fallback);
    --theme-bg: #ffffff;
    --theme-text: #22272a;
    --theme-link: #2563eb;
    --theme-accent: #cc2a42;
  }

  html {
    font-family: var(--font-body);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    text-align: left;
    background-color: var(--theme-bg);
    color: var(--theme-text);
  }
</style>

{import.meta.env.PUBLIC_GA_MEASUREMENT_ID && <GoogleAnalytics />}
<Hotjar />