---
import socialData from './social.json';
const currentYear = new Date().getFullYear();
const siteName = import.meta.env.PUBLIC_SITE_NAME;

// Add these environment variables
const businessPhone = import.meta.env.PUBLIC_BUSINESS_PHONE;
const businessEmail = import.meta.env.PUBLIC_BUSINESS_EMAIL;

const footerNavigation = {
  shop: [
    { name: 'New Arrivals', href: '/new' },
    { name: 'Rolex', href: '/rolex' },
    { name: 'Watches Under $5k', href: '/under-5k' },
    { name: 'Pre-Owned', href: '/pre-owned' },
  ],
  company: [
    { name: 'About Us', href: '/about' },
    { name: 'Service Center', href: '/service' },
    { name: 'Contact', href: '/contact' },
    { name: 'Careers', href: '/careers' },
  ],
  legal: [
    { name: 'Privacy Policy', href: '/privacy' },
    { name: 'Terms of Service', href: '/terms' },
    { name: 'Cookie Policy', href: '/cookies' },
    { name: 'Warranty', href: '/warranty' },
  ],
  social: socialData.social
};
---

<footer class="bg-black" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8 lg:pt-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8">
        <span class="text-2xl font-['Oswald'] font-light tracking-[0.25em] text-white/90 uppercase">{siteName}</span>
        <p class="text-sm leading-6 text-white/70 font-light tracking-wide font-['Montserrat']">
          Your premier destination for luxury timepieces and exceptional service.
        </p>
        <div class="flex space-x-6">
          {footerNavigation.social.map((item) => (
            <a href={item.href} class="text-white/60 hover:text-white/90 transition-colors duration-300">
              <span class="sr-only">{item.name}</span>
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={item.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-['Oswald'] uppercase tracking-[0.2em] text-white/90 font-light">Shop</h3>
            <ul role="list" class="mt-6 space-y-4">
              {footerNavigation.shop.map((item) => (
                <li>
                  <a href={item.href} class="text-sm text-white/60 hover:text-white/90 transition-colors duration-300 tracking-wide font-light font-['Montserrat']">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-['Oswald'] uppercase tracking-[0.2em] text-white/90 font-light">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              {footerNavigation.company.map((item) => (
                <li>
                  <a href={item.href} class="text-sm text-white/60 hover:text-white/90 transition-colors duration-300 tracking-wide font-light font-['Montserrat']">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-['Oswald'] uppercase tracking-[0.2em] text-white/90 font-light">Legal</h3>
            <ul role="list" class="mt-6 space-y-4">
              {footerNavigation.legal.map((item) => (
                <li>
                  <a href={item.href} class="text-sm text-white/60 hover:text-white/90 transition-colors duration-300 tracking-wide font-light font-['Montserrat']">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-['Oswald'] uppercase tracking-[0.2em] text-white/90 font-light">Contact</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li class="text-sm text-white/60 tracking-wide font-light font-['Montserrat']">
                {businessPhone}
              </li>
              <li>
                <a href={`mailto:${businessEmail}`} class="text-sm text-white/60 hover:text-white/90 transition-colors duration-300 tracking-wide font-light font-['Montserrat']">
                  {businessEmail}
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-white/10 pt-8 sm:mt-20 lg:mt-24">
      <p class="text-xs leading-5 text-white/60 font-light tracking-wide font-['Montserrat']">
        &copy; {currentYear} {siteName}. All rights reserved.
      </p>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full">
    <div class="h-px bg-gradient-to-r from-white/20 via-white/10 to-transparent"></div>
  </div>
</footer>

<style>
  /* Smooth text rendering */
  h3, p, a {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Enhanced link hover effects */
  a {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  a:hover {
    transform: translateX(4px);
  }

  /* Dark mode optimization */
  footer {
    color-scheme: dark;
    position: relative;
    overflow: hidden;
  }

  /* Social icon hover effects */
  .social-icon {
    transition: transform 0.3s ease;
  }

  .social-icon:hover {
    transform: translateY(-2px);
  }

  /* Gradient line animation */
  @keyframes gradientFlow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .border-t {
    background-size: 200% 200%;
    animation: gradientFlow 6s ease infinite;
  }
</style>