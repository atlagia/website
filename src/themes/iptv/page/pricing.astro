---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const lang = getLangFromUrl(Astro.url);
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = jsonData.siteTitle || 'StreamVista';
const PAGE_TITLE = 'Pricing Plans | ' + SITE_TITLE;
const PAGE_DESCRIPTION = 'Choose the perfect StreamVista subscription plan for your entertainment needs';

const plans = [
  {
    name: 'Basic',
    price: '9.99',
    duration: 'month',
    description: 'Perfect for casual viewers',
    features: [
      { text: '500+ Live Channels', included: true },
      { text: '1000+ Movies', included: true },
      { text: 'HD Quality', included: true },
      { text: '2 Devices', included: true },
      { text: '7-Day Replay', included: true },
      { text: '4K Content', included: false },
      { text: 'Cloud DVR', included: false },
      { text: 'Premium Sports', included: false },
      { text: 'Ad-Free Experience', included: false },
      { text: 'Priority Support', included: false }
    ],
    isPopular: false,
    ctaText: 'Start Basic Plan'
  },
  {
    name: 'Premium',
    price: '19.99',
    duration: 'month',
    description: 'Most popular choice for families',
    features: [
      { text: '1000+ Live Channels', included: true },
      { text: '5000+ Movies', included: true },
      { text: '4K Quality', included: true },
      { text: '4 Devices', included: true },
      { text: '30-Day Replay', included: true },
      { text: 'Cloud DVR', included: true },
      { text: 'Premium Sports', included: true },
      { text: 'Ad-Free Experience', included: true },
      { text: 'Priority Support', included: false },
      { text: 'PPV Events', included: false }
    ],
    isPopular: true,
    ctaText: 'Start Premium Plan'
  },
  {
    name: 'Ultimate',
    price: '29.99',
    duration: 'month',
    description: 'Everything unlimited for enthusiasts',
    features: [
      { text: 'All Premium Features', included: true },
      { text: 'Unlimited Devices', included: true },
      { text: '90-Day Replay', included: true },
      { text: 'Priority Support', included: true },
      { text: 'PPV Events Included', included: true },
      { text: 'Early Access Content', included: true },
      { text: 'Offline Downloads', included: true },
      { text: 'Custom Playlists', included: true },
      { text: 'Multi-Audio Tracks', included: true },
      { text: 'Advanced Statistics', included: true }
    ],
    isPopular: false,
    ctaText: 'Start Ultimate Plan'
  }
];
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} />
  </head>
  <body class="bg-black text-white">
    <Header />
    <main class="container mx-auto px-4 py-16 max-w-7xl">
      <section class="space-y-12">
        {/* Hero Section */}
        <div class="text-center space-y-4">
          <h1 class="text-4xl md:text-6xl font-bold gradient-text">
            Choose Your Plan
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            Select the perfect subscription that fits your entertainment needs.
          </p>
        </div>

        {/* Billing Toggle */}
        <div class="flex justify-center items-center gap-4">
          <span class="text-gray-300">Monthly</span>
          <button class="w-14 h-8 rounded-full bg-purple-600 relative">
            <span class="absolute left-1 top-1 w-6 h-6 rounded-full bg-white"></span>
          </button>
          <span class="text-gray-300">
            Yearly
            <span class="ml-2 text-sm text-emerald-400">Save 20%</span>
          </span>
        </div>

        {/* Pricing Cards */}
        <div class="grid md:grid-cols-3 gap-8">
          {plans.map(plan => (
            <div class={`glass rounded-2xl p-8 space-y-6 relative ${plan.isPopular ? 'border-2 border-purple-500' : ''}`}>
              {plan.isPopular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-purple-600 text-white px-4 py-1 rounded-full text-sm font-medium">
                  Most Popular
                </div>
              )}
              
              <div class="text-center">
                <h2 class="text-2xl font-bold mb-2">{plan.name}</h2>
                <p class="text-gray-400 text-sm">{plan.description}</p>
              </div>

              <div class="text-center">
                <div class="flex items-end justify-center">
                  <span class="text-4xl font-bold">${plan.price}</span>
                  <span class="text-gray-400">/{plan.duration}</span>
                </div>
              </div>

              <ul class="space-y-4">
                {plan.features.map(feature => (
                  <li class="flex items-center gap-3">
                    {feature.included ? (
                      <span class="text-emerald-400 text-xl">✓</span>
                    ) : (
                      <span class="text-gray-600 text-xl">×</span>
                    )}
                    <span class={feature.included ? 'text-gray-300' : 'text-gray-600'}>
                      {feature.text}
                    </span>
                  </li>
                ))}
              </ul>

              <button
                class={`w-full py-3 px-6 rounded-lg font-bold transition duration-200 ${
                  plan.isPopular
                    ? 'bg-purple-600 hover:bg-purple-700 text-white'
                    : 'bg-white/10 hover:bg-white/20 text-white'
                }`}
              >
                {plan.ctaText}
              </button>
            </div>
          ))}
        </div>

        {/* FAQ Section */}
        <div class="max-w-3xl mx-auto space-y-8">
          <h2 class="text-3xl font-bold text-center text-purple-400">
            Frequently Asked Questions
          </h2>
          <div class="space-y-4">
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">Can I change plans later?</h3>
              <p class="text-gray-300">
                Yes, you can upgrade or downgrade your plan at any time. Changes will be reflected in your next billing cycle.
              </p>
            </div>
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">Is there a free trial?</h3>
              <p class="text-gray-300">
                Yes, we offer a 7-day free trial for all new subscribers. You can cancel anytime during the trial period.
              </p>
            </div>
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">What payment methods do you accept?</h3>
              <p class="text-gray-300">
                We accept all major credit cards, PayPal, and cryptocurrency payments.
              </p>
            </div>
          </div>
        </div>

        {/* CTA Section */}
        <div class="glass rounded-2xl p-8 text-center space-y-6">
          <h2 class="text-3xl font-bold gradient-text">Still Not Convinced?</h2>
          <p class="text-xl text-gray-300">
            Try StreamVista free for 7 days. No commitment, cancel anytime.
          </p>
          <div class="flex justify-center gap-4">
            <a
              href="/signup"
              class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
            >
              Start Free Trial
            </a>
            <a
              href="/contact"
              class="bg-white/10 hover:bg-white/20 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
            >
              Contact Sales
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html> 