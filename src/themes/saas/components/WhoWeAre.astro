---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  stats: Stat[];
}

const { subtitle, title, description, image, stats } = Astro.props;
---

<section class="relative py-20 px-4 overflow-hidden bg-[#f9faff]">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Blobs -->
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Image Section -->
      <div class="flex-1 relative">
        <div class="absolute inset-0 bg-gradient-to-r from-pink-500/10 to-purple-500/10 rounded-3xl blur-2xl transform rotate-6"></div>
        <img 
          src={image}
          alt="AI Agency Illustration"
          class="relative w-full max-w-[600px] mx-auto drop-shadow-xl transform hover:scale-105 transition-transform duration-300"
        />
      </div>

      <!-- Content Section -->
      <div class="flex-1">
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full bg-pink-50 text-pink-600 border border-pink-100">
          {subtitle}
        </span>
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight mb-6">
          {title}
        </h2>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          {description}
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-8">
          {stats.map((stat) => (
            <div class="group">
              <div class="text-5xl font-bold text-gray-900 mb-2">
                {stat.value}
              </div>
              <div class="text-gray-600">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 