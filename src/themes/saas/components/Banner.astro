---
import { Button } from './ui/Button';

interface Props {
  headline: string;
  description: string;
  backgroundImage: string;
  button1Text: string;
  button1Link: string;
  button2Text: string;
  button2Link: string;
  subtitle?: string;
  cards?: Array<{
    title: string;
    description: string;
  }>;
}

const { 
  headline, 
  description, 
  backgroundImage,
  button1Text,
  button1Link,
  button2Text,
  button2Link,
  subtitle,
  cards
} = Astro.props;
---

<section class="relative py-32 overflow-hidden bg-navy-900">
  <!-- Curved top shape -->
  <div class="absolute top-0 left-0 w-full overflow-hidden">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-full h-[100px] text-white">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="currentColor"></path>
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Subtitle -->
    <div class="text-center mb-4">
      <span class="text-sm font-semibold tracking-wider text-pink-500 uppercase" id="content-subtitle">
        {subtitle || "HUGE HONOR"}
      </span>
    </div>

    <!-- Main Title -->
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white text-center mb-16" id="content-headline">
      {headline}
    </h2>

    <!-- Timeline with cards -->
    <div class="relative mb-20">
      <!-- Timeline line -->
      <div class="absolute left-1/2 transform -translate-x-1/2 w-px h-full bg-gray-700">
        {[0, 1, 2, 3].map((_, index) => (
          <div class={`absolute ${index === 2 ? 'bg-pink-500' : 'bg-white'} w-4 h-4 rounded-full -left-[7px] transform -translate-x-1/2`} style={`top: ${index * 33}%`}></div>
        ))}
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 relative">
        {cards?.map((card, index) => (
          <div class={`p-8 rounded-2xl bg-navy-800 backdrop-blur-lg ${index % 2 === 0 ? 'md:mr-8' : 'md:ml-8'} hover:bg-navy-700 transition-colors duration-300`}>
            <h3 class="text-2xl font-bold text-white mb-4" id={`content-card-${index}-title`}>{card.title}</h3>
            <p class="text-gray-300 leading-relaxed" id={`content-card-${index}-description`}>{card.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Video Presentation Button -->
    <div class="text-center">
      <button class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-navy-800 text-white hover:bg-navy-700 transition-colors duration-300">
        <span class="w-8 h-8 flex items-center justify-center rounded-full bg-pink-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
          </svg>
        </span>
        Video Presentation
      </button>
    </div>
  </div>

  <!-- Curved bottom shape -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden">
    <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="relative block w-full h-[100px] text-white rotate-180">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="currentColor"></path>
    </svg>
  </div>
</section>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }
  .bg-navy-700 {
    background-color: #1a1b3f;
  }

  /* Smooth transition for hover effects */
  .transition-colors {
    transition-property: background-color, border-color, color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }
</style>