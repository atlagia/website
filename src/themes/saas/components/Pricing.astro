---
interface PricingFeature {
  text: string;
  included: boolean;
}

interface PricingPlan {
  name: string;
  price: string;
  period: string;
  features: PricingFeature[];
  buttonText: string;
  buttonLink: string;
  isPopular?: boolean;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  plans: PricingPlan[];
}

const { subtitle, title, description, plans } = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-[#f9faff]">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full bg-pink-50 text-pink-600 border border-pink-100" id="content-subtitle">
        {subtitle}
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6" id="content-title">
        {title}
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto" id="content-description">
        {description}
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {plans.map((plan, index) => (
        <div class={`relative bg-white rounded-2xl shadow-lg overflow-hidden transition-transform duration-300 hover:-translate-y-2 ${plan.isPopular ? 'ring-2 ring-pink-500' : ''}`}>
          {plan.isPopular && (
            <div class="absolute top-0 right-0 bg-pink-500 text-white px-3 py-1 text-sm font-medium rounded-bl-lg" id={`content-plan-${index}-popular`}>
              Popular
            </div>
          )}
          
          <div class="p-8">
            <!-- Plan Header -->
            <h3 class="text-xl font-bold text-gray-900 mb-4" id={`content-plan-${index}-name`}>{plan.name}</h3>
            <div class="flex items-baseline mb-8">
              <span class="text-4xl font-bold text-gray-900" id={`content-plan-${index}-price`}>{plan.price}</span>
              <span class="text-gray-500 ml-2" id={`content-plan-${index}-period`}>{plan.period}</span>
            </div>

            <!-- Features List -->
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature, featureIndex) => (
                <li class="flex items-center text-gray-600" id={`content-plan-${index}-feature-${featureIndex}`}>
                  <svg 
                    class={`w-5 h-5 mr-3 ${feature.included ? 'text-green-500' : 'text-gray-400'}`}
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                  >
                    <path 
                      stroke-linecap="round" 
                      stroke-linejoin="round" 
                      stroke-width="2" 
                      d={feature.included ? "M5 13l4 4L19 7" : "M6 18L18 6M6 6l12 12"}
                    />
                  </svg>
                  <span class={feature.included ? 'text-gray-700' : 'text-gray-400'} id={`content-plan-${index}-feature-${featureIndex}-text`}>
                    {feature.text}
                  </span>
                </li>
              ))}
            </ul>

            <!-- Action Button -->
            <a
              href={plan.buttonLink}
              class={`block w-full text-center px-6 py-3 rounded-lg transition-colors duration-300 ${
                plan.isPopular
                  ? 'bg-pink-600 text-white hover:bg-pink-700'
                  : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
              }`}
              id={`content-plan-${index}-buttonLink`}
            >
              <span id={`content-plan-${index}-buttonText`}>{plan.buttonText}</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 