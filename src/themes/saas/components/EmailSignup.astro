---
import { Button } from './ui/Button';
import { Mail } from 'lucide-react';

interface Props {
  subtitle?: string;
  title: string;
  description: string;
  buttonText: string;
  placeholder?: string;
  features?: string[];
}

const {
  subtitle,
  title,
  description,
  buttonText,
  placeholder = "Enter your work email",
  features = []
} = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-[#f9faff]">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        {subtitle && (
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full bg-pink-50 text-pink-600 border border-pink-100" id="content-subtitle">
            {subtitle}
          </span>
        )}
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6" id="content-title">
          {title}
        </h2>
        <p class="text-xl text-gray-600 leading-relaxed" id="content-description">
          {description}
        </p>
      </div>

      <!-- Email Signup Form -->
      <form class="max-w-2xl mx-auto mb-12" onSubmit="event.preventDefault();">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1">
            <div class="relative">
              <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <input 
                type="email" 
                placeholder={placeholder}
                class="w-full pl-12 pr-4 py-4 text-gray-900 bg-white border border-gray-200 rounded-full focus:outline-none focus:border-pink-500 focus:ring-2 focus:ring-pink-500/20 transition-all duration-300"
                required
                id="content-emailInput"
              />
            </div>
          </div>
          <button
            type="submit"
            class="px-8 py-4 text-base font-semibold text-white bg-pink-600 hover:bg-pink-700 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-pink-500/25 hover:-translate-y-0.5"
            id="content-submitButton"
          >
            <span id="content-buttonText">{buttonText}</span>
          </button>
        </div>
      </form>

      <!-- Features List -->
      {features.length > 0 && (
        <div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
          {features.map((feature, index) => (
            <div class="flex items-center text-gray-600" id={`content-feature-${index}`}>
              <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>{feature}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>