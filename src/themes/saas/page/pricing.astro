---
import { SITE_TITLE } from '../consts';
import { Check } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific pricing data
const pricingData = await import(`../data/pricing/pricing_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// State for billing period (can be enhanced with client-side JS)
const billingPeriod = 'monthly';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Pricing | ${businessInfo.name}`}
      description={pricingData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-pink-50 text-pink-600">{pricingData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{pricingData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {pricingData.hero.description}
          </p>
        </div>
      </section>

      <!-- Pricing Toggle -->
      <section class="relative py-8 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="flex justify-center items-center gap-4">
            <span class="text-sm font-medium text-gray-500">{pricingData.billing.monthly}</span>
            <button class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 bg-pink-600">
              <span class="translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"></span>
            </button>
            <span class="text-sm font-medium text-gray-900">{pricingData.billing.yearly} <span class="text-pink-600">({pricingData.billing.discount})</span></span>
          </div>
        </div>
      </section>

      <!-- Pricing Cards -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {pricingData.plans.map(plan => (
              <div class={`relative p-8 bg-white rounded-2xl ${plan.featured ? 'ring-2 ring-pink-600 scale-105' : 'border border-gray-200'}`}>
                {plan.featured && (
                  <span class="absolute top-0 right-6 transform -translate-y-1/2 inline-flex px-4 py-1 rounded-full text-sm font-semibold bg-pink-600 text-white">
                    {plan.badge}
                  </span>
                )}
                <div class="text-center">
                  <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
                  <p class="text-gray-600 mb-6">{plan.description}</p>
                  <div class="mb-6">
                    <span class="text-4xl font-bold">${plan.price[billingPeriod]}</span>
                    <span class="text-gray-600">/{pricingData.billing[billingPeriod].toLowerCase()}</span>
                  </div>
                </div>
                <ul class="space-y-4 mb-8">
                  {plan.features.map(feature => (
                    <li class="flex items-center gap-3">
                      <Check className="w-5 h-5 text-pink-600 flex-shrink-0" />
                      <span class="text-gray-600">{feature}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={plan.cta.link}
                  class={`block w-full py-3 px-6 rounded-lg text-center font-semibold transition-colors ${
                    plan.featured
                      ? 'bg-navy-900 text-white hover:bg-navy-800'
                      : 'bg-[#f9faff] text-navy-900 hover:bg-gray-100'
                  }`}
                >
                  {plan.cta.text}
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="relative py-16 px-4 bg-[#f9faff]">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">Frequently Asked Questions</h2>
            <p class="text-gray-600">Find answers to common questions about our pricing and plans.</p>
          </div>
          <div class="space-y-6">
            {pricingData.faqs.map(faq => (
              <div class="bg-white p-6 rounded-xl">
                <h3 class="text-lg font-semibold mb-2">{faq.question}</h3>
                <p class="text-gray-600">{faq.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-4">{pricingData.cta.title}</h2>
          <p class="text-gray-600 mb-8">
            {pricingData.cta.description}
          </p>
          <div class="flex justify-center gap-4">
            {pricingData.cta.buttons.map(button => (
              <a
                href={button.link}
                class={`inline-flex items-center px-6 py-3 rounded-lg ${
                  button.primary
                    ? 'bg-navy-900 text-white hover:bg-navy-800'
                    : 'bg-[#f9faff] text-navy-900 hover:bg-gray-100'
                } font-semibold transition-colors`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 