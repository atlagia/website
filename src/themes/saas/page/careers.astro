---
import { SITE_TITLE } from '../consts';
import { getLangFromUrl } from '@utils/i18n';

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language and load appropriate content
const currentLang = getLangFromUrl(Astro.url);
const careersData = await import(`../data/careers/careers_${currentLang}.json`).catch(() => 
  import(`../data/careers/careers_en.json`)
);

const {
  pageTitle,
  pageDescription,
  hero,
  values,
  openPositions,
  perks,
  process,
  cta
} = careersData;
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${pageTitle} | ${siteName}`}
      description={pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-purple-100 shadow-lg mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute h-full w-full rounded-full bg-purple-400 opacity-75"></span>
              <span class="rounded-full h-2 w-2 bg-purple-500"></span>
            </span>
            <span class="text-sm font-medium text-purple-700">{hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
            {hero.description}
          </p>

          <div class="flex items-center justify-center gap-4">
            <a 
              href={hero.cta.primary.href}
              class="px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium hover:from-purple-700 hover:to-blue-700 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5"
            >
              {hero.cta.primary.text}
            </a>
            <a 
              href={hero.cta.secondary.href}
              class="px-8 py-4 rounded-xl bg-white text-gray-700 font-medium hover:bg-gray-50 transition-all duration-300 hover:shadow-lg hover:shadow-gray-200/50 hover:-translate-y-0.5"
            >
              {hero.cta.secondary.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Values Section -->
    <section class="py-20 bg-white relative">
      <div class="container mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold mb-4">{values.title}</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            {values.description}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.items.map((value) => (
            <div class="bg-white rounded-2xl p-8 shadow-lg shadow-gray-100/50 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
              <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                <span class="w-6 h-6 text-purple-600">
                  {value.icon === 'lightbulb' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>}
                  {value.icon === 'users' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
                  {value.icon === 'award' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>}
                  {value.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
                </span>
              </div>
              <h3 class="text-xl font-semibold mb-4">{value.title}</h3>
              <p class="text-gray-600">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Open Positions Section -->
    <section id="open-positions" class="py-32 relative">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6">{openPositions.title}</h2>
          <p class="text-xl text-gray-600">
            {openPositions.description}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {openPositions.positions.map((job) => (
            <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
              <!-- Card Glow Effect -->
              <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-500 to-blue-600 rounded-3xl blur opacity-25 group-hover:opacity-100 transition duration-500"></div>
              
              <!-- Card Content -->
              <div class="relative h-full bg-white backdrop-blur-sm rounded-3xl overflow-hidden border border-gray-200 p-8">
                <div class="flex flex-col h-full">
                  <div class="mb-6">
                    <div class="flex justify-between items-start mb-2">
                      <span class="px-3 py-1 text-xs font-medium bg-purple-100 text-purple-700 rounded-full">
                        {job.department}
                      </span>
                      <span class="px-3 py-1 text-xs font-medium bg-blue-100 text-blue-700 rounded-full">
                        {job.type}
                      </span>
                    </div>
                    <h3 class="text-xl font-semibold mb-2">{job.title}</h3>
                    <p class="text-gray-500 text-sm mb-4">{job.location}</p>
                    <p class="text-gray-600 mb-6">{job.description}</p>
                  </div>

                  <div class="mt-auto">
                    <div class="pt-4 border-t border-gray-100 flex justify-between items-center">
                      <span class="text-sm text-gray-500">Posted {job.posted}</span>
                      <a 
                        href={`/careers/${job.id}`}
                        class="inline-flex items-center text-purple-600 hover:text-purple-700"
                      >
                        <span class="font-medium mr-2">Apply Now</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polyline points="9 18 15 12 9 6"></polyline></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Perks & Benefits Section -->
    <section class="py-24 bg-white relative overflow-hidden">
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold mb-6">{perks.title}</h2>
          <p class="text-xl text-gray-600">
            {perks.description}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {perks.items.map((perk) => (
            <div class="bg-white rounded-2xl p-8 shadow-lg shadow-gray-100/50 hover:shadow-xl transition-shadow duration-300 border border-gray-100">
              <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                <span class="w-6 h-6 text-purple-600">
                  {perk.icon === 'globe' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>}
                  {perk.icon === 'dollar-sign' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
                  {perk.icon === 'heart' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>}
                  {perk.icon === 'graduation-cap' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>}
                  {perk.icon === 'users' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
                  {perk.icon === 'laptop' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>}
                </span>
              </div>
              <h3 class="text-xl font-semibold mb-4">{perk.title}</h3>
              <p class="text-gray-600">{perk.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Application Process Section -->
    <section id="application-process" class="py-32 relative bg-purple-900 text-white">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-purple-900 via-purple-800 to-blue-900">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold mb-6">{process.title}</h2>
          <p class="text-xl text-purple-100">
            {process.description}
          </p>
        </div>

        <div class="max-w-4xl mx-auto">
          {process.steps.map((stage, index) => (
            <div class={`relative pl-10 pb-10 ${index === process.steps.length - 1 ? '' : 'border-l-2 border-purple-700'}`}>
              <div class="absolute left-0 top-0 bg-gradient-to-r from-blue-500 to-purple-500 w-8 h-8 rounded-full flex items-center justify-center">
                {stage.step}
              </div>
              <div class="ml-8">
                <h3 class="text-xl font-semibold mb-3">{stage.title}</h3>
                <p class="text-purple-100">{stage.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cta.title}</h2>
          <p class="text-xl text-white/90 mb-8">
            {cta.description}
          </p>
          <div class="flex items-center justify-center gap-4">
            {cta.buttons.map((button) => (
              <a 
                href={button.href}
                class={`px-8 py-4 rounded-xl font-medium transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5 ${
                  button.variant === 'primary' 
                    ? 'bg-white text-purple-600 hover:bg-gray-100' 
                    : 'bg-white/10 text-white hover:bg-white/20'
                }`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      // Add smooth scrolling for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href')).scrollIntoView({
            behavior: 'smooth'
          });
        });
      });

      // Add intersection observer for fade-in animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('fade-in');
          }
        });
      }, {
        threshold: 0.1
      });

      // Observe all job cards and benefit cards
      document.querySelectorAll('.group').forEach(card => {
        observer.observe(card);
      });
    </script>
  </body>
</html>

<style>
  /* Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.4; }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s ease-in-out infinite;
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }

  /* Smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }
</style> 