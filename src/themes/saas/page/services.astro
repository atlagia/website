---
import { SITE_TITLE } from '../consts';
import { ArrowRight, BarChart2, Zap, Search, Users, Settings } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific data
const servicesData = await import(`../data/services/services_${lang}.json`);

// Map icon strings to actual components
const iconMap = {
  BarChart2,
  Zap,
  Search,
  Users,
  Settings
};

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// Update services with actual icon components
const services = servicesData.services.map(service => ({
  ...service,
  icon: iconMap[service.icon]
}));

const stats = [
  { value: '1000+', label: 'Happy Customers' },
  { value: '20%', label: 'Average Increase in Sales' }
];

const awards = [
  {
    title: 'AI-Driven Content Generation',
    description: 'Recognized for innovative AI content generation technology that helps businesses create engaging product descriptions.',
    year: '2023'
  },
  {
    title: 'Bulk Meta Tag Optimization',
    description: 'Award-winning bulk optimization tools that streamline SEO workflows and improve search rankings.',
    year: '2023'
  },
  {
    title: 'Universal Bulk Editor',
    description: 'Revolutionary bulk editing solution that helps e-commerce stores manage product modifications across multiple platforms.',
    year: '2023'
  },
  {
    title: 'Global SEO Enhancer',
    description: 'Innovative AI-powered SEO tool that helps businesses improve their global search rankings and visibility.',
    year: '2023'
  }
];

const platforms = [
  { name: 'WooCommerce', logo: '/images/platforms/woocommerce.svg' },
  { name: 'Shopify', logo: '/images/platforms/shopify.svg' },
  { name: 'PrestaShop', logo: '/images/platforms/prestashop.svg' },
  { name: 'Magento', logo: '/images/platforms/magento.svg' },
  { name: 'BigCommerce', logo: '/images/platforms/bigcommerce.svg' },
  { name: 'Wix', logo: '/images/platforms/wix.svg' }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Services | ${businessInfo.name}`}
      description={servicesData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Left Content -->
            <div>
              <span class="text-sm font-semibold text-gray-600 mb-4 block">{servicesData.hero.subtitle}</span>
              <h1 class="text-4xl md:text-5xl font-bold mb-6">{servicesData.hero.title}</h1>
              <p class="text-xl text-gray-600 mb-8">{servicesData.hero.description}</p>
              
              <!-- Stats -->
              <div class="flex gap-12">
                {servicesData.stats.map(stat => (
                  <div>
                    <div class="text-4xl font-bold text-navy-900 mb-2">{stat.value}</div>
                    <div class="text-gray-600">{stat.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Right Image -->
            <div>
              <img 
                src={servicesData.hero.image}
                alt="E-commerce Services"
                class="w-full h-auto"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Services Grid -->
      <section class="relative py-24 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {services.map(service => (
              <div class="group p-8 bg-[#f9faff] rounded-2xl hover:bg-navy-900 transition-all duration-300">
                <div class="w-14 h-14 mb-6 rounded-xl bg-pink-50 group-hover:bg-pink-500/20 flex items-center justify-center transition-colors">
                  <service.icon className="w-7 h-7 text-pink-600 group-hover:text-white" />
                </div>
                <h3 class="text-xl font-semibold mb-4 text-gray-900 group-hover:text-white">{service.title}</h3>
                <p class="text-gray-600 group-hover:text-gray-300 mb-6">{service.description}</p>
                <img 
                  src={service.image}
                  alt={service.title}
                  class="w-full h-auto mb-6"
                />
                <a href={service.link} class="inline-flex items-center text-pink-600 group-hover:text-white">
                  Learn More
                  <ArrowRight className="w-4 h-4 ml-2" />
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Awards Section -->
      <section class="relative py-24 px-4 bg-navy-900 overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl"></div>
        </div>
        <div class="relative max-w-7xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-16">Our Awards</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {servicesData.awards.map((award, index) => (
              <div class="relative p-6 bg-navy-800/50 rounded-xl backdrop-blur-sm">
                <img 
                  src={award.image}
                  alt={award.title}
                  class="w-16 h-16 mb-4"
                />
                <span class="absolute -top-3 left-6 px-3 py-1 bg-pink-600 text-white text-sm rounded-full">
                  {award.year}
                </span>
                <h3 class="text-lg font-semibold text-white mb-3">{award.title}</h3>
                <p class="text-gray-400">{award.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Workflow Section -->
      <section class="relative py-24 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
              <span class="text-sm font-semibold text-gray-600 mb-4 block">{servicesData.workflow.subtitle}</span>
              <h2 class="text-3xl md:text-4xl font-bold mb-6">{servicesData.workflow.title}</h2>
              <p class="text-gray-600 mb-8">{servicesData.workflow.description}</p>
              <a href={servicesData.workflow.cta.link} class="inline-flex items-center px-6 py-3 bg-navy-900 text-white rounded-lg hover:bg-navy-800 transition-colors">
                {servicesData.workflow.cta.text}
              </a>
            </div>
            <div>
              <img 
                src={servicesData.workflow.image}
                alt="Workflow Automation"
                class="w-full h-auto"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Platform Integration -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="flex flex-wrap justify-center items-center gap-12 opacity-60">
            {servicesData.platforms.map(platform => (
              <img 
                src={platform.logo}
                alt={platform.name}
                class="h-8 w-auto"
              />
            ))}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }
</style> 