---
import { SITE_TITLE } from '../consts';
import { Mail, Phone, MapPin } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific contact data
const contactData = await import(`../data/contact/contact_${lang}.json`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'contact@atalsia.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+1 2035 472 248',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || '124 City Road',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'London',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'United Kingdom'
  }
};

// Map icon strings to actual components
const iconMap = {
  Mail,
  Phone,
  MapPin
};

// Map contact info with actual icon components
const contactInfo = contactData.contactInfo.map(item => ({
  ...item,
  icon: iconMap[item.icon]
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Contact Us | ${businessInfo.name}`}
      description={contactData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-[#f9faff] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-purple-500/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-pink-50 text-pink-600">{contactData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{contactData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {contactData.hero.description}
          </p>
        </div>
      </section>

      <!-- Contact Options -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {contactInfo.map(item => (
              <a
                href={item.link}
                class="group p-8 bg-[#f9faff] rounded-2xl hover:bg-navy-900 transition-all duration-300"
              >
                <div class="flex flex-col items-center text-center">
                  <div class="w-14 h-14 mb-6 rounded-xl bg-pink-50 group-hover:bg-pink-500/20 flex items-center justify-center transition-colors">
                    <item.icon className="w-7 h-7 text-pink-600 group-hover:text-white" />
                  </div>
                  <h3 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-white">{item.title}</h3>
                  <p class="text-gray-600 group-hover:text-gray-300 mb-2">{item.description}</p>
                  <p class="font-medium text-gray-900 group-hover:text-white">{item.content}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Contact Form Section -->
      <section class="relative py-16 px-4 bg-[#f9faff]">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <!-- Left: Form -->
            <div class="bg-white p-8 rounded-2xl shadow-sm">
              <h2 class="text-2xl font-bold mb-6">{contactData.form.title}</h2>
              <form class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">
                      {contactData.form.fields.firstName.label}
                    </label>
                    <input
                      type="text"
                      id="first-name"
                      name="first-name"
                      placeholder={contactData.form.fields.firstName.placeholder}
                      required
                      class="w-full px-4 py-2.5 bg-[#f9faff] border border-gray-200 rounded-lg focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 transition-colors"
                    />
                  </div>
                  <div>
                    <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">
                      {contactData.form.fields.lastName.label}
                    </label>
                    <input
                      type="text"
                      id="last-name"
                      name="last-name"
                      placeholder={contactData.form.fields.lastName.placeholder}
                      required
                      class="w-full px-4 py-2.5 bg-[#f9faff] border border-gray-200 rounded-lg focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 transition-colors"
                    />
                  </div>
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                    {contactData.form.fields.email.label}
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder={contactData.form.fields.email.placeholder}
                    required
                    class="w-full px-4 py-2.5 bg-[#f9faff] border border-gray-200 rounded-lg focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 transition-colors"
                  />
                </div>
                <div>
                  <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                    {contactData.form.fields.subject.label}
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    placeholder={contactData.form.fields.subject.placeholder}
                    required
                    class="w-full px-4 py-2.5 bg-[#f9faff] border border-gray-200 rounded-lg focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 transition-colors"
                  />
                </div>
                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                    {contactData.form.fields.message.label}
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="6"
                    placeholder={contactData.form.fields.message.placeholder}
                    required
                    class="w-full px-4 py-2.5 bg-[#f9faff] border border-gray-200 rounded-lg focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 transition-colors"
                  ></textarea>
                </div>
                <button
                  type="submit"
                  class="w-full bg-navy-900 text-white py-3 px-6 rounded-lg font-semibold hover:bg-navy-800 transition-colors"
                >
                  {contactData.form.submitButton}
                </button>
              </form>
            </div>

            <!-- Right: Map & Info -->
            <div class="space-y-8">
              <div class="aspect-video w-full rounded-2xl overflow-hidden">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2482.4246767037074!2d-0.08744748422970276!3d51.52459667963792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48761ca671a6cfb7%3A0x9319acf4647dd5c4!2s124%20City%20Rd%2C%20London%20EC1V%202NX%2C%20UK!5e0!3m2!1sen!2sus!4v1647433829401!5m2!1sen!2sus"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                ></iframe>
              </div>
              <div class="bg-white p-8 rounded-2xl shadow-sm">
                <h3 class="text-xl font-bold mb-4">{contactData.support.hours.title}</h3>
                <p class="text-gray-600 mb-6">{contactData.support.hours.content}</p>
                <h3 class="text-xl font-bold mb-4">{contactData.support.additional.title}</h3>
                <p class="text-gray-600">
                  {contactData.support.additional.description} <a href={`mailto:${contactData.support.additional.email}`} class="text-pink-600 hover:text-pink-700">{contactData.support.additional.email}</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>