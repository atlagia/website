---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { 
  Globe, 
  Calendar,
  Users, 
  Brain, 
  ChevronRight, 
  Heart,
  TrendingUp,
  Star,
  BarChart,
  Play
} = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';
const solutionPath = Astro.url.pathname.split('/').pop() || 'dental-solution';

const validSolutions = [
  'dental-solution',
  'medical-solution',
  'pharmacy-solution',
  'clinic-solution',
  'hospital-solution',
  'laboratory-solution',
  'radiology-solution',
  'veterinary-solution',
  'ecommerce-solution',
  'retail-stores',
  'restaurants',
  'wholesale'
];

if (!validSolutions.includes(solutionPath)) {
  return Astro.redirect('/404');
}

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

const solutionData = await import(`../../data/solutions/${solutionPath}/${solutionPath}_${lang}.json`);

// Helper function to get YouTube video ID
function getYouTubeVideoId(url: string) {
  const regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[7].length === 11) ? match[7] : false;
}

export async function getStaticPaths() {
  const languages = ['en', 'fr', 'es', 'it', 'de'];
  const solutions = validSolutions;
  return languages.flatMap(lang => 
    solutions.map(solution => ({
      params: { lang, solutions: solution }
    }))
  );
}

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atlagia'
};

const iconMap = {
  globe: Globe,
  calendar: Calendar,
  users: Users,
  brain: Brain,
  heart: Heart,
  'trending-up': TrendingUp,
  star: Star,
  'chart-up': BarChart
};

const getIcon = (iconName: string) => {
  return iconMap[iconName.toLowerCase()] || Globe;
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${solutionData.hero.title} | ${businessInfo.name}`}
      description={solutionData.hero.description}
    />
    <style>
      .youtube-container {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
        height: 0;
        overflow: hidden;
        border-radius: 1rem;
      }
      .youtube-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }
      
      /* Custom Icon Styles */
      .icon-white {
        color: white !important;
      }
      .icon-white svg {
        stroke: white !important;
        fill: none !important;
      }
      
      /* Benefits section icons */
      .benefits-section svg {
        stroke: white !important;
        color: white !important;
        fill: none !important;
      }
    </style>
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Content -->
          <div class="space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-purple-100 shadow-lg">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute h-full w-full rounded-full bg-purple-400 opacity-75"></span>
                <span class="rounded-full h-2 w-2 bg-purple-500"></span>
              </span>
              <span class="text-sm font-medium text-purple-700">{solutionData.hero.subtitle}</span>
            </div>

            <h1 class="text-5xl lg:text-6xl font-bold leading-tight">
              <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
                {solutionData.hero.title}
              </span>
            </h1>

            <p class="text-xl text-gray-600 max-w-xl">
              {solutionData.hero.description}
            </p>

            <!-- Stats -->
            <div class="grid grid-cols-3 gap-8">
              {solutionData.hero.stats.map(stat => (
                <div class="text-center">
                  <div class="text-3xl font-bold text-purple-600">{stat.value}</div>
                  <div class="text-sm text-gray-600">{stat.label}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Video -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-500 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
            <div class="relative rounded-2xl overflow-hidden bg-white shadow-xl">
              <div class="youtube-container">
                <iframe
                  src={`https://www.youtube.com/embed/${getYouTubeVideoId(solutionData.hero.video.url)}?autoplay=0&rel=0&modestbranding=1`}
                  title={solutionData.hero.video.alt}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-32 relative overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <!-- Header -->
        <div class="text-center max-w-3xl mx-auto mb-20">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-50 border border-purple-100 mb-4">
            <span class="text-sm font-medium bg-gradient-to-r from-purple-600 to-blue-600 text-transparent bg-clip-text">
              {solutionData.features.subtitle}
            </span>
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6">{solutionData.features.title}</h2>
          <p class="text-xl text-gray-600">{solutionData.features.description}</p>
        </div>

        <!-- Categories -->
        <div class="grid md:grid-cols-2 gap-8 mb-16">
          {solutionData.features.categories.map((category, index) => (
            <div class="text-center p-8 rounded-2xl bg-white/50 backdrop-blur-sm border border-gray-100">
              <h3 class="text-2xl font-semibold mb-3">{category.name}</h3>
              <p class="text-gray-600">{category.description}</p>
            </div>
          ))}
        </div>

        <!-- Features Grid -->
        <div class="grid lg:grid-cols-2 gap-8">
          {solutionData.features.items.map((feature, index) => {
            const Icon = getIcon(feature.icon);
            return (
              <div class="group relative">
                <!-- Card Background Effects -->
                <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 to-blue-500/5 rounded-3xl transform group-hover:scale-[1.02] transition-transform duration-500"></div>
                <div class="relative p-8 bg-white/80 backdrop-blur-sm rounded-3xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-500">
                  <div class="flex items-start gap-6">
                    <!-- Icon Column -->
                    <div class="flex-shrink-0">
                      <div class="relative w-16 h-16 flex items-center justify-center">
                        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-blue-500/10 rounded-2xl transform group-hover:scale-110 transition-transform duration-500"></div>
                        <Icon class="w-8 h-8 text-purple-600 relative z-10" />
                      </div>
                    </div>

                    <!-- Content Column -->
                    <div class="flex-grow">
                      <!-- Category Badge -->
                      <div class="inline-block px-3 py-1 rounded-full bg-purple-50 text-purple-700 text-sm font-medium mb-4">
                        {feature.category}
                      </div>

                      <h3 class="text-2xl font-semibold mb-4">{feature.title}</h3>
                      <p class="text-gray-600 mb-6">{feature.description}</p>

                      <!-- Feature Image -->
                      <div class="relative rounded-xl overflow-hidden mb-6 group-hover:shadow-lg transition-shadow duration-500">
                        <img 
                          src={feature.image} 
                          alt={feature.title}
                          class="w-full h-48 object-cover transform group-hover:scale-105 transition-transform duration-500"
                        />
                      </div>

                      <!-- Highlights Grid -->
                      <div class="grid sm:grid-cols-2 gap-4 mb-6">
                        {feature.highlights.map(highlight => (
                          <div class="flex items-center gap-2 text-sm text-gray-600">
                            <ChevronRight class="w-4 h-4 text-purple-500 flex-shrink-0" />
                            <span>{highlight}</span>
                          </div>
                        ))}
                      </div>

                      <!-- Stats -->
                      <div class="flex items-center justify-end">
                        <div class="text-right">
                          <div class="text-2xl font-bold text-purple-600">{feature.stats.value}</div>
                          <div class="text-sm text-gray-600">{feature.stats.label}</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Showcase Section -->
    <section class="py-20 bg-gradient-to-br from-gray-900 to-purple-900 text-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl font-bold mb-4">{solutionData.showcase.title}</h2>
          <p class="text-xl opacity-80">{solutionData.showcase.description}</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Video -->
          <div class="relative group rounded-2xl overflow-hidden bg-white/5 backdrop-blur-sm">
            <div class="youtube-container">
              <iframe
                src={`https://www.youtube.com/embed/${getYouTubeVideoId(solutionData.showcase.video.url)}?autoplay=0&rel=0&modestbranding=1`}
                title="Showcase Video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          </div>

          <!-- Testimonials -->
          <div class="space-y-8">
            {solutionData.showcase.testimonials.map(testimonial => (
              <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6">
                <div class="flex items-center gap-4 mb-4">
                  <img 
                    src={testimonial.image} 
                    alt={testimonial.author}
                    class="w-12 h-12 rounded-full"
                  />
                  <div>
                    <div class="font-semibold">{testimonial.author}</div>
                    <div class="text-sm opacity-80">{testimonial.role}</div>
                  </div>
                </div>
                <p class="text-lg italic">"{testimonial.quote}"</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-32 relative overflow-hidden benefits-section">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-purple-900 to-blue-900"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <!-- Header -->
        <div class="text-center max-w-3xl mx-auto mb-20">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-4">
            <span class="text-sm font-medium text-white">{solutionData.benefits.subtitle}</span>
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-white">{solutionData.benefits.title}</h2>
          <p class="text-xl text-gray-300">{solutionData.benefits.description}</p>
        </div>

        <!-- Benefits Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {solutionData.benefits.items.map((benefit, index) => {
            const Icon = getIcon(benefit.icon);
            const colors = {
              blue: 'from-blue-400 to-blue-500',
              purple: 'from-purple-400 to-purple-500',
              green: 'from-emerald-400 to-emerald-500',
              yellow: 'from-amber-400 to-amber-500'
            };
            const gradientColor = colors[benefit.color] || colors.blue;
            
            return (
              <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                <!-- Card Glow Effect -->
                <div class={`absolute -inset-0.5 bg-gradient-to-r ${gradientColor} rounded-3xl blur opacity-30 group-hover:opacity-60 transition duration-500`}></div>
                
                <!-- Card Content -->
                <div class="relative h-full bg-white/10 backdrop-blur-sm border border-white/20 rounded-3xl p-8">
                  <!-- Icon Container with Glow -->
                  <div class="relative w-16 h-16 mb-6 mx-auto">
                    <div class={`absolute inset-0 bg-gradient-to-br ${gradientColor} rounded-2xl blur-sm opacity-40 group-hover:opacity-60 transition-opacity duration-500`}></div>
                    <div class="relative h-full flex items-center justify-center">
                      <Icon class="w-8 h-8" />
                    </div>
                  </div>

                  <!-- Content -->
                  <h3 class="text-2xl font-semibold text-white text-center mb-4">{benefit.title}</h3>
                  <p class="text-gray-300 text-center mb-6 leading-relaxed">{benefit.description}</p>

                  <!-- Stats with Enhanced Gradient -->
                  <div class="flex items-center justify-center mb-8">
                    <div class="text-center">
                      <div class={`text-5xl font-bold bg-gradient-to-r ${gradientColor} text-transparent bg-clip-text group-hover:scale-110 transition-transform duration-500`}>
                        {benefit.stats.value}
                      </div>
                      <div class="text-sm text-gray-300 mt-2">{benefit.stats.label}</div>
                    </div>
                  </div>

                  <!-- Highlights with Enhanced Dots -->
                  <div class="space-y-3">
                    {benefit.highlights.map(highlight => (
                      <div class="flex items-center gap-3 text-sm text-gray-300">
                        <div class={`w-2 h-2 rounded-full bg-gradient-to-r ${gradientColor} group-hover:scale-125 transition-transform duration-500`}></div>
                        <span class="group-hover:text-white transition-colors duration-500">{highlight}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-32 relative overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-purple-50 to-blue-50"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <!-- Header -->
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-50 border border-purple-100 mb-4">
            <span class="text-sm font-medium bg-gradient-to-r from-purple-600 to-blue-600 text-transparent bg-clip-text">
              {solutionData.pricing.subtitle}
            </span>
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6">{solutionData.pricing.title}</h2>
          <p class="text-xl text-gray-600">{solutionData.pricing.description}</p>
        </div>

        <!-- Billing Toggle -->
        <div class="flex justify-center items-center gap-6 mb-12">
          <div id="pricing-toggle" class="inline-flex bg-gray-100 p-1 rounded-full">
            <button id="monthly-toggle" class="px-6 py-2 rounded-full bg-purple-600 text-white font-medium transition-all duration-300">
              Monthly
            </button>
            <button id="yearly-toggle" class="px-6 py-2 rounded-full text-gray-700 font-medium transition-all duration-300">
              Annual <span class="ml-1 text-xs bg-green-100 text-green-800 px-1.5 py-0.5 rounded-full">-20%</span>
            </button>
          </div>
        </div>

        <!-- Pricing Grid -->
        <div class="grid lg:grid-cols-3 gap-8">
          {solutionData.pricing.plans.map((plan, index) => (
            <div class={`relative group transform hover:-translate-y-2 transition-all duration-500 ${plan.popular ? 'lg:scale-105' : ''}`}>
              <!-- Popular Badge -->
              {plan.popular && (
                <div class="absolute -top-5 left-1/2 transform -translate-x-1/2">
                  <div class="inline-flex items-center px-4 py-2 rounded-full bg-gradient-to-r from-purple-600 to-blue-600 text-white text-sm font-semibold shadow-lg">
                    Most Popular
                  </div>
                </div>
              )}

              <!-- Card Glow Effect -->
              <div class={`absolute -inset-0.5 bg-gradient-to-r ${plan.popular ? 'from-purple-600 to-blue-600' : 'from-gray-100 to-gray-200'} rounded-3xl blur opacity-30 group-hover:opacity-100 transition duration-500`}></div>

              <!-- Card Content -->
              <div class={`relative h-full ${plan.popular ? 'bg-white' : 'bg-white/80'} backdrop-blur-sm rounded-3xl p-8 ${plan.popular ? 'border-2 border-purple-500' : 'border border-gray-200'}`}>
                <!-- Plan Header -->
                <div class="text-center mb-8">
                  <h3 class="text-xl font-bold mb-3">{plan.name}</h3>
                  <p class="text-sm font-medium text-gray-500 mb-4">{plan.highlight}</p>
                  
                  <!-- Price Display -->
                  <div class="flex flex-col items-center gap-2">
                    <!-- Monthly Price -->
                    <div class="billing-monthly w-full h-12 flex items-center justify-center">
                      <span class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">{plan.monthlyPrice}</span>
                      {plan.monthlyPrice !== "Custom" && (
                        <span class="text-base font-normal text-gray-500 ml-1">/month</span>
                      )}
                    </div>
                    
                    <!-- Yearly Price -->
                    <div class="billing-yearly w-full h-12 flex items-center justify-center">
                      <span class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">{plan.yearlyPrice}</span>
                      {plan.yearlyPrice !== "Custom" && (
                        <span class="text-base font-normal text-gray-500 ml-1">/year</span>
                      )}
                    </div>
                    
                    <p class="text-sm text-gray-500 mt-1">{plan.yearlyDiscount}</p>
                  </div>
                  
                  <p class="mt-4 text-gray-600">{plan.description}</p>
                </div>

                <!-- Features List -->
                <div class="space-y-4 mb-8">
                  {plan.features.map(feature => (
                    <div class={`flex items-start gap-3 ${feature.isHeader ? 'pt-4 border-t border-gray-100' : ''}`}>
                      {feature.isHeader ? (
                        <p class="font-medium text-gray-900">{feature.text}</p>
                      ) : (
                        <>
                          <div class={`flex-shrink-0 ${plan.popular ? 'text-purple-600' : 'text-gray-400'}`}>
                            <ChevronRight class="w-5 h-5" />
                          </div>
                          <span class={`text-gray-600 ${feature.isNew ? 'relative' : ''}`}>
                            {feature.text}
                            {feature.isNew && (
                              <span class="absolute -right-12 -top-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                New
                              </span>
                            )}
                          </span>
                        </>
                      )}
                    </div>
                  ))}
                </div>

                <!-- CTA Button -->
                <button class={`w-full py-4 px-6 rounded-xl ${plan.popular ? 'bg-gradient-to-r from-purple-600 to-blue-600 text-white hover:from-purple-700 hover:to-blue-700' : 'bg-gray-900 text-white hover:bg-gray-800'} font-medium transition-colors`}>
                  {plan.cta}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Get the toggle buttons
        const monthlyToggle = document.getElementById('monthly-toggle');
        const yearlyToggle = document.getElementById('yearly-toggle');
        
        // Get pricing elements
        const monthlyElements = document.querySelectorAll('.billing-monthly');
        const yearlyElements = document.querySelectorAll('.billing-yearly');
        
        // Function to show monthly pricing
        function showMonthly() {
          // Update UI
          monthlyToggle.classList.add('bg-purple-600', 'text-white');
          monthlyToggle.classList.remove('text-gray-700');
          yearlyToggle.classList.remove('bg-purple-600', 'text-white');
          yearlyToggle.classList.add('text-gray-700');
          
          // Show/hide pricing
          monthlyElements.forEach(el => el.style.display = 'flex');
          yearlyElements.forEach(el => el.style.display = 'none');
        }
        
        // Function to show yearly pricing
        function showYearly() {
          // Update UI
          yearlyToggle.classList.add('bg-purple-600', 'text-white');
          yearlyToggle.classList.remove('text-gray-700');
          monthlyToggle.classList.remove('bg-purple-600', 'text-white');
          monthlyToggle.classList.add('text-gray-700');
          
          // Show/hide pricing
          monthlyElements.forEach(el => el.style.display = 'none');
          yearlyElements.forEach(el => el.style.display = 'flex');
        }
        
        // Add event listeners
        monthlyToggle.addEventListener('click', showMonthly);
        yearlyToggle.addEventListener('click', showYearly);
        
        // Initialize with monthly pricing
        showMonthly();
      });
    </script>
    
    <style is:global>
      /* Base styles for billing display */
      .billing-monthly,
      .billing-yearly {
        transition: all 0.3s ease;
      }
      
      /* Ensure toggle displays pointer */
      #pricing-toggle {
        cursor: pointer;
      }
    </style>

    <!-- CTA Section -->
    <section 
      class="relative py-20 bg-cover bg-center"
      style={`background-image: url(${solutionData.cta.background})`}
    >
      <div class="absolute inset-0 bg-gradient-to-r from-blue-900/90 to-purple-900/90"></div>
      <div class="relative container mx-auto px-4 text-center text-white">
        <h2 class="text-4xl font-bold mb-6">{solutionData.cta.title}</h2>
        <p class="text-xl opacity-90 max-w-2xl mx-auto mb-8">{solutionData.cta.description}</p>
        <div class="flex items-center justify-center gap-4">
          <a 
            href={solutionData.cta.primaryButton.link}
            class="px-8 py-4 rounded-xl bg-white text-purple-600 font-medium hover:bg-gray-100 transition-colors"
          >
            {solutionData.cta.primaryButton.text}
          </a>
          <a 
            href={solutionData.cta.secondaryButton.link}
            class="px-8 py-4 rounded-xl bg-white/10 text-white font-medium hover:bg-white/20 transition-colors"
          >
            {solutionData.cta.secondaryButton.text}
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.4; }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s ease-in-out infinite;
  }
</style> 