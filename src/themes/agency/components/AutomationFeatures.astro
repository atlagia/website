---
import { Workflow, Headphones, Megaphone, BarChart } from 'lucide-react';

interface AutomationFeature {
  icon: string;
  title: string;
  description: string;
  metrics: {
    value: string;
    label: string;
  }[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  features: AutomationFeature[];
}

const { subtitle, title, description, features } = Astro.props;

// Map icon names to Lucide components
const iconMap = {
  'Workflow': Workflow,
  'Headphones': Headphones,
  'Megaphone': Megaphone,
  'BarChart': BarChart
};
---

<section class="relative py-32 overflow-hidden bg-navy-950">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-purple-600/10 via-pink-600/10 to-blue-600/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-600/10 via-purple-600/10 to-pink-600/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-navy-900/50 border border-purple-500/20 backdrop-blur-sm shadow-lg shadow-purple-500/5 hover:shadow-purple-500/10 transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-purple-400 to-pink-400"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-purple-400 to-pink-400 text-transparent bg-clip-text">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
      
      <p class="text-lg text-gray-300 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {features.map((feature) => {
        const IconComponent = iconMap[feature.icon as keyof typeof iconMap];
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 bg-navy-900/50 rounded-2xl border border-gray-800 backdrop-blur-sm transition-all duration-500 group-hover:bg-navy-900/80 group-hover:border-purple-500/20 group-hover:shadow-xl"></div>
            
            <div class="relative p-8">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-gradient-to-br from-purple-500/20 to-pink-500/20 group-hover:from-purple-500/30 group-hover:to-pink-500/30 transition-colors duration-300">
                  <IconComponent className="w-8 h-8 text-purple-400" />
                </div>
                <h3 class="text-2xl font-bold text-white">
                  {feature.title}
                </h3>
              </div>

              <p class="text-gray-300 mb-8">
                {feature.description}
              </p>

              <!-- Metrics Grid -->
              <div class="grid grid-cols-2 gap-4">
                {feature.metrics.map((metric) => (
                  <div class="relative group/metric">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-xl opacity-0 group-hover/metric:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative p-4 rounded-xl bg-navy-800/50 backdrop-blur-sm border border-gray-800/50">
                      <div class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 text-transparent bg-clip-text mb-1">
                        {metric.value}
                      </div>
                      <div class="text-sm text-gray-400">
                        {metric.label}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .bg-navy-950 {
    background-color: #060714;
  }
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }
</style> 