---
import * as LucideIcons from 'lucide-react';

interface Step {
  number: string;
  title: string;
  description: string;
  icon: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  steps: Step[];
}

const { subtitle, title, description, steps } = Astro.props;

// Components need to be destructured directly from the import
const {
  Search,
  Layout,
  Code,
  CheckCircle,
  Zap,
  Settings,
  Users,
  Target,
  Cpu,
  Database,
  Globe,
  Rocket,
  Shield,
  Brain,
  Lightbulb,
  Circle
} = LucideIcons;

// Map icon names to their respective components
const iconMap = {
  search: Search,
  layout: Layout,
  code: Code,
  'check-circle': CheckCircle,
  zap: Zap,
  settings: Settings,
  users: Users,
  target: Target,
  cpu: Cpu,
  database: Database,
  globe: Globe,
  rocket: Rocket,
  shield: Shield,
  brain: Brain,
  lightbulb: Lightbulb
};
---

<section class="relative py-32 overflow-hidden bg-navy-950">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-navy-900/50 border border-purple-500/20 backdrop-blur-sm shadow-lg shadow-purple-500/5 hover:shadow-purple-500/10 transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-600 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-blue-600 to-purple-600"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-blue-500 to-purple-500 text-transparent bg-clip-text">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
      
      <p class="text-lg text-gray-300 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Process Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="group relative">
          <!-- Card Background -->
          <div class="absolute inset-0 bg-navy-900/50 rounded-2xl backdrop-blur-sm border border-purple-500/10 transition-all duration-500 group-hover:border-purple-500/20 group-hover:bg-navy-900/60"></div>
          
          <!-- Content -->
          <div class="relative p-8">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-purple-500/20 flex items-center justify-center">
                <span class="text-2xl font-bold bg-gradient-to-r from-blue-500 to-purple-500 text-transparent bg-clip-text">
                  {step.number}
                </span>
              </div>
              <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500/20 to-purple-500/20 flex items-center justify-center">
                <span class="w-6 h-6 text-white">
                  {step.icon === 'search' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>}
                  {step.icon === 'layout' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>}
                  {step.icon === 'code' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>}
                  {step.icon === 'check-circle' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>}
                  {step.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
                  {step.icon === 'settings' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>}
                  {step.icon === 'users' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
                  {step.icon === 'target' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>}
                  {!['search', 'layout', 'code', 'check-circle', 'zap', 'settings', 'users', 'target'].includes(step.icon) && 
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                  }
                </span>
              </div>
            </div>
            
            <h3 class="text-xl font-bold text-white mb-3">
              {step.title}
            </h3>
            
            <p class="text-gray-400">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bg-navy-950 {
    background-color: #060818;
  }
  
  .bg-navy-900 {
    background-color: #0a0b1e;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }
</style> 