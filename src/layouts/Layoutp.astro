---
import Header from '../themes/default/components/Header';
import { useCurrencyStore } from '../store/currency';

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Drivi';

// Add store name and domain
const storeName = import.meta.env.PUBLIC_STORE_NAME || 'DefaultStore';
const storeDomain = import.meta.env.PUBLIC_STORE_DOMAIN || 'localhost';

// Import layout styles with fallback (bodyClass, themeColor) - website first, default fallback
let layoutStyles: { bodyClass?: string; bodyClassProduct?: string; themeColor?: string } = {};
try {
  const themeLayout = await import(`../websites/${siteName}/themes/${theme}/styles/layout.json`);
  layoutStyles = themeLayout.default;
} catch {
  try {
    const defaultLayout = await import('../styles/default/layout.json');
    layoutStyles = defaultLayout.default;
  } catch {
    layoutStyles = { bodyClassProduct: 'min-h-screen flex flex-col', themeColor: '#ffffff' };
  }
}
const bodyClass = layoutStyles.bodyClassProduct ?? layoutStyles.bodyClass ?? 'min-h-screen flex flex-col';
const themeColor = layoutStyles.themeColor ?? '#ffffff';

// Import header styles with fallback logic
let headerStyles = {};
try {
  // Try to load theme-specific header styles first
  const themeHeaderStyles = await import(`../websites/${siteName}/themes/${theme}/styles/Header.json`);
  headerStyles = themeHeaderStyles.default;
  console.log(`✅ Loaded ${siteName}/${theme} header styles`);
} catch (error) {
  console.log(`⚠️ Theme-specific header styles not found for ${siteName}/${theme}, falling back to default`);
  try {
    // Fallback to default theme header styles
    const defaultHeaderStyles = await import(`../themes/default/styles/Header.json`);
    headerStyles = defaultHeaderStyles.default;
    console.log('✅ Loaded default header styles');
  } catch (fallbackError) {
    console.error('❌ Failed to load both theme and default header styles:', fallbackError);
    // Provide minimal fallback styles
    headerStyles = {
      wrapper: "bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50",
      container: "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
      nav: {
        wrapper: "flex items-center justify-between h-16",
        brand: "text-xl font-bold text-gray-900 hover:text-gray-700 transition-colors",
        menu: { item: "text-gray-700 hover:text-gray-900 px-3 py-2 rounded-md text-sm font-medium transition-colors" }
      },
      actions: { wrapper: "flex items-center space-x-4" }
    };
  }
}

// Theme-specific BaseHead (so product pages get site CSS variables e.g. --drivon-*)
let BaseHead;
try {
  const baseHeadModule = await import(`../websites/${siteName}/themes/${theme}/components/BaseHead.astro`);
  BaseHead = baseHeadModule.default;
} catch {
  const defaultBaseHead = await import(`../themes/default/components/BaseHead.astro`);
  BaseHead = defaultBaseHead.default;
}

// Import website-specific footer with fallback to theme footer
let Footer;
try {
  // Try to load website-specific footer first
  const websiteFooter = await import(`../websites/${siteName}/themes/${theme}/components/Footer.astro`);
  Footer = websiteFooter.default;
  console.log(`✅ Loaded ${siteName}/${theme} website-specific footer`);
} catch (error) {
  console.log(`⚠️ Website-specific footer not found for ${siteName}/${theme}, falling back to theme footer`);
  try {
    // Fallback to theme footer
    const themeFooter = await import(`../themes/${theme}/components/Footer.astro`);
    Footer = themeFooter.default;
    console.log('✅ Loaded theme footer');
  } catch (fallbackError) {
    console.error('❌ Failed to load both website and theme footers:', fallbackError);
    // Provide minimal fallback footer
    Footer = () => `<footer class="bg-gray-900 text-white py-8"><div class="max-w-7xl mx-auto px-4 text-center"><p>&copy; ${new Date().getFullYear()} ${siteName}. All rights reserved.</p></div></footer>`;
  }
}

// Import menu configuration with fallback logic
let menuConfig = {};
try {
  // Try to load theme-specific menu configuration first
  const themeMenuConfig = await import(`../websites/${siteName}/themes/${theme}/data/store/Menu.json`);
  menuConfig = themeMenuConfig.default;
  console.log(`✅ Loaded ${siteName}/${theme} menu configuration`);
} catch (error) {
  console.log(`⚠️ Theme-specific menu config not found for ${siteName}/${theme}, using default menu`);
  // Fallback to default menu configuration - only include allowed languages
  const allowedLanguages = getAllowedLanguages();
  menuConfig = {};
  
  allowedLanguages.forEach(lang => {
    switch(lang) {
      case 'en':
        menuConfig[lang] = {
          items: [
            { label: "Collections", href: "/en/collections" },
            { label: "Helmets", href: "/en/helmets" },
            { label: "Jackets", href: "/en/jackets" },
            { label: "Accessories", href: "/en/accessories" }
          ]
        };
        break;
      case 'fr':
        menuConfig[lang] = {
          items: [
            { label: "Collections", href: "/fr/collections" },
            { label: "Casques", href: "/fr/helmets" },
            { label: "Vestes", href: "/fr/jackets" },
            { label: "Accessoires", href: "/fr/accessories" }
          ]
        };
        break;
      case 'de':
        menuConfig[lang] = {
          items: [
            { label: "Kollektionen", href: "/de/collections" },
            { label: "Helme", href: "/de/helmets" },
            { label: "Jacken", href: "/de/jackets" },
            { label: "Zubehör", href: "/de/accessories" }
          ]
        };
        break;
      default:
        // For any other allowed language, use English structure
        menuConfig[lang] = {
          items: [
            { label: "Collections", href: `/${lang}/collections` },
            { label: "Helmets", href: `/${lang}/helmets` },
            { label: "Jackets", href: `/${lang}/jackets` },
            { label: "Accessories", href: `/${lang}/accessories` }
          ]
        };
    }
  });
}

// Get allowed languages from environment
const getAllowedLanguages = (): string[] => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const allowedLanguages = getAllowedLanguages();
const languageNames = {
  en: "English",
  fr: "Français",
  de: "Deutsch",
  es: "Español",
  it: "Italiano",
  pt: "Português",
  nl: "Nederlands",
  ru: "Русский",
  ar: "العربية",
  zh: "中文",
  tr: "Türkçe",
  ja: "日本語",
  ko: "한국어",
  sv: "Svenska",
  no: "Norsk",
  da: "Dansk",
  fi: "Suomi",
  pl: "Polski",
  cs: "Čeština",
  hu: "Magyar",
  ro: "Română",
  bg: "Български",
  hr: "Hrvatski",
  sk: "Slovenčina",
  sl: "Slovenščina",
  et: "Eesti",
  lv: "Latviešu",
  lt: "Lietuvių",
  el: "Ελληνικά",
  he: "עברית",
  th: "ไทย",
  vi: "Tiếng Việt",
  id: "Bahasa Indonesia",
  ms: "Bahasa Melayu",
  tl: "Filipino"
};

const languages = Object.fromEntries(
  allowedLanguages.map(lang => [lang, languageNames[lang] || lang])
);

interface Props {
  title: string;
  lang?: string;
  description?: string;
  image?: string;
  isProduct?: boolean;
  price?: any;
  availability?: boolean;
  alternateUrls?: Array<{lang: string, url: string}>;
  productSchema?: any;
  breadcrumbSchema?: any;
  projectType?: string;
}

// Get current path and language first
const currentPath = Astro.url.pathname;
const currentLang = currentPath.split('/')[1] || 'en'; // Extract language from path

const { 
  title, 
  lang = currentLang, 
  description, 
  image, 
  isProduct = false, 
  price, 
  availability, 
  alternateUrls = [], 
  productSchema, 
  breadcrumbSchema,
  projectType: projectTypeProp
} = Astro.props;

// Project type: from page prop, then env, then default (physical so quantity/cart behave for stores)
const PROJECT_TYPE = (projectTypeProp ?? import.meta.env.PROJECT_TYPE ?? 'physical').toString().toLowerCase();

// Add currency configuration
const currencies = {
  USD: '$',
  EUR: '€',
  GBP: '£',
  JPY: '¥',
  CNY: '¥',
  CAD: 'C$',
  AUD: 'A$'
};

// Fetch exchange rates with better error handling
let exchangeRates = {};
try {
  const response = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  const data = await response.json();
  exchangeRates = data.rates;
  console.log('Fetched exchange rates:', exchangeRates);
} catch (error) {
  console.error('Failed to fetch exchange rates:', error);
  // Provide fallback rates for common currencies
  exchangeRates = {
    USD: 1,
    EUR: 0.85,
    GBP: 0.73,
    JPY: 110.0,
    CAD: 1.25,
    AUD: 1.35,
    RUB: 92.5, // Current approximate rate, will be updated by API
    // Add more fallback rates as needed
  };
}

// Add search configuration with the correct language
const searchConfig = {
  apiEndpoint: import.meta.env.VITE_API_ENDPOINT,
  lang: currentLang, // Use the extracted language
  placeholder: {
    en: "Search products...",
    fr: "Rechercher des produits...",
    de: "Produkte suchen...",
    es: "Buscar productos...",
    it: "Cerca prodotti...",
    pt: "Procurar produtos...",
    nl: "Producten zoeken...",
    ru: "Поиск товаров..."
  }
};

// Payment configuration
const paymentConfig = {
  method: import.meta.env.PUBLIC_PAYMENT_METHOD || 'default',
  hoodpay: {
    apiUrl: import.meta.env.HOODPAY_API_URL,
    businessId: import.meta.env.HOODPAY_BUSINESS_ID,
    authToken: import.meta.env.HOODPAY_AUTH_TOKEN,
    redirectUrl: `${import.meta.env.DOMAINE}${import.meta.env.HOODPAY_REDIRECT_URL}`
  },
  // Add store configuration to paymentConfig
  store: {
    name: import.meta.env.PUBLIC_STORE_NAME,
    domain: import.meta.env.DOMAINE
  }
};


---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={title}
      description={description}
      image={image}
      isProduct={isProduct}
      price={price}
      availability={availability}
      alternateUrls={alternateUrls}
      productSchema={productSchema}
      breadcrumbSchema={breadcrumbSchema}
      projectType={PROJECT_TYPE}
    />
    
    <!-- Resource Hints -->
    <link rel="preconnect" href="https://cdn.shopify.com" />
    <link rel="dns-prefetch" href="https://cdn.shopify.com" />
    
    <!-- Preload critical assets -->
    {image && (
      <link 
        rel="preload" 
        as="image" 
        href={image}
        fetchpriority="high"
      />
    )}
    
    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="/fonts/inter-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    
    <!-- Defer non-critical CSS -->
    <link 
      rel="stylesheet" 
      href="/styles/non-critical.css"
      media="print" 
      onload="this.media='all'"
    />
    
    <!-- Additional Meta Tags -->
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    
    <!-- PWA Tags -->
    <meta name="theme-color" content={themeColor} />
    <link rel="manifest" href="/manifest.json" />
    
    <script define:vars={{ exchangeRates }}>
      // Make exchange rates available globally
      window.exchangeRates = exchangeRates;
      console.log('Initialized exchange rates:', window.exchangeRates);
    </script>
  </head>
  <body class={bodyClass} data-project-type={PROJECT_TYPE}>
    <Header 
      client:load 
      siteName={siteName}
      menuConfig={menuConfig}
      languages={languages}
      allowedLanguages={allowedLanguages}
      projectType={PROJECT_TYPE}
      currentPath={currentPath}
      currencies={currencies}
      styles={headerStyles}
      headerStyles={headerStyles}
      apiEndpoint={import.meta.env.VITE_API_ENDPOINT}
      searchConfig={searchConfig}
      paymentConfig={paymentConfig}
    />
    <slot />
    <Footer />

    <script>
      // Initialize currency store with exchange rates
      import { useCurrencyStore } from '../store/currency';
      
      // Wait for DOM content to be loaded
      document.addEventListener('DOMContentLoaded', () => {
        if (window.exchangeRates) {
          console.log('Setting exchange rates in store:', window.exchangeRates);
          useCurrencyStore.getState().setRates(window.exchangeRates);
        } else {
          console.error('Exchange rates not available');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --accent: 136, 58, 234;
    --accent-light: 224, 204, 250;
    --accent-dark: 49, 10, 101;
  }
  html {
    font-family: system-ui, sans-serif;
    background: #fff;
    scroll-behavior: smooth;
  }
</style>