---
import { getLangFromUrl } from '@utils/i18n';

const currentYear = new Date().getFullYear();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GlobalGiftCards';
const currentLang = getLangFromUrl(Astro.url);
const prefix = `/${currentLang}`;

const footerNav = {
  categories: [
    { name: 'Gaming', href: `${prefix}/collections/gaming` },
    { name: 'Entertainment', href: `${prefix}/collections/entertainment` },
    { name: 'Retail', href: `${prefix}/collections/retail` },
    { name: 'Travel', href: `${prefix}/collections/travel` },
    { name: 'Electronics', href: `${prefix}/collections/electronics` },
    { name: 'All categories', href: `${prefix}/collections` },
  ],
  support: [
    { name: 'Support', href: `${prefix}/support` },
    { name: 'FAQ', href: `${prefix}/faq` },
    { name: 'Contact', href: `${prefix}/contact` },
  ],
  legal: [
    { name: 'Privacy', href: `${prefix}/privacy` },
    { name: 'Terms', href: `${prefix}/terms` },
  ],
};
---

<footer class="bg-[var(--ggc-primary)] text-white" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <!-- Payment methods strip (BuysellVouchers-style) -->
  <div class="border-b border-white/20 bg-[var(--ggc-hero-dark)]/80">
    <div class="mx-auto max-w-7xl px-6 py-6 lg:px-8">
      <p class="font-body text-xs uppercase tracking-wider text-white/70 mb-4 text-center">Payment methods</p>
      <div class="flex flex-wrap items-center justify-center gap-6 opacity-90">
        <span class="text-white/80 font-body text-sm font-medium">Visa</span>
        <span class="text-white/80 font-body text-sm font-medium">Mastercard</span>
        <span class="text-white/80 font-body text-sm font-medium">PayPal</span>
        <span class="text-white/80 font-body text-sm font-medium">Payz</span>
        <span class="text-white/80 font-body text-sm font-medium">Crypto</span>
      </div>
    </div>
  </div>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-4">
        <span class="font-display text-2xl font-bold text-white">{siteName}</span>
        <p class="font-body text-sm leading-6 text-white/80">Instantly buy digital gift cards for gaming, entertainment, retail, travel, and more.</p>
      </div>
      <div class="mt-16 grid grid-cols-2 md:grid-cols-3 gap-8 xl:col-span-2 xl:mt-0">
        <div>
          <h3 class="font-body text-sm font-semibold text-white uppercase tracking-wider">Categories</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNav.categories.map((item) => (
              <li><a href={item.href} class="font-body text-sm text-white/80 hover:text-white transition-colors">{item.name}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-body text-sm font-semibold text-white">Support</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNav.support.map((item) => (
              <li><a href={item.href} class="font-body text-sm text-white/80 hover:text-white transition-colors">{item.name}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-body text-sm font-semibold text-white">Legal</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNav.legal.map((item) => (
              <li><a href={item.href} class="font-body text-sm text-white/80 hover:text-white transition-colors">{item.name}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-white/20 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-white/70">&copy; {currentYear} {siteName}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="Twitter"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="Facebook"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="Instagram"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.265.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.058 1.645-.07 4.849-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="LinkedIn"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
      </div>
      <p class="font-body text-xs text-white/60">We use cookies to improve your experience. <a href={`${prefix}/privacy`} class="underline hover:text-white">Privacy</a></p>
    </div>
  </div>
</footer>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
