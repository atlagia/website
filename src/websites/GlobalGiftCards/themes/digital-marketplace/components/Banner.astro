---
interface Props {
  headline: string;
  description?: string;
  backgroundImage?: string;
  icons?: { label: string; icon?: string }[];
}

const { headline, description, backgroundImage, icons = [] } = Astro.props;
---

<section
  class="relative py-20 md:py-28 px-4 md:px-8 bg-[var(--ggc-primary)]"
  style={backgroundImage ? `background-image: url(${backgroundImage}); background-size: cover; background-position: center;` : ''}
>
  <div class="absolute inset-0 bg-[var(--ggc-primary)]/95" aria-hidden="true"></div>
  <div class="relative max-w-4xl mx-auto text-center">
    <h2 class="font-display text-3xl md:text-5xl font-bold text-white tracking-tight mb-6">
      {headline}
    </h2>
    {description && <p class="font-body text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto">{description}</p>}
    {icons.length > 0 && (
      <div class="flex flex-wrap justify-center gap-8 md:gap-12 mt-10">
        {icons.map((item) => (
          <div class="flex flex-col items-center gap-2 text-white/90">
            <span class="text-2xl" aria-hidden="true">⚡</span>
            <span class="font-body text-xs uppercase tracking-wider">{item.label}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
