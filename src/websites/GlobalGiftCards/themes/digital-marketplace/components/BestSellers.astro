---
import { getCollectionProducts, getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description?: string;
  viewAllLink: string;
  lang: string;
  collectionHandle?: string;
}

const { title, description, viewAllLink, lang, collectionHandle } = Astro.props;

let productsData;
try {
  if (collectionHandle && collectionHandle !== 'all') {
    productsData = await getCollectionProducts(collectionHandle);
  } else {
    productsData = await getAllProducts();
  }
} catch (_) {
  try {
    productsData = await getAllProducts();
  } catch {
    productsData = { edges: [] };
  }
}

const products = (productsData?.edges || [])
  .slice(0, 12)
  .map(({ node }: { node: { id: string; title: string; handle: string; priceRange: { minVariantPrice: { amount: string; currencyCode: string } }; images: { edges: Array<{ node: { url: string } }> } } }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(parseFloat(node.priceRange.minVariantPrice.amount)),
    image: node.images.edges[0]?.node.url || 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&q=80',
    badge: 'POPULAR',
  }));
---

<section class="bg-[var(--ggc-bg)] border-t border-[var(--ggc-border)] py-16 md:py-20 px-4 sm:px-6 lg:px-8" aria-labelledby="best-sellers-heading">
  <div class="max-w-7xl mx-auto">
    <header class="mb-10">
      <h2 id="best-sellers-heading" class="font-display text-2xl sm:text-3xl font-semibold text-[var(--ggc-text)] tracking-tight">{title}</h2>
      {description && <p class="font-body text-[var(--ggc-muted)] text-sm mt-1">{description}</p>}
    </header>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 sm:gap-6 mb-10">
      {products.length === 0 ? (
        <div class="col-span-full py-16 text-center border border-dashed border-[var(--ggc-border)] rounded-xl bg-[var(--ggc-surface)]/50">
          <p class="font-body text-[var(--ggc-muted)] text-sm">Promoted gift cards will appear here soon.</p>
          <a href={viewAllLink} class="mt-4 inline-block text-[var(--ggc-accent)] text-xs font-semibold uppercase tracking-wider hover:underline font-body">Browse all categories</a>
        </div>
      ) : products.map((product) => (
        <article class="group flex flex-col bg-[var(--ggc-bg)] border border-[var(--ggc-border)] rounded-xl overflow-hidden hover:border-[var(--ggc-accent)]/40 hover:shadow-lg transition-all duration-200">
          <a href={`/${lang}/products/${product.handle}`} class="block flex-1">
            <div class="relative aspect-square overflow-hidden bg-[var(--ggc-surface)]">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-contain p-4 transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <span class="absolute top-2 right-2 px-2 py-1 rounded-lg bg-[var(--ggc-emerald)] text-white text-[10px] font-semibold uppercase tracking-wider shadow-md" title="Instant Delivery" aria-label="Instant Delivery">
                Instant
              </span>
            </div>
            <div class="p-3 flex-1 flex flex-col">
              <h3 class="font-body text-[var(--ggc-text)] font-medium text-xs sm:text-sm line-clamp-2 mb-1 group-hover:text-[var(--ggc-accent)] transition-colors">{product.name}</h3>
              <p class="font-body text-[var(--ggc-accent)] font-semibold text-sm mt-auto">{product.price}</p>
            </div>
          </a>
          <a
            href={`/${lang}/products/${product.handle}`}
            class="mx-3 mb-3 py-2.5 rounded-lg bg-[var(--ggc-accent)] text-white text-center text-xs font-semibold uppercase tracking-wider hover:opacity-90 transition-opacity font-body"
          >
            Buy now
          </a>
        </article>
      ))}
    </div>
    {products.length > 0 && (
    <div class="text-center">
      <a href={viewAllLink} class="inline-block border-2 border-[var(--ggc-accent)] text-[var(--ggc-accent)] text-xs font-semibold uppercase tracking-wider px-8 py-3 rounded-lg hover:bg-[var(--ggc-accent)] hover:text-white transition-all duration-200 font-body">
        View all
      </a>
    </div>
    )}
  </div>
</section>
