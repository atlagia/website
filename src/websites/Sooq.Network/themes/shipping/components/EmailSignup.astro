---
import { Button } from './ui/Button';
import { Mail } from 'lucide-react';

interface Props {
  subtitle?: string;
  title: string;
  description: string;
  buttonText: string;
  placeholder?: string;
  features?: string[];
  formType?: 'newsletter' | 'appointment';
  trustBadge?: {
    icon?: string;
    text: string;
  };
}

const {
  subtitle,
  title,
  description,
  buttonText,
  placeholder = "Enter your email",
  features = [],
  formType = 'newsletter',
  trustBadge
} = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-white via-[#0a91b1]/5 to-white" id="content-emailSignupSection">
  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        {subtitle && (
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20" id="content-subtitle">
            {subtitle}
          </span>
        )}
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-6" id="content-title">
          {title}
        </h2>
        <p class="text-xl text-gray-600 leading-relaxed" id="content-description">
          {description}
        </p>
      </div>

      <!-- Form Section -->
      <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
        <form class="space-y-4" onSubmit="event.preventDefault();">
          {formType === 'appointment' ? (
            <>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1" id="content-nameLabel">Full Name</label>
                  <input 
                    type="text" 
                    placeholder="John Doe"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/20 focus:border-[#0a91b1]"
                    required
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1" id="content-phoneLabel">Phone Number</label>
                  <input 
                    type="tel" 
                    placeholder="(555) 123-4567"
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/20 focus:border-[#0a91b1]"
                    required
                  />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" id="content-emailLabel">Email Address</label>
                <input 
                  type="email" 
                  placeholder={placeholder}
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/20 focus:border-[#0a91b1]"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" id="content-dateLabel">Preferred Date</label>
                <input 
                  type="date" 
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/20 focus:border-[#0a91b1]"
                  required
                />
              </div>
            </>
          ) : (
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1" id="content-emailLabel">Email Address</label>
              <input 
                type="email" 
                placeholder={placeholder}
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/20 focus:border-[#0a91b1]"
                required
              />
            </div>
          )}
          
          <button
            type="submit"
            class="w-full px-8 py-4 text-base font-medium text-white bg-[#0a91b1] hover:bg-[#097d99] rounded-lg transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
            id="content-buttonText"
          >
            {buttonText}
          </button>
        </form>

        <!-- Features List -->
        {features.length > 0 && (
          <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
            {features.map((feature, index) => (
              <div class="flex items-center text-gray-600">
                <svg class="w-5 h-5 mr-2 text-[#0a91b1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span id={`content-feature-${index}`}>{feature}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Trust Badge -->
      {trustBadge && (
        <div class="mt-8 text-center text-gray-500 text-sm">
          <div class="flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-[#0a91b1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={trustBadge.icon || "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"}/>
            </svg>
            <span id="content-trustBadgeText">{trustBadge.text}</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>