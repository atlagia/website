---
import { SITE_TITLE } from '../consts';
import pkg from 'lucide-react';
const { Mail, Phone, MapPin, Clock, Calendar, Stethoscope } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific contact data
const contactData = await import(`../data/contact/contact_${lang}.json`);

// Import styles
const styles = await import(`../style/page/contactpage.json`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'info@dentcare.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+1 (555) 123-4567',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || '123 Dental Avenue, Suite 200',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'New York',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'United States'
  }
};

// Define icon paths for each icon type
const iconPaths = {
  Mail: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>`,
  Phone: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>`,
  MapPin: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>`
};

// Map contact info with icon paths
const contactInfo = contactData.contactInfo.map(item => {
  const iconPath = iconPaths[item.icon] || '';
  return {
    ...item,
    iconPath
  };
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Contact Us | ${businessInfo.name}`}
      description={contactData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <span class={styles.hero.subtitle}>
            {contactData.hero.subtitle}
          </span>
          <h1 class={styles.hero.title}>{contactData.hero.title}</h1>
          <p class={styles.hero.description}>
            {contactData.hero.description}
          </p>
        </div>
      </section>

      <!-- Contact Options -->
      <section class={styles.contactOptions.section}>
        <div class={styles.contactOptions.container}>
          <div class={styles.contactOptions.grid}>
            {contactInfo.map(item => (
              <a
                href={item.link}
                class={styles.contactOptions.card}
              >
                <div class={styles.contactOptions.cardContent}>
                  <div class={styles.contactOptions.iconContainer}>
                    <svg 
                      class={styles.contactOptions.icon} 
                      fill="none" 
                      viewBox="0 0 24 24" 
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={item.iconPath}
                    />
                  </div>
                  <h3 class={styles.contactOptions.title}>{item.title}</h3>
                  <p class={styles.contactOptions.description}>{item.description}</p>
                  <p class={styles.contactOptions.content}>{item.content}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Contact Form Section -->
      <section class={styles.contactForm.section}>
        <div class={styles.contactForm.container}>
          <div class={styles.contactForm.grid}>
            <!-- Left: Form -->
            <div class={styles.contactForm.formContainer}>
              <h2 class={styles.contactForm.formTitle}>{contactData.form.title}</h2>
              <form class={styles.contactForm.form}>
                <div class={styles.contactForm.formRow}>
                  <div>
                    <label for="first-name" class={styles.contactForm.formGroup.label}>
                      {contactData.form.fields.firstName.label}
                    </label>
                    <input
                      type="text"
                      id="first-name"
                      name="first-name"
                      placeholder={contactData.form.fields.firstName.placeholder}
                      required
                      class={styles.contactForm.formGroup.input}
                    />
                  </div>
                  <div>
                    <label for="last-name" class={styles.contactForm.formGroup.label}>
                      {contactData.form.fields.lastName.label}
                    </label>
                    <input
                      type="text"
                      id="last-name"
                      name="last-name"
                      placeholder={contactData.form.fields.lastName.placeholder}
                      required
                      class={styles.contactForm.formGroup.input}
                    />
                  </div>
                </div>
                <div>
                  <label for="email" class={styles.contactForm.formGroup.label}>
                    {contactData.form.fields.email.label}
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder={contactData.form.fields.email.placeholder}
                    required
                    class={styles.contactForm.formGroup.input}
                  />
                </div>
                <div>
                  <label for="subject" class={styles.contactForm.formGroup.label}>
                    {contactData.form.fields.subject.label}
                  </label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    placeholder={contactData.form.fields.subject.placeholder}
                    required
                    class={styles.contactForm.formGroup.input}
                  />
                </div>
                <div>
                  <label for="message" class={styles.contactForm.formGroup.label}>
                    {contactData.form.fields.message.label}
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="6"
                    placeholder={contactData.form.fields.message.placeholder}
                    required
                    class={styles.contactForm.formGroup.textarea}
                  ></textarea>
                </div>
                <button
                  type="submit"
                  class={styles.contactForm.submitButton}
                >
                  {contactData.form.submitButton}
                </button>
              </form>
            </div>

            <!-- Right: Map & Info -->
            <div class={styles.mapInfo.container}>
              <div class={styles.mapInfo.map}>
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.215256264718!2d-73.98784492346177!3d40.75097623440235!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c259a9aeb1c6b5%3A0x35b1cfbc89a6097f!2s123%20W%2034th%20St%2C%20New%20York%2C%20NY%2010001!5e0!3m2!1sen!2sus!4v1647433829401!5m2!1sen!2sus"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                ></iframe>
              </div>
              
              <!-- Clinic Hours -->
              <div class={styles.mapInfo.hoursCard}>
                <div class={styles.mapInfo.hoursHeader}>
                  <div class={styles.mapInfo.hoursIconContainer}>
                    <svg class={styles.mapInfo.hoursIcon} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                  </div>
                  <h3 class={styles.mapInfo.hoursTitle}>{contactData.support.hours.title}</h3>
                </div>
                <div class={styles.mapInfo.hoursContent}>
                  <p>{contactData.support.hours.content}</p>
                </div>
              </div>
              
              <!-- Emergency Contact -->
              <div class={styles.mapInfo.emergencyCard}>
                <div class={styles.mapInfo.emergencyHeader}>
                  <div class={styles.mapInfo.emergencyIconContainer}>
                    <svg class={styles.mapInfo.emergencyIcon} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15.58 12a4.008 4.008 0 0 0-7.16 0"></path>
                      <path d="M12 4v4"></path>
                      <path d="M9 12H4"></path>
                      <path d="M12 20v-4"></path>
                      <path d="M20 12h-5"></path>
                    </svg>
                  </div>
                  <h3 class={styles.mapInfo.emergencyTitle}>{contactData.support.additional.title}</h3>
                </div>
                <div class={styles.mapInfo.emergencyContent}>
                  <p class={styles.mapInfo.emergencyDescription}>{contactData.support.additional.description}</p>
                  <a href={`tel:${contactData.support.additional.email}`} class={styles.mapInfo.emergencyContact}>
                    {contactData.support.additional.email}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style define:vars={{ 
  blobAnimation: styles.animations.blob 
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
  
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style>