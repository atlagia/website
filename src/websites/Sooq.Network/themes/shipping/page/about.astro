---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific about data
const aboutData = await import(`../data/about/about_${lang}.json`);

// Import styles
const styles = await import(`../style/page/aboutpage.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Map features with icon components
const features = aboutData.welcome.features.map(feature => {
  return {
    ...feature,
    IconComponent: LucideIcons[feature.icon] || LucideIcons.Globe
  };
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`About Us | ${businessInfo.name}`}
      description={aboutData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <span class={styles.hero.subtitle}>
            {aboutData.hero.subtitle}
          </span>
          <h1 class={styles.hero.title}>
            {aboutData.hero.title}
          </h1>
          <p class={styles.hero.description}>
            {aboutData.hero.description}
          </p>
        </div>
      </section>

      <!-- Welcome Section -->
      <section class={styles.welcome.section}>
        <div class={styles.welcome.container}>
          <div class={styles.welcome.grid}>
            <div>
              <span class={styles.welcome.subtitle}>
                {aboutData.welcome.subtitle}
              </span>
              <h2 class={styles.welcome.title}>
                {aboutData.welcome.title}
              </h2>
              <p class={styles.welcome.description}>
                {aboutData.welcome.description}
              </p>
              <div class={styles.welcome.featuresContainer}>
                {features.map(feature => (
                  <div class={styles.welcome.feature.container}>
                    <div class={styles.welcome.feature.iconContainer}>
                      <feature.IconComponent class={styles.welcome.feature.icon} />
                    </div>
                    <div>
                      <h3 class={styles.welcome.feature.content.title}>{feature.title}</h3>
                      <p class={styles.welcome.feature.content.description}>{feature.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class={styles.welcome.imageContainer}>
              <div class={styles.welcome.imageBlob1}></div>
              <div class={styles.welcome.imageBlob2}></div>
              <div class={styles.welcome.image}>
                <LucideIcons.Package2 width="100%" height="100%" strokeWidth={1.5} />
              </div>
              <div class={styles.welcome.experienceBadge}>
                <div class={styles.welcome.experienceNumber}>15+</div>
                <div class={styles.welcome.experienceText}>Years Experience</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Certifications Section -->
      <section class={styles.certifications.section}>
        <div class={styles.certifications.container}>
          <div class={styles.certifications.logoContainer}>
            {aboutData.certifications.map(cert => (
              <div class={styles.certifications.logo}>
                <LucideIcons.Award class="w-full h-full" strokeWidth={1.5} />
                <span class="text-sm font-medium mt-2">{cert.name}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Our Team Section -->
      <section class={styles.team.section}>
        <div class={styles.team.container}>
          <div class={styles.team.grid}>
            <div class={styles.team.imageContainer}>
              <div class={styles.team.imageBlob}></div>
              <div class={styles.team.image}>
                <LucideIcons.Users width="100%" height="100%" strokeWidth={1.5} />
              </div>
            </div>
            <div class={styles.team.contentContainer}>
              <span class={styles.team.subtitle}>
                {aboutData.team.subtitle}
              </span>
              <h2 class={styles.team.title}>
                {aboutData.team.title}
              </h2>
              <p class={styles.team.description}>
                {aboutData.team.description}
              </p>
              <div class={styles.team.statsGrid}>
                {aboutData.team.stats.map(stat => (
                  <div>
                    <div class={styles.team.statNumber}>{stat.number}</div>
                    <div class={styles.team.statTitle}>{stat.title}</div>
                  </div>
                ))}
              </div>
              <a 
                href={aboutData.team.cta.link}
                class={styles.team.cta}
              >
                {aboutData.team.cta.text}
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Testimonials -->
      <section class={styles.testimonials.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.testimonials.blob1}></div>
          <div class={styles.testimonials.blob2}></div>
        </div>
        <div class={styles.testimonials.container}>
          <div class={styles.testimonials.header}>
            <span class={styles.testimonials.subtitle}>
              CLIENT TESTIMONIALS
            </span>
            <h2 class={styles.testimonials.title}>
              {aboutData.testimonials.title}
            </h2>
            <p class={styles.testimonials.description}>
              {aboutData.testimonials.description}
            </p>
          </div>
          <div class={styles.testimonials.grid}>
            {aboutData.testimonials.items.map(testimonial => (
              <div class={styles.testimonials.testimonialCard}>
                <p class={styles.testimonials.testimonialContent}>"{testimonial.content}"</p>
                <div class={styles.testimonials.testimonialAuthor}>
                  <div class={styles.testimonials.authorImage}>
                    <LucideIcons.User strokeWidth={1.5} />
                  </div>
                  <div>
                    <div class={styles.testimonials.authorName}>{testimonial.name}</div>
                    <div class={styles.testimonials.authorPosition}>{testimonial.position}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class={styles.testimonials.ctaContainer}>
            <a
              href={aboutData.testimonials.cta.link}
              class={styles.testimonials.cta}
            >
              {aboutData.testimonials.cta.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style define:vars={{ 
  blobAnimation: styles.animations.blob 
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
</style>