---
import { SITE_TITLE } from '../consts';
import pkg from 'lucide-react';
const { Shield, Lock, FileCheck, Server, Eye, UserCheck, Database, Bell } = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import styles - reusing the contactpage styles as a base
const styles = await import(`../style/page/contactpage.json`);

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Global Shipping Solutions',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'support@sooq.network',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+1 (855) 256-4478',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || '5301A Rivergrade Rd.',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Irwindale',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'CA 91706'
  },
  website: import.meta.env.PUBLIC_BUSINESS_WEBSITE || 'www.sooq.network'
};

// Define last updated date
const lastUpdated = "June 15, 2024";

// Define icon paths for each icon type
const iconPaths = {
  Shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>`,
  Lock: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>`,
  FileCheck: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="m9 15 2 2 4-4"></path>`,
  Server: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line>`,
  Eye: `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>`,
  UserCheck: `<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline>`,
  Database: `<ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>`,
  Bell: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path>`
};

// Privacy policy sections
const privacySections = [
  {
    icon: "Shield",
    title: "Data Protection",
    description: "How we safeguard your personal information",
    iconPath: iconPaths.Shield
  },
  {
    icon: "Lock",
    title: "Information Security",
    description: "Measures we take to keep your data secure",
    iconPath: iconPaths.Lock
  },
  {
    icon: "FileCheck",
    title: "Data Collection",
    description: "Types of information we collect and process",
    iconPath: iconPaths.FileCheck
  },
  {
    icon: "Server",
    title: "Data Storage",
    description: "How and where your information is stored",
    iconPath: iconPaths.Server
  },
  {
    icon: "Eye",
    title: "Information Usage",
    description: "How we use your personal information",
    iconPath: iconPaths.Eye
  },
  {
    icon: "UserCheck",
    title: "Your Rights",
    description: "Your rights regarding your personal data",
    iconPath: iconPaths.UserCheck
  },
  {
    icon: "Database",
    title: "Third-Party Sharing",
    description: "When and how we share your information",
    iconPath: iconPaths.Database
  },
  {
    icon: "Bell",
    title: "Communication Preferences",
    description: "Managing notifications and communications",
    iconPath: iconPaths.Bell
  }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Privacy Policy | ${businessInfo.name}`}
      description="Our commitment to protecting your privacy and securing your personal information."
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class={styles.hero.section}>
        <div class="absolute inset-0 z-0">
          <div class={styles.hero.blob1}></div>
          <div class={styles.hero.blob2}></div>
        </div>
        <div class={styles.hero.container}>
          <span class={styles.hero.subtitle}>
            PRIVACY
          </span>
          <h1 class={styles.hero.title}>Privacy Policy</h1>
          <p class={styles.hero.description}>
            At {businessInfo.name}, we value your privacy and are committed to protecting your personal information. This Privacy Policy outlines how we collect, use, and safeguard your data.
          </p>
          <p class="text-sm mt-4 text-gray-600">Last Updated: {lastUpdated}</p>
        </div>
      </section>

      <!-- Privacy Sections Overview -->
      <section class={styles.contactOptions.section}>
        <div class={styles.contactOptions.container}>
          <div class={styles.contactOptions.grid}>
            {privacySections.map(item => (
              <a
                href={`#${item.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
                class={styles.contactOptions.card}
              >
                <div class={styles.contactOptions.cardContent}>
                  <div class={styles.contactOptions.iconContainer}>
                    <svg 
                      class={styles.contactOptions.icon} 
                      fill="none" 
                      viewBox="0 0 24 24" 
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={item.iconPath}
                    />
                  </div>
                  <h3 class={styles.contactOptions.title}>{item.title}</h3>
                  <p class={styles.contactOptions.description}>{item.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Privacy Content -->
      <section class="py-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Introduction -->
          <div class="prose max-w-none">
            <h2>Introduction</h2>
            <p>
              This Privacy Policy describes how {businessInfo.name} ("we," "us," or "our") collects, uses, and shares your personal information when you use our website, mobile applications, and shipping services (collectively, the "Services"). We respect your privacy and are committed to protecting your personal information.
            </p>
            <p>
              By accessing or using our Services, you agree to the terms of this Privacy Policy. If you do not agree with our policies and practices, please do not use our Services.
            </p>
          </div>

          <!-- Data Protection Section -->
          <div id="data-protection" class="mt-12 prose max-w-none">
            <h2>1. Data Protection</h2>
            <p>
              We implement appropriate technical and organizational measures to protect your personal information from unauthorized access, disclosure, alteration, and destruction. These measures include:
            </p>
            <ul>
              <li>Encryption of sensitive data using industry-standard protocols</li>
              <li>Regular security audits and vulnerability assessments</li>
              <li>Access controls restricting employee access to personal data</li>
              <li>Physical security measures at our facilities</li>
              <li>Employee training on data protection and privacy practices</li>
            </ul>
            <p>
              While we strive to use commercially acceptable means to protect your personal information, no method of transmission over the internet or electronic storage is 100% secure, and we cannot guarantee absolute security.
            </p>
          </div>

          <!-- Information Security Section -->
          <div id="information-security" class="mt-12 prose max-w-none">
            <h2>2. Information Security</h2>
            <p>
              We take information security seriously and implement various measures to protect your data:
            </p>
            <h3>2.1 Data Encryption</h3>
            <p>
              We use industry-standard SSL (Secure Socket Layer) encryption to protect data transmission between your device and our servers. Sensitive information such as payment details and personal identification is encrypted during transmission and storage.
            </p>
            
            <h3>2.2 Secure Infrastructure</h3>
            <p>
              Our systems are hosted in secure data centers with multiple layers of physical and network security. We regularly update our systems and applications to address security vulnerabilities.
            </p>
            
            <h3>2.3 Security Monitoring</h3>
            <p>
              We employ continuous security monitoring to detect and respond to potential security incidents. We maintain security incident response procedures to address any suspected or actual breaches of security.
            </p>
          </div>

          <!-- Data Collection Section -->
          <div id="data-collection" class="mt-12 prose max-w-none">
            <h2>3. Data Collection</h2>
            <p>
              We collect several types of information from and about users of our Services:
            </p>
            
            <h3>3.1 Personal Information</h3>
            <p>
              When you use our Services, we may collect the following personal information:
            </p>
            <ul>
              <li>Contact information (name, email address, phone number, postal address)</li>
              <li>Account credentials (username, password)</li>
              <li>Payment information (credit card details, billing address)</li>
              <li>Shipping information (recipient names, addresses, contact details)</li>
              <li>Identity verification documents (when required for certain shipments)</li>
              <li>Business information (for business accounts)</li>
            </ul>
            
            <h3>3.2 Usage Information</h3>
            <p>
              We also collect information about how you use our Services:
            </p>
            <ul>
              <li>Log data (IP address, browser type, operating system, referring pages)</li>
              <li>Device information (hardware model, operating system, unique device identifiers)</li>
              <li>Location data (when you enable location services)</li>
              <li>Tracking information (shipment history, tracking events)</li>
              <li>Service usage metrics (features used, time spent)</li>
            </ul>
            
            <h3>3.3 Collection Methods</h3>
            <p>
              We collect information through:
            </p>
            <ul>
              <li>Direct interactions (when you provide information through forms)</li>
              <li>Automated technologies (cookies, web beacons, tracking technologies)</li>
              <li>Third parties (business partners, carriers, service providers)</li>
            </ul>
          </div>

          <!-- Data Storage Section -->
          <div id="data-storage" class="mt-12 prose max-w-none">
            <h2>4. Data Storage</h2>
            <p>
              We store your personal information securely and retain it only as long as necessary for the purposes for which it was collected.
            </p>
            
            <h3>4.1 Data Retention</h3>
            <p>
              We retain your personal information for as long as necessary to:
            </p>
            <ul>
              <li>Provide the Services you have requested</li>
              <li>Comply with legal and regulatory requirements</li>
              <li>Resolve disputes and enforce our agreements</li>
              <li>Protect against fraudulent or illegal activity</li>
            </ul>
            <p>
              Different types of information may be retained for different periods based on their purpose and applicable laws.
            </p>
            
            <h3>4.2 Storage Locations</h3>
            <p>
              Your information may be stored and processed in the United States and other countries where we or our service providers operate. By using our Services, you consent to the transfer of your information to countries outside your country of residence, which may have different data protection rules.
            </p>
          </div>

          <!-- Information Usage Section -->
          <div id="information-usage" class="mt-12 prose max-w-none">
            <h2>5. Information Usage</h2>
            <p>
              We use the information we collect for various purposes:
            </p>
            
            <h3>5.1 Service Provision</h3>
            <p>
              We use your information to:
            </p>
            <ul>
              <li>Provide and maintain our Services</li>
              <li>Process and complete shipping transactions</li>
              <li>Authenticate users and verify identities</li>
              <li>Provide customer support and respond to inquiries</li>
              <li>Communicate with you about your shipments</li>
              <li>Generate shipping labels and customs documentation</li>
            </ul>
            
            <h3>5.2 Service Improvement</h3>
            <p>
              We also use your information to:
            </p>
            <ul>
              <li>Improve and optimize our Services</li>
              <li>Develop new features and functionality</li>
              <li>Understand user preferences and behaviors</li>
              <li>Monitor and analyze usage patterns and trends</li>
              <li>Test and troubleshoot new features</li>
            </ul>
            
            <h3>5.3 Marketing and Communications</h3>
            <p>
              With your consent, we may use your information to:
            </p>
            <ul>
              <li>Send promotional communications about our products and services</li>
              <li>Provide news and updates about our Services</li>
              <li>Deliver relevant advertising based on your preferences</li>
              <li>Offer special promotions and opportunities</li>
            </ul>
            <p>
              You can opt out of marketing communications at any time by following the unsubscribe instructions in our emails or contacting us directly.
            </p>
          </div>

          <!-- Your Rights Section -->
          <div id="your-rights" class="mt-12 prose max-w-none">
            <h2>6. Your Rights</h2>
            <p>
              Depending on your location, you may have certain rights regarding your personal information:
            </p>
            
            <h3>6.1 Access and Correction</h3>
            <p>
              You have the right to access the personal information we hold about you and to request that we correct any inaccurate information. You can access and update many details through your account settings or by contacting our customer service.
            </p>
            
            <h3>6.2 Data Portability</h3>
            <p>
              In certain circumstances, you may request a copy of your personal information in a structured, commonly used, and machine-readable format, and have it transferred to another service provider.
            </p>
            
            <h3>6.3 Deletion</h3>
            <p>
              You may request that we delete your personal information. We will comply with such requests unless we are legally obligated to retain certain information or need it to complete transactions or protect our legal rights.
            </p>
            
            <h3>6.4 Objection and Restriction</h3>
            <p>
              You may object to our processing of your personal information or request that we restrict processing in certain circumstances. This includes objecting to marketing communications or automated decision-making.
            </p>
            
            <h3>6.5 Exercising Your Rights</h3>
            <p>
              To exercise any of these rights, please contact us at {businessInfo.email}. We may need to verify your identity before fulfilling your request, and we will respond within the timeframes required by applicable law.
            </p>
          </div>

          <!-- Third-Party Sharing Section -->
          <div id="third-party-sharing" class="mt-12 prose max-w-none">
            <h2>7. Third-Party Sharing</h2>
            <p>
              We may share your personal information with third parties in certain circumstances:
            </p>
            
            <h3>7.1 Service Providers</h3>
            <p>
              We share information with service providers who perform services on our behalf, such as:
            </p>
            <ul>
              <li>Shipping carriers and logistics partners</li>
              <li>Payment processors</li>
              <li>Customer support services</li>
              <li>Cloud storage providers</li>
              <li>Analytics providers</li>
              <li>Email and communication services</li>
            </ul>
            <p>
              These service providers are contractually obligated to protect your information and may only use it for the specific services they provide to us.
            </p>
            
            <h3>7.2 Legal Requirements</h3>
            <p>
              We may disclose your information when required by law, such as:
            </p>
            <ul>
              <li>In response to a court order, subpoena, or similar legal process</li>
              <li>To comply with customs and import/export regulations</li>
              <li>To protect against fraud, illegal activity, or threats to public safety</li>
              <li>To enforce our terms of service or other agreements</li>
            </ul>
            
            <h3>7.3 Business Transfers</h3>
            <p>
              If we are involved in a merger, acquisition, or sale of all or a portion of our assets, your information may be transferred as part of that transaction. We will notify you of any change in ownership or uses of your personal information.
            </p>
            
            <h3>7.4 With Your Consent</h3>
            <p>
              We may share your information with third parties when you have given us your consent to do so. For example, if you choose to integrate our Services with third-party applications or platforms.
            </p>
          </div>

          <!-- Communication Preferences Section -->
          <div id="communication-preferences" class="mt-12 prose max-w-none">
            <h2>8. Communication Preferences</h2>
            <p>
              We respect your preferences regarding communications from us:
            </p>
            
            <h3>8.1 Email Communications</h3>
            <p>
              You can opt out of marketing emails by clicking the "unsubscribe" link at the bottom of our emails or by updating your communication preferences in your account settings. Please note that even if you opt out of marketing communications, we will still send you transactional emails related to your shipments and account.
            </p>
            
            <h3>8.2 Push Notifications</h3>
            <p>
              If you use our mobile applications, you can manage push notifications through your device settings. You can choose to receive notifications about shipment updates, promotions, and other information.
            </p>
            
            <h3>8.3 Text Messages</h3>
            <p>
              If you have opted in to receive text messages from us, you can opt out by replying "STOP" to any message or by contacting our customer service.
            </p>
          </div>

          <!-- Cookies and Tracking Section -->
          <div id="cookies-and-tracking" class="mt-12 prose max-w-none">
            <h2>9. Cookies and Tracking Technologies</h2>
            <p>
              We use cookies and similar tracking technologies to enhance your experience with our Services:
            </p>
            
            <h3>9.1 Cookies</h3>
            <p>
              Cookies are small text files that are stored on your device when you visit our website. We use cookies to:
            </p>
            <ul>
              <li>Remember your login status and preferences</li>
              <li>Understand how you use our Services</li>
              <li>Personalize your experience</li>
              <li>Improve our website and offerings</li>
              <li>Measure the effectiveness of our marketing campaigns</li>
            </ul>
            <p>
              You can manage cookie preferences through your browser settings. However, disabling certain cookies may limit your ability to use some features of our Services.
            </p>
            
            <h3>9.2 Analytics</h3>
            <p>
              We use analytics services, such as Google Analytics, to collect information about how users interact with our Services. These services use cookies and similar technologies to gather information about your use of our website and applications.
            </p>
            
            <h3>9.3 Do Not Track</h3>
            <p>
              Some browsers offer a "Do Not Track" feature that signals to websites that you do not want your online activities tracked. We currently do not respond to "Do Not Track" signals because there is no common industry standard for how to interpret these signals.
            </p>
          </div>

          <!-- Children's Privacy Section -->
          <div id="childrens-privacy" class="mt-12 prose max-w-none">
            <h2>10. Children's Privacy</h2>
            <p>
              Our Services are not directed to children under 18 years of age, and we do not knowingly collect personal information from children under 18. If you are a parent or guardian and believe that your child has provided us with personal information, please contact us at {businessInfo.email}, and we will take steps to delete such information.
            </p>
          </div>

          <!-- Changes to Privacy Policy Section -->
          <div id="changes-to-privacy-policy" class="mt-12 prose max-w-none">
            <h2>11. Changes to Privacy Policy</h2>
            <p>
              We may update this Privacy Policy from time to time to reflect changes in our practices or for other operational, legal, or regulatory reasons. When we make changes, we will update the "Last Updated" date at the top of this Privacy Policy and notify you as required by applicable law. Your continued use of our Services after any such changes constitutes your acceptance of the revised Privacy Policy.
            </p>
            <p>
              We encourage you to review this Privacy Policy periodically to stay informed about our information practices.
            </p>
          </div>

          <!-- Contact Information Section -->
          <div id="contact-information" class="mt-12 prose max-w-none">
            <h2>12. Contact Information</h2>
            <p>
              If you have any questions about this Privacy Policy, please contact us at:
            </p>
            <p>
              {businessInfo.name}<br>
              {businessInfo.address.street}<br>
              {businessInfo.address.city}, {businessInfo.address.country}<br>
              Email: {businessInfo.email}<br>
              Phone: {businessInfo.phone}<br>
              Website: {businessInfo.website}
            </p>
          </div>
          
          <!-- Conclusion -->
          <div class="mt-16 border-t border-gray-200 pt-8">
            <p class="text-gray-600 text-sm text-center">
              By using our Services, you acknowledge that you have read, understood, and agree to this Privacy Policy.
            </p>
            <p class="text-gray-500 text-xs text-center mt-4">
              Last Updated: {lastUpdated}
            </p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style define:vars={{ 
  blobAnimation: styles.animations.blob 
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }

  /* Prose customizations */
  .prose h2 {
    color: #0891b2;
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }
</style> 