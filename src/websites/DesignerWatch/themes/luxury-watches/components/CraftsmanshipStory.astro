---
interface Props {
  title: string;
  body: string;
  image?: string;
  imageAlt?: string;
  lang?: string;
}

const { title = 'Precision engineering meets timeless elegance.', body = 'Every timepiece is crafted with the same dedication to excellence that defines the world\'s most iconic watch houses. From macro watch details to mechanical components and luxury materials, discover the art behind each design.', image, imageAlt = 'Craftsmanship', lang = 'en' } = Astro.props;
---

<section class="bg-[var(--dw-bg)] py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div class="order-2 lg:order-1">
        <p class="font-body text-xs tracking-[0.4em] uppercase text-[var(--dw-accent)] mb-4">Craftsmanship</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--dw-text)] tracking-tight mb-8">{title}</h2>
        <div class="font-body text-[var(--dw-muted)] leading-relaxed space-y-4">
          {body.split('\n').map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
      <div class="order-1 lg:order-2 relative aspect-[4/5] lg:aspect-square overflow-hidden bg-[var(--dw-surface)] border border-[var(--dw-border)]">
        {image ? (
          <img src={image} alt={imageAlt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center text-[var(--dw-muted)] font-display text-2xl">◆</div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
