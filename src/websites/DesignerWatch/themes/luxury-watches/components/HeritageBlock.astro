---
interface Props {
  eyebrow?: string;
  headline: string;
  body: string;
  ctaText?: string;
  ctaLink?: string;
  image?: string;
  imageAlt?: string;
  imagePosition?: 'left' | 'right';
  year?: string;
  lang?: string;
}

const {
  eyebrow = 'Our Story',
  headline,
  body,
  ctaText = 'Learn more',
  ctaLink = '/about',
  image,
  imageAlt = 'Heritage',
  imagePosition = 'left',
  year,
  lang = 'en'
} = Astro.props;
const base = lang ? `/${lang}` : '';
---

<section class="bg-[var(--dw-bg)] py-24 lg:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center ${imagePosition === 'right' ? '' : ''}`}>
      <div class={imagePosition === 'right' ? 'lg:order-2' : 'lg:order-1'}>
        {image ? (
          <div class="relative aspect-[4/5] overflow-hidden rounded-2xl border border-[var(--dw-border)] bg-[var(--dw-surface)]">
            <img src={image} alt={imageAlt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
        ) : (
          <div class="aspect-[4/5] rounded-2xl border border-[var(--dw-border)] bg-[var(--dw-surface)] flex items-center justify-center">
            <span class="font-display text-6xl text-[var(--dw-border)]">◆</span>
          </div>
        )}
      </div>
      <div class={imagePosition === 'right' ? 'lg:order-1' : 'lg:order-2'}>
        {eyebrow && (
          <p class="font-body text-xs tracking-[0.4em] uppercase text-[var(--dw-accent)] mb-4">{eyebrow}</p>
        )}
        {year && (
          <p class="font-display text-5xl md:text-6xl text-[var(--dw-accent)]/80 tracking-tight mb-6">{year}</p>
        )}
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold text-[var(--dw-text)] tracking-tight mb-8">
          {headline}
        </h2>
        <div class="font-body text-[var(--dw-muted)] leading-relaxed space-y-5 text-lg mb-10">
          {body.split('\n').filter(Boolean).map((paragraph) => <p>{paragraph}</p>)}
        </div>
        {ctaText && ctaLink && (
          <a
            href={base + ctaLink}
            class="inline-flex items-center gap-2 font-body text-sm font-medium tracking-[0.2em] uppercase text-[var(--dw-accent)] hover:text-[var(--dw-text)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--dw-accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--dw-bg)]"
          >
            {ctaText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
