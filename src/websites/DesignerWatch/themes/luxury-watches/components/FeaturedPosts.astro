---
interface Post {
  title: string;
  excerpt?: string;
  link: string;
  image?: string;
}

interface Props {
  title: string;
  posts: Post[];
  lang?: string;
}

const { title = 'Editorial Journal', posts = [], lang = 'en' } = Astro.props;

const defaultPosts = [
  { title: 'History of luxury watchmaking', link: '/blog', excerpt: 'Explore the heritage of fine timepieces.' },
  { title: 'How to choose a luxury watch', link: '/blog', excerpt: 'A guide to finding your perfect timepiece.' },
  { title: 'Watch styling guide', link: '/blog', excerpt: 'Pair your watch with confidence.' },
];
const displayPosts = posts.length > 0 ? posts : defaultPosts;
---

<section class="bg-[var(--dw-bg)] py-24 lg:py-32 border-t border-[var(--dw-border)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-16">
      <p class="font-body text-xs tracking-[0.4em] uppercase text-[var(--dw-accent)] mb-3">Journal</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-[var(--dw-text)] tracking-tight">{title}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {displayPosts.map((post) => (
        <a href={`/${lang}${post.link}`} class="group block">
          <div class="aspect-[4/5] overflow-hidden bg-[var(--dw-surface)] border border-[var(--dw-border)] mb-4">
            {post.image ? <img src={post.image} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /> : <div class="w-full h-full flex items-center justify-center text-[var(--dw-muted)] font-display text-4xl">◆</div>}
          </div>
          <h3 class="font-display text-xl text-[var(--dw-text)] group-hover:text-[var(--dw-accent)] transition-colors mb-2">{post.title}</h3>
          {post.excerpt && <p class="font-body text-sm text-[var(--dw-muted)]">{post.excerpt}</p>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
