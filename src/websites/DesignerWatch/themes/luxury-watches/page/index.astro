---
/**
 * DesignerWatch — luxury watch boutique homepage.
 */
import { useTranslations, isValidLanguage } from '@utils/i18n';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);
const { default: Welcome } = await import(`../components/Welcome.astro`);
const { default: EmailSignup } = await import(`../components/EmailSignup.astro`);
const { default: CategoryGrid } = await import(`../components/CategoryGrid.astro`);
const { default: BestSellers } = await import(`../components/BestSellers.astro`);
const { default: CraftsmanshipStory } = await import(`../components/CraftsmanshipStory.astro`);
const { default: Banner } = await import(`../components/Banner.astro`);
const { default: ProductShowcase } = await import(`../components/ProductShowcase.astro`);
const { default: TrustBadges } = await import(`../components/TrustBadges.astro`);
const { default: FeaturedPosts } = await import(`../components/FeaturedPosts.astro`);
const { default: TestimonialSlider } = await import(`../components/TestimonialSlider.astro`);
const { default: StatsBar } = await import(`../components/StatsBar.astro`);
const { default: HeritageBlock } = await import(`../components/HeritageBlock.astro`);
const { default: FeaturedHighlight } = await import(`../components/FeaturedHighlight.astro`);
const { default: ValuesStrip } = await import(`../components/ValuesStrip.astro`);
const { default: DividerBlock } = await import(`../components/DividerBlock.astro`);
const { default: CraftsmanshipVideo } = await import(`../components/CraftsmanshipVideo.astro`);

const lang = Astro.props.lang ?? Astro.params?.lang ?? 'en';

if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = jsonData.siteTitle || 'DesignerWatch';
const SITE_DESCRIPTION = jsonData.siteDescription || 'Mastery of Time.';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map((l: string) => l.trim()).filter((l: string) => l.length > 0);
  return languages.map((l: string) => ({ params: { lang: l } }));
}
---

<!doctype html>
<html lang={lang} class="designerwatch">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[var(--dw-bg)] text-[var(--dw-text)]">
    <Header />
    <main>
      {jsonData.sections?.map((section) => (
        <>
          {section.type === 'welcomeSection' && (
            <Welcome
              headlineLine1={section.headlineLine1}
              headlineLine2={section.headlineLine2}
              description={section.description}
              primaryCtaText={section.primaryCtaText}
              primaryCtaLink={section.primaryCtaLink || '/collections'}
              secondaryCtaText={section.secondaryCtaText}
              secondaryCtaLink={section.secondaryCtaLink || '/about'}
              heroImage={section.heroImage}
              backgroundVideo={section.backgroundVideo}
            />
          )}
          {section.type === 'categoryGrid' && <CategoryGrid title={section.title} description={section.description} categories={section.categories || []} lang={lang} />}
          {section.type === 'bestSellers' && <BestSellers title={section.title} description={section.description} viewAllLink={section.viewAllLink || '/collections'} lang={lang} collectionHandle={section.collectionHandle} />}
          {section.type === 'craftsmanshipStory' && <CraftsmanshipStory title={section.title} body={section.body || ''} image={section.image} lang={lang} />}
          {section.type === 'bannerSection' && <Banner headline={section.headline} subtext={section.description} ctaText={section.ctaText} ctaLink={section.ctaLink} backgroundImage={section.backgroundImage} lang={lang} />}
          {section.type === 'productShowcase' && <ProductShowcase title={section.title} description={section.description} viewAllLink={section.viewAllLink || '/collections'} lang={lang} collectionHandle={section.collectionHandle} />}
          {section.type === 'trustBadges' && <TrustBadges title={section.title} items={section.items || []} />}
          {section.type === 'featuredPosts' && <FeaturedPosts title={section.title} posts={section.posts || []} lang={lang} />}
          {section.type === 'testimonialSlider' && <TestimonialSlider title={section.title} testimonials={section.testimonials || []} />}
          {section.type === 'statsBar' && <StatsBar stats={section.stats || []} />}
          {section.type === 'heritageBlock' && (
            <HeritageBlock
              eyebrow={section.eyebrow}
              headline={section.headline}
              body={section.body}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
              image={section.image}
              imageAlt={section.imageAlt}
              imagePosition={section.imagePosition || 'left'}
              year={section.year}
              lang={lang}
            />
          )}
          {section.type === 'featuredHighlight' && (
            <FeaturedHighlight
              title={section.title}
              description={section.description}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
              backgroundImage={section.backgroundImage}
              imageAlt={section.imageAlt}
              lang={lang}
            />
          )}
          {section.type === 'valuesStrip' && <ValuesStrip title={section.title} items={section.items || []} />}
          {section.type === 'dividerBlock' && (
            <DividerBlock quote={section.quote} optionalSubtext={section.optionalSubtext} />
          )}
          {section.type === 'craftsmanshipVideo' && (
            <CraftsmanshipVideo
              eyebrow={section.eyebrow}
              headline={section.headline}
              description={section.description}
              backgroundImage={section.backgroundImage}
              imageAlt={section.imageAlt}
              features={section.features || []}
              lang={lang}
            />
          )}
          {section.type === 'emailSignupSection' && (
            <EmailSignup
              title={section.title}
              description={section.description}
              backgroundImage={section.backgroundImage || ''}
              formAction={section.formAction || '/api/newsletter'}
              buttonText={section.submitText || 'Subscribe'}
            />
          )}
        </>
      ))}
    </main>
    <Footer />
  </body>
</html>
