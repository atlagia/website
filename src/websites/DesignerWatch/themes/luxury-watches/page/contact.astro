---
import Layoutc from '@layouts/Layoutc.astro';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map((l: string) => l.trim()).filter((l: string) => l.length > 0);
  return languages.map((l: string) => ({ params: { lang: l } }));
}

const { lang = 'en' } = Astro.props;
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'DesignerWatch';
const seoTitle = `Contact | ${storeName}`;
const seoDescription = 'Get in touch with DesignerWatch.';
const email = import.meta.env.PUBLIC_BUSINESS_EMAIL || 'contact@designerwatch.com';
const phone = import.meta.env.PUBLIC_BUSINESS_PHONE || '+1 234 567 8900';
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--dw-bg)]">
    <section class="max-w-4xl mx-auto px-4 sm:px-6 py-20">
      <h1 class="text-4xl md:text-5xl font-light tracking-wide text-[var(--dw-text)] font-display mb-6">Contact</h1>
      <p class="text-xl text-[var(--dw-muted)] max-w-2xl mb-12">Reach out for orders, support, or inquiries.</p>
      <div class="grid gap-6 sm:grid-cols-2">
        <a href={`mailto:${email}`} class="block p-6 rounded-xl bg-[var(--dw-surface)] border border-[var(--dw-border)] hover:border-[var(--dw-accent)]/50 transition-colors">
          <span class="text-sm font-medium uppercase tracking-wide text-[var(--dw-muted)]">Email</span>
          <p class="mt-2 text-lg text-[var(--dw-text)] font-display">{email}</p>
        </a>
        <a href={`tel:${phone}`} class="block p-6 rounded-xl bg-[var(--dw-surface)] border border-[var(--dw-border)] hover:border-[var(--dw-accent)]/50 transition-colors">
          <span class="text-sm font-medium uppercase tracking-wide text-[var(--dw-muted)]">Phone</span>
          <p class="mt-2 text-lg text-[var(--dw-text)] font-display">{phone}</p>
        </a>
      </div>
    </section>
  </div>
</Layoutc>
