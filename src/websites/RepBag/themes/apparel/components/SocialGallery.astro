---
interface GalleryImage {
  src: string;
  alt: string;
  link: string;
}

interface Props {
  title: string;
  images: GalleryImage[];
}

const { title, images } = Astro.props;
---

<section class="repbag-social-gallery bg-[var(--luxury-black)] py-24 md:py-32 px-4 sm:px-6 lg:px-8" aria-labelledby="social-gallery-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="social-gallery-heading" class="text-2xl sm:text-3xl font-medium text-[var(--luxury-ivory)] text-center tracking-tight mb-14" style="font-family: var(--font-display);">
      {title}
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
      {images.map((img) => (
        <a
          href={img.link}
          class="group block relative aspect-square overflow-hidden"
        >
          <img
            src={img.src}
            alt={img.alt}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            loading="lazy"
            width="400"
            height="400"
          />
          <div class="absolute inset-0 bg-[var(--luxury-black)]/0 group-hover:bg-[var(--luxury-black)]/20 transition-colors duration-300" aria-hidden="true" />
        </a>
      ))}
    </div>
  </div>
</section>
