---
interface Props {
  href: string;
  label?: string;
}

const { href, label = 'VIEW ALL BAGS' } = Astro.props;
---

<section class="repbag-viewall bg-[var(--luxury-ivory)] py-12 md:py-14 px-4 border-t border-[var(--luxury-beige)]">
  <div class="max-w-5xl mx-auto text-center">
    <a 
      href={href}
      class="inline-block border border-[var(--luxury-black)] text-[var(--luxury-black)] uppercase tracking-[0.25em] text-[11px] font-medium px-12 py-4 hover:bg-[var(--luxury-black)] hover:text-[var(--luxury-ivory)] transition-all duration-300"
    >
      {label}
    </a>
  </div>
</section>
