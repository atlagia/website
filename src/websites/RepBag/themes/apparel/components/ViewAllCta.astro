---
interface Props {
  href: string;
  label?: string;
}

const { href, label = 'VIEW ALL BAGS' } = Astro.props;
---

<section class="bg-white py-8 md:py-10 px-4 border-t border-neutral-200">
  <div class="max-w-5xl mx-auto text-center">
    <a 
      href={href}
      class="inline-block bg-black text-white uppercase tracking-[0.25em] text-xs font-medium px-10 py-3.5 hover:bg-neutral-800 transition-colors"
    >
      {label}
    </a>
  </div>
</section>
