---
interface Feature {
  id: string;
  title: string;
  icon: string;
}

interface Props {
  title: string;
  features: Feature[];
}

const { title, features } = Astro.props;
---

<section class="repbag-why-choose bg-[var(--luxury-ivory)] py-24 md:py-32 px-4 sm:px-6 lg:px-8" aria-labelledby="why-choose-heading">
  <div class="max-w-6xl mx-auto">
    <h2 id="why-choose-heading" class="text-2xl sm:text-3xl md:text-4xl font-medium text-[var(--luxury-black)] text-center tracking-tight mb-16" style="font-family: var(--font-display);">
      {title}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-6">
      {features.map((feature) => (
        <div class="text-center group">
          <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center text-[var(--luxury-gold)]">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--luxury-black)]">
            {feature.title}
          </h3>
        </div>
      ))}
    </div>
  </div>
</section>
