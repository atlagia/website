---
import { getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description: string;
  viewAllLink: string;
  lang: string;
}


const { title, description, viewAllLink, lang } = Astro.props;

// Fetch products from Shopify and limit to 4
const productsData = await getAllProducts();
const products = productsData
  .slice(0, 3)
  .map(({ node }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(node.priceRange.minVariantPrice.amount),
    image: node.images.edges[0]?.node.url || '/placeholder-image.jpg',
    category: 'Best Selling',
  }));
---

<section class="repbag-featured py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-[var(--luxury-ivory)]" aria-labelledby="featured-heading">
  <div class="max-w-6xl mx-auto">
    <header class="text-center mb-14 md:mb-16">
      <p class="text-[10px] sm:text-xs font-medium uppercase tracking-[0.4em] text-[var(--luxury-text)]/60 mb-3">Collection</p>
      <h2 id="featured-heading" class="text-3xl sm:text-4xl md:text-5xl font-medium text-[var(--luxury-black)] tracking-tight" style="font-family: var(--font-display);">
        {title}
      </h2>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-12 max-w-5xl mx-auto">
      {products.map((product) => (
        <a
          href={`/${lang}/products/${product.handle}`}
          class="group block text-center"
        >
          <div class="relative w-full aspect-[3/4] max-h-[340px] flex items-center justify-center bg-[var(--luxury-beige)]/30 rounded-sm overflow-hidden mb-5">
            <img
              src={product.image}
              alt={product.name}
              class="max-w-full max-h-full w-auto h-auto object-contain transition-transform duration-700 ease-out group-hover:scale-105"
              loading="lazy"
              width="400"
              height="533"
            />
          </div>
          <p class="text-[10px] text-[var(--luxury-text)]/60 tracking-[0.25em] uppercase mb-2">RepBag</p>
          <h3 class="text-[var(--luxury-black)] font-medium uppercase tracking-[0.08em] text-sm line-clamp-2 leading-tight group-hover:text-[var(--luxury-gold)] transition-colors duration-200">
            {product.name}
          </h3>
          <p class="text-[var(--luxury-text)]/80 text-sm mt-1.5">{product.price}</p>
        </a>
      ))}
    </div>
    {viewAllLink && (
      <div class="text-center mt-14">
        <a
          href={viewAllLink}
          class="inline-block border border-[var(--luxury-black)] text-[var(--luxury-black)] text-[11px] font-medium uppercase tracking-[0.25em] px-10 py-3.5 hover:bg-[var(--luxury-black)] hover:text-[var(--luxury-ivory)] transition-all duration-300"
        >
          View all bags
        </a>
      </div>
    )}
  </div>
</section>