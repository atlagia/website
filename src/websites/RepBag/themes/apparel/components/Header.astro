---
// Header.astro – e-commerce: Bag + slide cart (CartSidebarWithTrigger), Search, Lang, Sign In
import { Menu, Globe, Search } from 'lucide-react';
import { getLangFromUrl, getLocalizedPath } from '@utils/i18n';
import CartSidebarWithTrigger from '@themes/default/components/CartSidebarWithTrigger';

const navigation = [
  { name: 'Home', href: '/' },
  { name: 'Collections', href: '/collections' },
  { name: 'Best Sellers', href: '/best-sellers' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
];

// Get allowed languages from environment
const getAllowedLanguages = (): string[] => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const allowedLanguages = getAllowedLanguages();

const languageNames = {
  en: "English",
  fr: "Français", 
  de: "Deutsch",
  es: "Español",
  it: "Italiano",
  pt: "Português",
  nl: "Nederlands",
  ru: "Русский",
  ar: "العربية",
  zh: "中文",
  tr: "Türkçe",
  ja: "日本語",
  ko: "한국어",
  sv: "Svenska",
  no: "Norsk",
  da: "Dansk",
  fi: "Suomi",
  pl: "Polski",
  cs: "Čeština",
  hu: "Magyar",
  ro: "Română",
  bg: "Български",
  hr: "Hrvatski",
  sk: "Slovenčina",
  sl: "Slovenščina",
  et: "Eesti",
  lv: "Latviešu",
  lt: "Lietuvių",
  el: "Ελληνικά",
  he: "עברית",
  th: "ไทย",
  vi: "Tiếng Việt",
  id: "Bahasa Indonesia",
  ms: "Bahasa Melayu",
  tl: "Filipino"
};

const languages = allowedLanguages.map(lang => ({
  code: lang,
  name: languageNames[lang] || lang
}));

const currentPath = Astro.url.pathname;
const currentLang = getLangFromUrl(Astro.url);

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'RepBag';

// Localize navigation links
const localizedNavigation = navigation.map(item => ({
  ...item,
  href: `/${currentLang}${item.href === '/' ? '' : item.href}`
}));

// Header/cart styles from theme (for slide cart)
let headerStyles: { cart?: Record<string, string> } = {};
try {
  const themeHeaderStyles = await import('../styles/Header.json');
  headerStyles = themeHeaderStyles.default || {};
} catch (_) {}

const paymentConfig = {
  method: import.meta.env.PUBLIC_PAYMENT_METHOD || 'default',
  hoodpay: {
    apiUrl: import.meta.env.HOODPAY_API_URL,
    businessId: import.meta.env.HOODPAY_BUSINESS_ID,
    authToken: import.meta.env.HOODPAY_AUTH_TOKEN,
    redirectUrl: `${import.meta.env.DOMAINE || ''}${import.meta.env.HOODPAY_REDIRECT_URL || ''}`
  },
  store: {
    name: import.meta.env.PUBLIC_SITE_NAME || siteName,
    domain: import.meta.env.DOMAINE || 'localhost'
  }
};
const apiEndpoint = import.meta.env.VITE_API_ENDPOINT || '/api/checkout';
---

<header class="repbag-header fixed w-full top-0 z-[60] bg-[var(--luxury-ivory)]/95 backdrop-blur-sm border-b border-[var(--luxury-beige)]">
  <nav class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10" aria-label="Top">
    <div class="flex h-20 items-center justify-between">
      <div class="flex items-center">
        <a href={`/${currentLang}`} class="flex items-center">
          <span class="repbag-logo text-xl font-medium text-[var(--luxury-black)] tracking-[0.2em] uppercase" style="font-family: var(--font-display);">
            {siteName}
          </span>
        </a>
      </div>
      
      <div class="hidden md:flex items-center gap-10">
        {localizedNavigation.map((item) => (
          <a
            href={item.href}
            class="text-[11px] font-medium text-[var(--luxury-text)] hover:text-[var(--luxury-gold)] transition-colors duration-200 uppercase tracking-[0.25em]"
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4 sm:gap-6">
        <a href={`/${currentLang}/search`} class="p-2 text-[var(--luxury-text)]/80 hover:text-[var(--luxury-text)] transition-colors" aria-label="Search">
          <Search className="h-4 w-4 sm:h-[18px] sm:w-[18px]" />
        </a>
        <!-- Language Switcher -->
        <div class="relative group">
          <button
            type="button"
            class="inline-flex items-center gap-2 text-[var(--luxury-text)]/80 hover:text-[var(--luxury-text)] text-[11px] uppercase tracking-[0.2em]"
          >
            <Globe className="h-4 w-4" />
            <span class="hidden md:inline-block">
              {languages.find(lang => lang.code === currentLang)?.name}
            </span>
          </button>
          
          <div class="absolute right-0 mt-2 w-48 py-2 bg-[var(--luxury-ivory)] border border-[var(--luxury-beige)] shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="py-1" role="menu" aria-orientation="vertical">
              {languages.map((lang) => (
                <a
                  href={getLocalizedPath(currentPath, lang.code)}
                  class={`block px-4 py-2 text-[11px] uppercase tracking-[0.2em] ${currentLang === lang.code ? 'text-[var(--luxury-gold)]' : 'text-[var(--luxury-text)] hover:text-[var(--luxury-gold)]'}`}
                  role="menuitem"
                >
                  {lang.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <CartSidebarWithTrigger
          client:load
          triggerClassName="flex items-center gap-1.5 text-[var(--luxury-text)]/80 hover:text-[var(--luxury-text)] transition-colors py-2 text-[11px] uppercase tracking-[0.2em]"
          label="Bag"
          showLabel={true}
          paymentConfig={paymentConfig}
          apiEndpoint={apiEndpoint}
          headerStyles={headerStyles}
          projectType={import.meta.env.PROJECT_TYPE || 'physical'}
        />

        <a
          href={`/${currentLang}/account`}
          class="hidden md:inline-flex items-center justify-center px-6 py-2.5 border border-[var(--luxury-black)] text-[11px] font-medium text-[var(--luxury-black)] hover:bg-[var(--luxury-black)] hover:text-[var(--luxury-ivory)] transition-all duration-200 uppercase tracking-[0.2em]"
        >
          Sign In
        </a>
        
        <div class="relative md:hidden">
          <button
            type="button"
            id="mobile-menu-button"
            class="inline-flex items-center justify-center p-2 text-[var(--luxury-text)] hover:text-[var(--luxury-gold)]"
            aria-expanded="false"
          >
            <span class="sr-only">Open menu</span>
            <Menu className="h-6 w-6" aria-hidden="true" />
          </button>
          <div 
            id="mobile-menu-dropdown"
            class="absolute right-0 mt-2 w-48 py-2 bg-[var(--luxury-ivory)] border border-[var(--luxury-beige)] shadow-lg hidden z-50"
          >
              <div class="py-1" role="menu" aria-orientation="vertical">
                {localizedNavigation.map((item) => (
                  <a
                    href={item.href}
                    class="block px-4 py-2 text-[11px] text-[var(--luxury-text)] hover:text-[var(--luxury-gold)] uppercase tracking-[0.2em]"
                    role="menuitem"
                  >
                    {item.name}
                  </a>
                ))}
                <a href={`/${currentLang}/search`} class="block px-4 py-2 text-[11px] text-[var(--luxury-text)] hover:text-[var(--luxury-gold)] uppercase tracking-[0.2em]">Search</a>
                <button type="button" id="mobile-bag-trigger" class="w-full text-left px-4 py-2 text-[11px] text-[var(--luxury-text)] hover:text-[var(--luxury-gold)] uppercase tracking-[0.2em]">Bag</button>
                <a href={`/${currentLang}/account`} class="block px-4 py-2 text-[11px] text-[var(--luxury-text)] font-medium uppercase tracking-[0.2em]">Sign In</a>
              </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenuDropdown = document.getElementById('mobile-menu-dropdown');

  mobileMenuButton?.addEventListener('click', () => {
    const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    mobileMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenuDropdown?.classList.toggle('hidden');
  });

  // Close menu when clicking outside
  document.addEventListener('click', (event) => {
    if (!mobileMenuButton?.contains(event.target as Node) && 
        !mobileMenuDropdown?.contains(event.target as Node)) {
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
      mobileMenuDropdown?.classList.add('hidden');
    }
  });
</script>