---
interface Props {
  title: string;
  description: string;
  backgroundImage: string;
  formAction: string;
  buttonText: string;
}

const { title, description, backgroundImage, formAction, buttonText } = Astro.props;
---

<section class="bg-white border-t border-neutral-200 py-8 md:py-10 px-4 md:px-8">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div class="md:max-w-sm">
      <h2 class="text-sm font-semibold text-black uppercase tracking-[0.2em] mb-1">{title}</h2>
      {description && <p class="text-neutral-500 text-xs">{description}</p>}
    </div>
    <form action={formAction} method="POST" class="flex flex-col sm:flex-row gap-3 flex-1 md:justify-end">
      <input
        type="email"
        placeholder="Email address"
        required
        class="px-4 py-2.5 border border-neutral-300 text-black text-sm placeholder:text-neutral-400 focus:outline-none focus:border-black min-w-[200px]"
      />
      <button type="submit" class="bg-black text-white uppercase tracking-[0.2em] text-xs font-medium px-6 py-2.5 hover:bg-neutral-800 transition-colors whitespace-nowrap">
        {buttonText}
      </button>
    </form>
  </div>
</section>