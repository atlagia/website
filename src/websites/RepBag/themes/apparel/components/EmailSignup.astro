---
interface Props {
  title: string;
  description: string;
  backgroundImage: string;
  formAction: string;
  buttonText: string;
}

const { title, description, backgroundImage, formAction, buttonText } = Astro.props;
---

<section class="repbag-newsletter bg-[var(--luxury-black)] text-[var(--luxury-ivory)] py-16 md:py-20 px-4 md:px-8">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
    <div class="md:max-w-sm">
      <h2 class="text-[11px] font-medium uppercase tracking-[0.3em] mb-2" style="font-family: var(--font-display);">{title}</h2>
      {description && <p class="text-[var(--luxury-ivory)]/70 text-sm">{description}</p>}
    </div>
    <form action={formAction} method="POST" class="flex flex-col sm:flex-row gap-3 flex-1 md:justify-end">
      <input
        type="email"
        placeholder="Email address"
        required
        class="px-5 py-3 border border-[var(--luxury-ivory)]/30 bg-transparent text-[var(--luxury-ivory)] text-sm placeholder:text-[var(--luxury-ivory)]/50 focus:outline-none focus:border-[var(--luxury-gold)] min-w-[240px] transition-colors"
      />
      <button type="submit" class="border border-[var(--luxury-ivory)] text-[var(--luxury-ivory)] uppercase tracking-[0.2em] text-[11px] font-medium px-8 py-3 hover:bg-[var(--luxury-ivory)] hover:text-[var(--luxury-black)] transition-all duration-300 whitespace-nowrap">
        {buttonText}
      </button>
    </form>
  </div>
</section>