---
interface BackgroundVideo {
  type: 'youtube';
  videoId: string;
  fallbackImage: string;
}

interface Props {
  title?: string;
  description?: string;
  blogLink?: string;
  blogLinkText?: string;
  backgroundVideo?: BackgroundVideo;
  heroImage?: string;
  headlineLine1?: string;
  headlineLine2?: string;
  luxury?: boolean;
}

const { 
  title = 'RepBag',
  description = '',
  blogLink = '#', 
  blogLinkText = 'Explore the collection', 
  backgroundVideo = { type: 'youtube', videoId: '', fallbackImage: '/images/hero-bags.jpg' },
  heroImage,
  headlineLine1 = 'Timeless Luxury.',
  headlineLine2 = 'Iconic Style.',
  luxury = true
} = Astro.props;

const bgImage = heroImage || backgroundVideo?.fallbackImage || 'https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=1920';
---

<section 
  class="repbag-hero relative w-full min-h-[100vh] min-h-[100dvh] flex items-center justify-center overflow-hidden bg-[var(--luxury-black)]"
  itemScope 
  itemType="https://schema.org/WebPageElement"
>
  <!-- Full-screen cinematic background -->
  <div class="absolute inset-0 z-0">
    <img 
      src={bgImage} 
      alt="" 
      class="absolute inset-0 w-full h-full object-cover object-center scale-100 repbag-hero-img"
      fetchpriority="high"
      aria-hidden="true"
    />
    <!-- Cinematic overlay: soft vignette + contrast for readability -->
    <div 
      class="absolute inset-0 z-[1] repbag-hero-overlay" 
      aria-hidden="true"
    />
  </div>

  <!-- Editorial content: all light text on dark background -->
  <div class="relative z-10 text-center px-6 sm:px-8 max-w-4xl mx-auto">
    {title && (
      <p 
        class="repbag-hero-line text-[10px] sm:text-xs tracking-[0.4em] uppercase text-white/90 mb-4 font-[var(--font-body-luxury)]" 
        itemProp="name"
      >
        {title}
      </p>
    )}
    <p class="repbag-hero-line repbag-hero-line-2 text-white text-sm sm:text-base tracking-[0.35em] uppercase mb-2 font-[var(--font-body-luxury)]">
      {headlineLine1}
    </p>
    <h1 
      class="repbag-hero-line repbag-hero-title text-white text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-medium tracking-tight mb-8" 
      itemProp="headline" 
      role="heading" 
      aria-level="1"
      style="font-family: var(--font-display);"
    >
      {headlineLine2}
    </h1>
    {description && (
      <p class="repbag-hero-line repbag-hero-line-4 text-white/95 text-base sm:text-lg max-w-md mx-auto mb-12 leading-relaxed font-[var(--font-body-luxury)]">
        {description}
      </p>
    )}
    <a 
      href={blogLink}
      class="repbag-hero-line repbag-hero-cta inline-block border-2 border-white text-white uppercase tracking-[0.25em] text-[11px] font-medium px-12 py-4 hover:bg-white hover:text-[var(--luxury-black)] transition-all duration-300"
    >
      {blogLinkText}
    </a>
  </div>

  <!-- Scroll cue - light -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 repbag-hero-scroll">
    <span class="text-[9px] tracking-[0.3em] uppercase text-white/60">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-white/50 to-transparent" />
  </div>
</section>

<style>
  .repbag-hero-overlay {
    background: 
      radial-gradient(ellipse 100% 80% at 50% 50%, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.6) 100%),
      linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 40%, rgba(0, 0, 0, 0.35) 70%, rgba(0, 0, 0, 0.2) 100%);
  }

  .repbag-hero-img {
    transition: transform 14s cubic-bezier(0.2, 0.5, 0.3, 1);
  }

  .repbag-hero:hover .repbag-hero-img {
    transform: scale(1.04);
  }

  .repbag-hero-line {
    opacity: 0;
    transform: translateY(20px);
    animation: repbag-hero-fade 0.9s ease-out forwards;
  }

  .repbag-hero-line-2 { animation-delay: 0.12s; }
  .repbag-hero-title { animation-delay: 0.2s; }
  .repbag-hero-line-4 { animation-delay: 0.32s; }
  .repbag-hero-cta { animation-delay: 0.44s; }
  .repbag-hero-scroll { animation: repbag-hero-fade 0.8s ease-out 0.8s forwards; opacity: 0; }

  @keyframes repbag-hero-fade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .repbag-hero-cta {
    letter-spacing: 0.25em;
  }
</style>
