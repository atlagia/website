---
import { getCollectionProducts, getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description: string;
  viewAllLink: string;
  lang: string;
  collectionHandle?: string;
}

const { title, description, viewAllLink, lang, collectionHandle } = Astro.props;

// Fetch products with fallback logic
let productsData;
try {
  if (collectionHandle && collectionHandle !== 'all') {
    // Try to fetch from specific collection first
    productsData = await getCollectionProducts(collectionHandle);
  } else {
    // Fetch all products if no collection or 'all' specified
    productsData = await getAllProducts();
  }
} catch (error) {
  console.warn(`Failed to fetch products from collection "${collectionHandle}", falling back to all products:`, error.message);
  // Fallback to all products if collection fetch fails
  productsData = await getAllProducts();
}

const products = productsData
  .slice(0, 4)
  .map(({ node }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(node.priceRange.minVariantPrice.amount),
    image: node.images.edges[0]?.node.url || '/placeholder-image.jpg',
    badge: Math.random() > 0.5 ? 'BEST SELLER' : undefined, // Random badge assignment
  }));
---

<section class="py-20 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900">{title}</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">{description}</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {products.map((product) => (
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition-shadow duration-300 group">
          <div class="relative">
            <a href={`/${lang}/products/${product.handle}`}>
              <img 
                src={product.image} 
                alt={product.name}
                class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </a>
            {product.badge && (
              <div class="absolute top-3 left-3 bg-red-600 text-white px-2 py-1 rounded-md text-xs font-bold">
                {product.badge}
              </div>
            )}
          </div>
          
          <div class="p-6">
            <a href={`/${lang}/products/${product.handle}`}>
              <h3 class="font-bold text-lg mb-2 text-gray-900 hover:text-gray-700">{product.name}</h3>
            </a>
            <p class="text-gray-600 text-sm mb-4">Professional Performance Gear</p>
            
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2">
                <span class="text-2xl font-bold text-gray-900">{product.price}</span>
              </div>
            </div>
            
            <a 
              href={`/${lang}/products/${product.handle}`}
              class="block w-full bg-black text-white py-3 px-6 rounded-lg font-semibold hover:bg-gray-800 transition-colors duration-300 text-center"
            >
              View {product.name}
            </a>
          </div>
        </div>
      ))}
    </div>
    
    <div class="text-center">
      <a 
        href={viewAllLink}
        class="inline-block bg-gray-900 text-white px-8 py-3 rounded-lg font-semibold hover:bg-black transition-colors duration-300"
      >
        View All Products
      </a>
    </div>
  </div>
</section>