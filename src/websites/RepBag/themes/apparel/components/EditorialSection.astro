---
interface EditorialImage {
  src: string;
  alt: string;
}

interface Props {
  title: string;
  images: EditorialImage[];
  /** layout: '1-2' (one left, two right), '3-2' (three top, two bottom), '2-2' (2x2) */
  layout?: '1-2' | '3-2' | '2-2' | '3-1';
  /** Optional CTA below the grid */
  viewAllHref?: string;
  viewAllLabel?: string;
}

const { title, images, layout = '1-2', viewAllHref, viewAllLabel } = Astro.props;
---

<section class="repbag-editorial bg-[var(--luxury-ivory)] py-24 md:py-32 px-4 sm:px-6 lg:px-8" aria-labelledby="editorial-heading">
  <div class="max-w-6xl mx-auto">
    <header class="text-center mb-16 md:mb-20">
      <h2 id="editorial-heading" class="text-2xl sm:text-3xl md:text-4xl font-medium text-[var(--luxury-black)] tracking-tight" style="font-family: var(--font-display);">
        {title}
      </h2>
    </header>

    <div class="w-full">
      {layout === '1-2' && images.length >= 3 && (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-4 max-w-5xl mx-auto">
          <div class="md:col-span-5 relative aspect-[3/4] max-h-[340px] md:max-h-[400px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
            <img
              src={images[0].src}
              alt={images[0].alt}
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
              loading="lazy"
              width="600"
              height="800"
            />
          </div>
          <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4">
            <div class="relative aspect-[4/3] max-h-[200px] sm:max-h-[240px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={images[1].src}
                alt={images[1].alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
                width="400"
                height="300"
              />
            </div>
            <div class="relative aspect-[4/3] max-h-[200px] sm:max-h-[240px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={images[2].src}
                alt={images[2].alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
                width="400"
                height="300"
              />
            </div>
          </div>
        </div>
      )}
      {layout === '3-2' && images.length >= 5 && (
        <div class="grid grid-cols-2 md:grid-cols-6 gap-3 md:gap-4 max-w-5xl mx-auto">
          {images.slice(0, 3).map((img) => (
            <div class="md:col-span-2 relative aspect-[3/4] max-h-[220px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          ))}
          {images.slice(3, 5).map((img) => (
            <div class="md:col-span-3 relative aspect-[4/3] max-h-[180px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      )}
      {layout === '2-2' && images.length >= 4 && (
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 max-w-5xl mx-auto">
          {images.slice(0, 4).map((img) => (
            <div class="relative aspect-[3/4] max-h-[260px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      )}
      {layout === '3-1' && images.length >= 4 && (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 max-w-5xl mx-auto">
          {images.slice(0, 3).map((img) => (
            <div class="relative aspect-[3/4] max-h-[240px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          ))}
          <div class="md:col-span-3 flex justify-center">
            <div class="relative aspect-square w-full max-w-[240px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={images[3].src}
                alt={images[3].alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      )}
      {(!layout || layout === '1-2') && images.length > 0 && images.length < 3 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4 max-w-5xl mx-auto">
          {images.map((img) => (
            <div class="relative aspect-[3/4] max-h-[320px] overflow-hidden rounded-sm bg-[var(--luxury-beige)]">
              <img
                src={img.src}
                alt={img.alt}
                class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 ease-out hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      )}
    </div>

    {viewAllHref && viewAllLabel && (
      <div class="text-center mt-14 md:mt-16">
        <a
          href={viewAllHref}
          class="inline-block text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-text)] hover:text-[var(--luxury-gold)] transition-colors duration-200"
        >
          {viewAllLabel}
        </a>
      </div>
    )}
  </div>
</section>
