---
import { getLangFromUrl } from '@utils/i18n';

const currentYear = new Date().getFullYear();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// Get current language
const currentLang = getLangFromUrl(Astro.url);

// Load footer data dynamically based on language
let footerData;
try {
  footerData = await import(`../data/footer/footer_${currentLang}.json`);
} catch (error) {
  // Fallback to English if language file doesn't exist
  footerData = await import(`../data/footer/footer_en.json`);
}

const { description, navigation, social } = footerData.default;
---

<footer class="repbag-footer bg-[var(--luxury-black)] text-[var(--luxury-ivory)]" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-12 pt-20 sm:pt-24 lg:px-10 lg:pt-28">
    <div class="xl:grid xl:grid-cols-3 xl:gap-12">
      <div class="space-y-6">
        <span class="text-lg font-medium tracking-[0.25em] uppercase" style="font-family: var(--font-display);">{siteName}</span>
        <p class="text-sm leading-relaxed text-[var(--luxury-ivory)]/75 max-w-xs">
          {description}
        </p>
        <div class="flex gap-6">
          {social.map((item) => (
            <a href={item.href} class="text-[var(--luxury-ivory)]/60 hover:text-[var(--luxury-gold)] transition-colors duration-200">
              <span class="sr-only">{item.name}</span>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={item.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-10 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-10">
          <div>
            <h3 class="text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-ivory)]/80 mb-6">Shop</h3>
            <ul role="list" class="space-y-4">
              {navigation.shop.map((item) => (
                <li>
                  <a href={`/${currentLang}${item.href}`} class="text-sm text-[var(--luxury-ivory)]/75 hover:text-[var(--luxury-gold)] transition-colors duration-200">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-ivory)]/80 mb-6">Collections</h3>
            <ul role="list" class="space-y-4">
              {navigation.collections.map((item) => (
                <li>
                  <a href={`/${currentLang}${item.href}`} class="text-sm text-[var(--luxury-ivory)]/75 hover:text-[var(--luxury-gold)] transition-colors duration-200">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-10">
          <div>
            <h3 class="text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-ivory)]/80 mb-6">Company</h3>
            <ul role="list" class="space-y-4">
              {navigation.company.map((item) => (
                <li>
                  <a href={`/${currentLang}${item.href}`} class="text-sm text-[var(--luxury-ivory)]/75 hover:text-[var(--luxury-gold)] transition-colors duration-200">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-ivory)]/80 mb-6">Support</h3>
            <ul role="list" class="space-y-4">
              {navigation.support.map((item) => (
                <li>
                  <a href={`/${currentLang}${item.href}`} class="text-sm text-[var(--luxury-ivory)]/75 hover:text-[var(--luxury-gold)] transition-colors duration-200">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-1 md:gap-8">
          <div>
            <h3 class="text-[10px] font-medium uppercase tracking-[0.3em] text-[var(--luxury-ivory)]/80 mb-6">Legal</h3>
            <ul role="list" class="space-y-4">
              {navigation.legal.map((item) => (
                <li>
                  <a href={`/${currentLang}${item.href}`} class="text-sm text-[var(--luxury-ivory)]/75 hover:text-[var(--luxury-gold)] transition-colors duration-200">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-20 border-t border-[var(--luxury-ivory)]/10 pt-8">
      <p class="text-[11px] tracking-[0.15em] text-[var(--luxury-ivory)]/50">
        &copy; {currentYear} {siteName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>