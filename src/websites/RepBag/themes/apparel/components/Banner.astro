---
import { ArrowRight } from 'lucide-react';

interface Props {
  headline: string;
  description: string;
  backgroundImage: string;
  button1Text: string;
  button1Link: string;
  button2Text?: string;
  button2Link?: string;
}

const { 
  headline, 
  description, 
  backgroundImage,
  button1Text,
  button1Link,
  button2Text,
  button2Link
} = Astro.props;
---

<style>
  @keyframes gentle-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  @keyframes slow-pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.9; }
  }
  
  .animate-gentle-float { animation: gentle-float 6s ease-in-out infinite; }
  .animate-slow-pulse { animation: slow-pulse 4s ease-in-out infinite; }
  .delay-1s { animation-delay: 1s; }
  .delay-2s { animation-delay: 2s; }
</style>

<section 
  class="relative py-24 px-4 md:px-8 min-h-[80vh] flex items-center justify-center overflow-hidden font-sans"
  style={`background-image: url(${backgroundImage}); background-size: cover; background-position: center; filter: grayscale(30%);`}
>
  <div class="absolute inset-0 bg-white/80 backdrop-blur-sm z-10 animate-slow-pulse"></div>
  
  <!-- Simple floating elements -->
  <div class="absolute inset-0 z-15">
    <!-- Top floating elements -->
    <div class="absolute top-20 left-10 w-16 h-16 bg-white/20 rounded-full animate-gentle-float"></div>
    <div class="absolute top-40 right-20 w-12 h-12 bg-white/15 rounded-full animate-gentle-float delay-1s"></div>
    <div class="absolute top-32 left-1/4 w-10 h-10 bg-white/10 rounded-full animate-gentle-float delay-2s"></div>
    
    <!-- Bottom floating elements -->
    <div class="absolute bottom-20 right-10 w-16 h-16 bg-white/20 rounded-full animate-gentle-float delay-1s"></div>
    <div class="absolute bottom-40 left-20 w-12 h-12 bg-white/15 rounded-full animate-gentle-float delay-2s"></div>
    <div class="absolute bottom-32 right-1/4 w-10 h-10 bg-white/10 rounded-full animate-gentle-float"></div>
  </div>
  
  <div class="relative max-w-5xl mx-auto text-center px-4 z-20">
    <h2 class="text-6xl md:text-8xl font-extrabold text-black mb-6 uppercase tracking-tight leading-none">
      {headline}
    </h2>
    
    <p class="text-2xl md:text-3xl text-gray-900 mb-10 max-w-3xl mx-auto font-medium leading-tight tracking-wide">
      {description}
    </p>
    
    <div class="flex flex-wrap justify-center items-center gap-6">
      <a 
        href={button1Link}
        class="group inline-flex items-center gap-3 bg-gray-800 text-white px-10 py-4 rounded-lg uppercase tracking-wider hover:bg-gray-700 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-xl"
      >
        <span>{button1Text}</span>
        <ArrowRight className="w-6 h-6 transform group-hover:translate-x-1 transition-transform" />
      </a>
      
      {button2Text && button2Link && (
        <a 
          href={button2Link}
          class="group inline-flex items-center gap-3 border-2 border-gray-900 text-gray-900 px-10 py-4 rounded-lg uppercase tracking-wider hover:bg-gray-100 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-xl"
        >
          <span>{button2Text}</span>
          <ArrowRight className="w-6 h-6 transform group-hover:translate-x-1 transition-transform" />
        </a>
      )}
    </div>
  </div>
</section>