---
import Layoutc from '@layouts/Layoutc.astro';
import { Mail, Phone, MapPin } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// Load multilingual data
let data;
try {
  data = await import(`../data/contact/contact_${lang}.json`);
} catch (error) {
  // Fallback to English if language file doesn't exist
  data = await import(`../data/contact/contact_en.json`);
}

const pageData = data.default;

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Drivon',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'info@drivon.store',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+1234567890',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || '123 Racing Street',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'Speed City',
    region: import.meta.env.PUBLIC_BUSINESS_REGION || 'Racing State',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'USA',
    postalCode: import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE || '12345'
  },
  support: {
    hours: import.meta.env.PUBLIC_SUPPORT_HOURS || 'Monday - Friday, 9 AM - 6 PM (EST)',
    email: import.meta.env.PUBLIC_SUPPORT_EMAIL || 'support@drivon.store'
  }
};

const contactInfo = [
  {
    icon: Mail,
    title: pageData.contactInfo.email.title,
    content: businessInfo.support.email,
    link: `mailto:${businessInfo.support.email}`
  },
  {
    icon: Phone,
    title: pageData.contactInfo.phone.title,
    content: businessInfo.phone,
    link: `tel:${businessInfo.phone}`
  },
  {
    icon: MapPin,
    title: pageData.contactInfo.address.title,
    content: `${businessInfo.address.street}, ${businessInfo.address.city}`,
    link: `https://maps.google.com/maps?q=${encodeURIComponent(
      `${businessInfo.address.street}, ${businessInfo.address.city}, ${businessInfo.address.country}`
    )}`
  }
];

// SEO
const seoTitle = `${pageData.title} | ${storeName}`;
const seoDescription = pageData.description;
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative py-20 px-4 bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">{pageData.hero.title}</h1>
        <p class="text-xl text-gray-300 max-w-2xl">
          {pageData.hero.subtitle}
        </p>
      </div>
    </section>

    <!-- Contact Form & Info -->
    <section class="py-16 px-4">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Information -->
        <div>
          <h2 class="text-2xl font-bold mb-8">{pageData.sections.contactInfo.title}</h2>
          <div class="grid gap-8">
            {contactInfo.map(item => (
              <a
                href={item.link}
                class="flex items-center gap-4 p-6 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors"
              >
                <div class="bg-gray-900 text-white p-3 rounded-full">
                  <item.icon className="w-6 h-6" />
                </div>
                <div>
                  <h3 class="font-semibold">{item.title}</h3>
                  <p class="text-gray-600">{item.content}</p>
                </div>
              </a>
            ))}
          </div>
          
          <!-- Support Hours -->
          <div class="mt-8 p-6 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-900 mb-2">{pageData.support.hours.title}</h3>
            <p class="text-blue-700">{businessInfo.support.hours}</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold mb-8">{pageData.sections.contactForm.title}</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                {pageData.form.name.label}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder={pageData.form.name.placeholder}
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                {pageData.form.email.label}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder={pageData.form.email.placeholder}
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                {pageData.form.subject.label}
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                placeholder={pageData.form.subject.placeholder}
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                {pageData.form.message.label}
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                placeholder={pageData.form.message.placeholder}
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-gray-900 text-white py-3 px-6 rounded-lg font-semibold hover:bg-gray-800 transition-colors"
            >
              {pageData.form.submitButton}
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{pageData.faq.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {pageData.faq.items.map((item, index) => (
            <div class="bg-gray-50 rounded-lg p-6">
              <h3 class="text-lg font-semibold mb-3">{item.question}</h3>
              <p class="text-gray-600">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layoutc>