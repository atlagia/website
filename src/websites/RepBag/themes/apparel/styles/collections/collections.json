{
  "container": {
    "maxWidth": "max-w-7xl",
    "margin": "mx-auto",
    "padding": "px-4 pb-8 pt-[100px]",
    "background": "bg-white",
    "textColor": "text-gray-900"
  },
  "colors": {
    "navy": {
      "default": "#0A2342",
      "hover": "#123456",
      "text": "text-white"
    }
  },
  "header": {
    "background": "bg-gray-50",
    "padding": "py-16",
    "textAlign": "text-center"
  },
  "title": {
    "fontSize": "text-5xl md:text-6xl",
    "fontWeight": "font-black",
    "margin": "mb-8",
    "color": "text-red-600 uppercase tracking-tight",
    "textShadow": "drop-shadow-sm"
  },
  "subtitle": {
    "fontSize": "text-xl",
    "color": "text-gray-600",
    "maxWidth": "max-w-3xl",
    "margin": "mx-auto"
  },
  "grid": {
    "columns": "grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4",
    "gap": "gap-8",
    "background": "bg-white",
    "padding": "p-4"
  },
  "card": {
    "background": "bg-white",
    "border": "border border-gray-200 rounded-xl",
    "shadow": "shadow-sm hover:shadow-lg transition-shadow duration-300",
    "padding": "p-4",
    "hover": {
      "transform": "hover:scale-105",
      "transition": "transition-transform duration-300"
    }
  },
  "cardImage": {
    "aspectRatio": "aspect-[3/4]",
    "background": "bg-gray-100",
    "objectFit": "object-cover",
    "borderRadius": "rounded-lg overflow-hidden"
  },
  "cardTitle": {
    "fontSize": "text-lg",
    "fontWeight": "font-semibold",
    "color": "text-gray-900",
    "hover": "hover:text-red-600 transition-colors"
  },
  "cardPrice": {
    "fontSize": "text-base",
    "fontWeight": "font-bold",
    "color": "text-gray-900"
  },
  "button": {
    "default": "w-full mt-4 px-4 py-2 bg-blue-950 text-white rounded-md hover:bg-blue-900 transition-colors"
  },
  "pagination": {
    "container": "flex justify-center items-center gap-6 mt-12 bg-gray-50 py-4 rounded-lg",
    "button": "px-6 py-3 bg-blue-950 text-white rounded-md hover:bg-blue-900 transition-colors uppercase font-bold tracking-wider",
    "text": "text-gray-700 font-semibold"
  },
  "footer": {
    "textAlign": "text-center",
    "textSize": "text-sm",
    "textColor": "text-gray-500",
    "margin": "mt-8 pt-8 border-t border-gray-200"
  },
  "emptyState": {
    "background": "bg-gray-50",
    "padding": "py-16",
    "textAlign": "text-center",
    "borderRadius": "rounded-xl"
  },
  "dynamicClasses": {
    "container": {
      "base": "min-h-screen bg-gray-50",
      "maxWidth": "max-w-7xl mx-auto",
      "padding": "px-4 pt-24 pb-16"
    },
    "breadcrumb": {
      "container": "flex mb-8 text-sm",
      "list": "flex items-center space-x-2",
      "homeLink": "text-gray-500 hover:text-gray-700",
      "separator": "text-gray-400",
      "currentPage": "text-gray-900 font-medium"
    },
    "header": {
      "container": "text-center mb-16 relative overflow-hidden rounded-2xl",
      "imageOverlay": "absolute inset-0 z-0",
      "image": "w-full h-full object-cover opacity-30 filter brightness-50",
      "contentContainer": "relative z-10 py-16 px-4"
    },
    "productGrid": {
      "container": "grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-12 rounded-xl shadow-sm",
      "productCard": {
        "base": "block group",
        "card": "bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300",
        "imageContainer": "aspect-[3/4] overflow-hidden bg-gray-50 relative",
        "image": "w-full h-full object-contain p-4 transition-transform duration-300 group-hover:scale-105",
        "noImagePlaceholder": "w-full h-full flex items-center justify-center text-gray-400",
        "content": "p-4",
        "title": "text-lg font-medium text-gray-900 truncate mb-1 group-hover:text-blue-600 transition-colors",
        "priceContainer": "flex justify-between items-center",
        "price": "text-sm font-semibold text-gray-900"
      }
    },
    "quickAddButton": {
      "base": "absolute bottom-2 left-2 right-2 bg-blue-950 text-white py-2 rounded-md text-sm font-medium",
      "hover": "hover:bg-blue-900",
      "visibility": "opacity-0 group-hover:opacity-100",
      "transition": "transition-opacity duration-300",
      "focus": "focus:outline-none focus:ring-2 focus:ring-blue-700 focus:ring-opacity-50"
    },
    "pagination": {
      "container": "flex justify-between items-center bg-white rounded-lg shadow-sm p-4",
      "button": "flex items-center space-x-2 px-4 py-2 rounded-md transition-colors group",
      "text": "text-sm font-medium text-gray-600",
      "icon": "w-5 h-5 group-hover:translate-x-1 transition-transform"
    },
    "emptyState": {
      "container": "text-center py-16 bg-white rounded-2xl shadow-sm",
      "content": "max-w-md mx-auto",
      "title": "text-2xl font-semibold text-gray-900 mb-2",
      "description": "text-gray-600"
    },
    "footer": {
      "container": "mt-8 pt-4 text-center text-sm text-gray-500"
    }
  },
  "fadeIn": {
    "animation": "fadeIn 0.7s ease-out",
    "keyframes": {
      "from": { 
        "opacity": 0, 
        "transform": "translateY(20px)" 
      },
      "to": { 
        "opacity": 1, 
        "transform": "translateY(0)" 
      }
    }
  }
}