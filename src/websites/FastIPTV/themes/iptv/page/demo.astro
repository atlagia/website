---
import { getLangFromUrl } from '@utils/i18n';

const theme = import.meta.env.THEME || 'iptv';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'FastIPTV';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language and load appropriate content
const currentLang = getLangFromUrl(Astro.url);

// Try to load demo data, fallback to contact data if demo doesn't exist
let pageData;
try {
  const demoData = await import(`../data/demo/demo_${currentLang}.json`);
  pageData = demoData.default;
} catch {
  // If demo data doesn't exist, use contact data as fallback
  try {
    const contactData = await import(`../data/contact/contact_${currentLang}.json`);
    pageData = contactData.default;
  } catch {
    // Final fallback - create minimal data
    pageData = {
      pageTitle: 'Request a Demo',
      pageDescription: 'Experience our IPTV service with a free demo',
      hero: {
        title: 'Request a Demo',
        description: 'Experience our premium IPTV service with a free demo',
        badge: 'Get Started'
      }
    };
  }
}
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${pageData.pageTitle || 'Demo'} | ${siteName}`}
      description={pageData.pageDescription || 'Experience our IPTV service with a free demo'}
    />
  </head>
  <body class="bg-black text-white">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center py-20 overflow-hidden bg-gradient-to-br from-gray-900 via-purple-900 to-black">
      <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-8">
            <span class="text-sm font-medium">{pageData.hero?.badge || 'Get Started'}</span>
          </div>

          <h1 class="text-4xl lg:text-5xl font-bold leading-tight mb-8 gradient-text">
            {pageData.hero?.title || 'Request a Demo'}
          </h1>

          <p class="text-xl mb-12 max-w-3xl mx-auto text-gray-300">
            {pageData.hero?.description || 'Experience our premium IPTV service with a free demo and see why thousands of users trust us.'}
          </p>
        </div>
      </div>
    </section>

    <!-- Demo Form Section -->
    <section id="demo-form" class="py-24 bg-black relative">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4 gradient-text">Get in Touch</h2>
            <p class="text-xl text-gray-300">Fill out the form below and we'll get back to you soon.</p>
          </div>

          <div class="glass rounded-2xl p-8 md:p-12">
            <form id="demo-form" method="POST" action="#" class="space-y-6">
              <!-- Full Name -->
              <div>
                <label class="block text-sm font-medium mb-2 text-gray-300">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="fullName"
                  placeholder="Enter your full name"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500 text-white placeholder-gray-400"
                />
              </div>

              <!-- Email -->
              <div>
                <label class="block text-sm font-medium mb-2 text-gray-300">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  name="email"
                  placeholder="Enter your email"
                  required
                  class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500 text-white placeholder-gray-400"
                />
              </div>

              <!-- Message -->
              <div>
                <label class="block text-sm font-medium mb-2 text-gray-300">
                  Message
                </label>
                <textarea
                  name="message"
                  placeholder="Tell us about your needs..."
                  rows="4"
                  class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500 text-white placeholder-gray-400 resize-none"
                ></textarea>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full py-4 rounded-lg bg-purple-600 hover:bg-purple-700 text-white font-bold text-lg transition-all duration-300 shadow-lg hover:shadow-xl"
              >
                Submit Request
              </button>

              <!-- Consent -->
              <p class="text-sm text-gray-400 text-center">
                By submitting this form, you agree to our privacy policy and terms of service.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      // Form submission handling
      const form = document.getElementById('demo-form');
      const submitButton = form?.querySelector('button[type="submit"]');
      let isSubmitting = false;
      
      form?.addEventListener('submit', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        if (isSubmitting) {
          return;
        }
        
        isSubmitting = true;
        const originalButtonText = submitButton?.textContent;
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = 'Submitting...';
        }
        
        const formData = new FormData(form);
        const submissionData = {
          fullName: formData.get('fullName') || '',
          email: formData.get('email') || '',
          message: formData.get('message') || '',
          submissionTimestamp: new Date().toISOString()
        };
        
        try {
          await new Promise(resolve => setTimeout(resolve, 500));
          form.reset();
          alert('Demo request submitted! We\'ll get back to you shortly.');
        } catch (error) {
          console.error('Form submission error:', error);
          alert('Sorry, there was an error processing your request. Please try again.');
        } finally {
          isSubmitting = false;
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = originalButtonText;
          }
        }
      });
    </script>
  </body>
</html>

<style>
  * {
    scroll-behavior: smooth;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .glass {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>

