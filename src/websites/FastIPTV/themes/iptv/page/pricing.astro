---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const lang = getLangFromUrl(Astro.url);
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = jsonData.siteTitle || 'FastIPTV';
const PAGE_TITLE = 'Pricing Plans | ' + SITE_TITLE;
const PAGE_DESCRIPTION = 'Choose the perfect Fast IPTV subscription plan for your entertainment needs';
const breadcrumbs = [
  { name: 'Home', url: `/${lang}` },
  { name: 'Pricing', url: `/${lang}/pricing` }
];

// Get pricing data from pricing_<lang>.json
const pricingData = await import(`../data/pricing/pricing_${lang}.json`).then(m => m.default);
const plans = pricingData.plans || [];
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} breadcrumbs={breadcrumbs} />
  </head>
  <body class="bg-[#0a0a0a] text-white">
    <Header />
    <main class="container mx-auto px-4 py-16 max-w-7xl">
      <section class="space-y-12 pt-8">
        {/* Hero Section */}
        <div class="text-center space-y-4">
          <h1 class="text-4xl md:text-6xl font-bold gradient-text">
            {pricingData.hero.title}
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            {pricingData.hero.description}
          </p>
        </div>

        {/* Billing Toggle */}
        <div class="flex justify-center items-center gap-4">
          <span class="text-gray-300">Monthly</span>
          <button class="w-14 h-8 rounded-full bg-purple-600 relative">
            <span class="absolute left-1 top-1 w-6 h-6 rounded-full bg-white"></span>
          </button>
          <span class="text-gray-300">
            Yearly
            <span class="ml-2 text-sm text-emerald-400">Save 20%</span>
          </span>
        </div>

        {/* Pricing Cards */}
        <div class="grid md:grid-cols-3 gap-8">
          {plans.map(plan => (
            <div class={`glass rounded-2xl p-8 space-y-6 relative ${plan.isPopular ? 'border-2 border-purple-500' : ''}`}>
              {plan.isPopular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-purple-600 text-white px-4 py-1 rounded-full text-sm font-medium">
                  Most Popular
                </div>
              )}
              
              <div class="text-center">
                <h2 class="text-2xl font-bold mb-2">{plan.name}</h2>
              </div>

              <div class="text-center">
                <div class="flex items-end justify-center">
                  <span class="text-4xl font-bold">${plan.price}</span>
                  <span class="text-gray-400">/{plan.duration}</span>
                </div>
              </div>

              <ul class="space-y-4">
                {plan.features.map(feature => (
                  <li class="flex items-center gap-3">
                    <span class="text-emerald-400 text-xl">✓</span>
                    <span class="text-gray-300">
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>

              <a
                href={plan.checkoutUrl}
                class={`block w-full py-3 px-6 rounded-lg text-center font-bold transition duration-200 ${
                  plan.isPopular
                    ? 'bg-purple-600 hover:bg-purple-700 text-white'
                    : 'bg-white/10 hover:bg-white/20 text-white'
                }`}
              >
                Get Started
              </a>
            </div>
          ))}
        </div>

        {/* FAQ Section */}
        <div class="max-w-3xl mx-auto space-y-8">
          <h2 class="text-3xl font-bold text-center text-purple-400">
            Frequently Asked Questions
          </h2>
          <div class="space-y-4">
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">Can I change plans later?</h3>
              <p class="text-gray-300">
                Yes, you can upgrade or downgrade your plan at any time. Changes will be reflected in your next billing cycle.
              </p>
            </div>
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">Is there a free trial?</h3>
              <p class="text-gray-300">
                Yes, we offer a 7-day free trial for all new subscribers. You can cancel anytime during the trial period.
              </p>
            </div>
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-2">What payment methods do you accept?</h3>
              <p class="text-gray-300">
                We accept all major credit cards, PayPal, and cryptocurrency payments.
              </p>
            </div>
          </div>
        </div>

        {/* CTA Section */}
        <div class="glass rounded-2xl p-8 text-center space-y-6">
          <h2 class="text-3xl font-bold gradient-text">Ready to Get Started?</h2>
          <p class="text-xl text-gray-300">
            Join thousands of satisfied Fast IPTV users worldwide. Start streaming today!
          </p>
          <div class="flex justify-center gap-4">
            <a
              href={plans[1]?.checkoutUrl || '#'}
              class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
            >
              Get Started Now
            </a>
            <a
              href="/contact"
              class="bg-white/10 hover:bg-white/20 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
            >
              Contact Support
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html> 