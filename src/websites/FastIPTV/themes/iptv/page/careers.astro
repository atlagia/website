---
import { getLangFromUrl, useTranslations } from '@utils/i18n';

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Load content data
let contentData;
try {
  contentData = await import(`../data/careers-content.json`);
} catch (error) {
  // Fallback content
  contentData = {
    default: {
      en: {
        title: "Join Our Team",
        subtitle: "Build the future of streaming with us",
        description: "We're looking for passionate individuals to join our growing team and help shape the future of IPTV streaming.",
        sections: {
          whyJoin: {
            title: "Why Join FastIPTV?",
            description: "We offer competitive benefits and a dynamic work environment.",
            benefits: [
              {
                title: "Competitive Salary",
                description: "We offer market-competitive compensation packages."
              },
              {
                title: "Remote Work",
                description: "Work from anywhere in the world with flexible hours."
              },
              {
                title: "Growth Opportunities",
                description: "Continuous learning and career development programs."
              },
              {
                title: "Health Benefits",
                description: "Comprehensive health insurance and wellness programs."
              }
            ]
          },
          openPositions: {
            title: "Open Positions",
            description: "Check out our current job openings.",
            positions: [
              {
                title: "Frontend Developer",
                department: "Engineering",
                location: "Remote",
                type: "Full-time",
                description: "Build amazing user experiences for our streaming platform."
              },
              {
                title: "Backend Developer",
                department: "Engineering", 
                location: "Remote",
                type: "Full-time",
                description: "Develop scalable backend systems for our streaming service."
              },
              {
                title: "Content Manager",
                department: "Content",
                location: "Remote",
                type: "Full-time",
                description: "Manage and curate our streaming content library."
              }
            ]
          },
          application: {
            title: "How to Apply",
            description: "Ready to join our team? Here's how to get started.",
            steps: [
              "Browse our open positions",
              "Submit your application with resume",
              "Complete our interview process",
              "Join our amazing team!"
            ]
          }
        }
      }
    }
  };
}

const content = contentData.default[lang] || contentData.default.en;

// Get site title and description
const SITE_TITLE = "Careers | FastIPTV";
const SITE_DESCRIPTION = "Join our team and help shape the future of IPTV streaming";

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      isHomePage={false}
    />
  </head>
  <body class={`${lang === 'ar' ? 'rtl' : 'ltr'} bg-white text-gray-900`}>
    <Header transparent={false} />
    <main id="main-content" class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
      {/* Page Header */}
      <section class="relative py-20 px-4">
        <div class="max-w-7xl mx-auto text-center">
          <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
            {content.title}
          </h1>
          <p class="text-xl md:text-2xl text-gray-700 mb-8 max-w-3xl mx-auto">
            {content.subtitle}
          </p>
          <p class="text-lg text-gray-600 max-w-4xl mx-auto">
            {content.description}
          </p>
        </div>
      </section>

      {/* Why Join Section */}
      <section class="py-16 px-4">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.sections.whyJoin.title}</h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">{content.sections.whyJoin.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {content.sections.whyJoin.benefits.map((benefit) => (
              <div class="bg-white rounded-lg shadow-md p-6 text-center hover:shadow-lg transition-shadow">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">{benefit.title}</h3>
                <p class="text-gray-600">{benefit.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Open Positions Section */}
      <section class="py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.sections.openPositions.title}</h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">{content.sections.openPositions.description}</p>
          </div>
          
          <div class="space-y-6">
            {content.sections.openPositions.positions.map((position) => (
              <div class="bg-gray-50 rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                  <div class="mb-4 md:mb-0">
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">{position.title}</h3>
                    <div class="flex flex-wrap gap-4 text-sm text-gray-600">
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                        {position.department}
                      </span>
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        {position.location}
                      </span>
                      <span class="flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        {position.type}
                      </span>
                    </div>
                    <p class="text-gray-600 mt-2">{position.description}</p>
                  </div>
                  <div class="md:ml-6">
                    <button class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                      Apply Now
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Application Process Section */}
      <section class="py-16 px-4">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{content.sections.application.title}</h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">{content.sections.application.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {content.sections.application.steps.map((step, index) => (
              <div class="text-center">
                <div class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-lg font-bold">
                  {index + 1}
                </div>
                <p class="text-gray-700 font-medium">{step}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section class="py-16 px-4 bg-blue-50">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Ready to Join Our Team?</h2>
          <p class="text-gray-600 mb-6">Don't see a position that matches your skills? We're always looking for talented individuals.</p>
          <button class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors">
            Send Us Your Resume
          </button>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
