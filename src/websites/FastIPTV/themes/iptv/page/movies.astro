---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const lang = getLangFromUrl(Astro.url);
const translations = await useTranslations(lang);
const jsonData = translations.default;

// Load movies data dynamically based on language
const moviesData = await import(`../data/movies/movies_${lang}.json`);

const SITE_TITLE = jsonData.siteTitle || 'FastIPTV';
const PAGE_TITLE = moviesData.default.pageTitle || 'Movies | ' + SITE_TITLE;
const PAGE_DESCRIPTION = moviesData.default.pageDescription || 'Watch the latest movies in HD and 4K quality';

// Movie data from language-specific movies file
const movies = moviesData.default.movies;
const genres = moviesData.default.genres;
const years = moviesData.default.years;
const qualities = moviesData.default.qualities;
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} />
  </head>
  <body class="bg-[#0a0a0a] text-white">
    <Header />
    <main id="main-content" class="pt-24"> <!-- Add 96px (24 * 4px) padding to account for header height + extra space -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <section class="space-y-12">
          {/* Hero Section */}
          <div class="text-center space-y-4">
            <h1 class="text-4xl md:text-6xl font-bold gradient-text">
              {moviesData.default.heroTitle}
            </h1>
            <p class="text-xl text-gray-300 max-w-3xl mx-auto">
              {moviesData.default.heroDescription}
            </p>
          </div>

          {/* Search and Filters */}
          <div class="glass rounded-xl p-6 space-y-6">
            <div class="flex flex-col md:flex-row gap-4">
              <div class="flex-1">
                <input
                  type="search"
                  placeholder={lang === 'ar' ? 'البحث عن الأفلام...' : 
                             lang === 'es' ? 'Buscar películas...' :
                             lang === 'fr' ? 'Rechercher des films...' :
                             lang === 'de' ? 'Filme suchen...' :
                             lang === 'it' ? 'Cerca film...' :
                             lang === 'nl' ? 'Zoek films...' :
                             lang === 'pt' ? 'Pesquisar filmes...' :
                             lang === 'ru' ? 'Поиск фильмов...' :
                             lang === 'zh' ? '搜索电影...' :
                             'Search movies...'}
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500"
                />
              </div>
              <div class="flex gap-4">
                <select class="px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500">
                  <option value="">{lang === 'ar' ? 'جميع الأنواع' : 
                                   lang === 'es' ? 'Todos los Géneros' :
                                   lang === 'fr' ? 'Tous les Genres' :
                                   lang === 'de' ? 'Alle Genres' :
                                   lang === 'it' ? 'Tutti i Generi' :
                                   lang === 'nl' ? 'Alle Genres' :
                                   lang === 'pt' ? 'Todos os Gêneros' :
                                   lang === 'ru' ? 'Все Жанры' :
                                   lang === 'zh' ? '所有类型' :
                                   'All Genres'}</option>
                  {genres.map(genre => (
                    <option value={genre.toLowerCase()}>{genre}</option>
                  ))}
                </select>
                <select class="px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500">
                  <option value="">{lang === 'ar' ? 'سنة الإصدار' : 
                                   lang === 'es' ? 'Año de Lanzamiento' :
                                   lang === 'fr' ? 'Année de Sortie' :
                                   lang === 'de' ? 'Erscheinungsjahr' :
                                   lang === 'it' ? 'Anno di Uscita' :
                                   lang === 'nl' ? 'Uitgavejaar' :
                                   lang === 'pt' ? 'Ano de Lançamento' :
                                   lang === 'ru' ? 'Год Выпуска' :
                                   lang === 'zh' ? '发行年份' :
                                   'Release Year'}</option>
                  {years.map(year => (
                    <option value={year}>{year}</option>
                  ))}
                </select>
                <select class="px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500">
                  <option value="">{lang === 'ar' ? 'الجودة' : 
                                   lang === 'es' ? 'Calidad' :
                                   lang === 'fr' ? 'Qualité' :
                                   lang === 'de' ? 'Qualität' :
                                   lang === 'it' ? 'Qualità' :
                                   lang === 'nl' ? 'Kwaliteit' :
                                   lang === 'pt' ? 'Qualidade' :
                                   lang === 'ru' ? 'Качество' :
                                   lang === 'zh' ? '质量' :
                                   'Quality'}</option>
                  {qualities.map(quality => (
                    <option value={quality.toLowerCase()}>{quality}</option>
                  ))}
                </select>
              </div>
            </div>
          </div>

          {/* Featured Movies */}
          <div class="space-y-6">
            <h2 class="text-2xl font-bold text-purple-400">
              {lang === 'ar' ? 'الأفلام المميزة' : 
               lang === 'es' ? 'Películas Destacadas' :
               lang === 'fr' ? 'Films en Vedette' :
               lang === 'de' ? 'Empfohlene Filme' :
               lang === 'it' ? 'Film in Evidenza' :
               lang === 'nl' ? 'Uitgelichte Films' :
               lang === 'pt' ? 'Filmes em Destaque' :
               lang === 'ru' ? 'Рекомендуемые Фильмы' :
               lang === 'zh' ? '精选电影' :
               'Featured Movies'}
            </h2>
            <div class="grid md:grid-cols-3 gap-8">
              {movies.featured.map(movie => (
                <div class="glass rounded-xl overflow-hidden hover-scale hover-glow">
                  <div class="aspect-video bg-white/5 relative">
                    <img 
                      src={movie.image} 
                      alt={movie.title}
                      width={640}
                      height={360}
                      style="aspect-ratio: 16/9"
                      class="w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="absolute top-2 right-2 bg-purple-600 text-white px-2 py-1 rounded-lg text-sm">
                      {movie.quality}
                    </div>
                  </div>
                  <div class="p-4 space-y-2">
                    <div class="flex items-center justify-between">
                      <span class="text-sm text-gray-400">{movie.genre}</span>
                      <div class="flex items-center gap-1">
                        <span class="text-yellow-400">★</span>
                        <span>{movie.rating}</span>
                      </div>
                    </div>
                    <div class="flex items-center justify-between text-sm text-gray-400">
                      <span>{movie.year}</span>
                      <span>{movie.duration}</span>
                    </div>
                    <button class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 rounded-lg transition duration-200">
                      {lang === 'ar' ? 'شاهد الآن' : 
                       lang === 'es' ? 'Ver Ahora' :
                       lang === 'fr' ? 'Regarder Maintenant' :
                       lang === 'de' ? 'Jetzt Ansehen' :
                       lang === 'it' ? 'Guarda Ora' :
                       lang === 'nl' ? 'Nu Bekijken' :
                       lang === 'pt' ? 'Assistir Agora' :
                       lang === 'ru' ? 'Смотреть Сейчас' :
                       lang === 'zh' ? '立即观看' :
                       'Watch Now'}
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Movie Categories */}
          <div class="space-y-12">
            {movies.categories.map(category => (
              <div class="space-y-6">
                <h2 class="text-2xl font-bold text-purple-400">{category.name}</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
                  {category.movies.map(movie => (
                    <div class="glass rounded-xl overflow-hidden hover-scale hover-glow">
                      <div class="aspect-[2/3] bg-white/5 relative">
                        <img 
                          src={movie.image} 
                          alt={movie.title}
                          width={400}
                          height={600}
                          style="aspect-ratio: 2/3"
                          class="w-full h-full object-cover"
                          loading="lazy"
                          decoding="async"
                        />
                        <div class="absolute top-2 right-2 bg-purple-600 text-white px-2 py-1 rounded-lg text-sm">
                          {movie.quality}
                        </div>
                      </div>
                      <div class="p-3 space-y-2">
                        <div class="flex items-center justify-between text-sm">
                          <span>{movie.year}</span>
                          <div class="flex items-center gap-1">
                            <span class="text-yellow-400">★</span>
                            <span>{movie.rating}</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>

          {/* CTA Section */}
          <div class="glass rounded-2xl p-8 text-center space-y-6">
            <h2 class="text-3xl font-bold gradient-text">
              {lang === 'ar' ? 'أفلام غير محدودة' : 
               lang === 'es' ? 'Películas Ilimitadas' :
               lang === 'fr' ? 'Films Illimités' :
               lang === 'de' ? 'Unbegrenzte Filme' :
               lang === 'it' ? 'Film Illimitati' :
               lang === 'nl' ? 'Onbeperkte Films' :
               lang === 'pt' ? 'Filmes Ilimitados' :
               lang === 'ru' ? 'Неограниченные Фильмы' :
               lang === 'zh' ? '无限电影' :
               'Unlimited Movies'}
            </h2>
            <p class="text-xl text-gray-300">
              {lang === 'ar' ? 'احصل على الوصول إلى مجموعتنا الكاملة من الأفلام مع اشتراك FastIPTV.' : 
               lang === 'es' ? 'Obtén acceso a toda nuestra colección de películas con una suscripción FastIPTV.' :
               lang === 'fr' ? 'Accédez à toute notre collection de films avec un abonnement FastIPTV.' :
               lang === 'de' ? 'Erhalten Sie Zugang zu unserer gesamten Filmsammlung mit einem FastIPTV-Abonnement.' :
               lang === 'it' ? 'Ottieni accesso alla nostra intera collezione di film con un abbonamento FastIPTV.' :
               lang === 'nl' ? 'Krijg toegang tot onze volledige filmcollectie met een FastIPTV-abonnement.' :
               lang === 'pt' ? 'Obtenha acesso a toda nossa coleção de filmes com uma assinatura FastIPTV.' :
               lang === 'ru' ? 'Получите доступ ко всей нашей коллекции фильмов с подпиской FastIPTV.' :
               lang === 'zh' ? '通过FastIPTV订阅获得我们完整电影库的访问权限。' :
               'Get access to our entire movie collection with a FastIPTV subscription.'}
            </p>
            <div class="flex justify-center gap-4">
              <a
                href={`/${lang}/pricing`}
                class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
              >
                {lang === 'ar' ? 'عرض الخطط' : 
                 lang === 'es' ? 'Ver Planes' :
                 lang === 'fr' ? 'Voir les Forfaits' :
                 lang === 'de' ? 'Pläne Anzeigen' :
                 lang === 'it' ? 'Visualizza Piani' :
                 lang === 'nl' ? 'Plannen Bekijken' :
                 lang === 'pt' ? 'Ver Planos' :
                 lang === 'ru' ? 'Посмотреть Планы' :
                 lang === 'zh' ? '查看套餐' :
                 'View Plans'}
              </a>
              <a
                href={`/${lang}/signup`}
                class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
              >
                {lang === 'ar' ? 'ابدأ التجربة المجانية' : 
                 lang === 'es' ? 'Comenzar Prueba Gratuita' :
                 lang === 'fr' ? 'Commencer l\'Essai Gratuit' :
                 lang === 'de' ? 'Kostenlose Testversion Starten' :
                 lang === 'it' ? 'Inizia Prova Gratuita' :
                 lang === 'nl' ? 'Gratis Proefperiode Starten' :
                 lang === 'pt' ? 'Iniciar Teste Gratuito' :
                 lang === 'ru' ? 'Начать Бесплатную Пробу' :
                 lang === 'zh' ? '开始免费试用' :
                 'Start Free Trial'}
              </a>
            </div>
          </div>
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html> 