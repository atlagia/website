---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const lang = getLangFromUrl(Astro.url);
const translations = await useTranslations(lang);
const jsonData = translations.default;

// Load signup data dynamically
let signupData;
try {
  const signupModule = await import(`../data/signup/signup_${lang}.json`);
  signupData = signupModule.default;
} catch (error) {
  // Fallback to English if language-specific file doesn't exist
  const signupModule = await import(`../data/signup/signup_en.json`);
  signupData = signupModule.default;
}

const SITE_TITLE = jsonData.siteTitle || 'FastIPTV';
const PAGE_TITLE = signupData.pageTitle + ' | ' + SITE_TITLE;
const PAGE_DESCRIPTION = signupData.pageDescription;
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} />
  </head>
  <body class="bg-black text-white">
    <Header />
    <main class="pt-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {/* Hero Section with Urgency */}
        <div class="text-center space-y-6 mb-12">
          <div class="inline-block bg-red-600 text-white px-6 py-2 rounded-full text-sm font-bold animate-pulse">
            {signupData.urgencyBadge}
          </div>
          <h1 class="text-4xl md:text-6xl font-bold gradient-text">
            {signupData.heroTitle}
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            {signupData.heroDescription}
          </p>
          <div class="flex justify-center items-center gap-4 text-sm text-gray-400">
            <span>✓ {signupData.trustIndicators.instant}</span>
            <span>✓ {signupData.trustIndicators.secure}</span>
            <span>✓ {signupData.trustIndicators.support}</span>
          </div>
        </div>

        {/* Social Proof */}
        <div class="glass rounded-xl p-6 mb-12">
          <div class="text-center space-y-4">
            <p class="text-lg font-semibold">{signupData.socialProof.title}</p>
            <div class="flex justify-center items-center gap-8 text-sm">
              <div class="flex items-center gap-2">
                <span class="text-yellow-400">★★★★★</span>
                <span>{signupData.socialProof.rating}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-emerald-400">👥</span>
                <span>{signupData.socialProof.users}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-blue-400">📺</span>
                <span>{signupData.socialProof.channels}</span>
              </div>
            </div>
          </div>
        </div>

        {/* Featured Package */}
        <div class="glass rounded-2xl p-8 mb-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-gradient-to-r from-purple-600 to-emerald-500 text-white px-6 py-2 rounded-bl-2xl">
            {signupData.featuredPackage.savings}
          </div>
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <h1 class="text-4xl font-bold mb-4 gradient-text">
                {signupData.featuredPackage.name}
              </h1>
              <p class="text-gray-300 mb-6">
                {signupData.featuredPackage.description}
              </p>
              <div class="flex items-baseline mb-8">
                <span class="text-5xl font-bold">${signupData.featuredPackage.price}</span>
                <span class="text-gray-400 ml-2">/{signupData.featuredPackage.duration}</span>
              </div>
              <ul class="space-y-4 mb-8">
                {signupData.featuredPackage.features.map(feature => (
                  <li class="flex items-center text-gray-300">
                    <svg class="h-5 w-5 text-emerald-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a
                href={signupData.featuredPackage.checkoutUrl}
                class="inline-block bg-gradient-to-r from-purple-600 to-emerald-500 text-white px-8 py-3 rounded-lg hover:opacity-90 transition-opacity duration-200"
              >
                {signupData.featuredPackage.ctaButton}
              </a>
            </div>
            <div class="relative">
              <!-- Add package illustration or image here -->
            </div>
          </div>
        </div>

        {/* Bundle Options */}
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          {signupData.bundles.map(bundle => (
            <div class="glass rounded-xl p-6 space-y-6">
              {bundle.highlight && (
                <div class="text-center">
                  <span class="bg-purple-600 text-white px-4 py-1 rounded-full text-sm">
                    {bundle.highlight}
                  </span>
                </div>
              )}
              <div class="text-center space-y-2">
                <h3 class="text-2xl font-bold">{bundle.name}</h3>
                <p class="text-gray-400">{bundle.description}</p>
              </div>
              <div class="text-center">
                <div class="flex items-end justify-center gap-1">
                  <span class="text-3xl font-bold">${bundle.price}</span>
                  <span class="text-gray-400">/{bundle.duration}</span>
                </div>
              </div>
              <ul class="space-y-3">
                {bundle.features.map(feature => (
                  <li class="flex items-center gap-2">
                    <span class="text-emerald-400">✓</span>
                    <span class="text-gray-300">{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={bundle.checkoutUrl}
                class="w-full bg-white/10 hover:bg-white/20 text-white font-bold py-2 rounded-lg transition duration-200 text-center block"
              >
                {bundle.ctaButton}
              </a>
            </div>
          ))}
        </div>

        {/* Add-ons */}
        <div class="space-y-6 mb-12">
          <h2 class="text-2xl font-bold text-purple-400">{signupData.addons.title}</h2>
          <div class="grid md:grid-cols-4 gap-6">
            {signupData.addons.list.map(addon => (
              <div class="glass rounded-xl p-6 space-y-4">
                <div class="flex justify-between items-start">
                  <div>
                    <h3 class="font-bold">{addon.name}</h3>
                    <p class="text-sm text-gray-400">{addon.description}</p>
                  </div>
                  <span class="text-lg font-bold">${addon.price}</span>
                </div>
                <a
                  href={addon.checkoutUrl}
                  class="w-full bg-white/10 hover:bg-white/20 text-white py-2 rounded-lg transition duration-200 text-center block"
                >
                  {addon.ctaButton}
                </a>
              </div>
            ))}
          </div>
        </div>

        {/* Special Offers */}
        <div class="space-y-6 mb-12">
          <h2 class="text-2xl font-bold text-purple-400">{signupData.specialOffers.title}</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {signupData.specialOffers.list.map(offer => (
              <div class="glass rounded-xl p-6 space-y-4">
                <div class="flex items-start justify-between">
                  <h3 class="font-bold">{offer.name}</h3>
                  <span class="bg-emerald-600 text-white px-2 py-1 rounded-full text-xs">
                    {offer.badge}
                  </span>
                </div>
                <p class="text-gray-400">{offer.description}</p>
                <a
                  href={offer.checkoutUrl}
                  class="w-full bg-white/10 hover:bg-white/20 text-white py-2 rounded-lg transition duration-200 text-center block"
                >
                  {offer.ctaButton}
                </a>
              </div>
            ))}
          </div>
        </div>

        {/* Testimonials */}
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-center mb-8">{signupData.testimonials.title}</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {signupData.testimonials.list.map(testimonial => (
              <div class="glass rounded-xl p-6">
                <div class="flex items-center gap-2 mb-4">
                  <span class="text-yellow-400">★★★★★</span>
                  <span class="text-sm text-gray-400">{testimonial.rating}</span>
                </div>
                <p class="text-gray-300 mb-4">"{testimonial.text}"</p>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-purple-600 rounded-full flex items-center justify-center">
                    {testimonial.avatar}
                  </div>
                  <div>
                    <p class="font-semibold">{testimonial.name}</p>
                    <p class="text-sm text-gray-400">{testimonial.location}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* FAQ Section */}
        <div class="glass rounded-2xl p-8 mb-12">
          <h2 class="text-2xl font-bold text-center mb-8">{signupData.faq.title}</h2>
          <div class="grid md:grid-cols-2 gap-6">
            {signupData.faq.questions.map(question => (
              <div class="space-y-2">
                <h3 class="font-semibold">{question.question}</h3>
                <p class="text-gray-300 text-sm">{question.answer}</p>
              </div>
            ))}
          </div>
        </div>

        {/* Final CTA */}
        <div class="glass rounded-2xl p-8 text-center space-y-6 mb-12">
          <h2 class="text-3xl font-bold gradient-text">{signupData.finalCta.title}</h2>
          <p class="text-xl text-gray-300">{signupData.finalCta.description}</p>
          <div class="flex justify-center gap-4">
            <a
              href={signupData.finalCta.primaryButton.link}
              class="bg-gradient-to-r from-purple-600 to-emerald-500 text-white font-bold py-3 px-8 rounded-lg hover:opacity-90 transition-opacity duration-200"
            >
              {signupData.finalCta.primaryButton.text}
            </a>
            <a
              href={signupData.finalCta.secondaryButton.link}
              class="bg-white/10 hover:bg-white/20 text-white font-bold py-3 px-8 rounded-lg transition duration-200"
            >
              {signupData.finalCta.secondaryButton.text}
            </a>
          </div>
        </div>
      </div>
    </main>
    <Footer />


  </body>
</html>
