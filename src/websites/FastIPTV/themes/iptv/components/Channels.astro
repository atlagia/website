---
interface Props {
  title?: string;
  description?: string;
  channels?: {
    title: string;
    poster: string;
    category?: string;
  }[];
}

const { 
  title = "Best Streaming IPTV Platforms of 2025",
  description = "We are proud to offer the best IPTV service available",
  channels = []
} = Astro.props;
---

<section class="bg-black py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        {title}
      </h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto">
        {description}
      </p>
    </div>

    {channels.length > 0 && (
      <div class="channels-slider relative overflow-hidden">
        <div class="channels-container flex space-x-6 animate-slide">
          {/* Duplicate channels for infinite scroll effect */}
          {[...channels, ...channels].map((channel) => (
            <div class="channel-item flex-shrink-0 w-48 md:w-64 group">
              <div class="
                relative 
                overflow-hidden 
                rounded-xl 
                shadow-lg 
                transform 
                transition-all 
                duration-300 
                hover:scale-105 
                hover:shadow-2xl
              ">
                <img 
                  src={channel.poster} 
                  alt={channel.title} 
                  class="
                    w-full 
                    h-72 
                    md:h-96 
                    object-cover 
                    transition-transform 
                    duration-300 
                    group-hover:scale-110
                  "
                />
                <div class="
                  absolute 
                  inset-0 
                  bg-gradient-to-b 
                  from-transparent 
                  via-black/30 
                  to-black/80 
                  opacity-0 
                  group-hover:opacity-100 
                  transition-opacity 
                  duration-300
                "></div>
                <div class="
                  absolute 
                  bottom-0 
                  left-0 
                  right-0 
                  p-4 
                  text-white 
                  opacity-0 
                  group-hover:opacity-100 
                  transition-opacity 
                  duration-300
                ">
                  <h3 class="
                    text-lg 
                    font-bold 
                    mb-1 
                    truncate
                    text-shadow
                  ">
                    {channel.title}
                  </h3>
                  <p class="
                    text-sm 
                    text-gray-300 
                    uppercase 
                    tracking-wider
                  ">
                    {channel.category}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  @keyframes slide {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-slide {
    animation: slide 20s linear infinite;
  }

  .channels-slider:hover .animate-slide {
    animation-play-state: paused;
  }

  .text-shadow {
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const channelsContainer = document.querySelector('.channels-container');
    
    if (channelsContainer) {
      // Pause animation on hover
      channelsContainer.addEventListener('mouseenter', () => {
        channelsContainer.style.animationPlayState = 'paused';
      });

      // Resume animation when mouse leaves
      channelsContainer.addEventListener('mouseleave', () => {
        channelsContainer.style.animationPlayState = 'running';
      });
    }
  });
</script> 