---
interface Props {
  title: string;
  description: string;
  stats: {
    channels: string;
    movies: string;
    shows: string;
  };
  cta: {
    primary: { text: string; link: string };
    secondary: { text: string; link: string };
  };
  backgroundImages?: string[];
}

const { title, description, stats, cta, backgroundImages = [] } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-20 sm:py-24 lg:py-32 bg-[#0a0a0a]">
  <!-- Cinematic background with strong overlay for text readability -->
  <div class="absolute inset-0">
    {backgroundImages.length > 0 ? (
      <div class="absolute inset-0 background-slider">
        {backgroundImages.map((image, i) => (
          <div
            class="absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
            style={`background-image:url('${image}');opacity:${i===0?1:0};z-index:${i===0?2:1}`}
            data-slide={i}
          />
        ))}
      </div>
    ) : null}
    <div class="absolute inset-0 bg-gradient-to-b from-black/85 via-black/75 to-[#0a0a0a]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(139,92,246,0.12),transparent)]" />
  </div>

  <!-- Particle glow effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/20 rounded-full blur-[100px] animate-pulse" />
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-blue-500/15 rounded-full blur-[80px] animate-pulse" style="animation-delay:1s" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cyan-500/5 rounded-full blur-[120px]" />
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-md border border-white/10 mb-8">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75" />
        <span class="relative inline-flex rounded-full h-2 w-2 bg-purple-500" />
      </span>
      <span class="text-sm font-medium text-white/90">Premium IPTV • 32,000+ Channels</span>
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white tracking-tight max-w-5xl mx-auto mb-6 leading-[1.15] px-1">
      <span class="block drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)]">Unlimited Entertainment.</span>
      <span class="block bg-gradient-to-r from-purple-400 via-blue-400 to-cyan-400 bg-clip-text text-transparent drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)]">
        One Powerful IPTV Platform.
      </span>
    </h1>

    <p class="text-base sm:text-lg md:text-xl text-gray-200 max-w-2xl mx-auto mb-10 leading-relaxed px-2">
      {description}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
      <a
        href={cta.primary.link}
        class="group inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold text-lg shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5"
      >
        {cta.primary.text}
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href={cta.secondary.link}
        class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold hover:bg-white/10 hover:border-white/20 transition-all duration-300"
      >
        {cta.secondary.text}
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 max-w-4xl mx-auto px-2">
      {Object.entries(stats).map(([key, value], i) => (
        <div
          class="group relative p-5 sm:p-6 rounded-2xl bg-white/[0.06] backdrop-blur-md border border-white/10 hover:border-purple-500/30 transition-all duration-300 hover:shadow-[0_0_30px_rgba(139,92,246,0.2)]"
          style={`animation: fadeUp 0.6s ease-out ${i*0.1}s both`}
        >
          <p class="text-xl sm:text-2xl md:text-3xl font-bold text-white">{value}</p>
          <p class="text-sm text-gray-300 capitalize mt-1">{key === 'shows' ? 'TV Shows' : key}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.background-slider > div');
    if (slides.length <= 1) return;
    let i = 0;
    setInterval(() => {
      slides[i].style.opacity = '0';
      slides[i].style.zIndex = '1';
      i = (i + 1) % slides.length;
      slides[i].style.opacity = '1';
      slides[i].style.zIndex = '2';
    }, 6000);
  });
</script>
