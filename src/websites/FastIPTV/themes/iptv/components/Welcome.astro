---
interface Props {
  title: string;
  description: string;
  stats: {
    channels: string;
    movies: string;
    shows: string;
  };
  cta: {
    primary: {
      text: string;
      link: string;
    };
    secondary: {
      text: string;
      link: string;
    };
  };
  backgroundImages?: string[];
}

const { 
  title, 
  description, 
  stats, 
  cta,
  backgroundImages = []
} = Astro.props;

// Split title to highlight the last word
const words = title.split(' ');
const lastWord = words.pop();
const titleStart = words.join(' ');

// Features list
const features = [
  { icon: "📺", text: "HD Quality Streaming" },
  { icon: "🌍", text: "Global Content" },
  { icon: "📱", text: "Multi-device Support" },
  { icon: "⚡", text: "Low Latency" }
];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden py-20 lg:py-32 bg-black">
  <!-- Background Image Slider -->
  <div class="absolute inset-0 bg-black/90">
    <div class="background-slider absolute inset-0">
      {backgroundImages.map((image, index) => (
        <div 
          class={`
            absolute 
            inset-0 
            bg-cover 
            bg-center 
            transition-opacity 
            duration-1000 
            ease-in-out
          `}
          style={`
            background-image: url('${image}');
            opacity: ${index === 0 ? 1 : 0};
            z-index: ${index === 0 ? 10 : 1};
          `}
          data-slide={index}
        >
          {/* Dark gradient overlay */}
          <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/70 to-black/90"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Additional Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-black/90 via-black/80 to-black/90 opacity-80"></div>
  
  <!-- Animated Grid Lines -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute h-[1px] w-full top-1/4 left-0 bg-gradient-to-r from-transparent via-purple-500/20 to-transparent animate-[gradient-slide-1_8s_infinite]"></div>
    <div class="absolute h-[1px] w-full top-2/4 left-0 bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent animate-[gradient-slide-2_12s_infinite]"></div>
    <div class="absolute h-[1px] w-full top-3/4 left-0 bg-gradient-to-r from-transparent via-purple-500/20 to-transparent animate-[gradient-slide-3_10s_infinite]"></div>
    <!-- Vertical Lines -->
    <div class="absolute w-[1px] h-full left-1/4 top-0 bg-gradient-to-b from-transparent via-purple-500/20 to-transparent animate-[gradient-slide-vertical_15s_infinite]"></div>
    <div class="absolute w-[1px] h-full left-3/4 top-0 bg-gradient-to-b from-transparent via-emerald-500/20 to-transparent animate-[gradient-slide-vertical_12s_infinite]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full z-20">
    <!-- Enhanced Premium Badge -->
    <div class="flex justify-center mb-8">
      <div class="group inline-flex items-center px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 shadow-2xl hover:bg-white/10 transition-all duration-300">
        <span class="flex h-2 w-2 mr-2">
          <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-purple-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-purple-500"></span>
        </span>
        <span class="text-white/90 text-sm font-medium group-hover:text-white transition-colors">Premium IPTV Service</span>
        <!-- Animated Dots -->
        <div class="flex space-x-1 ml-2">
          {Array.from({ length: 3 }).map((_, i) => (
            <span
              class="w-1 h-1 rounded-full bg-purple-500 animate-bounce"
              style={`animation-delay: ${i * 0.5}s`}
            ></span>
          ))}
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-white mb-6 perspective">
        <span class="inline-block hover:animate-float">{titleStart}</span>
        <span class="inline-block bg-gradient-to-r from-purple-400 via-purple-500 to-emerald-400 text-transparent bg-clip-text animate-gradient-x hover:scale-110 transition-transform duration-300">
          {lastWord}
        </span>
      </h1>
      
      <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed max-w-3xl mx-auto animate-fade-in">
        {description}
      </p>

      <!-- Features List -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        {features.map((feature, index) => (
          <div 
            class="feature-card bg-white/5 backdrop-blur-sm rounded-lg px-4 py-2 flex items-center space-x-2 hover:bg-white/10 transition-all duration-300"
            style={`animation-delay: ${index * 0.2}s`}
          >
            <span class="text-2xl animate-bounce" style={`animation-delay: ${index * 0.1}s`}>{feature.icon}</span>
            <span class="text-gray-300">{feature.text}</span>
          </div>
        ))}
      </div>

      <!-- Enhanced CTA Buttons -->
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
        <a
          href={cta.primary.link}
          class="group inline-flex items-center px-8 py-3 rounded-lg bg-gradient-to-r from-purple-600 to-emerald-500 text-white font-semibold shadow-lg shadow-purple-500/25 hover:shadow-purple-500/50 transform hover:-translate-y-0.5 transition-all duration-200 relative overflow-hidden"
        >
          <span class="relative z-10 flex items-center">
            {cta.primary.text}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-emerald-500 opacity-0 group-hover:opacity-50 transition-opacity duration-300"></div>
        </a>
        <a
          href={cta.secondary.link}
          class="group inline-flex items-center px-8 py-3 rounded-lg bg-white/5 text-white font-semibold backdrop-blur-sm border border-white/10 hover:bg-white/10 transform hover:-translate-y-0.5 transition-all duration-200"
        >
          <span class="relative z-10">{cta.secondary.text}</span>
          <div class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/5 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
      </div>

      <!-- Enhanced Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {Object.entries(stats).map(([key, value], index) => (
          <div class="relative group perspective" style={`animation-delay: ${index * 0.2}s`}>
            <div class="absolute inset-0 bg-gradient-to-r from-purple-600/20 to-emerald-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
            <div class="relative p-8 rounded-2xl bg-white/5 backdrop-blur-sm border border-white/10 hover:border-white/20 transition-all duration-300 transform group-hover:rotate-y-12 group-hover:scale-105">
              <div class="flex items-center justify-center mb-4">
                {key === 'channels' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-purple-400 group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
                {key === 'movies' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-400 group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
                  </svg>
                )}
                {key === 'shows' && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-purple-400 group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                )}
              </div>
              <h3 class="text-2xl lg:text-3xl font-bold text-white mb-2 group-hover:scale-105 transition-transform">{value}</h3>
              <p class="text-sm text-gray-400 capitalize group-hover:text-gray-300 transition-colors">{key === 'shows' ? 'TV Shows' : key}</p>
              
              <!-- Animated Corner Accents -->
              <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-purple-500/30 rounded-tl-lg"></div>
              <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-emerald-500/30 rounded-br-lg"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Randomly position particles
  const particles = document.querySelectorAll('.particle');
  particles.forEach(particle => {
    const x = Math.random() * 100;
    const y = Math.random() * 100;
    particle.style.left = `${x}%`;
    particle.style.top = `${y}%`;
  });

  // Background Image Slider
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.background-slider > div');
    
    // Exit if no slides or only one slide
    if (slides.length <= 1) return;

    let currentSlide = 0;

    function nextSlide() {
      // Hide current slide
      slides[currentSlide].style.opacity = '0';
      slides[currentSlide].style.zIndex = '1';

      // Move to next slide
      currentSlide = (currentSlide + 1) % slides.length;

      // Show next slide
      slides[currentSlide].style.opacity = '1';
      slides[currentSlide].style.zIndex = '10';
    }

    // Start the slider
    const sliderInterval = setInterval(nextSlide, 5000); // Change slide every 5 seconds

    // Optional: Pause slider on hover (uncomment if desired)
    const sliderContainer = document.querySelector('.background-slider');
    sliderContainer.addEventListener('mouseenter', () => {
      clearInterval(sliderInterval);
    });
    sliderContainer.addEventListener('mouseleave', () => {
      // Restart the interval when mouse leaves
      sliderInterval = setInterval(nextSlide, 5000);
    });
  });
</script>

<style>
  /* Existing styles from previous component */
  @keyframes gradient-slide-1 {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(100%); }
  }
  @keyframes gradient-slide-2 {
    0%, 100% { transform: translateX(100%); }
    50% { transform: translateX(-100%); }
  }
  @keyframes gradient-slide-3 {
    0%, 100% { transform: translateX(-50%); }
    50% { transform: translateX(50%); }
  }
  @keyframes gradient-slide-vertical {
    0%, 100% { transform: translateY(-100%); }
    50% { transform: translateY(100%); }
  }
  @keyframes gradient-x {
    0%, 100% { background-size: 200% 200%; background-position: left center; }
    50% { background-size: 200% 200%; background-position: right center; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @keyframes rotate-y {
    0% { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
  }
  .animate-gradient-x {
    animation: gradient-x 8s ease infinite;
  }
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  .perspective {
    perspective: 1000px;
  }
  .rotate-y-12 {
    transform: rotateY(12deg);
  }
  .feature-card {
    animation: slideIn 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .particles .particle {
    position: absolute;
    animation: float var(--speed) ease-in-out infinite;
    width: var(--size);
    height: var(--size);
    animation-delay: var(--delay);
    opacity: 0.6;
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style> 