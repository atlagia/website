---
interface Props {
  title: string;
  description: string;
  testimonials: {
    name: string;
    location: string;
    rating: number;
    comment: string;
  }[];
}

const { title, description, testimonials } = Astro.props;
---

<section class="relative py-24 overflow-hidden bg-[#0a0a0a]">
  <!-- Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-900/20 via-black to-black"></div>
    <!-- Animated Quote Marks -->
    <div class="absolute top-20 left-10 text-8xl text-purple-500/10 font-serif animate-float">"</div>
    <div class="absolute bottom-20 right-10 text-8xl text-emerald-500/10 font-serif animate-float-delay">"</div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 animate-fade-in">
        {title}
      </h2>
      <p class="text-gray-300 text-lg animate-fade-in-delay">
        {description}
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div 
          class="testimonial-card group relative"
          style={`animation-delay: ${index * 0.2}s`}
        >
          <!-- Card Background -->
          <div class="absolute inset-0 bg-gradient-to-br from-purple-900/30 to-emerald-900/30 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white/[0.03] backdrop-blur-xl rounded-2xl p-8 border border-white/10 group-hover:border-purple-500/30 group-hover:shadow-[0_0_30px_rgba(139,92,246,0.15)] transition-all duration-300">
            <!-- Rating Stars -->
            <div class="flex space-x-1 mb-6">
              {Array.from({ length: testimonial.rating }).map((_, i) => (
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="h-5 w-5 text-yellow-500 animate-star" 
                  style={`animation-delay: ${i * 0.1}s`}
                  viewBox="0 0 20 20" 
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Comment -->
            <p class="text-gray-300 mb-6 italic">"{testimonial.comment}"</p>

            <!-- User Info -->
            <div class="flex items-center">
              <div class="w-10 h-10 rounded-full bg-gradient-to-r from-purple-500 to-emerald-500 flex items-center justify-center text-white font-semibold">
                {testimonial.name.charAt(0)}
              </div>
              <div class="ml-3">
                <h4 class="text-white font-medium">{testimonial.name}</h4>
                <p class="text-gray-300 text-sm">{testimonial.location}</p>
              </div>
            </div>

            <!-- Corner Accents -->
            <div class="absolute top-0 left-0 w-16 h-16 pointer-events-none">
              <div class="absolute top-0 left-0 w-[2px] h-8 bg-gradient-to-b from-purple-500/50 to-transparent transform origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
              <div class="absolute top-0 left-0 w-8 h-[2px] bg-gradient-to-r from-purple-500/50 to-transparent transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            </div>
            <div class="absolute bottom-0 right-0 w-16 h-16 pointer-events-none">
              <div class="absolute bottom-0 right-0 w-[2px] h-8 bg-gradient-to-t from-emerald-500/50 to-transparent transform origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
              <div class="absolute bottom-0 right-0 w-8 h-[2px] bg-gradient-to-l from-emerald-500/50 to-transparent transform origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Badge -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center px-6 py-3 rounded-full bg-white/5 backdrop-blur-sm border border-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-white/90 text-sm font-medium">Trusted by Thousands of Users Worldwide</span>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .animate-fade-in-delay {
    animation: fadeIn 0.5s ease-out 0.2s forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-delay {
    animation: float 6s ease-in-out infinite 3s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  .animate-star {
    animation: star 0.5s ease-out forwards;
    opacity: 0;
    transform: scale(0);
  }

  @keyframes star {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  // Add intersection observer for animation triggers
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('show');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
    }
  );

  document.querySelectorAll('.testimonial-card').forEach((card) => {
    observer.observe(card);
  });
</script> 