---
interface Props {
  title: string;
  description: string;
  plans: {
    name: string;
    price: string;
    duration: string;
    checkoutUrl: string;
    features: string[];
    isPopular: boolean;
  }[];
}

const { title, description, plans } = Astro.props;
---

<section class="relative py-24 overflow-hidden bg-[#0a0a0a]">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_100%,rgba(59,130,246,0.06),transparent_50%)]" />
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">{title}</h2>
      <p class="text-gray-300 text-lg">{description}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map((plan, i) => (
        <div
          class={`relative group ${plan.isPopular ? 'md:-translate-y-2' : ''}`}
          style={`animation: priceFade 0.6s ease-out ${i * 0.1}s both`}
        >
          {plan.isPopular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1.5 rounded-full bg-gradient-to-r from-purple-600 to-blue-600 text-white text-sm font-semibold shadow-lg shadow-purple-500/30">
              Most Popular
            </div>
          )}
          <div
            class={`relative p-8 rounded-2xl backdrop-blur-xl border transition-all duration-300 h-full flex flex-col
              ${plan.isPopular
                ? 'bg-gradient-to-b from-purple-500/10 to-transparent border-purple-500/30 hover:shadow-[0_0_50px_rgba(139,92,246,0.2)]'
                : 'bg-white/[0.03] border-white/10 hover:border-white/20'
              }`}
          >
            <h3 class="text-xl font-bold text-white mb-2">{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-4xl font-bold text-white">${plan.price}</span>
              <span class="text-gray-300">/{plan.duration}</span>
            </div>
            <ul class="space-y-4 mb-8 flex-1">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-gray-300">
                  <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a
              href={plan.checkoutUrl}
              class={`block w-full py-3 px-6 rounded-xl text-center font-semibold transition-all duration-300
                ${plan.isPopular
                  ? 'bg-gradient-to-r from-purple-600 to-blue-600 text-white hover:shadow-lg hover:shadow-purple-500/30'
                  : 'bg-white/10 text-white hover:bg-white/20 border border-white/10'
                }`}
            >
              Get Started
            </a>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10">
        <svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm font-medium text-white/90">30-Day Money Back Guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes priceFade {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
