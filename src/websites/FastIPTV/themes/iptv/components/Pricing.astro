---
interface Props {
  title: string;
  description: string;
  plans: {
    name: string;
    price: string;
    duration: string;
    checkoutUrl: string;
    features: string[];
    isPopular: boolean;
  }[];
}

const { title, description, plans } = Astro.props;
---

<section class="relative py-20 overflow-hidden bg-black">
  <!-- Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-900/20 via-black to-black"></div>
    <!-- Animated Circles -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-emerald-500/30 rounded-full blur-3xl animate-pulse-slow-delay"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4 animate-fade-in">
        {title}
      </h2>
      <p class="text-gray-400 text-lg animate-fade-in-delay">
        {description}
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map((plan, index) => (
        <div 
          class={`pricing-card group relative ${plan.isPopular ? 'scale-105 md:-translate-y-4' : ''}`}
          style={`animation-delay: ${index * 0.2}s`}
        >
          <!-- Card Background -->
          <div class={`absolute inset-0 rounded-2xl transition-all duration-300
            ${plan.isPopular 
              ? 'bg-gradient-to-b from-purple-600/20 via-purple-900/10 to-black/50'
              : 'bg-gradient-to-b from-gray-800/20 via-gray-900/10 to-black/50'}`}>
          </div>

          <!-- Popular Badge -->
          {plan.isPopular && (
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
              <div class="inline-flex items-center px-4 py-1 rounded-full bg-gradient-to-r from-purple-500 to-emerald-500 shadow-lg">
                <span class="text-white text-sm font-semibold">Most Popular</span>
              </div>
            </div>
          )}
          
          <!-- Card Content -->
          <div class={`relative p-8 rounded-2xl backdrop-blur-sm border transition-all duration-300
            ${plan.isPopular 
              ? 'border-purple-500/20 group-hover:border-purple-500/40'
              : 'border-white/10 group-hover:border-white/20'}`}>
            
            <!-- Plan Name -->
            <h3 class="text-2xl font-bold text-white mb-2">{plan.name}</h3>

            <!-- Price -->
            <div class="flex items-baseline mb-6">
              <span class="text-4xl font-bold text-white">${plan.price}</span>
              <span class="text-gray-400 ml-2">/{plan.duration}</span>
            </div>

            <!-- Features List -->
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="feature-item flex items-center space-x-3 text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <!-- CTA Button -->
            <a
              href={plan.checkoutUrl}
              class={`block w-full py-3 px-6 rounded-lg text-center font-semibold transition-all duration-300
                ${plan.isPopular
                  ? 'bg-gradient-to-r from-purple-600 to-emerald-500 text-white hover:shadow-lg hover:shadow-purple-500/25'
                  : 'bg-white/10 text-white hover:bg-white/20'}`}
            >
              Get Started
            </a>

            <!-- Corner Accents -->
            <div class="absolute top-0 left-0 w-16 h-16 pointer-events-none">
              <div class="absolute top-0 left-0 w-[2px] h-8 bg-gradient-to-b from-purple-500/50 to-transparent transform origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
              <div class="absolute top-0 left-0 w-8 h-[2px] bg-gradient-to-r from-purple-500/50 to-transparent transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            </div>
            <div class="absolute bottom-0 right-0 w-16 h-16 pointer-events-none">
              <div class="absolute bottom-0 right-0 w-[2px] h-8 bg-gradient-to-t from-emerald-500/50 to-transparent transform origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500"></div>
              <div class="absolute bottom-0 right-0 w-8 h-[2px] bg-gradient-to-l from-emerald-500/50 to-transparent transform origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Money Back Guarantee -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-white/90 text-sm font-medium">30-Day Money Back Guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-card {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  .feature-item {
    animation: fadeInRight 0.5s ease-out forwards;
    opacity: 0;
    transform: translateX(-10px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInRight {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }

  .animate-fade-in-delay {
    animation: fadeIn 0.5s ease-out 0.2s forwards;
    opacity: 0;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-pulse-slow {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .animate-pulse-slow-delay {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite 2s;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 0.3;
      transform: scale(1.1);
    }
  }
</style>

<script>
  // Add intersection observer for animation triggers
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('show');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1,
    }
  );

  document.querySelectorAll('.pricing-card').forEach((card) => {
    observer.observe(card);
  });
</script> 