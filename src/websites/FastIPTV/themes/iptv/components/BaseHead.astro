---
import { ViewTransitions } from 'astro:transitions';
import { generateCanonicalURL, generateSchema, type SEOProps } from '@utils/seo';
// Reviews fetch removed to avoid Supabase/DB dependency and fetch failures
import GoogleAnalytics from '@components/GoogleAnalytics.astro';
import Hotjar from '@components/Hotjar.astro';

// Import global styles
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  isHomePage?: boolean;
  image?: string;
  keywords?: string[];
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

const { 
  title, 
  description, 
  isHomePage = false, 
  image = '/og-image.jpg',
  keywords = [
    'Fast IPTV', 
    'Stronger IPTV', 
    'Premium IPTV', 
    'IPTV streaming', 
    'live TV channels', 
    '32,000+ channels', 
    '140,000+ movies', 
    'HD streaming', 
    '4K streaming', 
    '8K streaming', 
    'sports channels', 
    'movie streaming', 
    'TV shows online', 
    'international channels',
    'Champions League',
    'Premier League',
    'La Liga',
    'Serie A',
    'Bundesliga',
    'Ligue 1',
    'Europa League',
    'live sports',
    'catch up TV',
    'EPG guide',
    'cloud DVR',
    'multi-device streaming',
    'anti-freeze technology',
    '24/7 support',
    'money back guarantee'
  ],
  author = 'FastIPTV Team',
  publishedTime,
  modifiedTime,
  section = 'IPTV Services',
  tags = ['IPTV', 'Streaming', 'Live TV', 'Movies', 'Sports']
} = Astro.props;

// Get current language from URL
const currentPath = Astro.url.pathname;
const currentLang = currentPath.split('/')[1];

// Get allowed languages from environment
const getAllowedLanguages = () => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const supportedLanguages = getAllowedLanguages();

// Generate hreflang URLs - Fixed implementation
const hrefLangURLs = [];

// Determine the base path (without language prefix)
let basePath = currentPath;
if (currentLang && supportedLanguages.includes(currentLang)) {
  // Remove language prefix from path
  basePath = currentPath.substring(currentLang.length + 1) || '/';
}

// Generate hreflang URLs for each supported language
const uniqueLangs = new Set();
supportedLanguages.forEach(lang => {
  let url;
  
  if (basePath === '/') {
    // For home pages, each language gets its own home page
    url = `${Astro.url.origin}/${lang}`;
  } else {
    // For other pages, add language prefix to the base path
    url = `${Astro.url.origin}/${lang}${basePath}`;
  }
  
  // Add all language variants, including self-referential
  if (!uniqueLangs.has(lang)) {
    uniqueLangs.add(lang);
    hrefLangURLs.push({ lang, url });
  }
});

// Add self-referential hreflang tag (required by Google)
if (currentLang && supportedLanguages.includes(currentLang)) {
  hrefLangURLs.push({ lang: currentLang, url: Astro.url.href });
}

// Add x-default pointing to English version (always)
const xDefaultUrl = basePath === '/' 
  ? `${Astro.url.origin}/en` 
  : `${Astro.url.origin}/en${basePath}`;
hrefLangURLs.push({ lang: 'x-default', url: xDefaultUrl });

// Set canonical URL - each language should have its own canonical URL
let canonicalURL;
if (currentPath === '/') {
  // Root path should redirect to English version
  canonicalURL = `${Astro.url.origin}/en`;
} else if (currentLang && supportedLanguages.includes(currentLang)) {
  // Language-specific pages have their own canonical URL
  canonicalURL = Astro.url.href;
} else {
  // Non-language pages should point to English version
  canonicalURL = `${Astro.url.origin}/en${currentPath}`;
}

const currentYear = new Date().getFullYear();

// Determine if the current language is RTL
const lang = currentLang || 'en';
const isRTL = ['ar'].includes(lang);

// Enhanced structured data for FastIPTV
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "FastIPTV",
  "alternateName": ["Fast IPTV", "Stronger IPTV", "Premium IPTV"],
  "url": Astro.site,
  "logo": `${Astro.site}logo.png`,
  "description": "Premium IPTV streaming service with 32,000+ channels and 140,000+ movies. Fast, reliable, and powerful IPTV solution.",
  "foundingDate": "2023",
  "founders": [
    {
      "@type": "Person",
      "name": "FastIPTV Founder"
    }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": "support@fastiptv.com",
    "availableLanguage": ["English", "French", "Arabic", "German", "Dutch", "Italian", "Portuguese", "Spanish", "Russian", "Chinese"]
  },
  "sameAs": [
    "https://facebook.com/fastiptv",
    "https://twitter.com/fastiptv",
    "https://instagram.com/fastiptv",
    "https://youtube.com/fastiptv"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "Global"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "FastIPTV Plans",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "1 Month Fast IPTV Plan",
          "description": "32,000+ channels, 140,000+ movies, HD/4K/8K quality"
        },
        "price": "16.99",
        "priceCurrency": "USD"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "12 Month Stronger IPTV Plan",
          "description": "Best value plan with all premium features"
        },
        "price": "59.99",
        "priceCurrency": "USD"
      }
    ]
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "OnlineService",
  "name": "FastIPTV Premium Streaming Service",
  "alternateName": "Fast IPTV",
  "url": Astro.site,
  "description": description,
  "provider": {
    "@type": "Organization",
    "name": "FastIPTV"
  },
  "offers": {
    "@type": "Offer",
    "price": "16.99",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "validFrom": "2023-01-01"
  },
  "serviceType": "IPTV Streaming",
  "areaServed": "Worldwide",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "FastIPTV Channel Packages"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "FastIPTV",
  "url": Astro.site,
  "description": "Premium IPTV streaming service with 32,000+ channels and 140,000+ movies",
  "publisher": {
    "@type": "Organization",
    "name": "FastIPTV"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${Astro.site}search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

// No review fetch - avoids Supabase/DB errors (fetch failed, ECONNREFUSED)
const reviewStats = null;
const reviews = null;
---

<!-- Charset and Viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
<meta name="generator" content={Astro.generator} />

<!-- Language and Direction -->
<html lang={lang} dir={isRTL ? 'rtl' : 'ltr'}>
  <head>
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(', ')} />
    <meta name="author" content={author} />
    <!-- Robots Meta Tag - Allow indexing of all language versions -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={isHomePage ? 'website' : 'article'} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="FastIPTV - Premium IPTV Streaming Service" />
    <meta property="og:site_name" content="FastIPTV" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'fr' ? 'fr_FR' : lang === 'ar' ? 'ar_AR' : 'en_US'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}
    {section && <meta property="article:section" content={section} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
    <meta property="twitter:image:alt" content="FastIPTV - Premium IPTV Streaming Service" />
    <meta name="twitter:site" content="@fastiptv" />
    <meta name="twitter:creator" content="@fastiptv" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/fastiptv-favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Premium fonts: Bricolage Grotesque + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {isRTL ? (
      <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700&family=Noto+Kufi+Arabic:wght@400;600;700&display=swap" rel="stylesheet" />
    ) : (
      <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    )}

    <!-- Verification and Ownership -->
    <meta name="msvalidate.01" content="YOUR_BING_WEBMASTER_TOOLS_VERIFICATION_CODE" />
    <meta name="google-site-verification" content="YOUR_GOOGLE_SEARCH_CONSOLE_VERIFICATION_CODE" />
    <meta name="yandex-verification" content="YOUR_YANDEX_VERIFICATION_CODE" />

    <!-- Geo Tags -->
    <meta name="geo.region" content="Global" />
    <meta name="geo.position" content="0;0" />
    <meta name="ICBM" content="0, 0" />

    <!-- Language Alternates (hreflang) -->
    {hrefLangURLs.map(({ lang, url }) => (
      <link rel="alternate" hreflang={lang} href={url} />
    ))}

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>

    <!-- Review Schema -->
    {reviews && reviews.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Product",
        "name": "FastIPTV Premium Streaming Service",
        "alternateName": "Fast IPTV",
        "description": description,
        "brand": {
          "@type": "Brand",
          "name": "FastIPTV"
        },
        "category": "IPTV Streaming Service",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": reviewStats.averageRating,
          "reviewCount": reviewStats.totalReviews,
          "bestRating": "5",
          "worstRating": "1"
        },
        "review": reviews.slice(0, 10).map(review => ({
          "@type": "Review",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": review.rating,
            "bestRating": "5",
            "worstRating": "1"
          },
          "author": {
            "@type": "Person",
            "name": review.username
          },
          "reviewBody": review.comment,
          "datePublished": review.created_at
        }))
      })}></script>
    )}

    <!-- Performance and Security Headers (X-Frame-Options must be set via HTTP headers, not meta) -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />

    <!-- DNS Prefetch for performance -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="dns-prefetch" href="//cdn.atlagia.com" />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- Analytics -->
    <GoogleAnalytics />
    <Hotjar />

    <!-- Styles -->
    <style is:global>
      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #0f0f0f;
        --accent-purple: #8b5cf6;
        --accent-blue: #3b82f6;
        --accent-cyan: #06b6d4;
        --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
        --font-body: 'DM Sans', system-ui, sans-serif;
        --glass-bg: rgba(255,255,255,0.03);
        --glass-border: rgba(255,255,255,0.08);
      }
      * { box-sizing: border-box; }
      body {
        font-family: var(--font-body);
        background: var(--bg-primary);
        color: #e5e5e5;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, h4, h5, h6 { font-family: var(--font-display); }
      img { max-width: 100%; height: auto; display: block; }
    </style>
  </head>
</html>