---
interface CategoryBlock {
  id: string;
  name: string;
  link: string;
  image: string;
}

interface Props {
  categories: CategoryBlock[];
}

const { categories } = Astro.props;
---

<section class="f1-category-blocks">
  {categories.map((cat) => (
    <a
      href={cat.link}
      class="group block relative h-[50vh] min-h-[320px] overflow-hidden"
    >
      <img
        src={cat.image}
        alt={cat.name}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-[var(--drivon-bg)]/60 group-hover:bg-[var(--drivon-bg)]/40 transition-colors duration-500"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="font-headline text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-[var(--drivon-text)] uppercase tracking-wide transition-transform duration-500 group-hover:scale-105">
          {cat.name}
        </span>
      </div>
    </a>
  ))}
</section>

<style>
  .font-headline { font-family: var(--font-headline); }
</style>
