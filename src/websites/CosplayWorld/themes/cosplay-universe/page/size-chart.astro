                  <td class="border border-gray-200 px-6 py-4 text-center text-gray-700">46</td>
                  <td class="border border-gray-200 px-6 py-4 text-center text-gray-700">44</td>
                  <td class="border border-gray-200 px-6 py-4 text-center text-gray-700">111-116</td>
                  <td class="border border-gray-200 px-6 py-4 text-center text-gray-700">96-101</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Tips Section -->
        <div class="bg-gradient-to-r from-red-50 to-gray-50 rounded-2xl p-8">
          <h2 class="text-3xl font-bold text-[var(--drivon-text)] mb-8 text-center">Sizing Tips</h2>
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="text-xl font-semibold text-[var(--drivon-text)] mb-4">General Guidelines</h3>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  Measure yourself while wearing the type of clothing you'll wear with the item
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  For a relaxed fit, add 2-4 inches to your chest measurement
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  For a slim fit, add 1-2 inches to your chest measurement
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  If you're between sizes, we recommend sizing up
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-[var(--drivon-text)] mb-4">Care Instructions</h3>
              <ul class="space-y-3 text-gray-700">
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  Machine wash cold with like colors
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  Tumble dry low or hang dry for best results
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  Iron on low heat if needed
                </li>
                <li class="flex items-start">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                  Do not bleach automotive graphics
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Contact Section -->
        <div class="text-center mt-12">
          <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Need Help Finding Your Size?</h3>
          <p class="text-[var(--drivon-muted)] mb-6">Our customer service team is here to help you find the perfect fit</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-red-600 text-white px-8 py-3 rounded-lg hover:bg-red-700 transition-colors font-medium">
              Contact Support
            </a>
            <a href="/collections" class="bg-gray-200 text-gray-800 px-8 py-3 rounded-lg hover:bg-gray-300 transition-colors font-medium">
              Browse Collections
            </a>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
