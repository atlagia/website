        </div>

        <!-- Important Information -->
        <div class="grid md:grid-cols-2 gap-8 mb-16">
          <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-8">
            <h3 class="text-xl font-bold text-yellow-800 mb-4">⚠️ Important Notes</h3>
            <ul class="space-y-3 text-yellow-700">
              <li class="flex items-start">
                <span class="w-2 h-2 bg-yellow-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                Delivery times are estimates and may vary due to weather or carrier delays
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-yellow-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                Someone must be available to receive the package
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-yellow-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                We are not responsible for packages delivered to incorrect addresses
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-yellow-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                International customers are responsible for customs fees
              </li>
            </ul>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-2xl p-8">
            <h3 class="text-xl font-bold text-blue-800 mb-4">📦 Packaging</h3>
            <ul class="space-y-3 text-blue-700">
              <li class="flex items-start">
                <span class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                All items are carefully packaged in protective materials
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                Eco-friendly packaging materials used when possible
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                Fragile items are double-boxed for protection
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></span>
                Each package includes order confirmation and return policy
              </li>
            </ul>
          </div>
        </div>

        <!-- Contact Section -->
        <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-2xl p-8 text-center">
          <h2 class="text-3xl font-bold text-[var(--drivon-text)] mb-4">Need Help with Shipping?</h2>
          <p class="text-[var(--drivon-muted)] mb-6">Our customer service team is here to help with any shipping questions</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-red-600 text-white px-8 py-3 rounded-lg hover:bg-red-700 transition-colors font-medium">
              Contact Support
            </a>
            <a href="/size-chart" class="bg-gray-200 text-gray-800 px-8 py-3 rounded-lg hover:bg-gray-300 transition-colors font-medium">
              Size Chart
            </a>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
