<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }
  
  .animation-delay-1000 {
    animation-delay: 1s;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
  
  @keyframes float-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float-subtle {
    animation: float-subtle 6s ease-in-out infinite;
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(10, 145, 177, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(10, 145, 177, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  /* Dashboard Animation Styles */
  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: pulse-animation 2s infinite;
  }
  
  @keyframes pulse-animation {
    0% { transform: scale(0.8); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(0.8); opacity: 0.5; }
  }
  
  .appointment-item {
    transition: all 0.6s ease-out;
  }
  
  .typing-indicator {
    display: inline-flex;
    align-items: center;
    height: 10px;
  }
  
  .typing-indicator span {
    display: inline-block;
    width: 4px;
    height: 4px;
    margin: 0 1px;
    background: #0a91b1;
    border-radius: 50%;
    animation: typing 1s infinite ease-in-out;
  }
  
  .typing-indicator span:nth-child(1) { animation-delay: 0s; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  
  @keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .dashboard-tab-pane {
      animation: fadeIn 0.5s;
  }

  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Dashboard Tab functionality
  const tabContainer = document.getElementById('dashboard-tabs');
  if (tabContainer) {
    const tabButtons = tabContainer.querySelectorAll('.dashboard-tab-button');
    const mainContentContainer = tabContainer.closest('.grid').querySelector('.col-span-9');
    const tabPanes = mainContentContainer.querySelectorAll('.dashboard-tab-pane');

    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        const tabId = button.dataset.tab;
        
        // Update buttons state
        tabButtons.forEach(btn => {
          const icon = btn.querySelector('svg');
          btn.classList.remove('bg-[#0a91b1]/10', 'text-[#0a91b1]', 'font-medium');
          btn.classList.add('hover:bg-gray-50', 'text-gray-700');
          icon.classList.add('text-gray-500');
          icon.classList.remove('text-[#0a91b1]');
        });
        
        const clickedIcon = button.querySelector('svg');
        button.classList.add('bg-[#0a91b1]/10', 'text-[#0a91b1]', 'font-medium');
        button.classList.remove('hover:bg-gray-50', 'text-gray-700');
        clickedIcon.classList.remove('text-gray-500');
        clickedIcon.classList.add('text-[#0a91b1]');

        // Update panes visibility
        tabPanes.forEach(pane => {
          if (pane.id === `tab-${tabId}`) {
            pane.classList.remove('hidden');
            pane.classList.add('active');
          } else {
            pane.classList.add('hidden');
            pane.classList.remove('active');
          }
        });
      });
    });
  }

  // Set up intersection observer to trigger animations when dashboard is visible
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Animate progress bar
        const progressBars = entry.target.querySelectorAll('.progress-bar');
        progressBars.forEach(bar => {
          const targetWidth = bar.getAttribute('data-width');
          setTimeout(() => {
            bar.style.width = `${targetWidth}%`;
          }, 300);
        });
        
        // Animate count-up numbers
        const countElements = entry.target.querySelectorAll('.count-up');
        countElements.forEach(el => {
          const target = parseInt(el.getAttribute('data-target'));
          animateCount(el, target);
        });
        
        // Animate count-up numbers with prefix
        const countPrefixElements = entry.target.querySelectorAll('.count-up-prefix');
        countPrefixElements.forEach(el => {
          const target = parseInt(el.getAttribute('data-target'));
          const prefix = el.getAttribute('data-prefix') || '';
          animateCountPrefix(el, target, prefix);
        });
        
        // Animate appointments sliding in
        const appointments = entry.target.querySelectorAll('.appointment-item');
        appointments.forEach((app, index) => {
          setTimeout(() => {
            app.style.transform = 'translateX(0)';
            app.style.opacity = '1';
          }, 300 + (index * 200));
        });
        
        // Unobserve after triggering animations
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  
  // Observe all interactive elements
  document.querySelectorAll('.appointment-list').forEach(el => {
    observer.observe(el.closest('.bg-white'));
  });
  
  document.querySelectorAll('.count-up, .count-up-prefix').forEach(el => {
    observer.observe(el.closest('.bg-white'));
  });
  
  // Function to animate count-up
  function animateCount(element, target) {
    let current = 0;
    const increment = Math.ceil(target / 30); // Divide animation into 30 steps
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      element.textContent = current;
    }, 50);
  }
  
  // Function to animate count-up with prefix
  function animateCountPrefix(element, target, prefix) {
    let current = 0;
    const increment = Math.ceil(target / 30); // Divide animation into 30 steps
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      element.textContent = `${prefix}${current}`;
    }, 50);
  }
  
  // Feature card animation on scroll
  const featureCards = document.querySelectorAll('.feature-card');
  const featureObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add('opacity-100');
          entry.target.classList.remove('opacity-0', 'translate-y-10');
        }, index * 100);
        featureObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  
  featureCards.forEach(card => {
    card.classList.add('opacity-0', 'translate-y-10', 'transition-all', 'duration-500');
    featureObserver.observe(card);
  });
});
</script> 