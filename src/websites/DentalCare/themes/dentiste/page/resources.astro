---
import { SITE_TITLE } from '../consts';
import { BookOpen, FileText, Server, Database, Video, Calendar, Users, Brain, CheckCircle, ClipboardList, Layers, DollarSign, Bell, Star, Map, ListChecks, BarChart, GraduationCap, Share2, Shield, MessageCircle, LifeBuoy, Download, ExternalLink, ChevronRight } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific resources data
const resourcesData = await import(`../data/resources/resources_${lang}.json`);

// Map icon strings to actual components
const iconMap = {
  BookOpen,
  FileText,
  Server,
  Database,
  Video,
  Calendar,
  Users,
  Brain,
  CheckCircle,
  ClipboardList,
  Layers,
  DollarSign,
  Bell,
  Star,
  Map,
  ListChecks,
  BarChart,
  GraduationCap,
  Share2,
  Shield,
  MessageCircle,
  LifeBuoy
};

// Map category icons
const categories = resourcesData.categories.map(category => {
  const mappedResources = category.resources.map(resource => ({
    ...resource,
    IconComponent: iconMap[resource.icon]
  }));
  
  return {
    ...category,
    IconComponent: iconMap[category.icon],
    resources: mappedResources
  };
});

// Map downloadable resources icons
const downloadableResources = resourcesData.downloadableResources.resources.map(resource => ({
  ...resource,
  IconComponent: iconMap[resource.icon]
}));

// Map support section icons
const supportOptions = resourcesData.supportSection.options.map(option => ({
  ...option,
  IconComponent: iconMap[option.icon]
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Resources | ${SITE_TITLE}`}
      description={resourcesData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main>
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          
          <!-- Grid Pattern -->
          <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
        </div>
        
        <div class="relative z-10 max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold bg-[#0a91b1]/20 text-[#0a91b1] rounded-full border border-[#0a91b1]/30">{resourcesData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">{resourcesData.hero.title}</h1>
          <p class="text-lg md:text-xl text-gray-600 max-w-3xl mx-auto">{resourcesData.hero.description}</p>
        </div>
      </section>

      <!-- Resource Categories -->
      {categories.map((category, index) => (
        <section class={`py-16 px-4 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
          <div class="max-w-7xl mx-auto">
            <div class="flex items-center mb-12">
              <div class={`w-16 h-16 rounded-xl bg-${category.color}-100 flex items-center justify-center mr-6`}>
                <category.IconComponent className={`w-8 h-8 text-${category.color}-600`} />
              </div>
              <div>
                <h2 class="text-3xl font-bold">{category.title}</h2>
                <p class="text-gray-600 mt-2">{category.description}</p>
              </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              {category.resources.map(resource => (
                <a href={resource.link} class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100">
                  <div class="flex items-start">
                    <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center mr-4 flex-shrink-0">
                      <resource.IconComponent className="w-6 h-6 text-gray-700" />
                    </div>
                    <div>
                      <h3 class="font-semibold mb-2">{resource.title}</h3>
                      <p class="text-sm text-gray-600">{resource.description}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}

      <!-- Downloadable Resources -->
      <section class="py-16 px-4 bg-[#0a91b1]/5">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{resourcesData.downloadableResources.title}</h2>
            <p class="text-gray-600 max-w-3xl mx-auto">{resourcesData.downloadableResources.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {downloadableResources.map(resource => (
              <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
                <div class="flex items-center mb-4">
                  <div class="w-10 h-10 rounded-lg bg-[#0a91b1]/10 flex items-center justify-center mr-4">
                    <resource.IconComponent className="w-5 h-5 text-[#0a91b1]" />
                  </div>
                  <h3 class="font-semibold">{resource.title}</h3>
                </div>
                <p class="text-sm text-gray-600 mb-4">{resource.description}</p>
                <a href={resource.link} class="inline-flex items-center text-[#0a91b1] font-medium hover:text-[#097d99]">
                  <Download className="w-4 h-4 mr-2" /> Download
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Webinars Section -->
      <section class="py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{resourcesData.webinars.title}</h2>
            <p class="text-gray-600 max-w-3xl mx-auto">{resourcesData.webinars.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {resourcesData.webinars.events.map(event => (
              <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                <div class="mb-4">
                  <span class="text-sm font-medium text-[#0a91b1]">{event.date} • {event.time}</span>
                  <h3 class="text-xl font-bold mt-2">{event.title}</h3>
                </div>
                <p class="text-gray-600 mb-4 text-sm">{event.description}</p>
                <div class="flex items-center mb-6">
                  <div class="w-8 h-8 bg-gray-200 rounded-full mr-3"></div>
                  <span class="text-sm font-medium">{event.host}</span>
                </div>
                <a href={event.registrationLink} class="block w-full py-2 bg-[#0a91b1] hover:bg-[#097d99] text-white text-center rounded-lg transition-colors">
                  Register Now
                </a>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Support Options -->
      <section class="py-16 px-4 bg-gray-50">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold mb-4">{resourcesData.supportSection.title}</h2>
            <p class="text-gray-600">{resourcesData.supportSection.description}</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {supportOptions.map(option => (
              <a href={option.link} class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:bg-[#0a91b1]/5 transition-colors text-center">
                <div class="w-14 h-14 rounded-full bg-[#0a91b1]/10 flex items-center justify-center mx-auto mb-4">
                  <option.IconComponent className="w-7 h-7 text-[#0a91b1]" />
                </div>
                <h3 class="font-semibold mb-2">{option.title}</h3>
                <p class="text-sm text-gray-600 mb-4">{option.description}</p>
                <span class="inline-flex items-center text-[#0a91b1] font-medium">
                  Get Support <ChevronRight className="w-4 h-4 ml-1" />
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
      
      <!-- CTA Section -->
      <section class="py-16 px-4 bg-white">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-6">Ready to Transform Your Dental Practice?</h2>
          <p class="text-lg text-gray-600 mb-8">
            Experience the full power of Atlagia DentalCare with a personalized demo.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/demo" class="px-8 py-3.5 bg-[#0a91b1] hover:bg-[#097d99] text-white font-medium rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-[#0a91b1]/25">
              Schedule a Demo
            </a>
            <a href="/pricing" class="px-8 py-3.5 bg-white hover:bg-gray-100 text-[#0a91b1] font-medium rounded-lg border border-gray-200 transition-all duration-300 shadow-sm hover:shadow-md">
              View Pricing
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }
  
  .animation-delay-1000 {
    animation-delay: 1s;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(10, 145, 177, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(10, 145, 177, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style> 