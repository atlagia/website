---
import { SITE_TITLE } from '../consts';
import { Mail, Phone, MapPin } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific contact data
const contactData = await import(`../data/contact/contact_${lang}.json`);

// Import form configuration
const { config, form } = await import('../forms/contact/config.json');

// Get language-specific form configuration
const formConfig = form[lang] || form['en']; // Fallback to English if language not found

// Get business information from environment variables
const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia',
  email: import.meta.env.PUBLIC_BUSINESS_EMAIL || 'contact@atalsia.com',
  phone: import.meta.env.PUBLIC_BUSINESS_PHONE || '+1 2035 472 248',
  address: {
    street: import.meta.env.PUBLIC_BUSINESS_ADDRESS || '124 City Road',
    city: import.meta.env.PUBLIC_BUSINESS_CITY || 'London',
    country: import.meta.env.PUBLIC_BUSINESS_COUNTRY || 'United Kingdom'
  }
};

// Map icon strings to actual components
const iconMap = {
  Mail,
  Phone,
  MapPin
};

// Map contact info with actual icon components
const contactInfo = contactData.contactInfo.map(item => ({
  ...item,
  icon: iconMap[item.icon]
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`Contact Us | ${businessInfo.name}`}
      description={contactData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-pink-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
          
          <!-- Software Grid Pattern -->
          <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center z-10">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold bg-[#0a91b1]/20 text-[#0a91b1] rounded-full border border-[#0a91b1]/30 backdrop-blur-sm">{contactData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{contactData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            {contactData.hero.description}
          </p>
        </div>
      </section>

      <!-- Contact Options -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {contactInfo.map(item => (
              <a
                href={item.link}
                class="group p-8 bg-gray-50 rounded-2xl hover:bg-[#0a91b1] transition-all duration-300"
              >
                <div class="flex flex-col items-center text-center">
                  <div class="w-14 h-14 mb-6 rounded-xl bg-[#0a91b1]/20 group-hover:bg-[#0a91b1]/20 flex items-center justify-center transition-colors">
                    <item.icon className="w-7 h-7 text-[#0a91b1] group-hover:text-white" />
                  </div>
                  <h3 class="text-xl font-semibold mb-2 text-gray-900 group-hover:text-white">{item.title}</h3>
                  <p class="text-gray-600 group-hover:text-gray-200 mb-2">{item.description}</p>
                  <p class="font-medium text-gray-900 group-hover:text-white">{item.content}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Contact Form Section -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          
          <!-- Software Grid Pattern -->
          <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
        </div>
        <div class="max-w-7xl mx-auto relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <!-- Left: Form -->
            <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-200 backdrop-blur-md">
              <h2 class="text-2xl font-bold mb-6">{formConfig.title}</h2>
              <form id="contact-form" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {Object.entries(formConfig.fields).map(([key, field]) => (
                    <div class={field.type === 'textarea' ? 'md:col-span-2' : ''}>
                      <label for={field.id} class="block text-sm font-medium text-gray-700 mb-1.5">
                        {field.label}
                      </label>
                      {field.type === 'textarea' ? (
                        <textarea
                          id={field.id}
                          name={field.id}
                          rows={field.rows || 4}
                          placeholder={field.placeholder}
                          required={field.required}
                          class="w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50 focus:border-[#0a91b1] transition-colors"
                        ></textarea>
                      ) : (
                        <input
                          type={field.type || "text"}
                          id={field.id}
                          name={field.id}
                          placeholder={field.placeholder}
                          required={field.required}
                          class="w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50 focus:border-[#0a91b1] transition-colors"
                        />
                      )}
                    </div>
                  ))}
                </div>
                
                <div class="flex items-center space-x-2 text-sm text-gray-600">
                  <input type="checkbox" id="privacy-policy" name="privacy-policy" class="rounded text-[#0a91b1] focus:ring-[#0a91b1]" required />
                  <label for="privacy-policy">I agree to the privacy policy and terms of service</label>
                </div>
                
                <button
                  type="submit"
                  class="w-full py-3.5 text-base font-medium text-white bg-[#0a91b1] hover:bg-[#097d99] rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50"
                >
                  {formConfig.submitButton}
                </button>
              </form>
              
              <!-- Form Icons -->
              <div class="flex justify-between mt-8 border-t border-gray-200 pt-6">
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-[#0a91b1]/20 flex items-center justify-center mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#0a91b1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-500">Fast Response</span>
                </div>
                
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-[#0a91b1]/20 flex items-center justify-center mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#0a91b1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-500">Secure</span>
                </div>
                
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-[#0a91b1]/20 flex items-center justify-center mb-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#0a91b1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-500">Confidential</span>
                </div>
              </div>
            </div>

            <!-- Right: Map & Info -->
            <div class="space-y-8">
              <div class="aspect-video w-full rounded-2xl overflow-hidden shadow-xl border border-gray-200">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2482.4246767037074!2d-0.08744748422970276!3d51.52459667963792!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48761ca671a6cfb7%3A0x9319acf4647dd5c4!2s124%20City%20Rd%2C%20London%20EC1V%202NX%2C%20UK!5e0!3m2!1sen!2sus!4v1647433829401!5m2!1sen!2sus"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                ></iframe>
              </div>
              <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-200 backdrop-blur-md">
                <h3 class="text-xl font-bold mb-4">{contactData.support.hours.title}</h3>
                <p class="text-gray-600 mb-6">{contactData.support.hours.content}</p>
                <h3 class="text-xl font-bold mb-4">{contactData.support.additional.title}</h3>
                <p class="text-gray-600">
                  {contactData.support.additional.description} <a href={`mailto:${contactData.support.additional.email}`} class="text-[#0a91b1] hover:text-[#097d99]">{contactData.support.additional.email}</a>
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />

    <div id="success-message" class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50 hidden">
      <div class="bg-white p-8 rounded-2xl max-w-md mx-4 shadow-xl">
        <h3 class="text-2xl font-bold text-gray-900 mb-4">{formConfig.successMessage.title}</h3>
        <p class="text-gray-600 mb-6">{formConfig.successMessage.description}</p>
        <button onclick="this.parentElement.parentElement.classList.add('hidden')" class="w-full bg-[#0a91b1] text-white py-3 px-6 rounded-lg font-medium hover:bg-[#097d99] transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25">
          {formConfig.successMessage.buttonText}
        </button>
      </div>
    </div>
  </body>
</html>

<script define:vars={{ config, businessInfo, formConfig }}>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('contact-form');
  const successMessage = document.getElementById('success-message');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const timestamp = new Date().toISOString();
    
    // Prepare the data according to the schema
    const submissionData = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone') || null,
      subject: formData.get('subject'),
      message: formData.get('message'),
      submissionTimestamp: timestamp,
      status: 'Pending'
    };

    try {
      const response = await fetch(
        `${config.apiBaseUrl}/builder/entities/${config.schemaId}/entries/create/`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Schema-Key-Token': config.keyToken
          },
          body: JSON.stringify({
            data: submissionData,
            key_token: config.keyToken
          })
        }
      );

      const result = await response.json();
      
      if (result.id) {
        // Success
        form.reset();
        successMessage.classList.remove('hidden');
      } else {
        throw new Error(result.error || 'Failed to submit form');
      }
    } catch (error) {
      console.error('Form submission error:', error);
      alert(formConfig.errorMessage);
    }
  });
});
</script>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(10, 145, 177, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(10, 145, 177, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  .backdrop-blur-md {
    backdrop-filter: blur(12px);
  }
</style>