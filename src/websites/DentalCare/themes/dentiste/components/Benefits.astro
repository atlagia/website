---
import { 
  Calendar, 
  UserCog, 
  LineChart, 
  Brain, 
  Database, 
  Shield, 
  MessageSquare, 
  Cog 
} from 'lucide-react';
import styles from '../style/component/benefitsSection.json';

interface Benefit {
  title: string;
  description: string;
  icon?: string;
}

interface Stat {
  value: string;
  label: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  benefits: Benefit[];
  stats?: Stat[];
}

const { subtitle, title, description, benefits, stats } = Astro.props;

// Software-specific SVG paths
const benefitIcons = [
  // Calendar - Appointment Management
  `<rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
   <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <rect x="8" y="14" width="3" height="3" rx="0.5" fill="currentColor"/>`,

  // Brain - AI Integration
  `<path d="M9.5 2C7.01472 2 5 4.01472 5 6.5C5 7.19871 5.14929 7.86196 5.41484 8.46384C3.43536 9.63192 2 11.6948 2 14C2 16.3981 3.4292 18.5138 5.49914 19.6573C5.1893 20.1596 5 20.7597 5 21.4C5 23.3882 6.61177 25 8.6 25C9.99469 25 11.1957 24.1955 11.7315 23H15.2685C15.8043 24.1955 17.0053 25 18.4 25C20.3882 25 22 23.3882 22 21.4C22 20.7597 21.8107 20.1596 21.5009 19.6573C23.5708 18.5138 25 16.3981 25 14C25 11.6948 23.5646 9.63192 21.5852 8.46384C21.8507 7.86196 22 7.19871 22 6.5C22 4.01472 19.9853 2 17.5 2C15.6978 2 14.1343 3.12573 13.5177 4.74856C13.1841 4.66294 12.8371 4.62 12.4824 4.62C12.1276 4.62 11.7807 4.66294 11.447 4.74856C10.8305 3.12573 9.2675 2 7.46534 2H9.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M12 22C15.866 22 19 18.866 19 15C19 11.134 15.866 8 12 8C8.13401 8 5 11.134 5 15C5 18.866 8.13401 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,

  // User Cog - Patient Management
  `<path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15H6C4.93913 15 3.92172 15.4214 3.17157 16.1716C2.42143 16.9217 2 17.9391 2 19V21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <circle cx="19" cy="8" r="2" stroke="currentColor" stroke-width="2"/>
   <path d="M19 4.5V6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M19 10V11.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M16.5 5.5L17.5 6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M20.5 9.5L21.5 10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M16.5 10.5L17.5 9.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
   <path d="M20.5 6.5L21.5 5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,

  // Line Chart - Analytics
  `<path d="M21 21H3V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M21 9L15 15L9 9L3 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,

  // Database - Cloud Storage
  `<ellipse cx="12" cy="5" rx="9" ry="3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M21 12C21 13.66 16.97 15 12 15C7.03 15 3 13.66 3 12" stroke="currentColor" stroke-width="2"/>
   <path d="M3 5V19C3 20.66 7.03 22 12 22C16.97 22 21 20.66 21 19V5" stroke="currentColor" stroke-width="2"/>`,

  // Shield - Security
  `<path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`
];
---

<section class={styles.section.container}>
  <div class={styles.content.container}>
    <!-- Header -->
    <div class={styles.header.container}>
      <span class={styles.header.subtitle}>
        {subtitle}
      </span>
      <h2 class={styles.header.title}>
        {title}
      </h2>
      <p class={styles.header.description}>
        {description}
      </p>
    </div>

    <!-- Features Grid with System UI Design -->
    <div class="relative mb-16">
      <!-- Decorative Background Elements -->
      <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-teal-500/5 rounded-3xl blur-3xl transform -rotate-1"></div>
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.015]"></div>
      
      <!-- Grid Container -->
      <div class={styles.benefitsGrid.container}>
        {benefits.map((benefit, index) => (
          <div class="relative group rounded-xl p-6 bg-white/80 backdrop-blur-sm border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-teal-500/5 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <!-- Icon with Animation -->
            <div class="relative">
              <div class="h-14 w-14 rounded-xl bg-[#0a91b1]/10 flex items-center justify-center mb-5 group-hover:bg-[#0a91b1]/20 transition-colors duration-300">
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="h-7 w-7 text-[#0a91b1] group-hover:scale-110 transition-transform duration-300" 
                  fill="none" 
                  viewBox="0 0 24 24" 
                  set:html={benefit.icon ? benefit.icon : benefitIcons[index % benefitIcons.length]}
                />
              </div>
              
              <!-- Content -->
              <h3 class="text-xl font-semibold mb-3 text-gray-900">
                {benefit.title}
              </h3>
              <p class="text-gray-600">
                {benefit.description}
              </p>
              
              <!-- Tech-Style Tag -->
              <div class="mt-5 inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                {index === 0 ? 'Core Feature' : 
                 index === 1 ? 'AI-Powered' : 
                 index === 2 ? 'Cloud-Based' : 'Premium'}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- System Stats with Modern Dashboard Style -->
    {stats && stats.length > 0 && (
      <div class="relative">
        <div class="absolute inset-0 bg-[#0a91b1]/5 rounded-2xl"></div>
        <div class="relative grid grid-cols-2 md:grid-cols-4 gap-4 p-6 rounded-2xl bg-white/90 backdrop-blur-sm border border-[#0a91b1]/20 shadow-sm">
          {stats.map((stat) => (
            <div class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-[#0a91b1]/5 transition-colors duration-200">
              <div class="text-3xl font-bold text-[#0a91b1] mb-1">
                {stat.value}
              </div>
              <div class="text-sm text-gray-600 font-medium">
                {stat.label}
              </div>
              
              <!-- Progress Indicator -->
              <div class="w-full h-1 bg-gray-100 rounded-full mt-3 overflow-hidden">
                <div class="h-full bg-gradient-to-r from-[#0a91b1] to-[#0a91b1]/70 rounded-full" style={`width: ${Math.random() * 50 + 50}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style define:vars={{ 
  primaryColor: styles.colors.primary,
  primaryLight: styles.colors.primaryLight,
  primaryLighter: styles.colors.primaryLighter,
  transitionDuration: styles.transitions.all.duration,
  transitionTiming: styles.transitions.all.timing,
  hoverShadow: styles.transitions.hover.shadow,
  hoverScale: styles.transitions.hover.scale
}}>
  /* Smooth Transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: var(--transitionTiming);
    transition-duration: var(--transitionDuration);
  }

  /* Card Hover Effect */
  .hover\:shadow-xl:hover {
    box-shadow: var(--hoverShadow);
  }

  /* Group Hover Animations */
  .group:hover .group-hover\:scale-110 {
    transform: var(--hoverScale);
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(0, 0, 0, 0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style> 