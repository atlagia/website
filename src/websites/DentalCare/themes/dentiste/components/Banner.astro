---
import { Button } from './ui/Button';
import { Calendar, UserCog, LineChart, Brain, Database, Shield } from 'lucide-react';
import styles from '../style/component/bannerSection.json';

interface Props {
  headline: string;
  description: string;
  backgroundImage: string;
  button1Text: string;
  button1Link: string;
  button2Text: string;
  button2Link: string;
  subtitle?: string;
  cards?: Array<{
    title: string;
    description: string;
    icon?: string;
  }>;
  trustBadges?: string[];
}

const { 
  headline, 
  description, 
  backgroundImage,
  button1Text,
  button1Link,
  button2Text,
  button2Link,
  subtitle,
  cards,
  trustBadges
} = Astro.props;

// Feature icons for software management system
const featureIcons = [
  `<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M9.5 2C7.01472 2 5 4.01472 5 6.5C5 7.19871 5.14929 7.86196 5.41484 8.46384C3.43536 9.63192 2 11.6948 2 14C2 16.3981 3.4292 18.5138 5.49914 19.6573C5.1893 20.1596 5 20.7597 5 21.4C5 23.3882 6.61177 25 8.6 25C9.99469 25 11.1957 24.1955 11.7315 23H15.2685C15.8043 24.1955 17.0053 25 18.4 25C20.3882 25 22 23.3882 22 21.4C22 20.7597 21.8107 20.1596 21.5009 19.6573C23.5708 18.5138 25 16.3981 25 14C25 11.6948 23.5646 9.63192 21.5852 8.46384C21.8507 7.86196 22 7.19871 22 6.5C22 4.01472 19.9853 2 17.5 2C15.6978 2 14.1343 3.12573 13.5177 4.74856C13.1841 4.66294 12.8371 4.62 12.4824 4.62C12.1276 4.62 11.7807 4.66294 11.447 4.74856C10.8305 3.12573 9.2675 2 7.46534 2H9.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M21 8v8a5 5 0 01-5 5H8a5 5 0 01-5-5V8a5 5 0 015-5h8a5 5 0 015 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M16 9v1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M16 14v1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
   <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`
];

---

<section class={styles.section.container}>
  <!-- Animated Background Elements -->
  <div class={styles.backgroundElements.container}>
    <div class={styles.backgroundElements.blob1}></div>
    <div class={styles.backgroundElements.blob2}></div>
    
    <!-- Software Dashboard-Like Background Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.02]"></div>
  </div>

  <!-- Content -->
  <div class={styles.content.container}>
    <!-- Header Content -->
    <div class={styles.content.header.container}>
      {subtitle && (
        <span class={styles.content.header.subtitle}>
          {subtitle}
        </span>
      )}
      <h2 class={styles.content.header.headline}>
        {headline}
      </h2>
      
      <!-- Dashboard Preview (Floating UI Element) -->
      <div class="relative mx-auto my-8 max-w-4xl">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-teal-500/5 rounded-xl blur-xl transform rotate-1"></div>
        <div class="relative bg-white/90 backdrop-blur-sm border border-gray-200 rounded-xl shadow-lg overflow-hidden" id="animated-dashboard">
          <!-- Dashboard Header -->
          <div class="bg-[#0a91b1]/10 px-4 py-2 flex items-center justify-between border-b border-gray-200">
            <div class="flex items-center space-x-2">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            </div>
            <div class="text-xs font-medium text-gray-600">Atlagia DentalCare Dashboard</div>
            <div class="flex items-center space-x-2">
              <div class="pulse-dot bg-green-500"></div>
              <span class="text-xs text-green-600">Live Data</span>
            </div>
          </div>
          
          <!-- Dashboard Preview Content -->
          <div class="p-4 flex flex-col md:flex-row gap-4">
            <!-- Left Stats Panel -->
            <div class="flex-1 bg-gray-50/50 p-3 rounded-lg border border-gray-100">
              <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-medium text-gray-700">Patient Overview</h4>
                <span class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full animate-pulse">+12%</span>
              </div>
              <div class="space-y-2">
                <div class="flex justify-between items-center">
                  <span class="text-xs text-gray-500">Total Patients</span>
                  <span class="text-sm font-semibold count-up" data-target="1245">0</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-xs text-gray-500">New This Month</span>
                  <span class="text-sm font-semibold count-up" data-target="68">0</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-xs text-gray-500">Appointments</span>
                  <span class="text-sm font-semibold count-up" data-target="324">0</span>
                </div>
                <div class="w-full h-1 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-[#0a91b1] rounded-full progress-bar" data-width="75"></div>
                </div>
              </div>
            </div>
            
            <!-- Right Calendar Preview -->
            <div class="flex-1 bg-white p-3 rounded-lg border border-gray-100">
              <div class="flex items-center justify-between mb-3">
                <h4 class="text-sm font-medium text-gray-700">Today's Schedule</h4>
                <span class="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full notification-badge">3 New</span>
              </div>
              <div class="space-y-2 appointment-list">
                <div class="flex items-center bg-blue-50/50 p-2 rounded-md transform translate-x-full opacity-0 appointment-item">
                  <div class="w-2 h-2 bg-blue-500 rounded-full mr-2"></div>
                  <span class="text-xs text-gray-600">09:30</span>
                  <span class="text-xs font-medium text-gray-800 ml-2">Alissa McGuire</span>
                  <span class="ml-auto text-xs bg-blue-200 text-blue-800 px-1.5 py-0.5 rounded">Check-up</span>
                </div>
                <div class="flex items-center bg-green-50/50 p-2 rounded-md transform translate-x-full opacity-0 appointment-item">
                  <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                  <span class="text-xs text-gray-600">11:00</span>
                  <span class="text-xs font-medium text-gray-800 ml-2">Lucy Grinalds</span>
                  <span class="ml-auto text-xs bg-green-200 text-green-800 px-1.5 py-0.5 rounded">Treatment</span>
                </div>
                <div class="flex items-center bg-purple-50/50 p-2 rounded-md transform translate-x-full opacity-0 appointment-item">
                  <div class="w-2 h-2 bg-purple-500 rounded-full mr-2"></div>
                  <span class="text-xs text-gray-600">14:30</span>
                  <span class="text-xs font-medium text-gray-800 ml-2">Mohammed B.</span>
                  <span class="ml-auto text-xs bg-purple-200 text-purple-800 px-1.5 py-0.5 rounded">Consultation</span>
                </div>
              </div>
              <!-- Activity Indicator -->
              <div class="mt-3 pt-2 border-t border-gray-100 flex items-center justify-between">
                <div class="flex items-center">
                  <div class="typing-indicator"><span></span><span></span><span></span></div>
                  <span class="text-xs text-gray-500 ml-2">AI analyzing patient data...</span>
                </div>
                <div class="text-xs text-gray-500">Just now</div>
              </div>
            </div>
          </div>
          
          <!-- Analytics Quick View -->
          <div class="px-4 py-2 bg-gray-50 border-t border-gray-200 flex justify-between items-center">
            <div class="flex items-center space-x-3">
              <div class="chart-pill">
                <div class="chart-line"></div>
                <div class="chart-line"></div>
                <div class="chart-line"></div>
                <div class="chart-line"></div>
                <div class="chart-line"></div>
              </div>
              <span class="text-xs text-gray-600">Weekly Revenue: <span class="font-medium text-gray-800">$12,450</span></span>
            </div>
            <div class="flex items-center space-x-1">
              <span class="text-xs text-gray-600">System Status:</span>
              <span class="text-xs font-medium text-green-600">Optimal</span>
              <div class="pulse-dot bg-green-500 ml-1"></div>
            </div>
          </div>
        </div>
      </div>
      
      <p class={styles.content.header.description}>
        {description}
      </p>
      
      <!-- Action Buttons -->
      <div class={styles.content.header.buttonsContainer}>
        <a
          href={button1Link}
          class={styles.content.header.primaryButton}
        >
          {button1Text}
        </a>
        <a
          href={button2Link}
          class={styles.content.header.secondaryButton}
        >
          {button2Text}
        </a>
      </div>
    </div>

    <!-- Feature Cards -->
    {cards && cards.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
        {cards.map((card, index) => (
          <div class="relative group bg-white/80 backdrop-blur-sm border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 bg-[#0a91b1]/10 w-24 h-24 rounded-bl-full -mr-6 -mt-6 z-0"></div>
            
            <div class="relative z-10">
              <!-- Feature Icon -->
              <div class="w-12 h-12 rounded-lg bg-[#0a91b1]/10 flex items-center justify-center mb-4">
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class="w-6 h-6 text-[#0a91b1]" 
                  fill="none" 
                  viewBox="0 0 24 24" 
                  set:html={card.icon || featureIcons[index % featureIcons.length]}
                />
              </div>
              
              <!-- Feature Title -->
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                {card.title}
              </h3>
              
              <!-- Feature Description -->
              <p class="text-gray-600 text-sm mb-4">
                {card.description}
              </p>
              
              <!-- Software Feature Tag -->
              <div class="inline-flex items-center px-2 py-1 bg-gray-100 rounded-md text-xs font-medium text-gray-600">
                {index === 0 ? 'Core Module' : 
                 index === 1 ? 'Premium Feature' : 
                 index === 2 ? 'AI-Powered' : 
                 index === 3 ? 'Integration' : 
                 index === 4 ? 'Analytics' : 'Cloud Sync'}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- System Security Badges -->
    {trustBadges && trustBadges.length > 0 && (
      <div class="mt-16 py-6 px-8 bg-[#0a91b1]/5 rounded-2xl border border-[#0a91b1]/10 backdrop-blur-sm">
        <div class="flex items-center justify-center mb-4">
          <div class="w-5 h-5 rounded-full bg-[#0a91b1]/20 flex items-center justify-center mr-2">
            <svg class="w-3 h-3 text-[#0a91b1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-gray-700">System Security & Compliance</span>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {trustBadges.map((badge) => (
            <div class="flex items-center bg-white/80 px-4 py-3 rounded-lg border border-gray-100">
              <svg class="w-5 h-5 text-green-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-sm text-gray-700">{badge}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style define:vars={{ 
  blobDuration: styles.animations.blob.duration,
  backdropBlur: styles.effects.backdropBlur,
  hoverTranslate: styles.effects.hoverTranslate
}}>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob var(--blobDuration, 20s) infinite linear;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(0, 0, 0, 0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  /* Dashboard Animation Styles */
  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: pulse-animation 2s infinite;
  }
  
  @keyframes pulse-animation {
    0% { transform: scale(0.8); opacity: 0.5; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(0.8); opacity: 0.5; }
  }
  
  .progress-bar {
    width: 0%;
    transition: width 1.5s ease-out;
  }
  
  .appointment-item {
    transition: all 0.6s ease-out;
  }
  
  .notification-badge {
    position: relative;
    animation: badge-pulse 2s infinite;
  }
  
  @keyframes badge-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }
  
  .typing-indicator {
    display: inline-flex;
    align-items: center;
    height: 10px;
  }
  
  .typing-indicator span {
    display: inline-block;
    width: 4px;
    height: 4px;
    margin: 0 1px;
    background: #0a91b1;
    border-radius: 50%;
    animation: typing 1s infinite ease-in-out;
  }
  
  .typing-indicator span:nth-child(1) { animation-delay: 0s; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
  
  @keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  
  .chart-pill {
    display: flex;
    align-items: flex-end;
    height: 16px;
    gap: 2px;
  }
  
  .chart-line {
    width: 3px;
    background-color: #0a91b1;
    border-radius: 1px;
    animation: chart-animation 2.5s infinite;
  }
  
  .chart-line:nth-child(1) { height: 6px; animation-delay: 0s; }
  .chart-line:nth-child(2) { height: 10px; animation-delay: 0.2s; }
  .chart-line:nth-child(3) { height: 8px; animation-delay: 0.4s; }
  .chart-line:nth-child(4) { height: 12px; animation-delay: 0.6s; }
  .chart-line:nth-child(5) { height: 9px; animation-delay: 0.8s; }
  
  @keyframes chart-animation {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.2); }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Set up intersection observer to trigger animations when dashboard is visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Animate progress bar
          const progressBar = entry.target.querySelector('.progress-bar');
          if (progressBar) {
            const targetWidth = progressBar.getAttribute('data-width');
            setTimeout(() => {
              progressBar.style.width = `${targetWidth}%`;
            }, 300);
          }
          
          // Animate count-up numbers
          const countElements = entry.target.querySelectorAll('.count-up');
          countElements.forEach(el => {
            const target = parseInt(el.getAttribute('data-target'));
            animateCount(el, target);
          });
          
          // Animate appointments sliding in
          const appointments = entry.target.querySelectorAll('.appointment-item');
          appointments.forEach((app, index) => {
            setTimeout(() => {
              app.style.transform = 'translateX(0)';
              app.style.opacity = '1';
            }, 300 + (index * 200));
          });
          
          // Unobserve after triggering animations
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    
    // Observe the dashboard element
    const dashboard = document.getElementById('animated-dashboard');
    if (dashboard) {
      observer.observe(dashboard);
    }
    
    // Function to animate count-up
    function animateCount(element, target) {
      let current = 0;
      const increment = Math.ceil(target / 30); // Divide animation into 30 steps
      const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        element.textContent = current;
      }, 50);
    }
  });
</script>