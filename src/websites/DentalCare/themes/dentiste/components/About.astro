---
interface Feature {
  icon: string;
  title: string;
  description: string;
  bullets?: string[];
  backgroundSvg?: string;
  keywords?: string[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  features?: Array<{
    title: string;
    description: string;
    icon?: string;
  }>;
  stats?: Array<{
    value: string;
    label: string;
  }>;
  experienceBadge?: {
    value: string;
    label: string;
  };
  ctaButton?: {
    text: string;
    link: string;
  };
}

const { 
  subtitle, 
  title, 
  description, 
  image,
  features = [],
  stats = [],
  experienceBadge,
  ctaButton
} = Astro.props;

// Software feature icons
const featureIcons = [
  `<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M9.5 2C7.01472 2 5 4.01472 5 6.5C5 7.19871 5.14929 7.86196 5.41484 8.46384C3.43536 9.63192 2 11.6948 2 14C2 16.3981 3.4292 18.5138 5.49914 19.6573C5.1893 20.1596 5 20.7597 5 21.4C5 23.3882 6.61177 25 8.6 25C9.99469 25 11.1957 24.1955 11.7315 23H15.2685C15.8043 24.1955 17.0053 25 18.4 25C20.3882 25 22 23.3882 22 21.4C22 20.7597 21.8107 20.1596 21.5009 19.6573C23.5708 18.5138 25 16.3981 25 14C25 11.6948 23.5646 9.63192 21.5852 8.46384C21.8507 7.86196 22 7.19871 22 6.5C22 4.01472 19.9853 2 17.5 2C15.6978 2 14.1343 3.12573 13.5177 4.74856C13.1841 4.66294 12.8371 4.62 12.4824 4.62C12.1276 4.62 11.7807 4.66294 11.447 4.74856C10.8305 3.12573 9.2675 2 7.46534 2H9.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`,
  `<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`
];
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-gray-900 to-gray-800" id="content-aboutSection">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
    
    <!-- Software Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Software Dashboard Section -->
      <div class="flex-1 order-2 lg:order-1">
        <div class="relative">
          <!-- Dashboard Container -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <!-- Software Window Frame -->
            <div class="bg-gray-800 px-4 py-2 flex items-center border-b border-gray-700">
              <div class="flex space-x-2 mr-4">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              </div>
              <div class="text-xs font-medium text-gray-400">Atlagia DentalCare Dashboard</div>
            </div>
            
            <!-- Dashboard Image -->
            <div class="relative z-10 h-[400px] bg-gray-900 rounded-2xl border border-gray-700 shadow-2xl">
              {image && (
                <video 
                  src="https://cdn.atlagia.com/Dental_Practice_Video_Creation_Request.mp4"
                  controls
                  autoplay
                  loop
                  muted
                  class="w-full h-full object-cover object-top rounded-2xl"
                  loading="lazy"
                  id="content-image"
                >Your browser does not support the video tag.</video>
              )}
              
              <!-- Dashboard Overlay UI Elements -->
              <div class="absolute top-4 right-4 bg-blue-500 text-white text-xs py-1 px-3 rounded-full animate-pulse">
                New Patient Added
              </div>
              
              <div class="absolute bottom-4 left-4 right-4 bg-gray-800/80 backdrop-blur-sm p-3 rounded-lg border border-gray-700">
                <div class="flex justify-between items-center">
                  <div class="text-sm font-medium text-white">Today's Schedule</div>
                  <div class="text-xs text-blue-400">View All</div>
                </div>
                <div class="mt-2 space-y-1.5">
                  <div class="flex justify-between items-center">
                    <div class="flex items-center">
                      <div class="w-2 h-2 bg-green-500 rounded-full mr-2"></div>
                      <span class="text-xs text-gray-300">09:30</span>
                      <span class="text-xs font-medium text-white ml-2">Alissa McGuire</span>
                    </div>
                    <span class="text-xs text-gray-400">Regular Checkup</span>
                  </div>
                  <div class="flex justify-between items-center">
                    <div class="flex items-center">
                      <div class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></div>
                      <span class="text-xs text-gray-300">11:00</span>
                      <span class="text-xs font-medium text-white ml-2">Mohammed B.</span>
                    </div>
                    <span class="text-xs text-gray-400">Crown Fitting</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Decorative Elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-[#0a91b1]/20 rounded-full blur-lg"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-blue-500/20 rounded-full blur-lg"></div>

          <!-- Experience Badge -->
          {experienceBadge && (
            <div class="absolute top-16 right-4 bg-gray-800/80 backdrop-blur-sm px-6 py-4 rounded-lg shadow-lg border border-gray-700">
              <div class="text-3xl font-bold text-[#0a91b1]" id="content-experienceBadgeValue">{experienceBadge.value}</div>
              <div class="text-sm text-gray-300" id="content-experienceBadgeLabel">{experienceBadge.label}</div>
            </div>
          )}
        </div>
      </div>

      <!-- Content Section -->
      <div class="flex-1 order-1 lg:order-2">
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/20 text-[#0a91b1] backdrop-blur-sm border border-[#0a91b1]/30" id="content-subtitle">
          {subtitle}
        </span>
        
        <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6" id="content-title">
          {title}
        </h2>
        
        <p class="text-lg text-gray-300 leading-relaxed mb-8" id="content-description">
          {description}
        </p>

        <!-- Features List -->
        <div class="space-y-6 mb-8">
          {features.map((feature, index) => (
            <div class="flex gap-4 group">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#0a91b1]/20 flex items-center justify-center border border-[#0a91b1]/30 group-hover:bg-[#0a91b1]/30 transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#0a91b1]" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={feature.icon || featureIcons[index % featureIcons.length]}>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white mb-1 group-hover:text-[#0a91b1] transition-colors duration-300" id={`content-featureTitle-${index}`}>{feature.title}</h3>
                <p class="text-gray-300" id={`content-featureDescription-${index}`}>{feature.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Stats Grid -->
        {stats && stats.length > 0 && (
          <div class="grid grid-cols-2 gap-4 mt-12">
            {stats.map((stat, index) => (
              <div class="relative p-4 bg-gray-800/50 backdrop-blur-sm rounded-xl border border-gray-700 overflow-hidden group hover:bg-gray-800/80 transition-all duration-300">
                <!-- Stat Highlight Effect -->
                <div class="absolute top-0 right-0 w-20 h-20 bg-[#0a91b1]/10 rounded-bl-full -mt-4 -mr-4 group-hover:bg-[#0a91b1]/20 transition-colors duration-300"></div>
                
                <div class="relative">
                  <div class="text-3xl font-bold text-[#0a91b1] mb-1" id={`content-statValue-${index}`}>{stat.value}</div>
                  <div class="text-gray-300 font-medium" id={`content-statLabel-${index}`}>{stat.label}</div>
                  
                  <!-- Progress Bar -->
                  <div class="w-full h-1 bg-gray-700 rounded-full mt-3 overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-[#0a91b1] to-blue-500/70 rounded-full" style={`width: ${Math.random() * 40 + 60}%`}></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- CTA Button -->
        {ctaButton && (
          <div class="mt-12">
            <a 
              href={ctaButton.link} 
              class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-[#0a91b1] hover:bg-[#097d99] rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25 hover:-translate-y-0.5"
              id="content-ctaButton"
            >
              {ctaButton.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style> 