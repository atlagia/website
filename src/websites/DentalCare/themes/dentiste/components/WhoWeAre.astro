---
import styles from '../style/component/whoWeAreSection.json';

interface Stat {
  value: string;
  label: string;
}

interface TrustIndicator {
  icon: string;
  text: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  stats: Stat[];
  trustIndicators?: TrustIndicator[];
  ctaButton?: {
    text: string;
    link: string;
  };
}

const { 
  subtitle, 
  title, 
  description, 
  image, 
  stats,
  trustIndicators,
  ctaButton
} = Astro.props;

// Team expertise icons
const expertiseIcons = [
  // Dental expertise
  `<path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>`,
  // Technology expertise
  `<path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>`,
  // AI & ML
  `<path d="M9.5 2C7.01472 2 5 4.01472 5 6.5C5 7.19871 5.14929 7.86196 5.41484 8.46384C3.43536 9.63192 2 11.6948 2 14C2 16.3981 3.4292 18.5138 5.49914 19.6573C5.1893 20.1596 5 20.7597 5 21.4C5 23.3882 6.61177 25 8.6 25C9.99469 25 11.1957 24.1955 11.7315 23H15.2685C15.8043 24.1955 17.0053 25 18.4 25C20.3882 25 22 23.3882 22 21.4C22 20.7597 21.8107 20.1596 21.5009 19.6573C23.5708 18.5138 25 16.3981 25 14C25 11.6948 23.5646 9.63192 21.5852 8.46384C21.8507 7.86196 22 7.19871 22 6.5C22 4.01472 19.9853 2 17.5 2C15.6978 2 14.1343 3.12573 13.5177 4.74856C13.1841 4.66294 12.8371 4.62 12.4824 4.62C12.1276 4.62 11.7807 4.66294 11.447 4.74856C10.8305 3.12573 9.2675 2 7.46534 2H9.5Z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>`
];
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-gray-50 to-gray-100" id="content-whoWeAreSection">
  <!-- Subtle Grid Pattern -->
  <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>

  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Team Image Section -->
      <div class="flex-1 order-2 lg:order-1">
        <div class="relative">
          <!-- Image Container with Perspective Effect -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl transform perspective-1000 group">
            <!-- Software Window Frame -->
            <div class="bg-gray-800 px-4 py-2 flex items-center border-b border-gray-700">
              <div class="flex space-x-2 mr-4">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              </div>
              <div class="text-xs font-medium text-gray-400">Atlagia Team Profile</div>
            </div>
            
            <div class="relative z-10 overflow-hidden">
              <video 
                src="https://cdn.atlagia.com/Atlagia_Team_Animated_Video_Request.mp4"
                controls
                autoplay
                loop
                muted
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700"
                id="content-whoWeAreImage"
              >Your browser does not support the video tag.</video>
              
              <!-- Team Badge Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-70"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex items-center space-x-2 mb-2">
                  <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
                  <span class="text-sm font-medium text-white">Team Status: Building the Future of Dental Tech</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  <span class="bg-[#0a91b1]/90 text-white text-xs px-2 py-1 rounded-md">Dental Experts</span>
                  <span class="bg-blue-600/90 text-white text-xs px-2 py-1 rounded-md">Software Engineers</span>
                  <span class="bg-purple-600/90 text-white text-xs px-2 py-1 rounded-md">AI Specialists</span>
                  <span class="bg-green-600/90 text-white text-xs px-2 py-1 rounded-md">UX Designers</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Decorative Elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-[#0a91b1]/20 rounded-full blur-lg"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-blue-500/20 rounded-full blur-lg"></div>
        </div>
      </div>

      <!-- Content Section -->
      <div class="flex-1 order-1 lg:order-2">
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/20 text-[#0a91b1] backdrop-blur-sm border border-[#0a91b1]/30" id="content-subtitle">
          {subtitle}
        </span>
        <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight mb-6" id="content-title">
          {title}
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8" id="content-description">
          {description}
        </p>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 gap-4 mb-8">
          {stats.map((stat, index) => (
            <div class="relative p-4 bg-white backdrop-blur-sm rounded-xl border border-gray-200 shadow-sm overflow-hidden group hover:shadow-md hover:border-[#0a91b1]/30 transition-all duration-300">
              <!-- Stat Highlight Effect -->
              <div class="absolute top-0 right-0 w-20 h-20 bg-[#0a91b1]/10 rounded-bl-full -mt-4 -mr-4 group-hover:bg-[#0a91b1]/20 transition-colors duration-300"></div>
              
              <div class="relative">
                <div class="text-3xl font-bold text-[#0a91b1] mb-1" id={`content-statValue-${index}`}>{stat.value}</div>
                <div class="text-gray-600 font-medium" id={`content-statLabel-${index}`}>{stat.label}</div>
                
                <!-- Progress Bar -->
                <div class="w-full h-1 bg-gray-100 rounded-full mt-3 overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-[#0a91b1] to-blue-500/70 rounded-full" style={`width: ${Math.random() * 40 + 60}%`}></div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Core Values & Expertise -->
        {trustIndicators && trustIndicators.length > 0 && (
          <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm mb-8">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Our Development Approach</h3>
            <div class="space-y-4">
              {trustIndicators.map((indicator, index) => (
                <div class="flex items-start gap-3 group">
                  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#0a91b1]/20 flex items-center justify-center group-hover:bg-[#0a91b1]/30 transition-colors duration-300">
                    <svg class="w-5 h-5 text-[#0a91b1]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={indicator.icon || expertiseIcons[index % expertiseIcons.length]}>
                    </svg>
                  </div>
                  <div>
                    <span class="block text-gray-900 font-medium group-hover:text-[#0a91b1] transition-colors duration-300" id={`content-trustIndicator-${index}`}>{indicator.text}</span>
                    <span class="text-sm text-gray-500">
                      {index === 0 ? 'We combine dental expertise with cutting-edge technology' : 
                       index === 1 ? 'Built with dentists for dentists, ensuring real-world utility' : 
                       'Continuous improvement based on customer feedback'}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- CTA Button -->
        {ctaButton && (
          <div class="mt-6">
            <a 
              href={ctaButton.link} 
              class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-[#0a91b1] hover:bg-[#097d99] rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25 hover:-translate-y-0.5"
              id="content-ctaButton"
            >
              {ctaButton.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(10, 145, 177, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(10, 145, 177, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  
  /* Perspective effect */
  .perspective-1000 {
    perspective: 1000px;
  }
</style> 