---
import styles from '../style/component/ctaSection.json';

interface Props {
  subtitle?: string;
  title: string;
  description: string;
  primaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonText: string;
  secondaryButtonLink: string;
  stats?: Array<{
    value: string;
    label: string;
  }>;
  emergencyContact?: {
    phone: string;
    hours: string;
  };
  trustIndicators?: string[];
}

const {
  subtitle,
  title,
  description,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  stats,
  emergencyContact,
  trustIndicators
} = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900" id="content-ctaSection">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/20 to-blue-500/20 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/20 to-[#0a91b1]/20 rounded-full blur-3xl animate-blob"></div>
    
    <!-- Software Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.05]"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-3 flex flex-col justify-center">
        {subtitle && (
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/20 text-[#0a91b1] backdrop-blur-sm border border-[#0a91b1]/30" id="content-subtitle">
            {subtitle}
          </span>
        )}
        <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6" id="content-title">
          {title}
        </h2>
        <p class="text-lg text-gray-300 leading-relaxed mb-8" id="content-description">
          {description}
        </p>
        
        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <a
            href={primaryButtonLink}
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-[#0a91b1] hover:bg-[#097d99] rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25 hover:-translate-y-0.5"
            id="content-primaryButtonText"
          >
            {primaryButtonText}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
          <a
            href={secondaryButtonLink}
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-gray-200 border-2 border-gray-700 hover:border-gray-600 bg-gray-800/50 hover:bg-gray-800 rounded-lg transition-all duration-300"
            id="content-secondaryButtonText"
          >
            {secondaryButtonText}
          </a>
        </div>
        
        <!-- Trust Indicators -->
        {trustIndicators && trustIndicators.length > 0 && (
          <div class="grid grid-cols-2 gap-3 mt-4">
            {trustIndicators.map((feature, index) => (
              <div class="flex items-center gap-2 text-gray-300 group">
                <div class="flex-shrink-0 w-6 h-6 rounded-full bg-[#0a91b1]/20 flex items-center justify-center group-hover:bg-[#0a91b1]/30 transition-colors duration-300">
                  <svg class="w-4 h-4 text-[#0a91b1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm" id={`content-trustIndicator-${index}`}>{feature}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Software Demo Preview -->
      <div class="lg:col-span-2">
        <div class="relative">
          <!-- Demo Card -->
          <div class="bg-gray-800/80 backdrop-blur-md rounded-xl border border-gray-700 shadow-xl overflow-hidden">
            <!-- Window Controls -->
            <div class="bg-gray-900 px-4 py-2 flex items-center justify-between border-b border-gray-700">
              <div class="flex space-x-2">
                <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              </div>
              <div class="text-xs font-medium text-gray-400">Atlagia DentalCare Demo</div>
            </div>
            
            <!-- Form -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-white mb-5">Request a Live Demo</h3>
              
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Practice Name</label>
                  <input type="text" class="w-full px-4 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50" placeholder="Your Practice Name" />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Your Name</label>
                  <input type="text" class="w-full px-4 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50" placeholder="Dr. Jane Smith" />
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Email Address</label>
                  <input type="email" class="w-full px-4 py-2 bg-gray-700/50 border border-gray-600 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0a91b1]/50" placeholder="jane@example.com" />
                </div>
                
                <button class="w-full py-3 bg-[#0a91b1] hover:bg-[#097d99] text-white font-medium rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#0a91b1]/25">
                  Schedule Demo
                </button>
              </div>
              
              <!-- Stats as badges -->
              {stats && (
                <div class="flex flex-wrap gap-2 mt-6">
                  {stats.map((stat, index) => (
                    <div class="bg-gray-700/50 rounded-full px-3 py-1 flex items-center gap-1">
                      <span class="text-[#0a91b1] font-bold text-sm" id={`content-statValue-${index}`}>{stat.value}</span>
                      <span class="text-gray-300 text-xs" id={`content-statLabel-${index}`}>{stat.label}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
          
          <!-- Support Section -->
          {emergencyContact && (
            <div class="mt-4 bg-gray-800/80 backdrop-blur-md rounded-xl border border-gray-700 p-4 shadow-lg">
              <div class="flex items-center">
                <div class="mr-3 p-2 rounded-full bg-[#0a91b1]/20 text-[#0a91b1]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-medium text-white" id="content-emergencyTitle">Technical Support</div>
                  <div class="text-base font-bold text-[#0a91b1]" id="content-emergencyPhone">
                    {emergencyContact.phone}
                  </div>
                  <div class="text-xs text-gray-400" id="content-emergencyHours">
                    {emergencyContact.hours}
                  </div>
                </div>
              </div>
            </div>
          )}
          
          <!-- Decorative Elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-[#0a91b1]/10 rounded-full blur-lg"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-blue-500/10 rounded-full blur-lg"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }
  
  .backdrop-blur-md {
    backdrop-filter: blur(12px);
  }

  .hover\:-translate-y-0.5:hover {
    transform: translateY(-2px);
  }
  
  /* Grid Pattern Background */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style> 