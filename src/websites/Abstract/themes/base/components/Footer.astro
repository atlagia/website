---
const currentYear = new Date().getFullYear();
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Abstract';

const footerNav = {
  company: [
    { name: 'About', href: '/about' },
    { name: 'Contact', href: '/contact' },
    { name: 'Blog', href: '/blog' },
  ],
  legal: [
    { name: 'Privacy', href: '/privacy' },
    { name: 'Terms', href: '/terms' },
  ],
};
---

<footer class="bg-gray-900" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-4">
        <span class="text-2xl font-bold text-white">{siteName}</span>
        <p class="text-sm leading-6 text-gray-300">Your site description here. Customize in Footer.astro.</p>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div>
          <h3 class="text-sm font-semibold text-white">Company</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNav.company.map((item) => (
              <li><a href={item.href} class="text-sm text-gray-300 hover:text-white">{item.name}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white">Legal</h3>
          <ul role="list" class="mt-6 space-y-4">
            {footerNav.legal.map((item) => (
              <li><a href={item.href} class="text-sm text-gray-300 hover:text-white">{item.name}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-white/10 pt-8">
      <p class="text-xs text-gray-400">&copy; {currentYear} {siteName}. All rights reserved.</p>
    </div>
  </div>
</footer>
