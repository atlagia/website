---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://www.motorracingapparel.com';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Racing Tees | ${storeName}`;
const seoDescription = "Premium tees celebrating racing culture. From F1 to Le Mans, wear the passion of motorsport with our racing tees collection.";
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--mra-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight text-[var(--mra-bg)] mb-6">
            Racing Tees
          </h1>
          <p class="text-xl md:text-2xl text-[var(--mra-bg)]/90 mb-8">
            Premium tees celebrating racing culture
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-cyan-600 hover:bg-cyan-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Racing Tees
            </a>
            <a href={`/${lang}/formula1-collection`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
              F1 Collection
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Tees Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Premium Racing Tees</h2>
          <p class="text-xl text-[var(--mra-muted)] max-w-3xl mx-auto">
            From F1 to Le Mans, our racing tees celebrate the world's greatest racing championships and the legends who have conquered them.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Crown class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">F1 Champions</h3>
            <p class="text-[var(--mra-muted)]">
              Celebrate the greatest Formula 1 champions who have conquered the pinnacle of motorsport and earned their place in racing history.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Star class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Le Mans Heroes</h3>
            <p class="text-[var(--mra-muted)]">
              Honor the legendary Le Mans heroes who have conquered the world's most grueling endurance race and inspired generations of racing fans.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Premium Quality</h3>
            <p class="text-[var(--mra-muted)]">
              Every tee is crafted with premium materials and attention to detail, ensuring comfort and durability for the racing enthusiast.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Tees Categories -->
    <section class="py-20 bg-[var(--mra-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Racing Tees Collection</h2>
          <p class="text-xl text-[var(--mra-muted)]">Celebrate the world's greatest racing championships</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/formula1-collection`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Crown class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">F1 Racing Tees</h3>
              <p class="text-[var(--mra-muted)] mb-4">Premium tees celebrating Formula 1 racing</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop F1 Racing Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/le-mans-hoodies`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Star class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Le Mans Racing Tees</h3>
              <p class="text-[var(--mra-muted)] mb-4">Classic tees honoring Le Mans endurance racing</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Le Mans Racing <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/rally-champions`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Rally Racing Tees</h3>
              <p class="text-[var(--mra-muted)] mb-4">Tees celebrating rally racing championships</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Rally Racing <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Wear Racing Culture</h2>
        <p class="text-xl text-[var(--mra-bg)]/90 mb-8">
          Join the global racing community and celebrate the world's greatest racing championships with our premium racing tees collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-cyan-600 hover:bg-cyan-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Racing Tees Collection
          </a>
          <a href={`/${lang}/formula1-collection`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
            Explore F1 Collection
          </a>
        </div>
      </div>
    </section>
  </div>
<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
</Layoutc>
