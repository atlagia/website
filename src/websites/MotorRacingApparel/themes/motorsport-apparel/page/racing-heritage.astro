---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Trophy, Clock, Flag, Award } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://www.motorracingapparel.com';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Racing Heritage | ${storeName}`;
const seoDescription = "Discover the rich heritage of motorsport racing. From Formula 1 legends to Le Mans heroes, celebrate the history and legacy of racing.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--mra-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight text-[var(--mra-bg)] mb-6">
            Racing Heritage
          </h1>
          <p class="text-xl md:text-2xl text-[var(--mra-bg)]/90 mb-8">
            Celebrating the legends and legacy of motorsport
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/f1-legends`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
              F1 Legends
            </a>
            <a href={`/${lang}/le-mans-heroes`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
              Le Mans Heroes
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Heritage Timeline -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">A Legacy of Excellence</h2>
          <p class="text-xl text-[var(--mra-muted)] max-w-3xl mx-auto">
            From the golden age of Formula 1 to the endurance challenges of Le Mans, we honor the champions who defined racing history.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Formula 1 Champions</h3>
            <p class="text-[var(--mra-muted)]">
              Celebrate the greatest F1 drivers and teams who made history on the world's most prestigious racing circuits.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Clock class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Le Mans Endurance</h3>
            <p class="text-[var(--mra-muted)]">
              Honor the heroes of 24-hour endurance racing who pushed the limits of speed and endurance at Le Mans.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Flag class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Rally Champions</h3>
            <p class="text-[var(--mra-muted)]">
              Remember the rally legends who conquered the world's toughest terrains and most challenging conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Categories -->
    <section class="py-20 bg-[var(--mra-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Racing Categories</h2>
          <p class="text-xl text-[var(--mra-muted)]">Explore different forms of motorsport heritage</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/formula1-collection`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Formula 1 Collection</h3>
              <p class="text-[var(--mra-muted)] mb-4">Premium F1 inspired merchandise celebrating racing legends</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/endurance-racing`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Clock class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Endurance Racing</h3>
              <p class="text-[var(--mra-muted)] mb-4">Le Mans and endurance racing heritage collection</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/rally-racing`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Flag class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Rally Racing</h3>
              <p class="text-[var(--mra-muted)] mb-4">Rally champions and iconic moments collection</p>
              <div class="flex items-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Racing Legends -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Racing Legends</h2>
          <p class="text-xl text-[var(--mra-muted)]">Honor the greatest drivers in motorsport history</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <a href={`/${lang}/f1-legends`} class="group bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Award class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4 text-center">F1 Legends</h3>
            <p class="text-[var(--mra-muted)] text-center mb-6">
              Celebrate the greatest Formula 1 drivers who made history on the world's most prestigious circuits.
            </p>
            <div class="flex items-center justify-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
              Explore F1 Legends <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>

          <a href={`/${lang}/le-mans-heroes`} class="group bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Clock class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4 text-center">Le Mans Heroes</h3>
            <p class="text-[var(--mra-muted)] text-center mb-6">
              Honor the endurance racing champions who conquered the 24 Hours of Le Mans.
            </p>
            <div class="flex items-center justify-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
              Explore Le Mans Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>

          <a href={`/${lang}/rally-champions`} class="group bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Flag class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4 text-center">Rally Champions</h3>
            <p class="text-[var(--mra-muted)] text-center mb-6">
              Remember the rally legends who conquered the world's toughest terrains and conditions.
            </p>
            <div class="flex items-center justify-center text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
              Explore Rally Champions <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Preserve Racing Heritage</h2>
        <p class="text-xl text-[var(--mra-bg)]/90 mb-8">
          Join us in celebrating the rich history of motorsport. Wear the legacy of racing champions and keep their stories alive.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
            Explore Heritage Collection
          </a>
          <a href={`/${lang}/racing-culture`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
            Learn Racing History
          </a>
        </div>
      </div>
    </section>
  </div>
<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
</Layoutc>
