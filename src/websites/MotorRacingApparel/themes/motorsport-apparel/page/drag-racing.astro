---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Zap, Car, Trophy, Star } from 'lucide-react';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

const seoTitle = `Drag Racing | ${storeName}`;
const seoDescription = "Experience the raw power of drag racing. From quarter-mile legends to drag strip heroes, celebrate the ultimate test of speed and acceleration.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--mra-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="relative z-10 text-center px-4 py-20">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight mb-6">
            Drag Racing
          </h1>
          <p class="font-body text-xl md:text-2xl text-[var(--mra-bg)]/90 mb-8">
            The ultimate test of speed and acceleration
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
              Drag Racing Collection
            </a>
            <a href={`/${lang}/racing-culture`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
              Racing Culture
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Drag Racing Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Quarter-Mile Legends</h2>
          <p class="font-body text-xl text-[var(--mra-muted)] max-w-3xl mx-auto">
            Drag racing is the ultimate test of speed, power, and acceleration. From quarter-mile legends to drag strip heroes, celebrate the champions who push the limits of speed.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--mra-card)] rounded-2xl p-8 shadow-sm border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Zap class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Quarter-Mile Champions</h3>
            <p class="font-body text-[var(--mra-muted)]">
              Celebrate the legendary drag racers who have conquered the quarter-mile and earned their place in drag racing history.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 shadow-sm border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Car class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Drag Strip Heroes</h3>
            <p class="font-body text-[var(--mra-muted)]">
              Honor the legendary drag cars and drivers who have shaped the sport and continue to inspire generations of drag racing enthusiasts.
            </p>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 shadow-sm border border-[var(--mra-border)]">
            <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Speed Records</h3>
            <p class="font-body text-[var(--mra-muted)]">
              Experience the rich history of drag racing through authentic designs that capture the spirit of speed and acceleration.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Drag Racing Categories -->
    <section class="py-20 bg-[var(--mra-surface)] border-y border-[var(--mra-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Drag Racing Collection</h2>
          <p class="font-body text-xl text-[var(--mra-muted)]">Celebrate the heroes of drag racing</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/collections`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
              <Zap class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Drag Racing Hoodies</h3>
              <p class="font-body text-[var(--mra-muted)] mb-4">Premium hoodies celebrating drag racing legends</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] transition-colors font-body">
                Shop Drag Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </span>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)]/90 flex items-center justify-center text-[var(--mra-bg)]">
              <Car class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Drag Racing Tees</h3>
              <p class="font-body text-[var(--mra-muted)] mb-4">Classic tees celebrating drag racing heritage</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] transition-colors font-body">
                Shop Drag Tees <ArrowRight class="w-4 h-4 ml-2" />
              </span>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--mra-text)]/80 flex items-center justify-center text-[var(--mra-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">Drag Accessories</h3>
              <p class="font-body text-[var(--mra-muted)] mb-4">Essential accessories for drag racing fans</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] transition-colors font-body">
                Shop Drag Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Drag Racing Culture -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Drag Racing Culture</h2>
          <p class="font-body text-xl text-[var(--mra-muted)]">Experience the authentic drag racing lifestyle</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] text-center">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Zap class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Quarter-Mile Scene</h3>
            <p class="font-body text-[var(--mra-muted)] mb-6">
              Experience the raw power of quarter-mile drag racing with authentic designs that capture the speed and acceleration of the sport.
            </p>
            <a href={`/${lang}/street-culture`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] hover:text-[var(--mra-accent-hover)] transition-colors font-body">
              Explore Drag Scene <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] text-center">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Car class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Speed Records</h3>
            <p class="font-body text-[var(--mra-muted)] mb-6">
              Celebrate the legendary speed records and achievements that have shaped drag racing history.
            </p>
            <a href={`/${lang}/racing-heritage`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] hover:text-[var(--mra-accent-hover)] transition-colors font-body">
              Explore Speed Records <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)] text-center">
            <div class="w-20 h-20 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--mra-text)]">
              <Star class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">Drag Community</h3>
            <p class="font-body text-[var(--mra-muted)] mb-6">
              Connect with like-minded drag racing enthusiasts who share your passion for speed and acceleration.
            </p>
            <a href={`/${lang}/car-communities`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] hover:text-[var(--mra-accent-hover)] transition-colors font-body">
              Join Drag Community <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Experience Drag Racing Heritage</h2>
        <p class="font-body text-xl text-[var(--mra-bg)]/90 mb-8">
          Join the global drag racing community and celebrate the ultimate test of speed and acceleration with our authentic drag racing collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
            Shop Drag Racing Collection
          </a>
          <a href={`/${lang}/racing-culture`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">
            Explore Racing Culture
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
