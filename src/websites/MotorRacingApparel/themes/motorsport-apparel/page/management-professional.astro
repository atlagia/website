---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Users, Target } from 'lucide-react';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

let pageData;
try {
  pageData = await import(`../data/management-professional/management-professional_${lang}.json`);
} catch (error) {
  pageData = await import(`../data/management-professional/management-professional_en.json`);
}

const data = pageData.default;

const seoTitle = `${data.title} | ${storeName}`;
const seoDescription = data.description;
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--mra-bg)]">
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="relative z-10 text-center px-4 py-20">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight mb-6">{data.hero.title}</h1>
          <p class="font-body text-xl md:text-2xl text-[var(--mra-bg)]/90 mb-8">{data.hero.subtitle}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">{data.hero.cta1}</a>
            <a href={`/${lang}/professional-series`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">{data.hero.cta2}</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">{data.sections.features.title}</h2>
          <p class="font-body text-xl text-[var(--mra-muted)] max-w-3xl mx-auto">{data.sections.features.subtitle}</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8 mb-16">
          {data.features.map(feature => (
            <div class="bg-[var(--mra-card)] rounded-2xl p-8 border border-[var(--mra-border)]">
              <div class="w-16 h-16 bg-[var(--mra-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--mra-text)]">
                <Users class="w-8 h-8" />
              </div>
              <h3 class="font-headline text-2xl text-[var(--mra-text)] uppercase tracking-wide mb-4">{feature.title}</h3>
              <p class="font-body text-[var(--mra-muted)]">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--mra-surface)] border-y border-[var(--mra-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--mra-text)] uppercase tracking-wide mb-4">{data.sections.collection.title}</h2>
          <p class="font-body text-xl text-[var(--mra-muted)]">{data.sections.collection.subtitle}</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {data.collections.map(product => (
            <a href={`/${lang}${product.link}`} class="group bg-[var(--mra-card)] rounded-2xl overflow-hidden border border-[var(--mra-border)] hover:border-[var(--mra-text)]/30 transition-colors">
              <div class="h-48 bg-[var(--mra-text)] flex items-center justify-center text-[var(--mra-bg)]">
                <Target class="w-16 h-16" />
              </div>
              <div class="p-6">
                <h3 class="font-headline text-xl text-[var(--mra-text)] uppercase tracking-wide mb-2">{product.title}</h3>
                <p class="font-body text-[var(--mra-muted)] mb-4">{product.description}</p>
                <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--mra-text)] group-hover:text-[var(--mra-accent-hover)] transition-colors font-body">{product.linkText} <ArrowRight class="w-4 h-4 ml-2" /></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--mra-text)] text-[var(--mra-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">{data.cta.title}</h2>
        <p class="font-body text-xl text-[var(--mra-bg)]/90 mb-8">{data.cta.subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--mra-bg)] text-[var(--mra-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">{data.cta.button1}</a>
          <a href={`/${lang}/professional-series`} class="inline-flex items-center justify-center border-2 border-[var(--mra-bg)] text-[var(--mra-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-bg)]/10 transition-colors font-body">{data.cta.button2}</a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
