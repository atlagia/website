---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="mra-stats bg-[var(--mra-bg)] border-b border-[var(--mra-border)]">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12 py-8 lg:py-10">
    <div class="flex flex-wrap justify-center gap-x-12 gap-y-6 lg:gap-x-20">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="font-display text-2xl md:text-3xl font-bold text-[var(--mra-accent)] tracking-tight">{stat.value}</p>
          <p class="text-[10px] md:text-[11px] tracking-[0.25em] uppercase text-[var(--mra-muted)] mt-1 font-body">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
