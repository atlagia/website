---
import { Menu, Globe, Search } from 'lucide-react';
import { getLangFromUrl, getLocalizedPath } from '@utils/i18n';
import CartSidebarWithTrigger from '@themes/default/components/CartSidebarWithTrigger';

const navigation = [
  { name: 'Home', href: '/' },
  { name: 'Collections', href: '/collections' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
];

const getAllowedLanguages = (): string[] => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const languageNames: Record<string, string> = {
  en: "English", fr: "Français", de: "Deutsch", es: "Español", it: "Italiano",
  pt: "Português", nl: "Nederlands", ar: "العربية", zh: "中文", ja: "日本語", ko: "한국어",
};

const allowedLanguages = getAllowedLanguages();
const languages = allowedLanguages.map(lang => ({ code: lang, name: languageNames[lang] || lang }));

const currentPath = Astro.url.pathname;
const currentLang = getLangFromUrl(Astro.url);
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'MotorRacingApparel';

const localizedNavigation = navigation.map(item => ({
  ...item,
  href: `/${currentLang}${item.href === '/' ? '' : item.href}`
}));

const announcement = 'Free shipping on orders over $75 — Join the MotorRacingApparel community';

// Header styles for cart sidebar (F1 theme)
let headerStyles = {};
try {
  const themeHeaderStyles = await import('../styles/Header.json');
  headerStyles = themeHeaderStyles.default || {};
} catch (_) {}

// Payment config so cart checkout respects PUBLIC_PAYMENT_METHOD
const paymentConfig = {
  method: import.meta.env.PUBLIC_PAYMENT_METHOD || 'default',
  hoodpay: {
    apiUrl: import.meta.env.HOODPAY_API_URL,
    businessId: import.meta.env.HOODPAY_BUSINESS_ID,
    authToken: import.meta.env.HOODPAY_AUTH_TOKEN,
    redirectUrl: `${import.meta.env.DOMAINE || ''}${import.meta.env.HOODPAY_REDIRECT_URL || ''}`
  },
  store: {
    name: import.meta.env.PUBLIC_SITE_NAME || siteName,
    domain: import.meta.env.DOMAINE || 'localhost'
  }
};
const apiEndpoint = import.meta.env.VITE_API_ENDPOINT || '/api/checkout';
---

<!-- Master-class ecommerce header: always solid, light theme, clear hierarchy -->
<div class="f1-header-wrapper fixed w-full top-0 z-50">
  <!-- Announcement: light bar, dark text -->
  <div class="f1-announcement h-8 flex items-center justify-center bg-[var(--mra-surface)] border-b border-[var(--mra-border)]">
    <p class="text-[10px] sm:text-[11px] tracking-[0.2em] uppercase font-body text-[var(--mra-text)] px-4 truncate max-w-full text-center">
      {announcement}
    </p>
  </div>
  <header class="f1-header bg-[var(--mra-card)] border-b border-[var(--mra-border)] shadow-[0_1px_0_0_rgba(0,0,0,0.06)]">
    <nav class="mx-auto max-w-[1600px] px-4 sm:px-6 lg:px-10" aria-label="Main">
      <div class="flex h-14 sm:h-16 items-center justify-between gap-6">
        <!-- Logo -->
        <a href={`/${currentLang}`} class="f1-logo font-headline text-[1.05rem] sm:text-[1.15rem] font-bold tracking-tight text-[var(--mra-text)] uppercase hover:text-[var(--mra-accent-hover)] transition-colors shrink-0">
          {siteName}
        </a>

        <!-- Center nav (desktop) -->
        <div class="hidden lg:flex items-center justify-center gap-10 xl:gap-14 absolute left-1/2 -translate-x-1/2">
          {localizedNavigation.map((item) => {
            const isActive = currentPath === item.href || (item.href !== `/${currentLang}` && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class={`text-[11px] font-medium tracking-[0.2em] uppercase transition-colors duration-200 ${isActive ? 'text-[var(--mra-text)]' : 'text-[var(--mra-muted)] hover:text-[var(--mra-text)]'}`}
              >
                {item.name}
              </a>
            );
          })}
        </div>

        <!-- Right: search, lang, bag, account -->
        <div class="flex items-center gap-4 sm:gap-6 shrink-0">
          <a href={`/${currentLang}/search`} class="p-2 text-[var(--mra-muted)] hover:text-[var(--mra-text)] transition-colors" aria-label="Search">
            <Search className="h-4 w-4 sm:h-[18px] sm:w-[18px]" />
          </a>
          <div class="relative group">
            <button type="button" class="flex items-center gap-1.5 text-[var(--mra-muted)] hover:text-[var(--mra-text)] transition-colors py-2" aria-haspopup="true" aria-expanded="false">
              <Globe className="h-4 w-4 sm:h-[18px] sm:w-[18px]" />
              <span class="hidden sm:inline text-[10px] uppercase tracking-[0.18em] font-body">
                {languages.find(l => l.code === currentLang)?.name}
              </span>
            </button>
            <div class="absolute right-0 top-full mt-1 w-36 py-2 bg-[var(--mra-card)] border border-[var(--mra-border)] rounded-sm shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              {languages.map((lang) => (
                <a
                  href={getLocalizedPath(currentPath, lang.code)}
                  class={`block px-4 py-2 text-[10px] uppercase tracking-wider font-body ${currentLang === lang.code ? 'text-[var(--mra-text)] font-medium' : 'text-[var(--mra-muted)] hover:text-[var(--mra-text)]'}`}
                >
                  {lang.name}
                </a>
              ))}
            </div>
          </div>
          <CartSidebarWithTrigger
            client:load
            triggerClassName="flex items-center gap-1.5 text-[var(--mra-muted)] hover:text-[var(--mra-text)] transition-colors py-2"
            label="Bag"
            showLabel={true}
            paymentConfig={paymentConfig}
            apiEndpoint={apiEndpoint}
            headerStyles={headerStyles}
            projectType={import.meta.env.PROJECT_TYPE || 'physical'}
          />
          <a
            href={`/${currentLang}/account`}
            class="hidden sm:inline-flex items-center justify-center h-8 px-4 bg-[var(--mra-text)] text-[var(--mra-card)] text-[10px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--mra-accent-hover)] transition-colors"
          >
            Sign In
          </a>

          <button type="button" id="mobile-menu-button" class="lg:hidden p-2 text-[var(--mra-muted)] hover:text-[var(--mra-text)]" aria-expanded="false" aria-controls="mobile-menu-dropdown">
            <span class="sr-only">Menu</span>
            <Menu className="h-5 w-5" />
          </button>
        </div>
      </div>

    <div id="mobile-menu-dropdown" class="lg:hidden hidden py-5 px-4 border-t border-[var(--mra-border)] bg-[var(--mra-card)]" role="region" aria-label="Mobile menu">
      <div class="flex flex-col gap-1">
        {localizedNavigation.map((item) => (
          <a href={item.href} class="py-3 text-[11px] tracking-[0.18em] uppercase text-[var(--mra-muted)] hover:text-[var(--mra-text)] font-body">
            {item.name}
          </a>
        ))}
        <a href={`/${currentLang}/search`} class="py-3 text-[11px] tracking-[0.18em] uppercase text-[var(--mra-muted)] font-body">Search</a>
        <button type="button" id="mobile-bag-trigger" class="w-full text-left py-3 text-[11px] tracking-[0.18em] uppercase text-[var(--mra-muted)] font-body hover:text-[var(--mra-text)]">Bag</button>
        <a href={`/${currentLang}/account`} class="py-3 text-[11px] tracking-[0.18em] uppercase text-[var(--mra-text)] font-medium font-body">Sign In</a>
      </div>
    </div>
  </nav>
</header>
</div>

<script>
  document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu-dropdown');
    const expanded = btn?.getAttribute('aria-expanded') === 'true';
    btn?.setAttribute('aria-expanded', (!expanded).toString());
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
