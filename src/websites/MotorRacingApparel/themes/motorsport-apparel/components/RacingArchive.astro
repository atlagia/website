---
interface Props {
  headline: string;
  body: string;
  image: string;
  imageAlt?: string;
}

const { headline, body, image, imageAlt = 'Racing archive' } = Astro.props;
---

<section class="f1-archive relative py-24 lg:py-36 bg-[var(--mra-surface)]">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
      <div class="relative aspect-[4/5] lg:aspect-auto lg:min-h-[600px] overflow-hidden order-2 lg:order-1">
        <img
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover grayscale opacity-90"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--mra-surface)] via-transparent to-transparent lg:bg-gradient-to-r from-[var(--mra-surface)] via-[var(--mra-surface)]/80 to-transparent pointer-events-none"></div>
      </div>
      <div class="flex flex-col justify-center py-16 lg:py-24 px-6 lg:pl-20 order-1 lg:order-2">
        <p class="text-[10px] tracking-[0.4em] uppercase text-[var(--mra-muted)] mb-6 font-body">Racing Archive</p>
        <h2 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-[var(--mra-text)] uppercase leading-[0.92] tracking-wide mb-8">
          {headline}
        </h2>
        <p class="text-[var(--mra-text)]/70 font-body text-base md:text-lg leading-relaxed max-w-md">
          {body}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
