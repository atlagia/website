---
interface Category {
  id: string;
  name: string;
  description: string;
  image: string;
  alt?: string;
  link: string;
}

interface Props {
  title: string;
  description: string;
  categories: Category[];
}

const { title, description, categories } = Astro.props;
---

<section class="drivon-categories bg-[var(--drivon-bg)] py-32 lg:py-44">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="mb-20 lg:mb-28">
      <p class="font-display text-[10px] tracking-[0.4em] uppercase text-[var(--drivon-accent)] mb-4">Categories</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-[var(--drivon-text)] uppercase tracking-tight mb-5">{title}</h2>
      <p class="text-base text-[var(--drivon-text)]/60 max-w-xl font-body tracking-wide">{description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {categories.map((category) => (
        <a
          href={category.link}
          class="group relative block aspect-[4/5] lg:aspect-[3/4] overflow-hidden bg-[var(--drivon-surface)]"
        >
          <img
            src={category.image}
            alt={category.alt ?? category.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            width="800"
            height="1000"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--drivon-bg)]/95 via-[var(--drivon-bg)]/20 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
            <h3 class="font-display text-3xl lg:text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-2 group-hover:opacity-90 transition-opacity">
              {category.name}
            </h3>
            <p class="text-sm text-[var(--drivon-text)]/60 font-body max-w-sm">{category.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
