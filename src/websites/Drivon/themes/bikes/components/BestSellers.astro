---
import { getCollectionProducts, getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description: string;
  viewAllLink: string;
  lang: string;
  collectionHandle?: string;
}

const { title, description, viewAllLink, lang, collectionHandle } = Astro.props;

let productsData;
try {
  if (collectionHandle && collectionHandle !== 'all') {
    productsData = await getCollectionProducts(collectionHandle);
  } else {
    productsData = await getAllProducts();
  }
} catch {
  productsData = await getAllProducts();
}

const products = productsData
  .slice(0, 4)
  .map(({ node }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(node.priceRange.minVariantPrice.amount),
    image: node.images.edges[0]?.node.url || '/placeholder-image.jpg',
  }));
---

<section class="drivon-bestsellers bg-[var(--drivon-bg)] py-24 lg:py-32">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-16">
      <div>
        <p class="font-display text-[11px] tracking-[0.35em] uppercase text-[var(--drivon-accent)] mb-3">Shop</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-[var(--drivon-text)] uppercase tracking-tight mb-4">{title}</h2>
        <p class="text-lg text-[var(--drivon-text)]/70 max-w-xl font-body">{description}</p>
      </div>
      <a
        href={viewAllLink}
        class="text-[11px] font-medium tracking-[0.25em] uppercase text-[var(--drivon-text)]/70 hover:text-[var(--drivon-accent)] transition-colors w-fit"
      >
        View all
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {products.map((product) => (
        <a href={`/${lang}/products/${product.handle}`} class="group block">
          <div class="relative aspect-[3/4] overflow-hidden bg-[var(--drivon-card)] mb-5">
            <img
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover transition-transform duration-600 ease-out group-hover:scale-105"
            />
          </div>
          <h3 class="font-display text-sm font-semibold text-[var(--drivon-text)] uppercase tracking-wide group-hover:text-[var(--drivon-accent)] transition-colors">
            {product.name}
          </h3>
          <span class="text-sm text-[var(--drivon-muted)] mt-1 font-body">{product.price}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
