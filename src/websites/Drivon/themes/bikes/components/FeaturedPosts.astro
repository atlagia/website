---
import type { ShopifyBlogPost } from '../utils/shopifyAPI';
import { ArrowRight } from 'lucide-react';

interface Props {
  title: string;
  posts: ShopifyBlogPost[];
  exploreMoreLink: string;
  exploreMoreText: string;
}

const { title, posts = [], exploreMoreLink, exploreMoreText } = Astro.props;

// Ensure we always have content to display
const hasContent = posts && posts.length > 0;
---

<section class="py-16 px-4 md:px-8 bg-[var(--drivon-surface)] border-t border-[var(--drivon-border)]">
  <div class="max-w-7xl mx-auto">
    <p class="font-display text-[10px] tracking-[0.4em] uppercase text-[var(--drivon-accent)] text-center mb-2">Blog</p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold mb-12 text-center text-[var(--drivon-text)] uppercase tracking-tight">{title}</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {hasContent ? (
        posts.slice(0, 3).map((post) => (
          <article class="group">
            <a href={`${exploreMoreLink.replace(/\/$/, '')}/${post.handle}`} class="block">
              <div class="relative overflow-hidden rounded-xl mb-4 border border-[var(--drivon-border)]">
                <img
                  src={post.image?.src || '/images/placeholder.jpg'}
                  alt={post.title}
                  class="w-full aspect-[16/9] object-cover transition-transform duration-300 group-hover:scale-105"
                  width="600"
                  height="338"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <h3 class="font-display text-lg font-semibold mb-2 text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent)] transition-colors uppercase tracking-wide">
                {post.title}
              </h3>
              <div class="flex items-center justify-between">
                <time class="text-sm text-[var(--drivon-muted)] font-body">
                  {new Date(post.published_at).toLocaleDateString()}
                </time>
                <span class="text-[var(--drivon-accent)] group-hover:translate-x-1 transition-transform">
                  <ArrowRight className="w-5 h-5" />
                </span>
              </div>
            </a>
          </article>
        ))
      ) : (
        <div class="col-span-full text-center py-8">
          <p class="text-[var(--drivon-muted)] font-body">No posts available at the moment. Check back soon!</p>
        </div>
      )}
    </div>
    
    {hasContent && (
      <div class="text-center mt-12">
        <a
          href={exploreMoreLink}
          class="inline-flex items-center gap-2 font-display text-[11px] font-semibold tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent)] transition-colors"
        >
          {exploreMoreText}
          <ArrowRight className="w-4 h-4" />
        </a>
      </div>
    )}
  </div>
</section>