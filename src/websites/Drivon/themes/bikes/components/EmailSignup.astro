---
interface Props {
  title: string;
  description: string;
  backgroundImage: string;
  formAction: string;
  buttonText: string;
}

const { title, description, formAction, buttonText } = Astro.props;
---

<section class="drivon-newsletter relative py-32 lg:py-44 bg-[var(--drivon-bg)] border-t border-[var(--drivon-border)]">
  <div class="max-w-[520px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-[var(--drivon-text)] uppercase tracking-wide mb-12">
      {title}
    </h2>
    <form action={formAction} method="POST" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
      <input
        type="email"
        name="email"
        placeholder="Your email"
        required
        class="flex-1 min-w-0 px-5 py-3.5 bg-transparent border-b border-[var(--drivon-border)] text-[var(--drivon-text)] placeholder:text-[var(--drivon-muted)] focus:outline-none focus:border-[var(--drivon-text)]/50 transition-colors text-sm font-body"
      />
      <button
        type="submit"
        class="px-6 py-3.5 border border-[var(--drivon-text)] text-[var(--drivon-text)] text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-text)] hover:text-[var(--drivon-bg)] transition-all duration-300 shrink-0"
      >
        {buttonText}
      </button>
    </form>
    <p class="text-[10px] text-[var(--drivon-muted)] mt-6 tracking-wider">
      Unsubscribe at any time.
    </p>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
