---
import { Mail } from 'lucide-react';

interface Props {
  title: string;
  description: string;
  backgroundImage: string;
  formAction: string;
  buttonText: string;
}

const { title, description, backgroundImage, formAction, buttonText } = Astro.props;
---

<section 
  class="relative py-20 px-4 md:px-8"
  style={`background-image: url(${backgroundImage}); background-size: cover; background-position: center; filter: grayscale(30%);`}
>
  <div class="absolute inset-0 bg-white/90 backdrop-blur-md"></div>
  <div class="relative max-w-4xl mx-auto text-center">
    <div class="mb-10">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-gray-900 rounded-full mb-8 shadow-lg">
        <Mail class="w-10 h-10 text-white" />
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 leading-tight">{title}</h2>
      <p class="text-xl md:text-2xl mb-12 text-gray-700 max-w-3xl mx-auto leading-relaxed">{description}</p>
    </div>
    
    <form 
      action={formAction}
      method="POST"
      class="flex flex-col md:flex-row gap-6 justify-center items-center"
    >
      <div class="relative w-full md:w-auto flex-1 max-w-md">
        <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-500">
          <Mail class="w-6 h-6" />
        </div>
        <input
          type="email"
          placeholder="Enter your email address"
          required
          class="w-full pl-12 pr-6 py-4 rounded-xl bg-white border-2 border-gray-200 text-gray-900 placeholder:text-gray-500 focus:outline-none focus:ring-4 focus:ring-gray-300 focus:border-gray-400 text-lg shadow-sm hover:shadow-md transition-all duration-300"
        />
      </div>
      <button type="submit" class="bg-black text-white hover:bg-gray-800 font-bold px-10 py-4 shadow-xl hover:shadow-2xl transition-all duration-300 text-lg rounded-xl border-0 outline-none focus:bg-black focus:text-white cursor-pointer">
        {buttonText}
      </button>
    </form>

    <div class="mt-8 text-sm text-gray-600 flex items-center justify-center gap-3 bg-gray-50/80 backdrop-blur-sm rounded-lg px-6 py-4 border border-gray-200">
      <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
      </svg>
      <span class="font-medium">We respect your privacy. Unsubscribe at any time.</span>
    </div>
    
    <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
      <div class="flex flex-col items-center">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Weekly Updates</h3>
        <p class="text-sm text-gray-600">Fresh content delivered every week</p>
      </div>
      <div class="flex flex-col items-center">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Expert Insights</h3>
        <p class="text-sm text-gray-600">Professional tips and industry news</p>
      </div>
      <div class="flex flex-col items-center">
        <div class="w-12 h-12 bg-gray-900 rounded-full flex items-center justify-center mb-3">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Secure & Private</h3>
        <p class="text-sm text-gray-600">Your data is always protected</p>
      </div>
    </div>
  </div>
</section>