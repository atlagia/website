---
import { ArrowRight } from 'lucide-react';

interface VideoSlide {
  videoUrl: string;
  videoUrlWebm?: string;
  poster?: string;
}

interface BackgroundVideo {
  type?: 'youtube';
  videoId?: string;
  fallbackImage: string;
  /** Single MP4 URL (used if slides not provided). */
  videoUrl?: string;
  videoUrlWebm?: string;
  /** Multiple slides for video background slider. */
  slides?: VideoSlide[];
}

interface Props {
  title: string;
  description: string;
  blogLink: string;
  blogLinkText: string;
  backgroundVideo?: BackgroundVideo;
}

const { title, description, blogLink, blogLinkText, backgroundVideo } = Astro.props;
const useYoutube = backgroundVideo?.type === 'youtube' && backgroundVideo?.videoId;
const youtubeEmbedUrl = useYoutube
  ? `https://www.youtube.com/embed/${backgroundVideo.videoId}?autoplay=1&mute=1&loop=1&playlist=${backgroundVideo.videoId}&controls=0&showinfo=0&rel=0&playsinline=1&background=1`
  : '';
const slides = backgroundVideo?.slides?.length
  ? backgroundVideo.slides
  : !useYoutube && (backgroundVideo?.videoUrl || backgroundVideo?.videoUrlWebm)
    ? [{ videoUrl: backgroundVideo.videoUrl!, videoUrlWebm: backgroundVideo.videoUrlWebm, poster: backgroundVideo.fallbackImage }]
    : [];
const fallbackImg = backgroundVideo?.fallbackImage;
const hasVideoSlider = !useYoutube && slides.length > 0;
---

<section
  class="drivon-hero drivon-hero-dark drivon-grain relative min-h-[100vh] min-h-[100dvh] flex items-end justify-start overflow-hidden bg-[#050505]"
  itemScope
  itemType="https://schema.org/WebPageElement"
>
  <!-- Dark base -->
  <div class="absolute inset-0 bg-[#050505]" aria-hidden="true"></div>
  <!-- YouTube video background (from data videoId): autoplay, mute, loop. Inline styles ensure full-bleed when root (/) injects this content and scoped CSS may not apply. -->
  {useYoutube && youtubeEmbedUrl && (
    <div
      class="hero-bg-video hero-youtube-wrap absolute inset-0 z-0"
      style="position:absolute;inset:0;overflow:hidden;z-index:0;"
      aria-hidden="true"
    >
      <iframe
        src={youtubeEmbedUrl}
        title=""
        class="hero-youtube-iframe"
        style="position:absolute;top:50%;left:50%;width:100vw;height:56.25vw;min-height:100vh;min-width:177.78vh;transform:translate(-50%,-50%);border:none;pointer-events:none;"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />
    </div>
  )}
  <!-- Video background slider (MP4): auto-loop, muted, playsinline -->
  {!useYoutube && hasVideoSlider ? (
    <div class="hero-bg-video hero-video-slider absolute inset-0 z-0" aria-hidden="true">
      {slides.map((slide, i) => (
        <div class={`hero-video-slide ${i === 0 ? 'active' : ''}`} data-slide-index={i}>
          <video
            class="absolute inset-0 w-full h-full object-cover"
            autoplay={i === 0}
            loop
            muted
            playsinline
            title=""
            poster={slide.poster || fallbackImg || undefined}
            data-video-slide
          >
            {slide.videoUrlWebm && <source src={slide.videoUrlWebm} type="video/webm" />}
            <source src={slide.videoUrl} type="video/mp4" />
          </video>
        </div>
      ))}
    </div>
  ) : fallbackImg ? (
    <div class="hero-bg-video absolute inset-0 z-0" aria-hidden="true">
      <img
        src={fallbackImg}
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
    </div>
  ) : null}
  <!-- Vector animation layer: subtle dark-style accents only -->
  <div class="hero-vectors absolute inset-0 w-full h-full" aria-hidden="true">
    <svg class="hero-svg absolute inset-0 w-full h-full" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="speed-line-grad-dark" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1a1a1a" stop-opacity="0" />
          <stop offset="50%" stop-color="#2a2a2a" stop-opacity="0.4" />
          <stop offset="100%" stop-color="#1a1a1a" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="streak-grad-dark" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#0a0a0a" stop-opacity="0" />
          <stop offset="50%" stop-color="#151515" stop-opacity="0.5" />
          <stop offset="100%" stop-color="#0a0a0a" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="accent-grad-dark" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#c9a962" stop-opacity="0" />
          <stop offset="30%" stop-color="#c9a962" stop-opacity="0.08" />
          <stop offset="70%" stop-color="#c9a962" stop-opacity="0.08" />
          <stop offset="100%" stop-color="#c9a962" stop-opacity="0" />
        </linearGradient>
      </defs>
      <!-- Speed lines: dark grey, very subtle -->
      <g class="speed-lines">
        <line x1="-100" y1="160" x2="2020" y2="180" stroke="url(#speed-line-grad-dark)" stroke-width="1.5" class="speed-line stream-1" />
        <line x1="-100" y1="300" x2="2020" y2="320" stroke="url(#speed-line-grad-dark)" stroke-width="1" class="speed-line stream-2" />
        <line x1="-100" y1="440" x2="2020" y2="460" stroke="url(#speed-line-grad-dark)" stroke-width="1.5" class="speed-line stream-3" />
        <line x1="-100" y1="580" x2="2020" y2="600" stroke="url(#speed-line-grad-dark)" stroke-width="1" class="speed-line stream-4" />
        <line x1="-100" y1="720" x2="2020" y2="740" stroke="url(#speed-line-grad-dark)" stroke-width="1.5" class="speed-line stream-5" />
        <line x1="-100" y1="860" x2="2020" y2="880" stroke="url(#speed-line-grad-dark)" stroke-width="1" class="speed-line stream-6" />
      </g>
      <!-- Diagonal streaks: dark only -->
      <g class="diagonal-streaks">
        <path d="M-200 0 L800 1080" stroke="url(#streak-grad-dark)" stroke-width="140" class="streak streak-1" />
        <path d="M0 150 L1200 1080" stroke="url(#streak-grad-dark)" stroke-width="110" class="streak streak-2" />
        <path d="M350 0 L1650 1080" stroke="url(#streak-grad-dark)" stroke-width="90" class="streak streak-3" />
        <path d="M750 0 L1920 750" stroke="url(#streak-grad-dark)" stroke-width="100" class="streak streak-4" />
      </g>
      <!-- Single subtle gold accent line (dark style, no dash animation) -->
      <line x1="-100" y1="520" x2="2020" y2="520" stroke="url(#accent-grad-dark)" stroke-width="1" class="accent-line-gold" />
      <!-- Road horizon: dark fill -->
      <path d="M0 900 Q960 840 1920 900 L1920 1080 L0 1080 Z" fill="#0c0c0c" class="road-curve" />
      <line x1="0" y1="920" x2="1920" y2="920" stroke="#1a1a1a" stroke-width="1" class="accent-line" />
    </svg>
  </div>
  <!-- Full dark overlay: no light at top -->
  <div class="hero-gradient hero-gradient-dark" aria-hidden="true"></div>

  <!-- Editorial column accent -->
  <div class="absolute left-6 sm:left-8 lg:left-12 top-0 bottom-0 z-20 w-px hero-accent-line" aria-hidden="true"></div>

  <div class="relative z-20 w-full max-w-[1600px] mx-auto pl-10 sm:pl-12 lg:pl-16 pr-6 sm:px-8 lg:px-12 pb-28 pt-28 lg:pb-44 lg:pt-36 drivon-hero-content">
    <!-- Overline: chic label -->
    <div class="flex items-center gap-4 mb-6 animate-fade-in" style="animation-delay: 0.1s; animation-fill-mode: both;">
      <span class="hero-overline-line w-12 sm:w-16 h-px bg-[var(--drivon-accent)]/80"></span>
      <p class="font-display text-[10px] tracking-[0.45em] uppercase text-white/80">
        Automotive lifestyle
      </p>
    </div>
    <h1
      class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[8rem] xl:text-[9rem] 2xl:text-[10rem] text-white uppercase leading-[0.9] max-w-5xl mb-6 animate-fade-in hero-title"
      style="animation-delay: 0.2s; animation-fill-mode: both; letter-spacing: 0.03em;"
      itemProp="headline"
      role="heading"
      aria-level="1"
    >
      {title}
    </h1>
    <div class="h-px bg-[var(--drivon-accent)]/60 mb-8 hero-title-underline" style="animation-delay: 0.25s; animation-fill-mode: both;"></div>
    <p class="text-sm md:text-base text-white/75 max-w-md mb-14 font-body font-light tracking-wide leading-relaxed animate-fade-in" style="animation-delay: 0.35s; animation-fill-mode: both;">
      {description}
    </p>
    <div class="flex flex-wrap items-center gap-4 sm:gap-6 animate-fade-in" style="animation-delay: 0.5s; animation-fill-mode: both;">
      <a
        href={`/${Astro.url.pathname.split('/')[1] || 'en'}/collections`}
        class="hero-cta-primary group inline-flex items-center gap-3 bg-white text-[#0a0a0a] px-8 py-3.5 text-[10px] font-medium tracking-[0.3em] uppercase transition-all duration-300"
      >
        <span>Shop The Drop</span>
        <ArrowRight className="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
      </a>
      <a
        href={blogLink}
        class="hero-cta-secondary group inline-flex items-center gap-3 border border-white/50 text-white px-8 py-3.5 text-[10px] font-medium tracking-[0.3em] uppercase transition-all duration-300 relative overflow-hidden"
      >
        <span class="relative z-10">Explore Collection</span>
        <ArrowRight className="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5 relative z-10" />
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-3 hero-scroll">
    <span class="text-[9px] tracking-[0.35em] uppercase text-white/50">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-white/40 to-transparent scroll-line"></div>
  </div>
</section>

{hasVideoSlider && (
  <script define:vars={{ slideCount: slides.length }}>
    (function () {
      const slider = document.querySelector('.hero-video-slider');
      if (!slider) return;
      const slideEls = slider.querySelectorAll('.hero-video-slide');
      const videos = slider.querySelectorAll('video');

      function playActive() {
        const active = slider.querySelector('.hero-video-slide.active');
        if (active) {
          const v = active.querySelector('video');
          if (v) {
            v.play().catch(() => {});
          }
        }
      }

      if (slideCount > 1) {
        let current = 0;
        function goNext() {
          slideEls[current].classList.remove('active');
          videos[current].pause();
          current = (current + 1) % slideCount;
          slideEls[current].classList.add('active');
          videos[current].play().catch(() => {});
        }
        const interval = 6000;
        let t = setInterval(goNext, interval);
        videos.forEach((v, i) => {
          v.addEventListener('ended', () => { if (slideCount > 1) goNext(); });
        });
        playActive();
      } else {
        playActive();
        if (videos[0]) videos[0].play().catch(() => {});
      }
    })();
  </script>
)}

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }

  .hero-vectors {
    z-index: 1;
    pointer-events: none;
  }

  .hero-svg {
    display: block;
    object-fit: cover;
  }

  /* Speed lines: streaming motion (dash offset = motion blur / speed) */
  .speed-lines line {
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 120 280;
    animation: speed-stream 3s linear infinite;
  }

  .accent-line-gold {
    vector-effect: non-scaling-stroke;
    opacity: 0.9;
  }

  .speed-line.stream-1 { animation-delay: 0s; }
  .speed-line.stream-2 { animation-delay: 0.35s; }
  .speed-line.stream-3 { animation-delay: 0.7s; }
  .speed-line.stream-4 { animation-delay: 1.05s; }
  .speed-line.stream-5 { animation-delay: 1.4s; }
  .speed-line.stream-6 { animation-delay: 1.75s; }

  @keyframes speed-stream {
    0% { stroke-dashoffset: 0; opacity: 0.9; }
    100% { stroke-dashoffset: -400; opacity: 0.9; }
  }

  /* Diagonal streaks: slow drift for depth and energy */
  .streak {
    animation: streak-drift 14s ease-in-out infinite;
  }

  .streak-1 { animation-delay: 0s; }
  .streak-2 { animation-delay: 1.5s; }
  .streak-3 { animation-delay: 3s; }
  .streak-4 { animation-delay: 4.5s; }

  @keyframes streak-drift {
    0%, 100% { opacity: 0.5; transform: translateX(0) scale(1); }
    50% { opacity: 0.9; transform: translateX(3%) scale(1.03); }
  }

  /* Road curve: very subtle dark pulse */
  .road-curve {
    animation: road-pulse 6s ease-in-out infinite;
  }

  @keyframes road-pulse {
    0%, 100% { opacity: 0.95; }
    50% { opacity: 1; }
  }

  .accent-line {
    animation: accent-pulse 3s ease-in-out infinite;
  }

  @keyframes accent-pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 1; }
  }

  /* Dark style: solid dark overlay, no light at top */
  .hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .hero-gradient-dark {
    background: linear-gradient(
      to top,
      rgba(5, 5, 5, 0.92) 0%,
      rgba(5, 5, 5, 0.55) 45%,
      rgba(5, 5, 5, 0.28) 100%
    );
  }

  /* Chic editorial accent: vertical line */
  .hero-accent-line {
    background: linear-gradient(to bottom, transparent 0%, rgba(201, 169, 98, 0.25) 30%, rgba(201, 169, 98, 0.4) 70%, transparent 100%);
    opacity: 0.8;
  }

  /* Refined title */
  .hero-title {
    text-shadow: 0 0 80px rgba(0, 0, 0, 0.4);
  }
  .hero-title-underline {
    transform-origin: left;
    animation: hero-underline-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
    width: 0;
  }
  @keyframes hero-underline-in {
    from { width: 0; opacity: 0.8; }
    to { width: 5rem; opacity: 1; }
  }

  /* Video background slider */
  .hero-video-slider {
    isolation: isolate;
  }
  .hero-video-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    z-index: 0;
  }
  .hero-video-slide.active {
    opacity: 1;
    z-index: 1;
  }
  .hero-video-slide video {
    min-width: 100%;
    min-height: 100%;
  }

  /* YouTube background: cover entire hero, no controls */
  .hero-youtube-wrap {
    overflow: hidden;
  }
  .hero-youtube-iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw; /* 16:9 */
    min-height: 100vh;
    min-width: 177.78vh; /* 16:9 */
    transform: translate(-50%, -50%);
    border: none;
    pointer-events: none;
  }

  .scroll-line {
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.7; transform: scaleY(0.85); }
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(32px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in-up 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
  }

  /* Pro CTA: primary = solid white, subtle shadow on hover */
  .hero-cta-primary:hover {
    box-shadow: 0 4px 24px rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  /* Pro CTA: secondary = outline, gold underline slide on hover */
  .hero-cta-secondary::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--drivon-accent), transparent);
    transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hero-cta-secondary:hover {
    border-color: rgba(201, 169, 98, 0.5);
  }
  .hero-cta-secondary:hover::after {
    width: 100%;
  }

  /* Refined scroll indicator */
  .hero-scroll .scroll-line {
    opacity: 0.6;
  }
</style>
