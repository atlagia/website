---
/** Renders a supported payment method logo by id. Use for TrustBadges / footer. */
interface Props {
  id: string;
  name: string;
  class?: string;
}
const { id, name, class: className = '' } = Astro.props;
---

<span class={`payment-icon inline-flex items-center justify-center bg-white rounded border border-neutral-200 shadow-sm p-1.5 ${className}`} title={name}>
  {(id === 'visa') && (
    <svg width="48" height="32" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="48" height="32" rx="4" fill="#1A1F71"/>
      <text x="24" y="21" text-anchor="middle" fill="#fff" font-family="Arial, sans-serif" font-size="11" font-weight="bold" letter-spacing="0.08em">VISA</text>
    </svg>
  )}
  {(id === 'mastercard' || id === 'mc') && (
    <svg width="48" height="32" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="48" height="32" rx="4" fill="#fff"/>
      <circle cx="18" cy="16" r="8" fill="#EB001B"/>
      <circle cx="30" cy="16" r="8" fill="#F79E1B"/>
      <path d="M24 11.05a8 8 0 0 1 0 9.9 8 8 0 0 1 0-9.9z" fill="#FF5F00"/>
    </svg>
  )}
  {(id === 'amex' || id === 'americanexpress') && (
    <svg width="48" height="32" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="48" height="32" rx="4" fill="#006FCF"/>
      <text x="24" y="20" text-anchor="middle" fill="#fff" font-family="Arial, sans-serif" font-size="9" font-weight="bold" letter-spacing="0.12em">AMEX</text>
    </svg>
  )}
  {(id === 'paypal') && (
    <svg width="48" height="32" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="48" height="32" rx="4" fill="#fff"/>
      <rect width="48" height="32" rx="4" fill="#003087"/>
      <text x="24" y="20" text-anchor="middle" fill="#fff" font-family="Arial, sans-serif" font-size="10" font-weight="bold">PayPal</text>
    </svg>
  )}
  {!['visa', 'mastercard', 'mc', 'amex', 'americanexpress', 'paypal'].includes(id) && (
    <span class="text-xs font-medium text-neutral-500">{name}</span>
  )}
</span>

<style>
  .payment-icon svg {
    display: block;
    max-height: 28px;
    width: auto;
    height: auto;
  }
</style>
