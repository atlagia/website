---
import { Menu, Globe } from 'lucide-react';
import { getLangFromUrl, getLocalizedPath } from '@utils/i18n';

const navigation = [
  { name: 'Home', href: '/' },
  { name: 'Collections', href: '/collections' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
];

const getAllowedLanguages = (): string[] => {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  return allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
};

const languageNames: Record<string, string> = {
  en: "English", fr: "Français", de: "Deutsch", es: "Español", it: "Italiano",
  pt: "Português", nl: "Nederlands", ar: "العربية", zh: "中文", ja: "日本語", ko: "한국어",
};

const allowedLanguages = getAllowedLanguages();
const languages = allowedLanguages.map(lang => ({ code: lang, name: languageNames[lang] || lang }));

const currentPath = Astro.url.pathname;
const currentLang = getLangFromUrl(Astro.url);
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

const localizedNavigation = navigation.map(item => ({
  ...item,
  href: `/${currentLang}${item.href === '/' ? '' : item.href}`
}));
---

<header class="drivon-header fixed w-full top-0 z-50 bg-transparent hover:bg-[var(--drivon-bg)]/95 backdrop-blur-md border-b border-transparent hover:border-[var(--drivon-border)] transition-all duration-500">
  <nav class="mx-auto max-w-[1600px] px-6 sm:px-8 lg:px-12" aria-label="Main">
    <div class="flex h-20 items-center justify-between">
      <a href={`/${currentLang}`} class="font-display text-xl font-bold tracking-tight text-[var(--drivon-text)] uppercase">
        {siteName}
      </a>

      <div class="hidden md:flex items-center gap-10">
        {localizedNavigation.map((item) => (
          <a
            href={item.href}
            class="text-[13px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)]/90 hover:text-[var(--drivon-text)] transition-colors duration-200"
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-6">
        <div class="relative group">
          <button type="button" class="flex items-center gap-2 text-[var(--drivon-text)]/80 hover:text-[var(--drivon-text)] transition-colors">
            <Globe className="h-4 w-4" />
            <span class="hidden sm:inline text-[11px] uppercase tracking-[0.2em]">
              {languages.find(l => l.code === currentLang)?.name}
            </span>
          </button>
          <div class="absolute right-0 mt-2 w-40 py-2 bg-[var(--drivon-surface)] border border-[var(--drivon-border)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-2xl">
            {languages.map((lang) => (
              <a
                href={getLocalizedPath(currentPath, lang.code)}
                class={`block px-4 py-2 text-[11px] uppercase tracking-widest ${currentLang === lang.code ? 'text-[var(--drivon-accent)]' : 'text-[var(--drivon-muted)] hover:text-[var(--drivon-text)]'}`}
              >
                {lang.name}
              </a>
            ))}
          </div>
        </div>

        <a
          href={`/${currentLang}/checkout`}
          class="hidden md:inline text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)]/80 hover:text-[var(--drivon-text)]"
        >
          Bag
        </a>

        <a
          href={`/${currentLang}/account`}
          class="hidden md:inline-flex items-center justify-center px-5 py-2.5 border border-[var(--drivon-accent)] text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-accent)] hover:bg-[var(--drivon-accent)] hover:text-[var(--drivon-bg)] transition-all duration-200"
        >
          Sign In
        </a>

        <button type="button" id="mobile-menu-button" class="md:hidden p-2 text-[var(--drivon-muted)] hover:text-[var(--drivon-text)]" aria-expanded="false">
          <span class="sr-only">Menu</span>
          <Menu className="h-5 w-5" />
        </button>
      </div>
    </div>

    <div id="mobile-menu-dropdown" class="md:hidden hidden py-6 border-t border-[var(--drivon-border)]">
      <div class="flex flex-col gap-4">
        {localizedNavigation.map((item) => (
          <a href={item.href} class="text-sm tracking-[0.15em] uppercase text-[var(--drivon-muted)] hover:text-[var(--drivon-text)]">
            {item.name}
          </a>
        ))}
        <a href={`/${currentLang}/checkout`} class="text-sm tracking-[0.15em] uppercase text-[var(--drivon-muted)]">Bag</a>
        <a href={`/${currentLang}/account`} class="text-sm tracking-[0.15em] uppercase text-[var(--drivon-accent)]">Sign In</a>
      </div>
    </div>
  </nav>
</header>

<script>
  document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
    const btn = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu-dropdown');
    const expanded = btn?.getAttribute('aria-expanded') === 'true';
    btn?.setAttribute('aria-expanded', (!expanded).toString());
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  .font-display { font-family: var(--font-display); }
</style>
