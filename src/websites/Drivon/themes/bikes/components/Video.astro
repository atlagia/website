---
import { Button } from './ui/Button';
import { Play } from 'lucide-react';

interface Props {
  headline: string;
  description: string;
  videoUrl: string;
  buttonText?: string;
  buttonLink?: string;
  headlinePosition?: 'left' | 'center' | 'right';
  textPosition?: 'left' | 'center' | 'right';
}

const { 
  headline, 
  description, 
  videoUrl,
  buttonText,
  buttonLink,
  headlinePosition = 'center',
  textPosition = 'center'
} = Astro.props;

// Use youtube-nocookie.com for Best Practices (third-party cookies)
const embedUrl = typeof videoUrl === 'string' && videoUrl.includes('youtube.com/embed')
  ? videoUrl.replace('youtube.com/embed', 'youtube-nocookie.com/embed')
  : videoUrl;

const alignmentClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right'
};
---

<section class="py-20 px-4 md:px-8 bg-[var(--drivon-surface)] border-t border-[var(--drivon-border)]">
  <div class="max-w-6xl mx-auto">
    <div class={`max-w-3xl mx-auto mb-12 ${alignmentClasses[headlinePosition]}`}>
      <p class="font-display text-[10px] tracking-[0.4em] uppercase text-[var(--drivon-accent)] mb-3">Video</p>
      <h2 class="font-display text-3xl md:text-4xl font-semibold text-[var(--drivon-text)] mb-4 uppercase tracking-tight">
        {headline}
      </h2>
      <p class={`text-lg text-[var(--drivon-muted)] font-body ${alignmentClasses[textPosition]}`}>
        {description}
      </p>
    </div>

    <div class="relative aspect-video rounded-xl overflow-hidden border border-[var(--drivon-border)] shadow-lg">
      <iframe
        src={embedUrl}
        class="absolute inset-0 w-full h-full"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    {buttonText && buttonLink && (
      <div class="mt-8 text-center">
        <a 
          href={buttonLink}
          class="inline-flex items-center gap-2 bg-[var(--drivon-text)] text-[var(--drivon-bg)] px-8 py-3 rounded-sm font-display text-[11px] font-semibold tracking-[0.2em] uppercase hover:bg-[var(--drivon-accent)] transition-colors"
        >
          <Play className="w-4 h-4" />
          {buttonText}
        </a>
      </div>
    )}
  </div>
</section>