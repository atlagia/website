---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  faqs: FaqItem[];
}

const { title, description, faqs } = Astro.props;
---

<section class="py-20 px-4 bg-gray-900">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">{title}</h2>
      <p class="text-lg text-gray-300">{description}</p>
    </div>
    
    <div class="space-y-6">
      {faqs.map((faq) => (
        <div class="bg-gray-800 rounded-lg border border-gray-700 p-6 hover:bg-gray-800/80 transition-colors duration-300">
          <h3 class="text-xl font-bold mb-3 text-white">{faq.question}</h3>
          <p class="text-gray-300">{faq.answer}</p>
          <div class="mt-4 border-t border-gray-700 pt-4 flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
            </svg>
            <span class="text-sm text-gray-500">Professional Insight</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section> 