---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  faqs: FaqItem[];
}

const { title, description, faqs } = Astro.props;
---

<section class="drivon-faq bg-[var(--drivon-bg)] py-32 lg:py-44">
  <div class="max-w-[800px] mx-auto px-6 sm:px-8 lg:px-12">
    <p class="font-display text-[10px] tracking-[0.4em] uppercase text-[var(--drivon-accent)] mb-4">Support</p>
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl text-[var(--drivon-text)] uppercase tracking-tight mb-5">{title}</h2>
    <p class="text-base text-[var(--drivon-text)]/60 font-body mb-20 tracking-wide">{description}</p>

    <ul class="space-y-0 divide-y divide-[var(--drivon-border)]">
      {faqs.map((faq) => (
        <li class="py-8 first:pt-0">
          <h3 class="font-display text-lg font-semibold text-[var(--drivon-text)] uppercase tracking-tight mb-3">
            {faq.question}
          </h3>
          <p class="text-[var(--drivon-text)]/75 font-body leading-relaxed">{faq.answer}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
