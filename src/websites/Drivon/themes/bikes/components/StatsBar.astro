---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="drivon-stats bg-[var(--drivon-bg)] border-b border-[var(--drivon-border)]">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12 py-6 lg:py-8">
    <div class="flex flex-wrap justify-center gap-x-16 gap-y-4 lg:gap-x-24">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="font-display text-xl md:text-2xl text-[var(--drivon-text)] tracking-tight">{stat.value}</p>
          <p class="text-[9px] md:text-[10px] tracking-[0.3em] uppercase text-[var(--drivon-muted)] mt-0.5 font-body">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
