---
import { getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description: string;
  viewAllLink: string;
  lang: string;
}


const { title, description, viewAllLink, lang } = Astro.props;

// Fetch products from Shopify and limit to 4
const productsData = await getAllProducts();
const products = productsData
  .slice(0, 4)
  .map(({ node }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(node.priceRange.minVariantPrice.amount),
    image: node.images.edges[0]?.node.url || '/placeholder-image.jpg',
    category: 'Best Selling',
  }));
---

<section class="py-20 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <!-- Welcome Section -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900">{title}</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">{description}</p>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {products.map((product) => (
        <a 
          href={`/${lang}/products/${product.handle}`} 
          class="block group bg-gray-50 rounded-xl p-4 border border-gray-200 hover:border-gray-300 transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
        >
          <div class="relative overflow-hidden rounded-lg mb-4">
            <img
              src={product.image}
              alt={product.name}
              class="w-full aspect-[4/3] object-cover transition-transform duration-300 group-hover:scale-105"
            />
            <div class="absolute top-2 right-2 bg-white text-gray-800 px-3 py-1 rounded-full text-sm font-medium shadow-sm">
              {product.price}
            </div>
          </div>
          <div class="space-y-3">
            <div>
              <h3 class="text-lg font-semibold line-clamp-1 text-gray-900 group-hover:text-gray-700 transition-colors">
                {product.name}
              </h3>
              <p class="text-sm text-gray-500 mt-1">Professional Performance Gear</p>
            </div>
            <div class="flex items-center justify-between">
              <span class="px-3 py-1 bg-gray-200 text-gray-800 rounded-full text-sm font-medium">
                {product.category}
              </span>
              <span class="text-sm text-gray-800 font-medium hover:text-gray-600 flex items-center gap-1">
                Learn More <span class="text-lg">→</span>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- View All Button -->
    <div class="text-center mt-12">
      <a
        href={viewAllLink}
        class="inline-block bg-gray-800 text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-700 transition-colors"
      >
        Explore All Products
      </a>
    </div>
  </div>
</section>