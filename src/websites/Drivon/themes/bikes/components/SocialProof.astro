---
interface Stat {
  id: string;
  number: string;
  label: string;
  icon: string;
}

interface RecentActivity {
  id: string;
  customerName: string;
  location: string;
  product: string;
  timeAgo: string;
}

interface Props {
  title: string;
  stats: Stat[];
  recentActivities: RecentActivity[];
  overallRating: number;
  totalReviews: string;
}

const { title, stats, recentActivities, overallRating, totalReviews } = Astro.props;
---

<section class="py-16 px-4 md:px-8 bg-[var(--drivon-bg)] border-t border-[var(--drivon-border)]">
  <div class="max-w-6xl mx-auto">
    <p class="font-display text-[10px] tracking-[0.4em] uppercase text-[var(--drivon-accent)] text-center mb-2">Community</p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-center mb-4 text-[var(--drivon-text)] uppercase tracking-tight">{title}</h2>
    
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-2 mb-2">
        <div class="flex items-center">
          {Array.from({length: 5}, (_, i) => (
            <svg class={`w-6 h-6 ${i < overallRating ? 'text-[var(--drivon-accent)]' : 'text-[var(--drivon-muted)]'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="font-display text-2xl font-semibold text-[var(--drivon-text)]">{overallRating}.0</span>
      </div>
      <p class="text-[var(--drivon-muted)] font-body text-sm">Based on {totalReviews} reviews</p>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mx-auto mb-3 text-xl">
            <span set:html={stat.icon}></span>
          </div>
          <div class="font-display text-3xl font-semibold mb-1 text-[var(--drivon-text)]">{stat.number}</div>
          <div class="text-[var(--drivon-muted)] text-sm font-body">{stat.label}</div>
        </div>
      ))}
    </div>
    
    <div class="bg-[var(--drivon-card)] border border-[var(--drivon-border)] rounded-2xl p-8">
      <h3 class="font-display text-[11px] font-semibold tracking-[0.2em] uppercase text-[var(--drivon-muted)] mb-6 text-center">Recent Customer Activity</h3>
      <div class="space-y-4">
        {recentActivities.map((activity) => (
          <div class="flex items-center justify-between bg-[var(--drivon-surface)] rounded-lg p-4 border border-[var(--drivon-border)]">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-[var(--drivon-bg)] rounded-full flex items-center justify-center border border-[var(--drivon-border)]">
                <span class="font-display font-semibold text-sm text-[var(--drivon-text)]">
                  {activity.customerName.split(' ').map(n => n[0]).join('')}
                </span>
              </div>
              <div>
                <p class="font-display font-semibold text-[var(--drivon-text)]">{activity.customerName} from {activity.location}</p>
                <p class="text-[var(--drivon-muted)] text-sm font-body">purchased {activity.product}</p>
              </div>
            </div>
            <span class="text-[var(--drivon-muted)] text-sm font-body">{activity.timeAgo}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
