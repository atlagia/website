---
interface Stat {
  id: string;
  number: string;
  label: string;
  icon: string;
}

interface RecentActivity {
  id: string;
  customerName: string;
  location: string;
  product: string;
  timeAgo: string;
}

interface Props {
  title: string;
  stats: Stat[];
  recentActivities: RecentActivity[];
  overallRating: number;
  totalReviews: string;
}

const { title, stats, recentActivities, overallRating, totalReviews } = Astro.props;
---

<section class="py-16 px-4 bg-gray-900 text-white">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">{title}</h2>
    
    <!-- Overall Rating -->
    <div class="text-center mb-12">
      <div class="flex items-center justify-center gap-2 mb-2">
        <div class="flex items-center">
          {Array.from({length: 5}, (_, i) => (
            <svg class={`w-6 h-6 ${i < overallRating ? 'text-yellow-400' : 'text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-2xl font-bold">{overallRating}.0</span>
      </div>
      <p class="text-gray-300">Based on {totalReviews} reviews</p>
    </div>
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-white bg-opacity-10 rounded-full flex items-center justify-center mx-auto mb-3">
            <div class="text-white text-xl" set:html={stat.icon}></div>
          </div>
          <div class="text-3xl font-bold mb-1">{stat.number}</div>
          <div class="text-gray-300 text-sm">{stat.label}</div>
        </div>
      ))}
    </div>
    
    <!-- Recent Activity -->
    <div class="bg-white bg-opacity-5 rounded-2xl p-8">
      <h3 class="text-xl font-bold mb-6 text-center">Recent Customer Activity</h3>
      <div class="space-y-4">
        {recentActivities.map((activity) => (
          <div class="flex items-center justify-between bg-white bg-opacity-5 rounded-lg p-4">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-gray-600 rounded-full flex items-center justify-center">
                <span class="text-white font-bold text-sm">
                  {activity.customerName.split(' ').map(n => n[0]).join('')}
                </span>
              </div>
              <div>
                <p class="font-semibold">{activity.customerName} from {activity.location}</p>
                <p class="text-gray-300 text-sm">purchased {activity.product}</p>
              </div>
            </div>
            <span class="text-gray-400 text-sm">{activity.timeAgo}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
