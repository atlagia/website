---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Clock, Trophy, Flag, Zap, Star } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Endurance Racing | ${storeName}`;
const seoDescription = "Celebrate the ultimate test of speed and endurance. From Le Mans to 24-hour races, honor the heroes of endurance racing.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Endurance Racing
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            The ultimate test of speed and endurance
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/le-mans-hoodies`} class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Le Mans Collection
            </a>
            <a href={`/${lang}/le-mans-heroes`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Le Mans Heroes
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Endurance Racing Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">The Ultimate Racing Challenge</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Endurance racing is the ultimate test of speed, strategy, and stamina. From the legendary 24 Hours of Le Mans to grueling endurance challenges, celebrate the heroes who push the limits.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6">
              <Clock class="w-8 h-8 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">24 Hours of Le Mans</h3>
            <p class="text-gray-600">
              The most prestigious endurance race in the world, where drivers and teams push themselves to the absolute limit for 24 grueling hours.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-green-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Endurance Champions</h3>
            <p class="text-gray-600">
              Honor the legendary drivers and teams who have conquered the world's toughest endurance challenges and earned their place in racing history.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mb-6">
              <Zap class="w-8 h-8 text-purple-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Racing Heritage</h3>
            <p class="text-gray-600">
              Experience the rich history of endurance racing through authentic designs that capture the spirit of determination and excellence.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Endurance Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Endurance Racing Collection</h2>
          <p class="text-xl text-gray-600">Celebrate the heroes of endurance racing</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/le-mans-hoodies`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Clock class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Le Mans Hoodies</h3>
              <p class="text-gray-600 mb-4">Premium hoodies celebrating Le Mans legends</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop Le Mans Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/le-mans-heroes`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Le Mans Heroes</h3>
              <p class="text-gray-600 mb-4">Celebrate the legendary Le Mans champions</p>
              <div class="flex items-center text-green-600 font-semibold group-hover:text-green-700">
                Explore Le Mans Heroes <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-purple-500 to-purple-700 flex items-center justify-center">
              <Flag class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Endurance Accessories</h3>
              <p class="text-gray-600 mb-4">Essential accessories for endurance racing fans</p>
              <div class="flex items-center text-purple-600 font-semibold group-hover:text-purple-700">
                Shop Endurance Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Le Mans Spotlight -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Le Mans Legends</h2>
          <p class="text-xl text-gray-600">Honor the greatest endurance racing champions</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Clock class="w-10 h-10 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">24-Hour Champions</h3>
            <p class="text-gray-600 text-center mb-6">
              Celebrate the drivers who have conquered the grueling 24 Hours of Le Mans and earned their place in endurance racing history.
            </p>
            <a href={`/${lang}/le-mans-heroes`} class="flex items-center justify-center text-blue-600 font-semibold hover:text-blue-700">
              Explore Champions <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Trophy class="w-10 h-10 text-green-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Endurance Icons</h3>
            <p class="text-gray-600 text-center mb-6">
              Honor the legendary drivers who have shaped endurance racing and inspired generations of racing fans.
            </p>
            <a href={`/${lang}/le-mans-heroes`} class="flex items-center justify-center text-green-600 font-semibold hover:text-green-700">
              Explore Icons <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-purple-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Star class="w-10 h-10 text-purple-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Modern Heroes</h3>
            <p class="text-gray-600 text-center mb-6">
              Celebrate today's endurance racing heroes who continue to push the boundaries of speed and endurance.
            </p>
            <a href={`/${lang}/le-mans-heroes`} class="flex items-center justify-center text-purple-600 font-semibold hover:text-purple-700">
              Explore Modern Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Experience Endurance Racing Heritage</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global endurance racing community and celebrate the ultimate test of speed and endurance with our authentic collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/le-mans-hoodies`} class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Endurance Collection
          </a>
          <a href={`/${lang}/le-mans-heroes`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Le Mans Heroes
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
