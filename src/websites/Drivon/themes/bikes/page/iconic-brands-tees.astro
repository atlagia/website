---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Iconic Brands Tees | ${storeName}`;
const seoDescription = "Premium tees celebrating iconic automotive brands. From Ferrari to Porsche, BMW to Mercedes, wear the passion of legendary car manufacturers.";
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-red-900 via-red-800 to-orange-900">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Iconic Brands Tees
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Premium tees celebrating legendary automotive brands
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Iconic Brands
            </a>
            <a href={`/${lang}/racing-heritage`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Brand Heritage
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Iconic Brands Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Premium Iconic Brands Tees</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From Ferrari to Porsche, BMW to Mercedes, our iconic brands tees celebrate the legendary automotive manufacturers with authentic designs and premium quality.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
              <Crown class="w-8 h-8 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Legendary Brands</h3>
            <p class="text-gray-600">
              Celebrate the most iconic automotive brands that have shaped the industry and continue to inspire car enthusiasts worldwide.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Authentic Heritage</h3>
            <p class="text-gray-600">
              Honor the legendary cars and heritage of iconic brands that have defined automotive excellence for generations.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Premium Quality</h3>
            <p class="text-gray-600">
              Every tee is crafted with premium materials and attention to detail, ensuring comfort and durability for the automotive enthusiast.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Iconic Brands Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Iconic Brands Collection</h2>
          <p class="text-xl text-gray-600">Celebrate the legendary automotive brands</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/ferrari-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Crown class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Ferrari Tees</h3>
              <p class="text-gray-600 mb-4">Premium tees celebrating the legendary Italian racing brand</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop Ferrari Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/porsche-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Porsche Tees</h3>
              <p class="text-gray-600 mb-4">Classic tees honoring Porsche racing heritage</p>
              <div class="flex items-center text-orange-600 font-semibold group-hover:text-orange-700">
                Shop Porsche Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/bmw-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">BMW Tees</h3>
              <p class="text-gray-600 mb-4">Tees celebrating BMW racing legends</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop BMW Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Wear Iconic Brands</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global automotive community and celebrate the legendary brands with our premium iconic brands tees collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Iconic Brands Collection
          </a>
          <a href={`/${lang}/racing-heritage`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Brand Heritage
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
