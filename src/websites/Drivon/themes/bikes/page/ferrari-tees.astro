---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Ferrari Tees | ${storeName}`;
const seoDescription = "Premium Ferrari tees celebrating the legendary Italian racing brand. From F1 champions to racing heritage, wear the passion of Ferrari.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-red-900 via-red-800 to-black">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Ferrari Tees
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Premium tees celebrating the legendary Italian racing brand
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Ferrari Tees
            </a>
            <a href={`/${lang}/f1-legends`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              F1 Legends
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Ferrari Tees Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Premium Ferrari Tees</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From F1 champions to racing heritage, our Ferrari tees celebrate the legendary Italian racing brand with authentic designs and premium quality.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
              <Crown class="w-8 h-8 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">F1 Champions</h3>
            <p class="text-gray-600">
              Celebrate the legendary Ferrari drivers who have conquered Formula 1 and earned their place in racing history.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Racing Heritage</h3>
            <p class="text-gray-600">
              Honor the legendary Ferrari cars and drivers who have shaped motorsport and continue to inspire generations of racing fans.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Premium Quality</h3>
            <p class="text-gray-600">
              Every tee is crafted with premium materials and attention to detail, ensuring comfort and durability for the Ferrari enthusiast.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Ferrari Tees Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Ferrari Tees Collection</h2>
          <p class="text-xl text-gray-600">Celebrate the legendary Italian racing brand</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Crown class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Ferrari F1 Tees</h3>
              <p class="text-gray-600 mb-4">Premium tees celebrating Ferrari F1 champions</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop F1 Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-yellow-500 to-yellow-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Ferrari Heritage Tees</h3>
              <p class="text-gray-600 mb-4">Classic tees honoring Ferrari racing heritage</p>
              <div class="flex items-center text-yellow-600 font-semibold group-hover:text-yellow-700">
                Shop Heritage Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Ferrari Legends Tees</h3>
              <p class="text-gray-600 mb-4">Tees celebrating Ferrari racing legends</p>
              <div class="flex items-center text-orange-600 font-semibold group-hover:text-orange-700">
                Shop Legends Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Ferrari Tees Spotlight -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Ferrari Tees Features</h2>
          <p class="text-xl text-gray-600">Premium quality and authentic designs</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Award class="w-10 h-10 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Premium Materials</h3>
            <p class="text-gray-600 text-center mb-6">
              Crafted with premium cotton and attention to detail, ensuring comfort and durability for the Ferrari enthusiast.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-red-600 font-semibold hover:text-red-700">
              Shop Premium Tees <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Zap class="w-10 h-10 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Authentic Designs</h3>
            <p class="text-gray-600 text-center mb-6">
              Featuring authentic Ferrari designs that celebrate the heritage and culture of the legendary Italian racing brand.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-yellow-600 font-semibold hover:text-yellow-700">
              Shop Authentic Designs <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-orange-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Star class="w-10 h-10 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Ferrari Heritage</h3>
            <p class="text-gray-600 text-center mb-6">
              Each tee tells a story of Ferrari heritage, from F1 champions to racing legends and iconic moments in motorsport history.
            </p>
            <a href={`/${lang}/f1-legends`} class="flex items-center justify-center text-orange-600 font-semibold hover:text-orange-700">
              Explore Ferrari Heritage <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Wear Ferrari Heritage</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global Ferrari community and celebrate the legendary Italian racing brand with our premium Ferrari tees collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Ferrari Tees Collection
          </a>
          <a href={`/${lang}/f1-legends`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore F1 Legends
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
