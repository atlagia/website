---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get the language parameter from the URL
const { lang } = Astro.params;

// Validate language and redirect to /en if invalid
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `${jsonData.title} - ${jsonData.siteTitle}`;
const SITE_DESCRIPTION = jsonData.description;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main class="min-h-screen bg-gray-50">
      <!-- Hero Section -->
      <section class="relative bg-gradient-to-br from-gray-900 via-blue-900 to-black text-white py-20">
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="relative max-w-6xl mx-auto px-4 text-center">
          <h1 class="text-5xl md:text-7xl font-black mb-6 uppercase tracking-tighter">
            {jsonData.hero.title}
          </h1>
          <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto font-medium">
            {jsonData.hero.subtitle}
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-8">
            <a href="#collections" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
              {jsonData.hero.cta1}
            </a>
            <a href={`/${lang}/contact`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
              {jsonData.hero.cta2}
            </a>
          </div>
        </div>
      </section>

      <!-- Professional Features -->
      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-gray-900 mb-4">{jsonData.sections.features.title}</h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
              {jsonData.sections.features.subtitle}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {jsonData.features.map((feature, index) => (
              <div class="text-center">
                <div class="bg-blue-600 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Professional Collections -->
      <section id="collections" class="py-16 bg-gray-100">
        <div class="max-w-6xl mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-gray-900 mb-4">{jsonData.sections.series.title}</h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
              {jsonData.sections.series.subtitle}
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {jsonData.series.map((series, index) => (
              <div class="group bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
                <div class="relative overflow-hidden">
                  <img 
                    src={`/images/collections/${series.link.replace('/', '')}.jpg`}
                    alt={series.title}
                    class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                  <div class="absolute top-4 left-4 bg-blue-600 text-white px-3 py-1 rounded-full text-sm font-semibold">
                    {series.title.split(' ')[0]}
                  </div>
                </div>
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 mb-2">{series.title}</h3>
                  <p class="text-gray-600 mb-4">{series.description}</p>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-500">Professional Grade</span>
                    <a href={`/${lang}${series.link}`} class="bg-gray-900 hover:bg-gray-800 text-white px-6 py-2 rounded-lg font-semibold transition-colors">
                      {series.linkText}
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Professional Standards -->
      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold text-gray-900 mb-4">Professional Standards</h2>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
              Our Professional Series meets the highest industry standards and certifications 
              required for professional motorsport and automotive industry applications.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center">
              <div class="bg-gray-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-gray-700">FIA</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">FIA Certified</h3>
              <p class="text-sm text-gray-600">Meets Fédération Internationale de l'Automobile safety standards</p>
            </div>

            <div class="text-center">
              <div class="bg-gray-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-gray-700">ISO</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">ISO 9001</h3>
              <p class="text-sm text-gray-600">Quality management system certification</p>
            </div>

            <div class="text-center">
              <div class="bg-gray-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-gray-700">CE</span>
              </div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">CE Marked</h3>
