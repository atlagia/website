---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `New Arrivals | ${storeName}`;
const seoDescription = "Discover the latest driver merchandise and racing gear. New arrivals featuring the newest designs and premium quality.";
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-indigo-900 via-purple-800 to-pink-900">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            New Arrivals
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Discover the latest driver merchandise and racing gear
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop New Arrivals
            </a>
            <a href={`/${lang}/collections`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              View All Products
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- New Arrivals Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Latest Driver Merchandise</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Discover the newest designs and premium quality driver merchandise featuring the latest trends in racing culture and automotive fashion.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mb-6">
              <Crown class="w-8 h-8 text-indigo-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Latest Designs</h3>
            <p class="text-gray-600">
              Stay ahead with the newest designs featuring the latest trends in racing culture and automotive fashion.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-purple-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Premium Quality</h3>
            <p class="text-gray-600">
              Every new arrival is crafted with premium materials and attention to detail, ensuring the highest quality for our customers.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-pink-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-pink-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Exclusive Access</h3>
            <p class="text-gray-600">
              Be the first to get your hands on the latest driver merchandise and racing gear with exclusive early access.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- New Arrivals Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">New Arrivals Collection</h2>
          <p class="text-xl text-gray-600">Discover the latest in driver merchandise</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/racing-hoodies`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Crown class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">New Racing Hoodies</h3>
              <p class="text-gray-600 mb-4">Latest racing hoodies with fresh designs</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop New Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/car-culture-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">New Car Culture Tees</h3>
              <p class="text-gray-600 mb-4">Fresh car culture tees with new designs</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop New Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/driver-accessories`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">New Driver Accessories</h3>
              <p class="text-gray-600 mb-4">Latest driver accessories and gear</p>
              <div class="flex items-center text-green-600 font-semibold group-hover:text-green-700">
                Shop New Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Discover New Arrivals</h2>
        <p class="text-xl text-gray-300 mb-8">
          Be the first to discover the latest driver merchandise and racing gear with our exclusive new arrivals collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop New Arrivals Collection
          </a>
          <a href={`/${lang}/collections`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            View All Products
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
