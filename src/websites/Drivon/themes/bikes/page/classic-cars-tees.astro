---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Classic Cars Tees | ${storeName}`;
const seoDescription = "Premium tees celebrating classic cars. From vintage Ferraris to classic Porsches, wear the passion of automotive heritage.";
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-amber-900 via-orange-800 to-yellow-900">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Classic Cars Tees
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Premium tees celebrating automotive heritage
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-amber-600 hover:bg-amber-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Classic Cars
            </a>
            <a href={`/${lang}/racing-heritage`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Automotive Heritage
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Classic Cars Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Premium Classic Cars Tees</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From vintage Ferraris to classic Porsches, our classic cars tees celebrate the timeless beauty and heritage of automotive legends.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mb-6">
              <Crown class="w-8 h-8 text-amber-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Vintage Classics</h3>
            <p class="text-gray-600">
              Celebrate the most iconic classic cars that have defined automotive design and continue to inspire car enthusiasts worldwide.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Timeless Design</h3>
            <p class="text-gray-600">
              Honor the legendary cars and timeless design that have shaped automotive history and continue to inspire generations.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Premium Quality</h3>
            <p class="text-gray-600">
              Every tee is crafted with premium materials and attention to detail, ensuring comfort and durability for the classic car enthusiast.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Classic Cars Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Classic Cars Collection</h2>
          <p class="text-xl text-gray-600">Celebrate the timeless automotive heritage</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/ferrari-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Crown class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Classic Ferrari Tees</h3>
              <p class="text-gray-600 mb-4">Premium tees celebrating vintage Ferrari legends</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop Classic Ferrari <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/porsche-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Classic Porsche Tees</h3>
              <p class="text-gray-600 mb-4">Classic tees honoring vintage Porsche heritage</p>
              <div class="flex items-center text-orange-600 font-semibold group-hover:text-orange-700">
                Shop Classic Porsche <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/bmw-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Classic BMW Tees</h3>
              <p class="text-gray-600 mb-4">Tees celebrating vintage BMW legends</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop Classic BMW <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Wear Classic Heritage</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global classic car community and celebrate the timeless automotive heritage with our premium classic cars tees collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-amber-600 hover:bg-amber-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Classic Cars Collection
          </a>
          <a href={`/${lang}/racing-heritage`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Automotive Heritage
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
