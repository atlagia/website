---
import Layoutc from '@layouts/Layoutc.astro';
import ProductCard from '../../../themes/default/components/ProductCard';
import { getAllProducts } from '../../../lib/shopify';

const storeName = import.meta.env.PUBLIC_SITE_NAME || import.meta.env.PUBLIC_BUSINESS_NAME || 'Drivon';
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const allowedLangs = (import.meta.env.ALLOWED_LANGUAGES || 'en').split(',').map((l: string) => l.trim());
const lang = pathSegments.length > 0 && allowedLangs.includes(pathSegments[0]) ? pathSegments[0] : 'en';

const products = await getAllProducts();

const seoTitle = `Collections | ${storeName}`;
const seoDescription = `Browse our collections of premium automotive lifestyle and driver merchandise. Racing hoodies, car culture tees, and driver essentials. ${storeName}.`;
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <main class="max-w-7xl mx-auto px-4 pb-8 pt-[100px]">
    <h1 class="text-3xl font-bold mb-8">Our Collections</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {products.map((product) => (
        <ProductCard
          client:load
          id={product.node.id}
          title={product.node.title}
          price={parseFloat(product.node.priceRange.minVariantPrice.amount)}
          image={product.node.images.edges[0]?.node.url}
          description={product.node.description}
          handle={product.node.handle}
        />
      ))}
    </div>
  </main>
</Layoutc>