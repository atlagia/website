---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Users, Car, Trophy, Star } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Street Culture | ${storeName}`;
const seoDescription = "Explore authentic street racing culture and automotive lifestyle. From underground racing to street art, discover the true spirit of street culture.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-gray-900 via-gray-800 to-black">
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Street Culture
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Where automotive passion meets urban lifestyle
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/street-racing-hoodies`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Street Collection
            </a>
            <a href={`/${lang}/street-racing-tees`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Street Racing Tees
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Street Culture Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Authentic Street Culture</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From underground racing scenes to urban automotive art, we celebrate the raw energy and creativity of street culture.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
              <Car class="w-8 h-8 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Underground Racing</h3>
            <p class="text-gray-600">
              Experience the thrill of underground street racing culture with authentic designs that capture the raw energy of the scene.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6">
              <Users class="w-8 h-8 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Urban Communities</h3>
            <p class="text-gray-600">
              Connect with like-minded enthusiasts who share your passion for automotive culture and street racing lifestyle.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Street Art</h3>
            <p class="text-gray-600">
              Discover automotive-inspired street art and designs that celebrate the creativity and rebellion of street culture.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Street Racing Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Street Racing Categories</h2>
          <p class="text-xl text-gray-600">Explore different aspects of street racing culture</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/street-racing-hoodies`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Street Racing Hoodies</h3>
              <p class="text-gray-600 mb-4">Premium hoodies inspired by underground racing culture</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/street-racing-tees`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Car class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Street Racing Tees</h3>
              <p class="text-gray-600 mb-4">Classic tees celebrating street racing heritage</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-gray-500 to-gray-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Street Accessories</h3>
              <p class="text-gray-600 mb-4">Essential accessories for street culture enthusiasts</p>
              <div class="flex items-center text-gray-600 font-semibold group-hover:text-gray-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Join the Street Culture Movement</h2>
        <p class="text-xl text-gray-300 mb-8">
          Be part of the authentic street racing community. Shop our exclusive collection and represent the true spirit of street culture.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore All Collections
          </a>
          <a href={`/${lang}/about`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Learn More
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
