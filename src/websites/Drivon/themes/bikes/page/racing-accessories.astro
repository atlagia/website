---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Award, Shield, Zap, Crown } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Racing Accessories | ${storeName}`;
const seoDescription = "Essential racing accessories for motorsport enthusiasts. From caps to bags, complete your racing look with premium accessories.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-gray-900 via-gray-800 to-black">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Racing Accessories
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Complete your racing look with premium accessories
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-gray-600 hover:bg-gray-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop Accessories
            </a>
            <a href={`/${lang}/racing-culture`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Racing Culture
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Accessories Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Essential Racing Accessories</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From caps to bags, complete your racing look with our premium collection of motorsport accessories designed for true racing enthusiasts.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-gray-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Premium Quality</h3>
            <p class="text-gray-600">
              Every accessory is crafted with premium materials and attention to detail, ensuring durability and style for the racing enthusiast.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6">
              <Award class="w-8 h-8 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Authentic Design</h3>
            <p class="text-gray-600">
              Our accessories feature authentic racing designs that celebrate the heritage and culture of motorsport racing.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-6">
              <Shield class="w-8 h-8 text-green-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Racing Heritage</h3>
            <p class="text-gray-600">
              Each piece tells a story of racing heritage, from Formula 1 legends to rally champions and endurance racing heroes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Accessories Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Racing Accessories Collection</h2>
          <p class="text-xl text-gray-600">Complete your racing look</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-gray-500 to-gray-700 flex items-center justify-center">
              <Star class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Racing Caps</h3>
              <p class="text-gray-600 mb-4">Premium caps celebrating racing heritage</p>
              <div class="flex items-center text-gray-600 font-semibold group-hover:text-gray-700">
                Shop Racing Caps <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Award class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Racing Bags</h3>
              <p class="text-gray-600 mb-4">Durable bags for racing enthusiasts</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop Racing Bags <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-green-500 to-green-700 flex items-center justify-center">
              <Shield class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Racing Gear</h3>
              <p class="text-gray-600 mb-4">Essential gear for racing fans</p>
              <div class="flex items-center text-green-600 font-semibold group-hover:text-green-700">
                Shop Racing Gear <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Racing Categories -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Racing Categories</h2>
          <p class="text-xl text-gray-600">Explore accessories by racing category</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Zap class="w-10 h-10 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Formula 1 Accessories</h3>
            <p class="text-gray-600 text-center mb-6">
              Premium accessories celebrating Formula 1 legends and the pinnacle of motorsport racing.
            </p>
            <a href={`/${lang}/formula1-collection`} class="flex items-center justify-center text-red-600 font-semibold hover:text-red-700">
              Explore F1 Accessories <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Crown class="w-10 h-10 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Endurance Racing</h3>
            <p class="text-gray-600 text-center mb-6">
              Essential accessories for endurance racing fans, celebrating Le Mans heroes and 24-hour champions.
            </p>
            <a href={`/${lang}/endurance-racing`} class="flex items-center justify-center text-blue-600 font-semibold hover:text-blue-700">
              Explore Endurance Accessories <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Star class="w-10 h-10 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Rally Racing</h3>
            <p class="text-gray-600 text-center mb-6">
              Rally-inspired accessories celebrating the champions who conquered the world's toughest terrains.
            </p>
            <a href={`/${lang}/rally-racing`} class="flex items-center justify-center text-yellow-600 font-semibold hover:text-yellow-700">
              Explore Rally Accessories <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Complete Your Racing Look</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global racing community and complete your racing look with our premium collection of motorsport accessories.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-gray-600 hover:bg-gray-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Racing Accessories
          </a>
          <a href={`/${lang}/racing-culture`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Racing Culture
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>