---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Flag, Trophy, Star, Award, Crown } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Rally Champions | ${storeName}`;
const seoDescription = "Celebrate the champions of rally racing. From WRC legends to rally heroes, honor the greatest drivers who conquered the world's toughest terrains.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-yellow-900 via-orange-800 to-red-900">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Rally Champions
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Conquerors of the world's toughest terrains
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/rally-hoodies`} class="bg-yellow-600 hover:bg-yellow-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Rally Champions Collection
            </a>
            <a href={`/${lang}/rally-racing`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Rally Racing
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Champions Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Champions of Rally Racing</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From the legendary WRC to grueling endurance rallies, celebrate the champions who have conquered the world's toughest terrains and most challenging conditions.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Flag class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">WRC Champions</h3>
            <p class="text-gray-600">
              Celebrate the legendary rally drivers who have conquered the World Rally Championship and earned their place in rally racing history.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Rally Legends</h3>
            <p class="text-gray-600">
              Honor the legendary drivers who have shaped rally racing and inspired generations of rally enthusiasts worldwide.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
              <Star class="w-8 h-8 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Modern Heroes</h3>
            <p class="text-gray-600">
              Celebrate today's rally heroes who continue to push the boundaries of speed and skill in the world's toughest conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Champions Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Rally Champions Collection</h2>
          <p class="text-xl text-gray-600">Celebrate the greatest rally racing champions</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/rally-hoodies`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-yellow-500 to-yellow-700 flex items-center justify-center">
              <Flag class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Rally Champions Hoodies</h3>
              <p class="text-gray-600 mb-4">Premium hoodies celebrating rally champions</p>
              <div class="flex items-center text-yellow-600 font-semibold group-hover:text-yellow-700">
                Shop Rally Champions Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Rally Champions Tees</h3>
              <p class="text-gray-600 mb-4">Classic tees honoring rally racing legends</p>
              <div class="flex items-center text-orange-600 font-semibold group-hover:text-orange-700">
                Shop Rally Champions Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Award class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Rally Champions Accessories</h3>
              <p class="text-gray-600 mb-4">Essential accessories for rally champions fans</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop Rally Champions Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Rally Champions Spotlight -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Legendary Rally Champions</h2>
          <p class="text-xl text-gray-600">Honor the greatest rally racing champions</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Flag class="w-10 h-10 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">WRC Champions</h3>
            <p class="text-gray-600 text-center mb-6">
              Celebrate the drivers who have conquered the World Rally Championship and earned their place in rally racing history.
            </p>
            <a href={`/${lang}/rally-hoodies`} class="flex items-center justify-center text-yellow-600 font-semibold hover:text-yellow-700">
              Shop WRC Champions <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-orange-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Trophy class="w-10 h-10 text-orange-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Rally Icons</h3>
            <p class="text-gray-600 text-center mb-6">
              Honor the legendary drivers who have shaped rally racing and inspired generations of rally enthusiasts.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-orange-600 font-semibold hover:text-orange-700">
              Shop Rally Icons <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Star class="w-10 h-10 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Modern Heroes</h3>
            <p class="text-gray-600 text-center mb-6">
              Celebrate today's rally heroes who continue to push the boundaries of speed and skill in the world's toughest conditions.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-red-600 font-semibold hover:text-red-700">
              Shop Modern Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Heritage -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Rally Heritage & Legacy</h2>
          <p class="text-xl text-gray-600">Experience the rich history of rally racing</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Flag class="w-10 h-10 text-yellow-600" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">WRC Records</h3>
            <p class="text-gray-600">
              Celebrate the drivers who have set incredible WRC records and achieved legendary status in rally racing.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-orange-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Trophy class="w-10 h-10 text-orange-600" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Rally Championships</h3>
            <p class="text-gray-600">
              Honor the drivers who have won multiple rally championships and earned their place in racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Award class="w-10 h-10 text-red-600" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Iconic Moments</h3>
            <p class="text-gray-600">
              Remember the legendary moments and achievements that have defined rally racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Crown class="w-10 h-10 text-green-600" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Rally Legacy</h3>
            <p class="text-gray-600">
              Experience the lasting impact and legacy of the greatest rally racing drivers in motorsport history.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Honor Rally Champions</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join the global rally racing community and celebrate the greatest drivers in rally history with our authentic champions collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/rally-hoodies`} class="bg-yellow-600 hover:bg-yellow-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop Rally Champions Collection
          </a>
          <a href={`/${lang}/rally-racing`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Rally Racing
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
