---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Trophy, Clock, Flag, Award } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'Drivon';

// SEO
const seoTitle = `Racing Heritage | ${storeName}`;
const seoDescription = "Discover the rich heritage of motorsport racing. From Formula 1 legends to Le Mans heroes, celebrate the history and legacy of racing.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="relative h-[60vh] bg-gradient-to-br from-red-900 via-red-800 to-black">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl md:text-7xl font-bold text-white mb-6">
            Racing Heritage
          </h1>
          <p class="text-xl md:text-2xl text-gray-200 mb-8">
            Celebrating the legends and legacy of motorsport
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/f1-legends`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              F1 Legends
            </a>
            <a href={`/${lang}/le-mans-heroes`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Le Mans Heroes
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Heritage Timeline -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">A Legacy of Excellence</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            From the golden age of Formula 1 to the endurance challenges of Le Mans, we honor the champions who defined racing history.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-6">
              <Trophy class="w-8 h-8 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Formula 1 Champions</h3>
            <p class="text-gray-600">
              Celebrate the greatest F1 drivers and teams who made history on the world's most prestigious racing circuits.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mb-6">
              <Clock class="w-8 h-8 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Le Mans Endurance</h3>
            <p class="text-gray-600">
              Honor the heroes of 24-hour endurance racing who pushed the limits of speed and endurance at Le Mans.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <Flag class="w-8 h-8 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4">Rally Champions</h3>
            <p class="text-gray-600">
              Remember the rally legends who conquered the world's toughest terrains and most challenging conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Racing Categories -->
    <section class="py-20 bg-gray-100">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Racing Categories</h2>
          <p class="text-xl text-gray-600">Explore different forms of motorsport heritage</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/formula1-collection`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center">
              <Trophy class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Formula 1 Collection</h3>
              <p class="text-gray-600 mb-4">Premium F1 inspired merchandise celebrating racing legends</p>
              <div class="flex items-center text-red-600 font-semibold group-hover:text-red-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/endurance-racing`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center">
              <Clock class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Endurance Racing</h3>
              <p class="text-gray-600 mb-4">Le Mans and endurance racing heritage collection</p>
              <div class="flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/rally-racing`} class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <div class="h-48 bg-gradient-to-br from-yellow-500 to-yellow-700 flex items-center justify-center">
              <Flag class="w-16 h-16 text-white" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2">Rally Racing</h3>
              <p class="text-gray-600 mb-4">Rally champions and iconic moments collection</p>
              <div class="flex items-center text-yellow-600 font-semibold group-hover:text-yellow-700">
                Shop Now <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Racing Legends -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Racing Legends</h2>
          <p class="text-xl text-gray-600">Honor the greatest drivers in motorsport history</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <a href={`/${lang}/f1-legends`} class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Award class="w-10 h-10 text-red-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">F1 Legends</h3>
            <p class="text-gray-600 text-center mb-6">
              Celebrate the greatest Formula 1 drivers who made history on the world's most prestigious circuits.
            </p>
            <div class="flex items-center justify-center text-red-600 font-semibold group-hover:text-red-700">
              Explore F1 Legends <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>

          <a href={`/${lang}/le-mans-heroes`} class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Clock class="w-10 h-10 text-blue-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Le Mans Heroes</h3>
            <p class="text-gray-600 text-center mb-6">
              Honor the endurance racing champions who conquered the 24 Hours of Le Mans.
            </p>
            <div class="flex items-center justify-center text-blue-600 font-semibold group-hover:text-blue-700">
              Explore Le Mans Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>

          <a href={`/${lang}/rally-champions`} class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6 mx-auto">
              <Flag class="w-10 h-10 text-yellow-600" />
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">Rally Champions</h3>
            <p class="text-gray-600 text-center mb-6">
              Remember the rally legends who conquered the world's toughest terrains and conditions.
            </p>
            <div class="flex items-center justify-center text-yellow-600 font-semibold group-hover:text-yellow-700">
              Explore Rally Champions <ArrowRight class="w-4 h-4 ml-2" />
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-gray-900 text-white">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="text-4xl font-bold mb-6">Preserve Racing Heritage</h2>
        <p class="text-xl text-gray-300 mb-8">
          Join us in celebrating the rich history of motorsport. Wear the legacy of racing champions and keep their stories alive.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Explore Heritage Collection
          </a>
          <a href={`/${lang}/racing-culture`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Learn Racing History
          </a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>
