          "example": "curl -X GET https://api.automatepro.com/v1/workflows"
        },
        {
          "method": "POST",
          "path": "/api/v1/workflows",
          "description": "Create a new workflow",
          "example": "curl -X POST https://api.automatepro.com/v1/workflows -d '{...}'"
        }
      ]
