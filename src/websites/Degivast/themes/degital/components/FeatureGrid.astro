---
interface Feature {
  title: string;
  description: string;
  icon: string;
  color: string;
}

interface Props {
  title: string;
  description: string;
  features: Feature[];
}

const { title, description, features } = Astro.props;

const colorMap = {
  purple: 'from-purple-400 to-purple-600',
  blue: 'from-blue-400 to-blue-600',
  indigo: 'from-indigo-400 to-indigo-600',
  pink: 'from-pink-400 to-pink-600',
  green: 'from-green-400 to-green-600',
  orange: 'from-orange-400 to-orange-600'
};

const iconMap = {
  brain: `<path d="M12 2a9 9 0 0 1 9 9c0 3.14-1.3 5.97-3.38 8H6.38A10.96 10.96 0 0 1 3 11a9 9 0 0 1 9-9zm0 2a7 7 0 0 0-7 7c0 2.57 1.26 4.84 3.19 6.25l.02.01h7.58l.02-.01A7.001 7.001 0 0 0 12 4zm0 2c2.76 0 5 2.24 5 5s-2.24 5-5 5-5-2.24-5-5 2.24-5 5-5zm0 2c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>`,
  chart: `<path d="M3 3v16h16v2H3a2 2 0 0 1-2-2V3h2zm5 3v12H6V6h2zm4 2v10h-2V8h2zm4 3v7h-2v-7h2zm4 3v4h-2v-4h2z"/>`,
  workflow: `<path d="M3 3h6v6H3V3zm12 0h6v6h-6V3zM3 15h6v6H3v-6zm12 0h6v6h-6v-6zm-6-6h6v6H9V9z"/>`,
  users: `<path d="M12 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm6 10a1 1 0 0 0 1-1 7 7 0 0 0-14 0 1 1 0 0 0 1 1z"/>`,
  shield: `<path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 2.18l7 3.12v4.7c0 4.83-3.4 9.36-7 10.4-3.6-1.04-7-5.57-7-10.4V6.3l7-3.12z"/>`,
  support: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-14h2v6h-2zm0 8h2v2h-2z"/>`
};
---

<div class="text-center max-w-3xl mx-auto mb-16">
  <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
    {title}
  </h2>
  <p class="text-xl text-gray-600">{description}</p>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
  {features.map((feature) => (
    <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
      {/* Card Glow Effect */}
      <div class={`absolute -inset-0.5 bg-gradient-to-r ${colorMap[feature.color]} rounded-2xl blur opacity-25 group-hover:opacity-100 transition duration-500`}></div>
      
      {/* Card Content */}
      <div class="relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-500">
        {/* Icon */}
        <div class="mb-6">
          <div class={`w-14 h-14 rounded-lg bg-gradient-to-br ${colorMap[feature.color]} p-3 text-white`}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-full h-full"
            >
              <Fragment set:html={iconMap[feature.icon]} />
            </svg>
          </div>
        </div>

        {/* Title */}
        <h3 class="text-xl font-semibold mb-4 group-hover:text-purple-600 transition-colors">
          {feature.title}
        </h3>

        {/* Description */}
        <p class="text-gray-600">
          {feature.description}
        </p>

        {/* Hover Arrow */}
        <div class="absolute bottom-8 right-8 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all duration-300">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class={`w-6 h-6 text-gradient-to-r ${colorMap[feature.color]}`}
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            />
          </svg>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .text-gradient-to-r {
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
</style> 