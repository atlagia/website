---
interface Logo {
  name: string;
  image: string;
  link: string;
}

interface Certification {
  name: string;
  image: string;
  description: string;
  issuer: string;
  year: string;
}

interface Props {
  title: string;
  description: string;
  logos: Logo[];
  certifications: Certification[];
}

const { title, description, logos, certifications } = Astro.props;
---

<section class="section-spacing bg-gray-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
        {title}
      </h2>
      <p class="text-xl text-gray-600">{description}</p>
    </div>

    <!-- Company Logos -->
    <div class="mb-20">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 items-center">
        {logos.map((logo) => (
          <a
            href={logo.link}
            class="group relative flex items-center justify-center p-4 grayscale hover:grayscale-0 transition-all duration-300"
          >
            <!-- Logo Glow Effect -->
            <div class="absolute inset-0 bg-gradient-to-r from-purple-600/0 via-purple-600/0 to-blue-600/0 group-hover:from-purple-600/5 group-hover:via-purple-600/5 group-hover:to-blue-600/5 rounded-xl transition-colors duration-300"></div>
            
            <img
              src={logo.image}
              alt={logo.name}
              class="max-h-12 w-auto transform group-hover:scale-110 transition-transform duration-300"
            />
          </a>
        ))}
      </div>
    </div>

    <!-- Certifications -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {certifications.map((cert) => (
        <div class="group relative">
          <!-- Card Glow Effect -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-600 rounded-2xl blur opacity-0 group-hover:opacity-25 transition duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
            <div class="flex items-start gap-6">
              <!-- Certificate Icon -->
              <div class="flex-shrink-0">
                <div class="w-16 h-16 rounded-xl bg-purple-50 flex items-center justify-center">
                  <img
                    src={cert.image}
                    alt={cert.name}
                    class="w-10 h-10 object-contain"
                  />
                </div>
              </div>

              <!-- Certificate Details -->
              <div>
                <h3 class="text-xl font-semibold mb-2">{cert.name}</h3>
                <p class="text-gray-600 mb-4">{cert.description}</p>
                
                <div class="flex items-center gap-4 text-sm text-gray-500">
                  <span>{cert.issuer}</span>
                  <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                  <span>{cert.year}</span>
                </div>
              </div>
            </div>

            <!-- Hover Indicator -->
            <div class="absolute bottom-4 right-4 w-8 h-8 rounded-full bg-purple-50 flex items-center justify-center transform scale-0 group-hover:scale-100 transition-transform duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Badge -->
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-green-50 text-green-700 border border-green-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="font-medium">Trusted by industry leaders worldwide</span>
      </div>
    </div>
  </div>
</section>

<style>
  .section-spacing {
    padding: 6rem 0;
  }
  
  /* Smooth hover transitions */
  .grayscale {
    filter: grayscale(100%);
  }
  
  .grayscale-0 {
    filter: grayscale(0%);
  }
</style> 