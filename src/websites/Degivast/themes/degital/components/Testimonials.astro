---
interface Testimonial {
  id: string;
  quote: string;
  author: {
    name: string;
    role: string;
    company: string;
    image: string;
  };
  rating: number;
  tags: string[];
}

interface Props {
  title: string;
  description: string;
  testimonials: Testimonial[];
}

const { title, description, testimonials } = Astro.props;
---

<section class="section-spacing relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50">
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
  </div>

  <div class="container mx-auto px-4 relative">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
        {title}
      </h2>
      <p class="text-xl text-gray-600">{description}</p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <div class="group relative">
          <!-- Card Glow Effect -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-600 rounded-2xl blur opacity-0 group-hover:opacity-25 transition duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow duration-300">
            <!-- Rating Stars -->
            <div class="flex gap-1 mb-6">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class={`h-5 w-5 ${i < testimonial.rating ? 'text-yellow-400' : 'text-gray-200'}`}
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-gray-700 mb-8">"{testimonial.quote}"</blockquote>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-8">
              {testimonial.tags.map(tag => (
                <span class="px-3 py-1 text-sm bg-purple-50 text-purple-700 rounded-full">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Author Info -->
            <div class="flex items-center gap-4">
              <img
                src={testimonial.author.image}
                alt={testimonial.author.name}
                class="w-12 h-12 rounded-full object-cover"
              />
              <div>
                <div class="font-medium text-gray-900">{testimonial.author.name}</div>
                <div class="text-sm text-gray-500">
                  {testimonial.author.role} at {testimonial.author.company}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Social Proof Counter -->
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-50 border border-purple-100">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute h-full w-full rounded-full bg-purple-400 opacity-75"></span>
          <span class="rounded-full h-2 w-2 bg-purple-500"></span>
        </span>
        <span class="text-sm font-medium text-purple-700">
          Join {testimonials.length * 100}+ satisfied customers worldwide
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .section-spacing {
    padding: 6rem 0;
  }
  
  blockquote {
    position: relative;
    font-style: italic;
    line-height: 1.6;
  }
  
  blockquote::before,
  blockquote::after {
    content: '"';
    font-size: 2em;
    color: #e5e7eb;
  }
</style> 