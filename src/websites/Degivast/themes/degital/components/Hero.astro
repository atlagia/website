---
interface Stat {
  value: string;
  label: string;
}

interface CTAButton {
  text: string;
  href: string;
  variant: 'primary' | 'secondary';
}

interface Props {
  title: string;
  description: string;
  stats: Stat[];
  primaryCTA: CTAButton;
  secondaryCTA: CTAButton;
  image?: string;
}

const {
  title,
  description,
  stats,
  primaryCTA,
  secondaryCTA,
  image = '/hero-illustration.svg'
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center py-20 overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50"></div>
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
    
    <!-- Animated Shapes -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-blue-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-20 left-1/2 w-72 h-72 bg-pink-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div class="space-y-8">
        <!-- Announcement Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-purple-100 shadow-lg">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute h-full w-full rounded-full bg-purple-400 opacity-75"></span>
            <span class="rounded-full h-2 w-2 bg-purple-500"></span>
          </span>
          <span class="text-sm font-medium text-purple-700">AI-Powered Automation Platform</span>
        </div>

        <!-- Title with Gradient -->
        <h1 class="text-5xl lg:text-6xl font-bold leading-tight">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
            {title}
          </span>
        </h1>

        <!-- Description -->
        <p class="text-xl text-gray-600 max-w-xl">
          {description}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4">
          <a
            href={primaryCTA.href}
            class="inline-flex items-center px-6 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 text-white font-medium hover:from-blue-700 hover:to-purple-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            {primaryCTA.text}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
          <a
            href={secondaryCTA.href}
            class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-gray-700 font-medium hover:bg-gray-50 border border-gray-200 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            {secondaryCTA.text}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-3 gap-8 pt-8">
          {stats.map(stat => (
            <div class="text-center">
              <div class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
                {stat.value}
              </div>
              <div class="text-sm text-gray-600 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- Trust Badges -->
        <div class="flex items-center gap-6 pt-8">
          <div class="text-sm text-gray-600">Trusted by leading companies:</div>
          <div class="flex items-center gap-6 grayscale opacity-50">
            <img src="/company-1-logo.svg" alt="Company 1" class="h-8" />
            <img src="/company-2-logo.svg" alt="Company 2" class="h-8" />
            <img src="/company-3-logo.svg" alt="Company 3" class="h-8" />
          </div>
        </div>
      </div>

      <!-- Hero Image/Animation -->
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-500 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
        <div class="relative rounded-2xl overflow-hidden bg-white shadow-xl">
          <img
            src={image}
            alt="Platform Preview"
            class="w-full h-auto transform group-hover:scale-105 transition-transform duration-500"
          />
          
          <!-- Floating Features -->
          <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm rounded-lg p-3 shadow-lg animate-float">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium">10,000+</div>
                <div class="text-xs text-gray-600">Active Users</div>
              </div>
            </div>
          </div>

          <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm rounded-lg p-3 shadow-lg animate-float animation-delay-2000">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium">99.9%</div>
                <div class="text-xs text-gray-600">Satisfaction</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-blob {
    animation: blob 7s infinite;
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 