---
interface BlogPost {
  title: string;
  description: string;
  slug: string;
  publishDate: string;
  author: {
    name: string;
    image: string;
    role: string;
  };
  category: string;
  readingTime: string;
  image: string;
  tags?: string[]; // Make tags optional
}

interface Props {
  title: string;
  description: string;
  posts: BlogPost[];
}

const { title, description, posts = [] } = Astro.props; // Provide default empty array

// Format date to be more readable
function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
}
---

<section class="section-spacing">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
        {title}
      </h2>
      <p class="text-xl text-gray-600">{description}</p>
    </div>

    <!-- Blog Posts Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts?.map((post) => (
        <article class="group relative">
          <!-- Card Glow Effect -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-600 rounded-2xl blur opacity-0 group-hover:opacity-25 transition duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
            <!-- Image -->
            <a href={`/blog/${post.slug}`} class="block relative aspect-[16/9] overflow-hidden">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transform group-hover:scale-105 transition duration-500"
              />
              {post.category && (
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1 text-sm font-medium bg-white/90 backdrop-blur-sm text-purple-700 rounded-full">
                    {post.category}
                  </span>
                </div>
              )}
            </a>

            <!-- Content -->
            <div class="p-6">
              <!-- Meta Info -->
              <div class="flex items-center gap-4 mb-4 text-sm text-gray-600">
                {post.publishDate && (
                  <time datetime={post.publishDate}>
                    {formatDate(post.publishDate)}
                  </time>
                )}
                {post.readingTime && (
                  <>
                    <span>•</span>
                    <span>{post.readingTime} read</span>
                  </>
                )}
              </div>

              <!-- Title & Description -->
              <h3 class="text-xl font-bold mb-2 group-hover:text-purple-600 transition-colors">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h3>
              {post.description && (
                <p class="text-gray-600 mb-4 line-clamp-2">{post.description}</p>
              )}

              <!-- Tags -->
              {post.tags && post.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-6">
                  {post.tags.map(tag => (
                    <span class="px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded-full">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}

              <!-- Author -->
              {post.author && (
                <div class="flex items-center gap-3">
                  {post.author.image && (
                    <img
                      src={post.author.image}
                      alt={post.author.name}
                      class="w-10 h-10 rounded-full object-cover"
                    />
                  )}
                  <div>
                    <div class="font-medium text-gray-900">{post.author.name}</div>
                    {post.author.role && (
                      <div class="text-sm text-gray-600">{post.author.role}</div>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View All Link -->
    <div class="text-center mt-12">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-purple-50 text-purple-700 font-medium hover:bg-purple-100 transition-colors"
      >
        View all articles
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .section-spacing {
    padding: 6rem 0;
  }
  
  /* Line clamp for descriptions */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style> 