---
interface Metric {
  label: string;
  value: string;
}

interface Author {
  name: string;
  role: string;
}

interface Story {
  company: string;
  logo: string;
  quote: string;
  author: Author;
  metrics: Metric[];
}

interface Props {
  title: string;
  description: string;
  stories: Story[];
}

const { title, description, stories } = Astro.props;
---

<div class="text-center max-w-3xl mx-auto mb-16">
  <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
    {title}
  </h2>
  <p class="text-xl text-gray-600">{description}</p>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
  {stories.map((story) => (
    <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
      {/* Card Glow Effect */}
      <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-600 rounded-2xl blur opacity-25 group-hover:opacity-100 transition duration-500"></div>
      
      {/* Card Content */}
      <div class="relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-500">
        {/* Company Logo */}
        <div class="mb-6">
          <img
            src={story.logo}
            alt={story.company}
            class="h-12 w-auto"
          />
        </div>

        {/* Quote */}
        <blockquote class="text-lg text-gray-700 mb-6">
          "{story.quote}"
        </blockquote>

        {/* Author */}
        <div class="flex items-center gap-4 mb-8">
          <div>
            <div class="font-medium text-gray-900">{story.author.name}</div>
            <div class="text-sm text-gray-600">{story.author.role}</div>
          </div>
        </div>

        {/* Metrics */}
        <div class="grid grid-cols-2 gap-4 pt-6 border-t border-gray-100">
          {story.metrics.map((metric) => (
            <div class="text-center">
              <div class="text-2xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
                {metric.value}
              </div>
              <div class="text-sm text-gray-600">{metric.label}</div>
            </div>
          ))}
        </div>

        {/* Hover Arrow */}
        <div class="absolute top-4 right-4 w-8 h-8 rounded-full bg-purple-50 flex items-center justify-center opacity-0 group-hover:opacity-100 transform rotate-45 group-hover:rotate-0 transition-all duration-300">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-purple-600"
            viewBox="0 0 20 20"
            fill="currentColor"
          >
            <path
              fill-rule="evenodd"
              d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
              clip-rule="evenodd"
            />
          </svg>
        </div>
      </div>
    </div>
  ))}
</div>

{/* Additional Success Metrics */}
<div class="mt-16 grid md:grid-cols-4 gap-8 text-center">
  <div>
    <div class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent mb-2">
      1M+
    </div>
    <div class="text-gray-600">Tasks Automated</div>
  </div>
  
  <div>
    <div class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent mb-2">
      500+
    </div>
    <div class="text-gray-600">Enterprise Clients</div>
  </div>
  
  <div>
    <div class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent mb-2">
      99.9%
    </div>
    <div class="text-gray-600">Uptime</div>
  </div>
  
  <div>
    <div class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent mb-2">
      24/7
    </div>
    <div class="text-gray-600">Support</div>
  </div>
</div>

<style>
  /* Smooth hover transitions */
  .group:hover .group-hover\:rotate-0 {
    transform: rotate(0deg);
  }
  
  /* Gradient text effect */
  .bg-clip-text {
    -webkit-background-clip: text;
    background-clip: text;
  }
</style> 