---
interface PricingPlan {
  name: string;
  price: string;
  description: string;
  features: string[];
  buttonText: string;
  buttonLink: string;
  popular?: boolean;
}

interface Props {
  title: string;
  description: string;
  plans: PricingPlan[];
}

const { title, description, plans } = Astro.props;
---

<section class="py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold mb-6">{title}</h2>
      <p class="text-xl text-gray-600">{description}</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {plans.map((plan) => (
        <div class={`relative p-8 rounded-2xl ${plan.popular ? 'bg-gradient-to-b from-blue-600 to-cyan-600 text-white' : 'bg-white border border-gray-200'}`}>
          {plan.popular && (
            <div class="absolute -top-5 left-0 right-0 flex justify-center">
              <span class="px-4 py-1 bg-gradient-to-r from-amber-400 to-amber-500 text-white text-sm font-medium rounded-full">
                Most Popular
              </span>
            </div>
          )}

          <div class="mb-8">
            <h3 class="text-2xl font-bold mb-4">{plan.name}</h3>
            <div class="flex items-baseline mb-4">
              <span class="text-4xl font-bold">{plan.price}</span>
              <span class="ml-2 text-sm opacity-80">/month</span>
            </div>
            <p class={`text-sm ${plan.popular ? 'text-white/80' : 'text-gray-600'}`}>
              {plan.description}
            </p>
          </div>

          <ul class="space-y-4 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start">
                <svg 
                  class={`h-6 w-6 ${plan.popular ? 'text-white' : 'text-blue-500'} mr-3 flex-shrink-0`}
                  fill="currentColor" 
                  viewBox="0 0 20 20"
                >
                  <path 
                    fill-rule="evenodd" 
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd" 
                  />
                </svg>
                <span class={`text-sm ${plan.popular ? 'text-white/80' : 'text-gray-600'}`}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>

          <a
            href={plan.buttonLink}
            class={`block w-full text-center px-6 py-3 rounded-lg font-medium transition-all duration-200 ${
              plan.popular
                ? 'bg-white text-blue-600 hover:bg-gray-50'
                : 'bg-gradient-to-r from-blue-600 to-cyan-500 text-white hover:from-blue-700 hover:to-cyan-600'
            }`}
          >
            {plan.buttonText}
          </a>
        </div>
      ))}
    </div>
  </div>
</section> 