---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, Download, Calendar, ChevronRight, ExternalLink } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Press & Media | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Press releases, media resources, and company news';

// Press releases
const pressReleases = [
  {
    title: 'AutomatePro Raises $50M Series B to Accelerate Growth',
    date: '2024-02-15',
    description: 'Funding will be used to expand product capabilities and accelerate international expansion.',
    category: 'Company News',
    link: '/press/series-b-funding'
  },
  {
    title: 'AutomatePro Named Leader in Automation Platforms',
    date: '2024-01-20',
    description: 'Recognized as a leader in the latest industry analyst report.',
    category: 'Recognition',
    link: '/press/analyst-recognition'
  },
  {
    title: 'AutomatePro Launches Enterprise AI Platform',
    date: '2024-01-05',
    description: 'New enterprise platform brings advanced AI capabilities to automation.',
    category: 'Product Launch',
    link: '/press/enterprise-ai-launch'
  }
];

// Media coverage
const mediaCoverage = [
  {
    title: 'The Future of Business Automation',
    publication: 'TechCrunch',
    date: '2024-02-10',
    description: 'How AutomatePro is revolutionizing business automation with AI.',
    link: 'https://techcrunch.com/example'
  },
  {
    title: 'Automation Leaders to Watch',
    publication: 'Forbes',
    date: '2024-01-25',
    description: 'AutomatePro CEO featured in annual industry leaders list.',
    link: 'https://forbes.com/example'
  },
  {
    title: 'The Rise of Intelligent Automation',
    publication: 'Business Insider',
    date: '2024-01-15',
    description: 'In-depth look at AutomatePro's innovative approach to automation.',
    link: 'https://businessinsider.com/example'
  }
];

// Media resources
const mediaResources = [
  {
    title: 'Press Kit',
    description: 'Logos, product screenshots, and brand guidelines',
    format: 'ZIP',
    size: '25MB',
    link: '/media/press-kit.zip'
  },
  {
    title: 'Company Fact Sheet',
    description: 'Key facts and figures about AutomatePro',
    format: 'PDF',
    size: '2MB',
    link: '/media/fact-sheet.pdf'
  },
  {
    title: 'Executive Headshots',
    description: 'High-resolution photos of our leadership team',
    format: 'ZIP',
    size: '15MB',
    link: '/media/headshots.zip'
  },
  {
    title: 'Product Media Assets',
    description: 'Product images and videos',
    format: 'ZIP',
    size: '50MB',
    link: '/media/product-assets.zip'
  }
];

// Press contacts
const pressContacts = {
  global: {
    name: 'Sarah Johnson',
    title: 'Head of Communications',
    email: 'press@automatepro.com',
    phone: '+1 (555) 123-4567'
  },
  regions: [
    {
      name: 'North America',
      contact: 'John Smith',
      email: 'press.na@automatepro.com'
    },
    {
      name: 'Europe',
      contact: 'Marie Dubois',
      email: 'press.eu@automatepro.com'
    },
    {
      name: 'Asia Pacific',
      contact: 'David Chen',
      email: 'press.apac@automatepro.com'
    }
  ]
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Press & Media</h1>
          <p class="text-xl text-gray-600 mb-8">
            Latest news, press releases, and media resources
          </p>
          
          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <Search class="w-5 h-5 text-gray-400" />
            </div>
            <input
              type="text"
              placeholder="Search press releases and news..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-colors"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Press Releases -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Latest Press Releases</h2>
        <div class="space-y-6">
          {pressReleases.map(release => (
            <a 
              href={release.link}
              class="block bg-white rounded-xl border border-gray-100 p-6 hover:shadow-lg transition-all duration-300"
            >
              <div class="flex items-center gap-2 mb-3">
                <span class="px-3 py-1 bg-purple-50 text-purple-700 text-sm font-medium rounded-full">
                  {release.category}
                </span>
                <span class="text-sm text-gray-500">
                  <Calendar class="w-4 h-4 inline-block mr-1" />
                  {release.date}
                </span>
              </div>
              <h3 class="text-xl font-semibold mb-2 hover:text-purple-600 transition-colors">
                {release.title}
              </h3>
              <p class="text-gray-600">{release.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Media Coverage -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Media Coverage</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {mediaCoverage.map(article => (
            <a 
              href={article.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group block bg-gray-50 rounded-xl border border-gray-100 p-6 hover:shadow-lg transition-all duration-300"
            >
              <div class="flex items-center justify-between mb-4">
                <span class="font-semibold text-gray-900">{article.publication}</span>
                <ExternalLink class="w-4 h-4 text-gray-400 group-hover:text-purple-600 transition-colors" />
              </div>
              <h3 class="text-lg font-semibold mb-2 group-hover:text-purple-600 transition-colors">
                {article.title}
              </h3>
              <p class="text-gray-600 mb-4">{article.description}</p>
              <div class="text-sm text-gray-500">
                <Calendar class="w-4 h-4 inline-block mr-1" />
                {article.date}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Media Resources -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Media Resources</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {mediaResources.map(resource => (
            <a 
              href={resource.link}
              class="group block bg-white rounded-xl border border-gray-100 p-6 hover:shadow-lg transition-all duration-300"
            >
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center">
                  <Download class="w-6 h-6 text-purple-600" />
                </div>
                <div class="text-sm">
                  <span class="font-medium">{resource.format}</span>
                  <span class="text-gray-500 ml-2">{resource.size}</span>
                </div>
              </div>
              <h3 class="text-lg font-semibold mb-2">{resource.title}</h3>
              <p class="text-gray-600 text-sm">{resource.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Press Contacts -->
    <section class="py-12 bg-gray-900 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold mb-12">Press Contacts</h2>
          
          <!-- Global Contact -->
          <div class="bg-gray-800 rounded-xl p-8 mb-8">
            <h3 class="text-xl font-semibold mb-2">Global Press Office</h3>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <div class="font-medium">{pressContacts.global.name}</div>
                <div class="text-gray-400">{pressContacts.global.title}</div>
              </div>
              <div>
                <div class="text-purple-400">{pressContacts.global.email}</div>
                <div class="text-gray-400">{pressContacts.global.phone}</div>
              </div>
            </div>
          </div>
          
          <!-- Regional Contacts -->
          <div class="grid md:grid-cols-3 gap-6">
            {pressContacts.regions.map(region => (
              <div class="bg-gray-800 rounded-xl p-6">
                <h4 class="font-semibold mb-2">{region.name}</h4>
                <div class="text-sm text-gray-400">{region.contact}</div>
                <div class="text-sm text-purple-400">{region.email}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 