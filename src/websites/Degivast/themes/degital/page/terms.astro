---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, FileText, Scale, AlertTriangle, Shield } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Terms of Service | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Terms and conditions for using our services';

// Last updated date
const lastUpdated = '2024-02-15';

// Terms sections
const sections = [
  {
    id: 'acceptance',
    title: 'Acceptance of Terms',
    icon: FileText,
    content: `
      <p class="mb-4">By accessing or using our services, you agree to be bound by these Terms of Service and all applicable laws and regulations. If you do not agree with any of these terms, you are prohibited from using our services.</p>
      <p>These terms apply to all users of our services, including without limitation:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Registered users</li>
        <li>Subscribers</li>
        <li>Customers</li>
        <li>Contributors</li>
        <li>Merchants</li>
      </ul>
    `
  },
  {
    id: 'service-license',
    title: 'Service License',
    icon: Scale,
    content: `
      <p class="mb-4">Subject to these Terms, we grant you a limited, non-exclusive, non-transferable license to:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Access and use our services</li>
        <li>Use any related documentation</li>
        <li>Use provided features and functionalities</li>
      </ul>
      <p class="mb-4">You may not:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Modify or copy the materials</li>
        <li>Use the materials for commercial purposes</li>
        <li>Transfer the materials to another person</li>
        <li>Reverse engineer or decompile the software</li>
      </ul>
    `
  },
  {
    id: 'user-obligations',
    title: 'User Obligations',
    icon: AlertTriangle,
    content: `
      <p class="mb-4">As a user of our services, you agree to:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Provide accurate and complete information</li>
        <li>Maintain the security of your account</li>
        <li>Comply with all applicable laws</li>
        <li>Not interfere with service operation</li>
        <li>Not engage in unauthorized access</li>
      </ul>
      <p>Violation of these obligations may result in immediate termination of your account.</p>
    `
  },
  {
    id: 'intellectual-property',
    title: 'Intellectual Property',
    icon: Shield,
    content: `
      <p class="mb-4">All rights, title, and interest in and to our services, including all intellectual property rights, are and will remain our exclusive property.</p>
      <p class="mb-4">This includes:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Software code and architecture</li>
        <li>User interface designs</li>
        <li>Logos and trademarks</li>
        <li>Content and documentation</li>
      </ul>
      <p>Any feedback, comments, or suggestions you may provide are entirely voluntary, and we will be free to use such feedback without any obligation to you.</p>
    `
  }
];

// Quick links
const quickLinks = [
  { title: 'Privacy Policy', href: '/privacy' },
  { title: 'Cookie Policy', href: '/cookies' },
  { title: 'Acceptable Use Policy', href: '/acceptable-use' },
  { title: 'Service Level Agreement', href: '/sla' }
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Terms of Service</h1>
          <p class="text-xl text-gray-600 mb-4">
            Please read these terms carefully before using our services
          </p>
          <p class="text-sm text-gray-500">
            Last updated: {lastUpdated}
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-12 gap-8">
          <!-- Sidebar -->
          <div class="lg:col-span-3">
            <div class="sticky top-8">
              <div class="bg-white rounded-xl border border-gray-100 p-6">
                <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
                <ul class="space-y-2">
                  {quickLinks.map(link => (
                    <li>
                      <a 
                        href={link.href}
                        class="text-gray-600 hover:text-purple-600 transition-colors"
                      >
                        {link.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="bg-white rounded-xl border border-gray-100 p-6 mt-6">
                <h3 class="text-lg font-semibold mb-4">On This Page</h3>
                <ul class="space-y-2">
                  {sections.map(section => (
                    <li>
                      <a 
                        href={`#${section.id}`}
                        class="text-gray-600 hover:text-purple-600 transition-colors"
                      >
                        {section.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:col-span-9">
            <div class="bg-white rounded-xl border border-gray-100 p-8">
              <div class="prose prose-lg max-w-none">
                <p class="text-xl text-gray-600 mb-8">
                  These Terms of Service ("Terms") govern your access to and use of our services. By using our services, you agree to these Terms.
                </p>

                {sections.map(section => {
                  const Icon = section.icon;
                  return (
                    <div id={section.id} class="scroll-mt-24 mb-12">
                      <div class="flex items-center gap-3 mb-6">
                        <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center">
                          <Icon class="w-6 h-6 text-purple-600" />
                        </div>
                        <h2 class="text-2xl font-semibold">{section.title}</h2>
                      </div>
                      <div class="text-gray-600" set:html={section.content} />
                    </div>
                  );
                })}

                <!-- Contact Section -->
                <div class="bg-gray-50 rounded-xl p-6 mt-12">
                  <h2 class="text-2xl font-semibold mb-4">Questions About the Terms?</h2>
                  <p class="text-gray-600 mb-6">
                    If you have any questions about these Terms of Service, please contact our legal team:
                  </p>
                  <div class="space-y-2">
                    <div>
                      <strong>Email:</strong> 
                      <a href="mailto:legal@automatepro.com" class="text-purple-600 hover:text-purple-700">
                        legal@automatepro.com
                      </a>
                    </div>
                    <div>
                      <strong>Address:</strong> 123 Legal Street, Terms City, 12345
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 