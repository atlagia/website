---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, Shield, Lock, Eye, UserCheck } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Privacy Policy | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Our commitment to protecting your privacy and data';

// Last updated date
const lastUpdated = '2024-02-15';

// Privacy sections
const sections = [
  {
    id: 'information-collection',
    title: 'Information We Collect',
    icon: Eye,
    content: `
      <p class="mb-4">We collect information that you provide directly to us, including:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Account information (name, email, company)</li>
        <li>Usage data and preferences</li>
        <li>Payment information</li>
        <li>Communication history</li>
      </ul>
      <p>We also automatically collect certain information when you use our services, including:</p>
      <ul class="list-disc pl-6 space-y-2">
        <li>Device and browser information</li>
        <li>IP address and location data</li>
        <li>Usage statistics and patterns</li>
        <li>Cookies and similar technologies</li>
      </ul>
    `
  },
  {
    id: 'information-use',
    title: 'How We Use Your Information',
    icon: Shield,
    content: `
      <p class="mb-4">We use the information we collect to:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Provide and improve our services</li>
        <li>Personalize your experience</li>
        <li>Process your transactions</li>
        <li>Send you updates and communications</li>
        <li>Ensure platform security</li>
        <li>Comply with legal obligations</li>
      </ul>
      <p>We do not sell your personal information to third parties.</p>
    `
  },
  {
    id: 'data-security',
    title: 'Data Security',
    icon: Lock,
    content: `
      <p class="mb-4">We implement appropriate technical and organizational measures to protect your data, including:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Encryption of data in transit and at rest</li>
        <li>Regular security assessments</li>
        <li>Access controls and authentication</li>
        <li>Employee training and policies</li>
      </ul>
      <p>While we strive to protect your information, no method of transmission over the Internet is 100% secure.</p>
    `
  },
  {
    id: 'your-rights',
    title: 'Your Rights and Choices',
    icon: UserCheck,
    content: `
      <p class="mb-4">You have certain rights regarding your personal information:</p>
      <ul class="list-disc pl-6 mb-4 space-y-2">
        <li>Access your personal information</li>
        <li>Correct inaccurate information</li>
        <li>Request deletion of your information</li>
        <li>Opt-out of marketing communications</li>
        <li>Control cookie preferences</li>
      </ul>
      <p>Contact our privacy team to exercise these rights.</p>
    `
  }
];

// Quick links
const quickLinks = [
  { title: 'Cookie Policy', href: '/cookies' },
  { title: 'Terms of Service', href: '/terms' },
  { title: 'Data Processing Agreement', href: '/dpa' },
  { title: 'GDPR Compliance', href: '/gdpr' }
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Privacy Policy</h1>
          <p class="text-xl text-gray-600 mb-4">
            Our commitment to protecting your privacy and data
          </p>
          <p class="text-sm text-gray-500">
            Last updated: {lastUpdated}
          </p>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-12 gap-8">
          <!-- Sidebar -->
          <div class="lg:col-span-3">
            <div class="sticky top-8">
              <div class="bg-white rounded-xl border border-gray-100 p-6">
                <h3 class="text-lg font-semibold mb-4">Quick Links</h3>
                <ul class="space-y-2">
                  {quickLinks.map(link => (
                    <li>
                      <a 
                        href={link.href}
                        class="text-gray-600 hover:text-purple-600 transition-colors"
                      >
                        {link.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="bg-white rounded-xl border border-gray-100 p-6 mt-6">
                <h3 class="text-lg font-semibold mb-4">On This Page</h3>
                <ul class="space-y-2">
                  {sections.map(section => (
                    <li>
                      <a 
                        href={`#${section.id}`}
                        class="text-gray-600 hover:text-purple-600 transition-colors"
                      >
                        {section.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:col-span-9">
            <div class="bg-white rounded-xl border border-gray-100 p-8">
              <div class="prose prose-lg max-w-none">
                <p class="text-xl text-gray-600 mb-8">
                  This Privacy Policy describes how we collect, use, and handle your personal information when you use our services.
                </p>

                {sections.map(section => {
                  const Icon = section.icon;
                  return (
                    <div id={section.id} class="scroll-mt-24 mb-12">
                      <div class="flex items-center gap-3 mb-6">
                        <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center">
                          <Icon class="w-6 h-6 text-purple-600" />
                        </div>
                        <h2 class="text-2xl font-semibold">{section.title}</h2>
                      </div>
                      <div class="text-gray-600" set:html={section.content} />
                    </div>
                  );
                })}

                <!-- Contact Section -->
                <div class="bg-gray-50 rounded-xl p-6 mt-12">
                  <h2 class="text-2xl font-semibold mb-4">Contact Us</h2>
                  <p class="text-gray-600 mb-6">
                    If you have any questions about this Privacy Policy, please contact us at:
                  </p>
                  <div class="space-y-2">
                    <div>
                      <strong>Email:</strong> 
                      <a href="mailto:privacy@automatepro.com" class="text-purple-600 hover:text-purple-700">
                        privacy@automatepro.com
                      </a>
                    </div>
                    <div>
                      <strong>Address:</strong> 123 Privacy Street, Security City, 12345
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 