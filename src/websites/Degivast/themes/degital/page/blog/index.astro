---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, Clock, User, Tag } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Blog | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Latest news, updates, and insights about automation and digital transformation';

// Featured posts
const featuredPosts = [
  {
    title: 'The Future of Business Automation',
    description: 'Explore how AI and automation are transforming business operations',
    image: '/images/blog/automation-future.jpg',
    category: 'Automation',
    author: {
      name: 'John Smith',
      avatar: '/images/authors/john-smith.jpg'
    },
    date: '2024-02-15',
    readTime: '5 min read',
    slug: 'future-of-business-automation'
  },
  {
    title: 'Maximizing ROI with Smart Analytics',
    description: 'Learn how to leverage analytics for better business decisions',
    image: '/images/blog/analytics-roi.jpg',
    category: 'Analytics',
    author: {
      name: 'Sarah Johnson',
      avatar: '/images/authors/sarah-johnson.jpg'
    },
    date: '2024-02-10',
    readTime: '7 min read',
    slug: 'maximizing-roi-analytics'
  },
  {
    title: 'Digital Transformation Success Stories',
    description: 'Real-world examples of successful digital transformation',
    image: '/images/blog/success-stories.jpg',
    category: 'Case Studies',
    author: {
      name: 'Michael Chen',
      avatar: '/images/authors/michael-chen.jpg'
    },
    date: '2024-02-05',
    readTime: '6 min read',
    slug: 'digital-transformation-success'
  }
];

// Recent posts
const recentPosts = [
  {
    title: 'Best Practices for API Integration',
    description: 'Essential tips for seamless API integration',
    image: '/images/blog/api-integration.jpg',
    category: 'Development',
    author: {
      name: 'Alex Turner',
      avatar: '/images/authors/alex-turner.jpg'
    },
    date: '2024-02-01',
    readTime: '4 min read',
    slug: 'api-integration-best-practices'
  },
  {
    title: 'Securing Your Automation Workflows',
    description: 'Key security considerations for automation',
    image: '/images/blog/security.jpg',
    category: 'Security',
    author: {
      name: 'Emma Davis',
      avatar: '/images/authors/emma-davis.jpg'
    },
    date: '2024-01-28',
    readTime: '8 min read',
    slug: 'securing-automation-workflows'
  }
];

// Categories
const categories = [
  { name: 'Automation', count: 25 },
  { name: 'Analytics', count: 18 },
  { name: 'Development', count: 15 },
  { name: 'Security', count: 12 },
  { name: 'Case Studies', count: 8 },
  { name: 'Tutorials', count: 20 }
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Blog</h1>
          <p class="text-xl text-gray-600 mb-8">
            Latest insights about automation, analytics, and digital transformation
          </p>
          
          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <Search class="w-5 h-5 text-gray-400" />
            </div>
            <input
              type="text"
              placeholder="Search articles..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-colors"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Posts -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Featured Articles</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {featuredPosts.map(post => (
            <a 
              href={`/blog/${post.slug}`}
              class="group block bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300"
            >
              <div class="aspect-video overflow-hidden">
                <img 
                  src={post.image} 
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-2 mb-4">
                  <span class="px-3 py-1 bg-purple-50 text-purple-700 text-sm font-medium rounded-full">
                    {post.category}
                  </span>
                </div>
                <h3 class="text-xl font-semibold mb-2 group-hover:text-purple-600 transition-colors">
                  {post.title}
                </h3>
                <p class="text-gray-600 mb-4">{post.description}</p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <img 
                      src={post.author.avatar} 
                      alt={post.author.name}
                      class="w-8 h-8 rounded-full"
                    />
                    <span class="text-sm text-gray-600">{post.author.name}</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm text-gray-500">
                    <Clock class="w-4 h-4" />
                    <span>{post.readTime}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid lg:grid-cols-12 gap-8">
          <!-- Recent Posts -->
          <div class="lg:col-span-8">
            <h2 class="text-2xl font-semibold mb-8">Recent Articles</h2>
            <div class="space-y-8">
              {recentPosts.map(post => (
                <a 
                  href={`/blog/${post.slug}`}
                  class="group block bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300"
                >
                  <div class="flex flex-col md:flex-row">
                    <div class="md:w-1/3">
                      <div class="aspect-video md:aspect-square overflow-hidden">
                        <img 
                          src={post.image} 
                          alt={post.title}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      </div>
                    </div>
                    <div class="md:w-2/3 p-6">
                      <div class="flex items-center gap-2 mb-4">
                        <span class="px-3 py-1 bg-purple-50 text-purple-700 text-sm font-medium rounded-full">
                          {post.category}
                        </span>
                      </div>
                      <h3 class="text-xl font-semibold mb-2 group-hover:text-purple-600 transition-colors">
                        {post.title}
                      </h3>
                      <p class="text-gray-600 mb-4">{post.description}</p>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                          <img 
                            src={post.author.avatar} 
                            alt={post.author.name}
                            class="w-8 h-8 rounded-full"
                          />
                          <span class="text-sm text-gray-600">{post.author.name}</span>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-gray-500">
                          <Clock class="w-4 h-4" />
                          <span>{post.readTime}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-4">
            <!-- Categories -->
            <div class="bg-white rounded-xl border border-gray-100 p-6 mb-8">
              <h3 class="text-lg font-semibold mb-4">Categories</h3>
              <div class="space-y-2">
                {categories.map(category => (
                  <a 
                    href={`/blog/category/${category.name.toLowerCase()}`}
                    class="flex items-center justify-between py-2 text-gray-600 hover:text-purple-600 transition-colors"
                  >
                    <span>{category.name}</span>
                    <span class="text-sm bg-gray-100 px-2 py-1 rounded-full">
                      {category.count}
                    </span>
                  </a>
                ))}
              </div>
            </div>

            <!-- Newsletter -->
            <div class="bg-gray-900 rounded-xl p-6 text-white">
              <h3 class="text-lg font-semibold mb-2">Subscribe to Our Newsletter</h3>
              <p class="text-gray-300 mb-4">
                Get the latest articles and insights delivered to your inbox
              </p>
              <form class="space-y-4">
                <input
                  type="email"
                  placeholder="Enter your email"
                  class="w-full px-4 py-3 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500"
                />
                <button
                  type="submit"
                  class="w-full px-6 py-3 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 transition-colors"
                >
                  Subscribe
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 