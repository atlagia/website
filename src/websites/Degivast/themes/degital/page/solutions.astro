---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import { Fragment } from 'astro';

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);
const { default: Hero } = await import(`../components/Hero.astro`);
const { default: Features } = await import(`../components/Features.astro`);
const { default: CTA } = await import(`../components/CTA.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

// Get site title and description
const SITE_TITLE = 'Solutions | ' + jsonData.siteTitle;
const SITE_DESCRIPTION = 'Explore our comprehensive suite of business solutions';

// Icon paths mapping
const iconPaths = {
  'shopping-cart': 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  'bar-chart': 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'megaphone': 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z',
  'lightbulb': 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
};

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}

// Solution categories with their features
const solutions = [
  {
    name: 'Commerce',
    icon: 'shopping-cart',
    description: 'Build and scale your online business with powerful e-commerce tools',
    features: [
      'Store Builder',
      'Sales Management',
      'Inventory Control',
      'Payment Processing'
    ],
    link: '/solutions/commerce'
  },
  {
    name: 'Analytics',
    icon: 'bar-chart',
    description: 'Turn data into actionable insights with our analytics platform',
    features: [
      'Custom Dashboards',
      'Predictive Analytics',
      'Performance Tracking',
      'Real-time Reporting'
    ],
    link: '/solutions/analytics'
  },
  {
    name: 'Marketing',
    icon: 'megaphone',
    description: 'Transform your marketing with AI-powered automation',
    features: [
      'Campaign Management',
      'Customer Journey Automation',
      'Content Optimization',
      'Performance Analytics'
    ],
    link: '/solutions/marketing'
  },
  {
    name: 'Insights',
    icon: 'lightbulb',
    description: 'Unlock the power of your business data with AI-driven insights',
    features: [
      'Smart Analysis',
      'Data Visualization',
      'Performance Tracking',
      'Team Collaboration'
    ],
    link: '/solutions/insights'
  }
];
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .gradient-bg {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #d946ef 100%);
      }
      .solution-card {
        transition: transform 0.3s ease-in-out;
      }
      .solution-card:hover {
        transform: translateY(-5px);
      }
    </style>
  </head>
  <body class={lang === 'ar' ? 'rtl' : 'ltr'}>
    <Header />
    <main>
      {/* Hero Section */}
      <section class="py-20 gradient-bg text-white">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mx-auto text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-6">
              Powerful Solutions for Modern Business
            </h1>
            <p class="text-xl opacity-90 mb-8">
              Discover our comprehensive suite of tools designed to help you automate, analyze, and grow your business.
            </p>
            <div class="flex justify-center gap-4">
              <a
                href="#explore"
                class="bg-white text-purple-600 px-8 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition-colors"
              >
                Explore Solutions
              </a>
              <a
                href="/contact"
                class="border-2 border-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-purple-600 transition-colors"
              >
                Contact Sales
              </a>
            </div>
          </div>
        </div>
      </section>

      {/* Solutions Grid */}
      <section id="explore" class="py-20">
        <div class="container mx-auto px-4">
          <div class="text-center mb-16">
            <h2 class="text-3xl font-bold mb-4">Choose Your Solution</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">
              Each solution is designed to address specific business needs while seamlessly integrating with our entire platform.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            {solutions.map((solution) => (
              <div class="solution-card bg-white rounded-xl shadow-lg overflow-hidden">
                <div class="p-8">
                  <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-6">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-6 w-6 text-purple-600"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d={iconPaths[solution.icon]}
                      />
                    </svg>
                  </div>
                  <h3 class="text-2xl font-semibold mb-4">{solution.name}</h3>
                  <p class="text-gray-600 mb-6">{solution.description}</p>
                  <ul class="space-y-3 mb-8">
                    {solution.features.map((feature) => (
                      <li class="flex items-center text-gray-700">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-5 w-5 text-green-500 mr-3"
                          viewBox="0 0 20 20"
                          fill="currentColor"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"
                          />
                        </svg>
                        {feature}
                      </li>
                    ))}
                  </ul>
                  <a
                    href={solution.link}
                    class="inline-flex items-center text-purple-600 font-semibold hover:text-purple-700"
                  >
                    Learn More
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5 ml-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Benefits Section */}
      <section class="py-20 bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mx-auto text-center mb-16">
            <h2 class="text-3xl font-bold mb-4">Why Choose Our Solutions</h2>
            <p class="text-gray-600">
              Our platform combines cutting-edge technology with user-friendly design to deliver powerful capabilities for your business.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-purple-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 10V3L4 14h7v7l9-11h-7z"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-4">Lightning Fast</h3>
              <p class="text-gray-600">
                High-performance architecture ensuring your solutions run at peak efficiency.
              </p>
            </div>

            <div class="text-center">
              <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-purple-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-4">Enterprise Security</h3>
              <p class="text-gray-600">
                Bank-grade security with encryption and regular security audits.
              </p>
            </div>

            <div class="text-center">
              <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-8 w-8 text-purple-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-4">Team Collaboration</h3>
              <p class="text-gray-600">
                Built-in tools for team collaboration and workflow management.
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section class="py-20 gradient-bg text-white">
        <div class="container mx-auto px-4">
          <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl font-bold mb-6">Ready to Transform Your Business?</h2>
            <p class="text-xl opacity-90 mb-8">
              Join thousands of businesses already using our platform to streamline their operations.
            </p>
            <div class="flex justify-center gap-4">
              <a
                href="/signup"
                class="bg-white text-purple-600 px-8 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition-colors"
              >
                Get Started
              </a>
              <a
                href="/contact"
                class="border-2 border-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-purple-600 transition-colors"
              >
                Talk to Sales
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      // Intersection Observer for animations
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // Observe all sections
      document.querySelectorAll('section').forEach(section => {
        observer.observe(section);
      });
    </script>
  </body>
</html> 