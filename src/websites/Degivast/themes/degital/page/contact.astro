---
import { getLangFromUrl, useTranslations } from '@utils/i18n';

const { lang } = Astro.params;
const translations = await useTranslations(lang);
const jsonData = translations.default;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const SITE_TITLE = `${jsonData.siteTitle} - Contact Us`;
const SITE_DESCRIPTION = jsonData.contactDescription || 'Get in touch with our team for support or inquiries';

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class={lang === 'ar' ? 'rtl' : 'ltr'}>
    <Header />
    <main class="container mx-auto px-4 py-16">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="text-4xl font-bold mb-4">{jsonData.contact?.title}</h1>
          <p class="text-xl text-gray-600">{jsonData.contact?.subtitle}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16">
          <div>
            <h2 class="text-2xl font-semibold mb-6">{jsonData.contact?.info?.title}</h2>
            <div class="space-y-6">
              {jsonData.contact?.info?.items?.map((item) => (
                <div class="flex items-start">
                  <div class="text-primary mr-4">
                    <span class="text-2xl">{item.icon}</span>
                  </div>
                  <div>
                    <h3 class="font-semibold mb-1">{item.title}</h3>
                    <p class="text-gray-600">{item.value}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-12">
              <h2 class="text-2xl font-semibold mb-6">{jsonData.contact?.social?.title}</h2>
              <div class="flex space-x-4">
                {jsonData.contact?.social?.links?.map((link) => (
                  <a 
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-600 hover:text-primary transition-colors"
                  >
                    <span class="text-2xl">{link.icon}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-semibold mb-6">{jsonData.contact?.form?.title}</h2>
            <form class="space-y-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  {jsonData.contact?.form?.name}
                </label>
                <input
                  type="text"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                  required
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  {jsonData.contact?.form?.email}
                </label>
                <input
                  type="email"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                  required
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  {jsonData.contact?.form?.subject}
                </label>
                <input
                  type="text"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                  required
                />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  {jsonData.contact?.form?.message}
                </label>
                <textarea
                  rows="4"
                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                  required
                ></textarea>
              </div>
              
              <button
                type="submit"
                class="w-full bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-dark transition-colors"
              >
                {jsonData.contact?.form?.submit}
              </button>
            </form>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html> 