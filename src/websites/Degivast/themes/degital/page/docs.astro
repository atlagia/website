---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, ChevronRight } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Documentation | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Comprehensive documentation and guides for our platform';

// Documentation categories
const categories = [
  {
    title: 'Getting Started',
    icon: '🚀',
    items: [
      { title: 'Quick Start Guide', href: '/docs/quick-start' },
      { title: 'Installation', href: '/docs/installation' },
      { title: 'Basic Concepts', href: '/docs/concepts' },
      { title: 'First Steps', href: '/docs/first-steps' }
    ]
  },
  {
    title: 'Core Features',
    icon: '⚡',
    items: [
      { title: 'Dashboard', href: '/docs/dashboard' },
      { title: 'Analytics', href: '/docs/analytics' },
      { title: 'Automation', href: '/docs/automation' },
      { title: 'Integration', href: '/docs/integration' }
    ]
  },
  {
    title: 'Advanced Topics',
    icon: '🔧',
    items: [
      { title: 'API Reference', href: '/docs/api' },
      { title: 'Security', href: '/docs/security' },
      { title: 'Performance', href: '/docs/performance' },
      { title: 'Customization', href: '/docs/customization' }
    ]
  },
  {
    title: 'Resources',
    icon: '📚',
    items: [
      { title: 'Best Practices', href: '/docs/best-practices' },
      { title: 'Tutorials', href: '/docs/tutorials' },
      { title: 'Examples', href: '/docs/examples' },
      { title: 'FAQ', href: '/docs/faq' }
    ]
  }
];

// Popular articles
const popularArticles = [
  {
    title: 'Getting Started with AutomatePro',
    description: 'Learn the basics and set up your first automation',
    href: '/docs/getting-started'
  },
  {
    title: 'API Integration Guide',
    description: 'Connect your systems using our powerful API',
    href: '/docs/api-integration'
  },
  {
    title: 'Security Best Practices',
    description: 'Keep your automation workflows secure',
    href: '/docs/security-best-practices'
  }
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Documentation</h1>
          <p class="text-xl text-gray-600 mb-8">
            Everything you need to know about using and customizing our platform
          </p>
          
          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <Search class="w-5 h-5 text-gray-400" />
            </div>
            <input
              type="text"
              placeholder="Search documentation..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-colors"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Popular Articles -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Popular Articles</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {popularArticles.map(article => (
            <a 
              href={article.href}
              class="block p-6 bg-white rounded-xl border border-gray-100 hover:border-purple-200 hover:shadow-lg transition-all duration-300"
            >
              <h3 class="text-lg font-semibold mb-2">{article.title}</h3>
              <p class="text-gray-600">{article.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Documentation Categories -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8">
          {categories.map(category => (
            <div class="bg-white rounded-xl border border-gray-100 p-6">
              <div class="flex items-center gap-3 mb-6">
                <span class="text-2xl">{category.icon}</span>
                <h2 class="text-xl font-semibold">{category.title}</h2>
              </div>
              <ul class="space-y-3">
                {category.items.map(item => (
                  <li>
                    <a 
                      href={item.href}
                      class="flex items-center gap-2 text-gray-600 hover:text-purple-600 transition-colors"
                    >
                      <ChevronRight class="w-4 h-4" />
                      <span>{item.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Help Section -->
    <section class="py-12 bg-gray-900 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-4">Need More Help?</h2>
          <p class="text-gray-300 mb-8">
            Can't find what you're looking for? Our support team is here to help.
          </p>
          <div class="flex justify-center gap-4">
            <a 
              href="/contact"
              class="px-6 py-3 bg-white text-gray-900 rounded-lg font-medium hover:bg-gray-100 transition-colors"
            >
              Contact Support
            </a>
            <a 
              href="/community"
              class="px-6 py-3 bg-gray-800 text-white rounded-lg font-medium hover:bg-gray-700 transition-colors"
            >
              Join Community
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 