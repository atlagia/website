---
import { SITE_TITLE } from '../../consts';
import pkg from 'lucide-react';
const { 
  Phone,
  Clock,
  Shield,
  Heart,
  AlertTriangle,
  Bandage,
  Stethoscope,
  Activity
} = pkg;

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../../components/BaseHead.astro`);
const { default: Header } = await import(`../../components/Header.astro`);
const { default: Footer } = await import(`../../components/Footer.astro`);

// Import language-specific service data
const serviceData = await import(`../../data/services/emergency/emergency_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'DentCare'
};

// Define icon paths
const iconPaths = {
  phone: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  heart: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  "alert-triangle": `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  bandage: `<path d="M21 3v18M3 3v18M12 12h.01M8 12h.01M16 12h.01M12 8h.01M8 8h.01M16 8h.01M12 16h.01M8 16h.01M16 16h.01"/>`,
  stethoscope: `<path d="M19 4v3m0 0a3 3 0 1 1 0 6 3 3 0 0 1 0-6z"/><path d="M19 13v4a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4V7a2 2 0 0 0-2-2H2"/>`,
  activity: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`${serviceData.hero.title} | ${businessInfo.name}`}
      description={serviceData.hero.description}
    />
  </head>
  <body>
    <Header />
    <main class="pt-10">
      <!-- Hero Section with Emergency Contact -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#f0f9ff] via-white to-transparent overflow-hidden">
        <div class="absolute inset-0 z-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-[#0a91b1]/10 to-blue-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-sky-500/10 to-[#0a91b1]/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-[#0a91b1]/10 text-[#0a91b1] border border-[#0a91b1]/20">
            {serviceData.hero.subtitle}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{serviceData.hero.title}</h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
            {serviceData.hero.description}
          </p>
          <div class="bg-[#0a91b1] text-white py-4 px-6 rounded-2xl inline-block">
            <p class="text-sm mb-2">{serviceData.contact.available}</p>
            <a href={`tel:${serviceData.contact.emergency_number}`} class="text-2xl font-bold hover:text-white/90 transition-colors">
              {serviceData.contact.emergency_number}
            </a>
          </div>
        </div>
      </section>

      <!-- Emergency Services -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.emergencies.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.emergencies.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {serviceData.emergencies.services.map(service => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <div class="flex items-center mb-4">
                  <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center mr-4">
                    <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                      <line x1="12" y1="9" x2="12" y2="13"/>
                      <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900">{service.name}</h3>
                </div>
                <p class="text-gray-600 mb-4">{service.description}</p>
                <ul class="space-y-2">
                  {service.symptoms.map(symptom => (
                    <li class="flex items-center text-gray-600">
                      <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {symptom}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- First Aid Instructions -->
      <section class="relative py-16 px-4 bg-gradient-to-b from-white via-[#0a91b1]/5 to-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.firstAid.title}</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">{serviceData.firstAid.description}</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {serviceData.firstAid.tips.map(tip => (
              <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300">
                <h3 class="text-xl font-bold text-gray-900 mb-4">{tip.situation}</h3>
                <ul class="space-y-3">
                  {tip.instructions.map(instruction => (
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-[#0a91b1] mr-3 mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <span class="text-gray-600">{instruction}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Prevention Tips -->
      <section class="relative py-16 px-4 bg-white">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-4">{serviceData.prevention.title}</h2>
          </div>
          <div class="max-w-3xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {serviceData.prevention.tips.map(tip => (
                <div class="flex items-center p-4 bg-white rounded-xl shadow-sm">
                  <svg class="w-5 h-5 text-[#0a91b1] mr-3" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-gray-700">{tip}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Emergency CTA -->
      <section class="relative py-16 px-4 bg-[#0a91b1]">
        <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">{serviceData.cta.title}</h2>
          <p class="text-xl text-white/90 max-w-3xl mx-auto mb-8">{serviceData.cta.description}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href={`tel:${serviceData.contact.emergency_number}`}
              class="inline-flex items-center justify-center px-8 py-3 bg-white text-[#0a91b1] font-semibold rounded-full hover:bg-gray-100 transition-colors duration-300"
            >
              <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {serviceData.cta.primaryButton.text}
            </a>
            <a
              href={serviceData.cta.secondaryButton.href}
              class="inline-block px-8 py-3 bg-transparent text-white font-semibold rounded-full border-2 border-white hover:bg-white/10 transition-colors duration-300"
            >
              {serviceData.cta.secondaryButton.text}
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 