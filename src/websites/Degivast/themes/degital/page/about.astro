---
import { getLangFromUrl, useTranslations } from '@utils/i18n';

const { lang } = Astro.params;
const translations = await useTranslations(lang);
const jsonData = translations.default;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const SITE_TITLE = `${jsonData.siteTitle} - About Us`;
const SITE_DESCRIPTION = jsonData.aboutDescription || 'Learn about our mission to revolutionize business automation';

// Generate static paths for all supported languages
export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'de' } },
    { params: { lang: 'nl' } },
    { params: { lang: 'pt' } },
  ];
}

const achievements = [
  {
    year: '2020',
    title: 'Foundation',
    description: 'AutomatePro was founded with a vision to democratize business automation'
  },
  {
    year: '2021',
    title: 'Rapid Growth',
    description: 'Expanded to 20+ countries and secured Series A funding'
  },
  {
    year: '2022',
    title: 'Innovation Award',
    description: 'Recognized as the Most Innovative Automation Platform'
  },
  {
    year: '2023',
    title: 'Global Expansion',
    description: 'Reached 50+ countries and launched enterprise solutions'
  }
];

const technologies = [
  {
    icon: '🤖',
    name: 'AI & Machine Learning',
    description: 'State-of-the-art algorithms powering intelligent automation'
  },
  {
    icon: '🔄',
    name: 'Process Automation',
    description: 'Advanced workflow automation with smart decision making'
  },
  {
    icon: '🔍',
    name: 'Predictive Analytics',
    description: 'Data-driven insights for proactive business decisions'
  },
  {
    icon: '🔐',
    name: 'Enterprise Security',
    description: 'Bank-grade security with end-to-end encryption'
  }
];

const partners = [
  {
    logo: '/images/partners/microsoft.svg',
    name: 'Microsoft',
    type: 'Technology Partner'
  },
  {
    logo: '/images/partners/aws.svg',
    name: 'Amazon Web Services',
    type: 'Cloud Partner'
  },
  {
    logo: '/images/partners/salesforce.svg',
    name: 'Salesforce',
    type: 'Integration Partner'
  }
];
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .gradient-text {
        background: linear-gradient(135deg, #3b82f6, #06b6d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 200% 200%;
        animation: gradient-shift 5s ease infinite;
      }

      @keyframes gradient-shift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      .stat-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
        transition: all 0.3s ease;
      }

      .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(31, 38, 135, 0.25);
      }

      .team-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .team-card:hover {
        transform: translateY(-10px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      }

      .achievement-card {
        position: relative;
        transition: all 0.3s ease;
      }

      .achievement-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(135deg, #3b82f6, #06b6d4);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .achievement-card:hover::before {
        opacity: 1;
      }

      .tech-card {
        background: white;
        border-radius: 1rem;
        transition: all 0.3s ease;
        border: 1px solid rgba(0, 0, 0, 0.1);
      }

      .tech-card:hover {
        background: linear-gradient(135deg, #3b82f6, #06b6d4);
        color: white;
        transform: translateY(-5px);
      }

      .tech-card:hover p {
        color: rgba(255, 255, 255, 0.9) !important;
      }

      .partner-card {
        transition: all 0.3s ease;
        filter: grayscale(100%);
      }

      .partner-card:hover {
        filter: grayscale(0%);
        transform: scale(1.05);
      }

      .scroll-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s ease;
      }

      .scroll-reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body class={lang === 'ar' ? 'rtl' : 'ltr'}>
    <Header />

    {/* Hero Section */}
    <section class="relative min-h-[80vh] flex items-center bg-gradient-to-b from-blue-50 via-white to-white overflow-hidden">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-blue-500/10 to-cyan-500/10"></div>
      </div>
      <div class="container mx-auto px-4 relative">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-6xl md:text-7xl font-bold mb-8">
            About <span class="gradient-text">AutomatePro</span>
          </h1>
          <p class="text-2xl text-gray-600 leading-relaxed mb-12">
            Pioneering the future of business automation with innovative solutions that empower organizations worldwide
          </p>
          <div class="flex justify-center gap-6">
            <a href="/contact" class="bg-gradient-to-r from-blue-600 to-cyan-600 text-white px-8 py-4 rounded-lg font-semibold hover:from-blue-700 hover:to-cyan-700 transition-all duration-300 shadow-lg hover:shadow-xl">
              Get in Touch
            </a>
            <a href="#story" class="bg-white text-gray-800 px-8 py-4 rounded-lg font-semibold hover:bg-gray-50 transition-all duration-300 shadow-lg hover:shadow-xl border border-gray-200">
              Our Story
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Mission Section */}
    <section id="story" class="py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="mb-20 scroll-reveal">
            <h2 class="text-4xl font-bold mb-8">Our Mission</h2>
            <p class="text-xl text-gray-600 leading-relaxed">
              {jsonData.about?.sections?.[0]?.content}
            </p>
          </div>

          <div class="scroll-reveal">
            <h2 class="text-4xl font-bold mb-8">Our Story</h2>
            <p class="text-xl text-gray-600 leading-relaxed mb-12">
              {jsonData.about?.sections?.[1]?.content}
            </p>

            <div class="grid gap-8">
              {achievements.map((achievement) => (
                <div class="achievement-card bg-white rounded-lg p-6 shadow-lg">
                  <div class="flex items-start">
                    <div class="text-3xl font-bold text-blue-600 mr-6">{achievement.year}</div>
                    <div>
                      <h3 class="text-xl font-bold mb-2">{achievement.title}</h3>
                      <p class="text-gray-600">{achievement.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Stats Section */}
    <section class="py-24 bg-gradient-to-br from-blue-50 to-cyan-50 relative overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          {jsonData.about?.stats?.map((stat) => (
            <div class="stat-card rounded-2xl p-8 text-center">
              <div class="text-6xl font-bold gradient-text mb-4">{stat.value}</div>
              <div class="text-gray-800 text-lg font-medium">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Technology Section */}
    <section class="py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h2 class="text-4xl font-bold mb-6">Our Technology</h2>
          <p class="text-xl text-gray-600">Powered by cutting-edge technologies and innovative solutions</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
          {technologies.map((tech) => (
            <div class="tech-card p-6">
              <div class="text-4xl mb-4">{tech.icon}</div>
              <h3 class="text-xl font-bold mb-3">{tech.name}</h3>
              <p class="text-gray-600">{tech.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Team Section */}
    <section class="py-24 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-4">
        <h2 class="text-4xl font-bold text-center mb-16">{jsonData.about?.team?.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto">
          {jsonData.about?.team?.members?.map((member) => (
            <div class="team-card bg-white rounded-2xl overflow-hidden shadow-xl">
              <div class="relative overflow-hidden pt-[100%]">
                <img 
                  src={member.image} 
                  alt={member.name}
                  class="absolute top-0 left-0 w-full h-full object-cover transition-transform duration-500 hover:scale-110"
                />
              </div>
              <div class="p-8 text-center">
                <h3 class="text-2xl font-bold mb-2">{member.name}</h3>
                <p class="text-blue-600 font-medium mb-4">{member.role}</p>
                <div class="flex justify-center space-x-4">
                  <a href="#" class="text-gray-400 hover:text-blue-600 transition-colors">
                    <span class="sr-only">LinkedIn</span>
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                  </a>
                  <a href="#" class="text-gray-400 hover:text-blue-600 transition-colors">
                    <span class="sr-only">Twitter</span>
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Partners Section */}
    <section class="py-24">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h2 class="text-4xl font-bold mb-6">Trusted Partners</h2>
          <p class="text-xl text-gray-600">Working with industry leaders to deliver excellence</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto">
          {partners.map((partner) => (
            <div class="partner-card p-8 text-center">
              <img src={partner.logo} alt={partner.name} class="h-16 mx-auto mb-4" />
              <h3 class="text-xl font-bold mb-2">{partner.name}</h3>
              <p class="text-gray-600">{partner.type}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA Section */}
    <section class="py-24 bg-gradient-to-r from-blue-600 to-cyan-600 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="container mx-auto px-4 relative">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-4xl font-bold mb-6">Ready to Transform Your Business?</h2>
          <p class="text-xl mb-12 opacity-90">Join thousands of businesses already using AutomatePro to streamline their operations and drive growth</p>
          <div class="flex justify-center gap-6">
            <a href="/signup" class="bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold hover:bg-gray-50 transition-all duration-300 shadow-lg hover:shadow-xl">
              Start Free Trial
            </a>
            <a href="/contact" class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition-all duration-300">
              Schedule Demo
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      // Scroll reveal animation
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.scroll-reveal').forEach((element) => {
        observer.observe(element);
      });
    </script>
  </body>
</html> 