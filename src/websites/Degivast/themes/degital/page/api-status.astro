---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { CheckCircle, AlertTriangle, XCircle, Clock, RefreshCcw } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `API Status | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Real-time status of our API services and system components';

// API Services status
const services = [
  {
    name: 'API Core',
    status: 'operational',
    uptime: '99.99%',
    responseTime: '45ms'
  },
  {
    name: 'Authentication',
    status: 'operational',
    uptime: '99.98%',
    responseTime: '65ms'
  },
  {
    name: 'Database',
    status: 'operational',
    uptime: '99.99%',
    responseTime: '35ms'
  },
  {
    name: 'File Storage',
    status: 'operational',
    uptime: '99.95%',
    responseTime: '85ms'
  },
  {
    name: 'Search Service',
    status: 'degraded',
    uptime: '99.90%',
    responseTime: '120ms'
  },
  {
    name: 'Analytics Engine',
    status: 'operational',
    uptime: '99.97%',
    responseTime: '75ms'
  }
];

// Recent incidents
const incidents = [
  {
    date: '2024-02-15',
    title: 'Search Service Degraded Performance',
    status: 'investigating',
    description: 'We are investigating reports of increased latency in our search service.',
    updates: [
      {
        time: '14:30 UTC',
        message: 'Investigating reports of increased search latency'
      },
      {
        time: '14:45 UTC',
        message: 'Identified issue with search index optimization'
      }
    ]
  },
  {
    date: '2024-02-10',
    title: 'API Rate Limiting Issue',
    status: 'resolved',
    description: 'Rate limiting was incorrectly applied to some API endpoints.',
    updates: [
      {
        time: '09:15 UTC',
        message: 'Issue identified with rate limiting configuration'
      },
      {
        time: '09:45 UTC',
        message: 'Configuration updated and service restored'
      }
    ]
  }
];

// Status indicators
const statusColors = {
  operational: 'bg-green-500',
  degraded: 'bg-yellow-500',
  down: 'bg-red-500'
};

const statusIcons = {
  operational: CheckCircle,
  degraded: AlertTriangle,
  down: XCircle
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-50 border border-green-100 mb-6">
            <div class="w-2 h-2 rounded-full bg-green-500"></div>
            <span class="text-sm font-medium text-green-700">All Systems Operational</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">API Status</h1>
          <p class="text-xl text-gray-600">
            Current status of our API services and system components
          </p>
        </div>
      </div>
    </section>

    <!-- Status Overview -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
          <div class="p-6 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <h2 class="text-2xl font-semibold">System Status</h2>
              <button class="flex items-center gap-2 text-gray-500 hover:text-gray-700 transition-colors">
                <RefreshCcw class="w-5 h-5" />
                <span class="text-sm">Refresh</span>
              </button>
            </div>
          </div>
          
          <div class="divide-y divide-gray-100">
            {services.map(service => {
              const StatusIcon = statusIcons[service.status];
              return (
                <div class="p-6 flex items-center gap-6">
                  <div class="w-48 flex items-center gap-3">
                    <StatusIcon class={`w-5 h-5 ${service.status === 'operational' ? 'text-green-500' : service.status === 'degraded' ? 'text-yellow-500' : 'text-red-500'}`} />
                    <span class="font-medium">{service.name}</span>
                  </div>
                  <div class="flex-grow grid grid-cols-2 md:grid-cols-4 gap-6">
                    <div>
                      <div class="text-sm text-gray-500">Status</div>
                      <div class="font-medium capitalize">{service.status}</div>
                    </div>
                    <div>
                      <div class="text-sm text-gray-500">Uptime</div>
                      <div class="font-medium">{service.uptime}</div>
                    </div>
                    <div>
                      <div class="text-sm text-gray-500">Response Time</div>
                      <div class="font-medium">{service.responseTime}</div>
                    </div>
                    <div class="hidden md:block">
                      <div class="h-2 rounded-full bg-gray-100 overflow-hidden">
                        <div class={`h-full ${statusColors[service.status]}`} style={`width: ${service.uptime.replace('%', '')}`}></div>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Incident History -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Recent Incidents</h2>
        <div class="space-y-6">
          {incidents.map(incident => (
            <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
              <div class="p-6 border-b border-gray-100">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`inline-block px-3 py-1 rounded-full text-sm font-medium ${
                        incident.status === 'resolved' ? 'bg-green-50 text-green-700' : 'bg-yellow-50 text-yellow-700'
                      }`}>
                        {incident.status === 'resolved' ? 'Resolved' : 'Investigating'}
                      </span>
                      <span class="text-sm text-gray-500">{incident.date}</span>
                    </div>
                    <h3 class="text-lg font-semibold">{incident.title}</h3>
                    <p class="text-gray-600 mt-2">{incident.description}</p>
                  </div>
                </div>
              </div>
              <div class="px-6 py-4 bg-gray-50">
                <div class="text-sm font-medium text-gray-500 mb-3">Updates</div>
                <div class="space-y-3">
                  {incident.updates.map(update => (
                    <div class="flex items-start gap-3">
                      <div class="flex-shrink-0">
                        <Clock class="w-4 h-4 text-gray-400 mt-1" />
                      </div>
                      <div>
                        <div class="text-sm font-medium">{update.time}</div>
                        <div class="text-sm text-gray-600">{update.message}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Subscribe Section -->
    <section class="py-12 bg-gray-900 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-4">Stay Updated</h2>
          <p class="text-gray-300 mb-8">
            Subscribe to receive notifications about system status and incidents
          </p>
          <form class="flex gap-4 max-w-md mx-auto">
            <input
              type="email"
              placeholder="Enter your email"
              class="flex-grow px-4 py-3 rounded-lg bg-gray-800 border border-gray-700 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500"
            />
            <button
              type="submit"
              class="px-6 py-3 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 transition-colors"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 