---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import pkg from 'lucide-react';
const { Search, MapPin, Briefcase, Clock, ChevronRight } = pkg;

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

// Import components
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get translations
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Careers | ${jsonData.siteTitle || 'AutomatePro'}`;
const SITE_DESCRIPTION = 'Join our team and help shape the future of automation';

// Job listings
const jobs = [
  {
    title: 'Senior Software Engineer',
    department: 'Engineering',
    location: 'San Francisco, CA',
    type: 'Full-time',
    description: 'Join our core engineering team to build the next generation of automation tools.',
    requirements: [
      'Bachelor's degree in Computer Science or related field',
      '5+ years of experience in software development',
      'Strong experience with React, Node.js, and TypeScript',
      'Experience with cloud platforms (AWS/GCP)'
    ],
    slug: 'senior-software-engineer'
  },
  {
    title: 'Product Manager',
    department: 'Product',
    location: 'Remote',
    type: 'Full-time',
    description: 'Lead product strategy and development for our automation platform.',
    requirements: [
      '3+ years of product management experience',
      'Experience with B2B SaaS products',
      'Strong analytical and communication skills',
      'Technical background preferred'
    ],
    slug: 'product-manager'
  },
  {
    title: 'Solutions Architect',
    department: 'Customer Success',
    location: 'London, UK',
    type: 'Full-time',
    description: 'Help our enterprise customers implement and optimize their automation solutions.',
    requirements: [
      '5+ years of technical consulting experience',
      'Strong understanding of enterprise software',
      'Excellent communication skills',
      'Experience with automation tools'
    ],
    slug: 'solutions-architect'
  }
];

// Company values
const values = [
  {
    title: 'Innovation First',
    description: 'We push boundaries and embrace new technologies to solve complex problems.',
    icon: '💡'
  },
  {
    title: 'Customer Success',
    description: 'Our customers' success is our success. We go above and beyond to deliver value.',
    icon: '🎯'
  },
  {
    title: 'Collaboration',
    description: 'We work together across teams and time zones to achieve our goals.',
    icon: '🤝'
  },
  {
    title: 'Continuous Learning',
    description: 'We invest in our team's growth and encourage continuous learning.',
    icon: '📚'
  }
];

// Benefits
const benefits = [
  {
    title: 'Health & Wellness',
    items: [
      'Comprehensive health insurance',
      'Mental health support',
      'Gym membership',
      'Wellness programs'
    ]
  },
  {
    title: 'Work-Life Balance',
    items: [
      'Flexible working hours',
      'Remote work options',
      'Unlimited PTO',
      'Paid parental leave'
    ]
  },
  {
    title: 'Growth & Development',
    items: [
      'Learning & development budget',
      'Conference attendance',
      'Mentorship programs',
      'Career coaching'
    ]
  },
  {
    title: 'Team & Culture',
    items: [
      'Regular team events',
      'Company retreats',
      'Employee resource groups',
      'Recognition programs'
    ]
  }
];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50"></div>
      <div class="relative container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">Join Our Team</h1>
          <p class="text-xl text-gray-600 mb-8">
            Help us shape the future of business automation and make an impact
          </p>
          
          <!-- Search Bar -->
          <div class="relative max-w-2xl mx-auto">
            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <Search class="w-5 h-5 text-gray-400" />
            </div>
            <input
              type="text"
              placeholder="Search open positions..."
              class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 transition-colors"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Open Positions -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <h2 class="text-2xl font-semibold mb-8">Open Positions</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {jobs.map(job => (
            <a 
              href={`/careers/${job.slug}`}
              class="group bg-white rounded-xl border border-gray-100 p-6 hover:shadow-lg transition-all duration-300"
            >
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 bg-purple-50 rounded-lg flex items-center justify-center">
                  <Briefcase class="w-6 h-6 text-purple-600" />
                </div>
                <div>
                  <h3 class="text-xl font-semibold group-hover:text-purple-600 transition-colors">
                    {job.title}
                  </h3>
                  <div class="text-gray-600">{job.department}</div>
                </div>
              </div>
              
              <p class="text-gray-600 mb-6">{job.description}</p>
              
              <div class="flex items-center gap-6 text-sm text-gray-500">
                <div class="flex items-center gap-2">
                  <MapPin class="w-4 h-4" />
                  <span>{job.location}</span>
                </div>
                <div class="flex items-center gap-2">
                  <Clock class="w-4 h-4" />
                  <span>{job.type}</span>
                </div>
              </div>
              
              <div class="mt-6 flex items-center text-purple-600">
                <span class="text-sm font-medium">Learn more</span>
                <ChevronRight class="w-4 h-4 ml-1" />
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Company Values -->
    <section class="py-12 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2 class="text-3xl font-bold mb-4">Our Values</h2>
          <p class="text-xl text-gray-600">
            The principles that guide everything we do
          </p>
        </div>
        
        <div class="grid md:grid-cols-4 gap-8">
          {values.map(value => (
            <div class="text-center">
              <div class="text-4xl mb-4">{value.icon}</div>
              <h3 class="text-xl font-semibold mb-2">{value.title}</h3>
              <p class="text-gray-600">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-12">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2 class="text-3xl font-bold mb-4">Benefits & Perks</h2>
          <p class="text-xl text-gray-600">
            We take care of our team with comprehensive benefits
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {benefits.map(category => (
            <div class="bg-white rounded-xl border border-gray-100 p-6">
              <h3 class="text-xl font-semibold mb-4">{category.title}</h3>
              <ul class="space-y-3">
                {category.items.map(item => (
                  <li class="flex items-center gap-2 text-gray-600">
                    <div class="w-1.5 h-1.5 rounded-full bg-purple-500"></div>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-12 bg-gray-900 text-white">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-4">Ready to Make an Impact?</h2>
          <p class="text-xl text-gray-300 mb-8">
            Join our team and help shape the future of business automation
          </p>
          <div class="flex justify-center gap-4">
            <a 
              href="/careers#positions"
              class="px-8 py-3 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 transition-colors"
            >
              View Open Positions
            </a>
            <a 
              href="/careers/internships"
              class="px-8 py-3 bg-gray-800 text-white rounded-lg font-medium hover:bg-gray-700 transition-colors"
            >
              Student Opportunities
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html> 