---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const lang = getLangFromUrl(Astro.url);
const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = jsonData.siteTitle || 'FastIPTV';
const PAGE_TITLE = 'Contact Us | ' + SITE_TITLE;
const PAGE_DESCRIPTION = jsonData.contactPageDescription || 'Get in touch with FastIPTV support team';
---

<!doctype html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} />
  </head>
  <body class="bg-[#0a0a0a] text-white">
    <Header />
    <main class="container mx-auto px-4 py-16 max-w-6xl">
      <section class="space-y-12">
        {/* Hero Section */}
        <div class="text-center space-y-4">
          <h1 class="text-4xl md:text-6xl font-bold gradient-text">
            Contact FastIPTV
          </h1>
          <p class="text-xl text-gray-300 max-w-3xl mx-auto">
            Our support team is available 24/7 to help you with any questions or concerns.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          {/* Contact Form */}
          <div class="glass rounded-2xl p-8">
            <h2 class="text-2xl font-bold mb-6">Send us a Message</h2>
            <form class="space-y-6">
              <div>
                <label class="block text-sm font-medium mb-2" for="name">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2" for="email">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-medium mb-2" for="subject">
                  Subject
                </label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500"
                  required
                >
                  <option value="">Select a subject</option>
                  <option value="technical">Technical Support</option>
                  <option value="billing">Billing</option>
                  <option value="account">Account</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2" for="message">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-2 rounded-lg bg-white/10 border border-white/20 focus:border-purple-500 focus:ring-2 focus:ring-purple-500"
                  required
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200"
              >
                Send Message
              </button>
            </form>
          </div>

          {/* Contact Information */}
          <div class="space-y-8">
            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-4">24/7 Support</h3>
              <p class="text-gray-300 mb-4">
                Our dedicated support team is available around the clock to assist you.
              </p>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <span class="text-purple-400">📧</span>
                  <a href="mailto:support@fastiptv.com" class="hover:text-purple-400">
                    support@fastiptv.com
                  </a>
                </div>
                <div class="flex items-center gap-4">
                  <span class="text-purple-400">💬</span>
                  <span>Live Chat Available</span>
                </div>
              </div>
            </div>

            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-4">Business Inquiries</h3>
              <p class="text-gray-300 mb-4">
                For business partnerships and opportunities:
              </p>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <span class="text-purple-400">📧</span>
                  <a href="mailto:business@fastiptv.com" class="hover:text-purple-400">
                    business@fastiptv.com
                  </a>
                </div>
              </div>
            </div>

            <div class="glass rounded-xl p-6">
              <h3 class="text-xl font-bold mb-4">Office Location</h3>
              <p class="text-gray-300">
                123 Streaming Street<br />
                Tech Valley, CA 94025<br />
                United States
              </p>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html> 