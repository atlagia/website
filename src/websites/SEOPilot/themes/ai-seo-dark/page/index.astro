---
import { getLangFromUrl, useTranslations } from '@utils/i18n';
import { SITE_TITLE as CONST_SITE_TITLE, SITE_DESCRIPTION as CONST_SITE_DESCRIPTION } from '../consts';

const theme = import.meta.env.THEME || 'default';
const { lang } = Astro.params;

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);
const { default: Welcome } = await import(`../components/Welcome.astro`);
const { default: Features } = await import(`../components/Features.astro`);
const { default: HowItWorks } = await import(`../components/HowItWorks.astro`);
const { default: DashboardPreview } = await import(`../components/DashboardPreview.astro`);
const { default: Integrations } = await import(`../components/Integrations.astro`);
const { default: Pricing } = await import(`../components/Pricing.astro`);
const { default: Banner } = await import(`../components/Banner.astro`);
const { default: WhyChoose } = await import(`../components/WhyChoose.astro`);
const { default: Testimonials } = await import(`../components/Testimonials.astro`);
const { default: FAQ } = await import(`../components/FAQ.astro`);
const { default: CTA } = await import(`../components/CTA.astro`);

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = jsonData.siteTitle || CONST_SITE_TITLE;
const SITE_DESCRIPTION = jsonData.siteDescription || CONST_SITE_DESCRIPTION;

const faqSection = jsonData.sections?.find(section => section.type === 'faq');
const faqSchema = faqSection?.questions ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSection.questions.map((q: any) => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": { "@type": "Answer", "text": q.answer }
  }))
}) : null;

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
  ];
}
---

<!doctype html>
<html lang={lang ?? 'en'}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      isHomePage={true}
    />
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
  </head>
  <body class="bg-[#0a0a0a] text-white">
    <Header transparent={true} lang={lang} />
    <main>
      {jsonData.sections?.map((section) => {
        switch (section.type) {
          case 'welcome':
            return (
              <Welcome
                title={section.title}
                description={section.description}
                stats={section.stats}
                cta={section.cta}
              />
            );
          
          case 'features':
            return (
              <Features
                title={section.title}
                description={section.description}
                features={section.features}
              />
            );

          case 'howItWorks':
            return (
              <HowItWorks
                title={section.title}
                description={section.description}
                steps={section.steps}
              />
            );

          case 'dashboardPreview':
            return (
              <DashboardPreview
                title={section.title}
                description={section.description}
                features={section.features}
              />
            );

          case 'integrations':
            return (
              <Integrations
                title={section.title}
                description={section.description}
                platforms={section.platforms}
              />
            );

          case 'pricing':
            return (
              <Pricing
                title={section.title}
                description={section.description}
                plans={section.plans}
              />
            );

          case 'banner':
            return (
              <Banner
                title={section.title}
                description={section.description}
                cta={section.cta}
              />
            );

          case 'whyChoose':
            return (
              <WhyChoose
                title={section.title}
                description={section.description}
                reasons={section.reasons}
              />
            );

          case 'testimonials':
            return (
              <Testimonials
                title={section.title}
                description={section.description}
                testimonials={section.testimonials}
              />
            );

          case 'faq':
            return (
              <FAQ
                title={section.title}
                description={section.description}
                questions={section.questions}
              />
            );

          case 'cta':
            return (
              <CTA
                title={section.title}
                description={section.description}
                button={section.button}
                features={section.features}
                lang={lang}
              />
            );
          
          default:
            return null;
        }
      })}
    </main>
    <Footer />

    <script>
      (function() {
        function runObserver() {
          var observerOptions = { root: null, rootMargin: '0px', threshold: 0.1 };
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate-in');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);
          document.querySelectorAll('section, .feature-card, .pricing-card').forEach(function(el) { observer.observe(el); });
        }
        if (typeof requestIdleCallback !== 'undefined') requestIdleCallback(runObserver, { timeout: 3000 });
        else setTimeout(runObserver, 100);
      })();
    </script>

    <style is:global>
      body { @apply antialiased; }
      .animate-in { animation: fadeInUp 0.5s ease-out forwards; }
      @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
      ::-webkit-scrollbar { width: 10px; }
      ::-webkit-scrollbar-track { @apply bg-black; }
      ::-webkit-scrollbar-thumb { @apply bg-emerald-600 rounded-full; }
      ::-webkit-scrollbar-thumb:hover { @apply bg-emerald-500; }
      .gradient-text { @apply bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-cyan-400; }
      .glass { @apply bg-white/5 backdrop-blur-sm; }
    </style>
  </body>
</html>
