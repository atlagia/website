---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  stats: Stat[];
}

const { subtitle, title, description, image, stats } = Astro.props;
---

<section class="relative py-32 px-4 overflow-hidden bg-gradient-to-b from-white to-[#f8f9ff]">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-gradient-to-br from-purple-500/5 via-pink-500/5 to-blue-500/5 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/3 left-1/4 w-[400px] h-[400px] bg-gradient-to-tr from-blue-500/5 via-purple-500/5 to-pink-500/5 rounded-full blur-3xl animate-float-delayed"></div>
    <!-- Decorative Grid -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-5"></div>
    <!-- Decorative Dots -->
    <div class="absolute top-20 right-20 w-20 h-20 bg-gradient-to-r from-purple-500/10 to-pink-500/10 rounded-full filter blur-sm animate-pulse"></div>
    <div class="absolute bottom-20 left-20 w-16 h-16 bg-gradient-to-r from-pink-500/10 to-purple-500/10 rounded-full filter blur-sm animate-pulse delay-300"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Title Section -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 border border-purple-100/20 backdrop-blur-sm shadow-sm hover:shadow-md transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-600 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-pink-600 to-purple-600"></span>
        </span>
        <span class="text-sm font-medium text-[#C026D3]">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#C026D3] to-[#DB2777] leading-tight max-w-4xl mx-auto mb-12 pt-4 pb-2">
        {title}
      </h2>
      
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Image Section -->
      <div class="flex-1 relative group perspective-1000">
        <!-- Decorative Elements -->
        <div class="absolute -top-6 -right-6 w-12 h-12 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-lg transform rotate-45 animate-float-slow"></div>
        <div class="absolute -bottom-6 -left-6 w-12 h-12 bg-gradient-to-br from-pink-500/20 to-purple-500/20 rounded-full animate-float-delayed"></div>
        
        <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 rounded-3xl blur-2xl transform rotate-6 group-hover:rotate-12 transition-transform duration-500"></div>
        <div class="relative transform group-hover:translate-z-10 transition-transform duration-500">
          <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <img 
            src={image}
            alt="AI Agency Illustration"
            class="relative w-full max-w-[600px] mx-auto rounded-2xl shadow-2xl transform group-hover:scale-[1.02] transition-all duration-500"
          />
          <!-- Image Overlay Effects -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-t from-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="flex-1">
        <div class="grid grid-cols-2 md:grid-cols-2 gap-8">
          {stats.map((stat) => (
            <div class="relative group">
              <!-- Decorative Background -->
              <div class="absolute inset-0 bg-white/50 rounded-2xl transform transition-transform group-hover:scale-105 duration-300"></div>
              <!-- Stat Content -->
              <div class="relative p-6 text-center">
                <div class="text-4xl xl:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#C026D3] to-[#DB2777] mb-3">
                  {stat.value}
                </div>
                <div class="text-sm text-gray-600 font-medium">
                  {stat.label}
                </div>
                <!-- Hover Effect -->
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-purple-500/5 to-pink-500/5 opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) rotate(45deg); }
    50% { transform: translate(0, -10px) rotate(45deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  .animate-float-slow {
    animation: float-slow 10s ease-in-out infinite;
  }

  .perspective-1000 {
    perspective: 1000px;
  }

  .translate-z-10 {
    transform: translateZ(10px);
  }

  .delay-300 {
    animation-delay: 300ms;
  }
</style> 