---
import { Brain, Code, Cpu, Layers } from 'lucide-react';

interface Feature {
  icon: string;
  title: string;
  description: string;
  keywords: string[];
  bullets: string[];
  backgroundSvg: string;
}

interface Props {
  subtitle: string;
  title: string;
  features: Feature[];
  ctaText: string;
  ctaLink: string;
}

const { subtitle, title, features, ctaText, ctaLink } = Astro.props;

// Map icon names to Lucide components
const iconMap = {
  'ai-development': Brain,
  'software-solutions': Code,
  'digital-transformation': Cpu,
  'industry-solutions': Layers
};

// Simplified position function for single keyword
function getKeywordPosition(): string {
  return 'absolute -top-2 right-0 translate-x-1/3 -translate-y-full'; // Position above and slightly to the right
}
---

<section class="relative py-32 overflow-hidden" style="background-color: #060818;">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
    
    <!-- Animated Particles -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-purple-500/30 rounded-full animate-pulse"></div>
      <div class="absolute top-3/4 right-1/4 w-2 h-2 bg-pink-500/30 rounded-full animate-pulse delay-150"></div>
      <div class="absolute top-1/2 left-1/2 w-2 h-2 bg-blue-500/30 rounded-full animate-pulse delay-300"></div>
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-purple-500/20 backdrop-blur-sm shadow-lg shadow-purple-500/5 hover:shadow-purple-500/10 transition-all duration-300 mb-8" style="background-color: rgba(10, 11, 30, 0.5);">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-600 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-pink-600 to-purple-600"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-pink-500 to-purple-500 text-transparent bg-clip-text">
          {subtitle}
        </span>
      </div>
      
      <div class="relative inline-block">
        <h2 class="text-4xl lg:text-5xl font-bold text-white pb-4 mb-4">
          {title}
        </h2>
        <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-purple-500 to-transparent"></div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      {features.map((feature) => {
        const Icon = iconMap[feature.icon];
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 rounded-2xl backdrop-blur-sm border border-purple-500/10 transition-all duration-500 group-hover:border-purple-500/20" style="background-color: rgba(10, 11, 30, 0.5);"></div>
            
            <!-- Animated Border -->
            <div class="absolute inset-0 rounded-2xl [background:linear-gradient(60deg,transparent_30%,rgba(168,85,247,0.1),transparent_70%)] animate-gradient-border"></div>
            
            <!-- Content -->
            <div class="relative p-8">
              <div class="flex items-start gap-6">
                <!-- Icon -->
                <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-white/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 border border-white/20">
                  <Icon strokeWidth={2} color="white" className="w-8 h-8" />
                </div>
                
                <!-- Text Content -->
                <div class="flex-1">
                  <h3 class="text-xl font-bold text-white mb-2 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-pink-500 group-hover:to-purple-500 transition-all duration-300">
                    {feature.title}
                  </h3>
                  
                  <!-- Keywords -->
                  <div class="flex flex-wrap gap-2 mb-4">
                    {feature.keywords.map((keyword) => (
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-purple-500/10 text-purple-300 border border-purple-500/20">
                        {keyword}
                      </span>
                    ))}
                  </div>
                  
                  <p class="text-gray-300 mb-6">
                    {feature.description}
                  </p>
                  
                  <!-- Bullets -->
                  <ul class="space-y-2">
                    {feature.bullets.map((bullet) => (
                      <li class="flex items-center gap-2 text-sm text-gray-400">
                        <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-r from-pink-500 to-purple-500"></span>
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>

    <!-- CTA Button -->
    <div class="text-center">
      <a 
        href={ctaLink}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white font-medium shadow-lg shadow-purple-500/25 hover:shadow-purple-500/50 transform hover:-translate-y-1 transition-all duration-300"
      >
        {ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-bounce-x" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bg-navy-950 {
    background-color: #060818;
  }
  
  .bg-navy-900 {
    background-color: #0a0b1e;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes gradient-border {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .animate-gradient-border {
    animation: gradient-border 8s linear infinite;
    background-size: 200% 200%;
  }

  @keyframes bounce-x {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(3px); }
  }

  .animate-bounce-x {
    animation: bounce-x 1s ease-in-out infinite;
  }

  .delay-150 {
    animation-delay: 150ms;
  }

  .delay-300 {
    animation-delay: 300ms;
  }
</style> 