---
interface Props {
  subtitle?: string;
  title: string;
  description: string;
  primaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonText: string;
  secondaryButtonLink: string;
  stats?: Array<{
    value: string;
    label: string;
  }>;
  partnerLogos?: Array<{
    src: string;
    alt: string;
  }>;
}

const {
  subtitle,
  title,
  description,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  stats,
  partnerLogos
} = Astro.props;

const defaultStats = [
  {
    value: "10K+",
    label: "Active Users"
  },
  {
    value: "50+",
    label: "Countries"
  },
  {
    value: "95%",
    label: "Success Rate"
  },
  {
    value: "24/7",
    label: "AI Support"
  }
];
---

<section class="relative py-24 px-4 overflow-hidden" style="background-color: #0a0b1e;">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-bl from-purple-500/20 to-blue-500/20 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-tr from-pink-500/20 to-cyan-500/20 rounded-full blur-3xl animate-blob"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-12">
      {subtitle && (
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full bg-pink-500/10 text-pink-400 border border-pink-500/20" id="content-subtitle">
          {subtitle || "Join the AI Revolution"}
        </span>
      )}
      <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6" id="content-title">
        {title || "Ready to Transform Your Business?"}
      </h2>
      <p class="text-xl text-gray-300 leading-relaxed" id="content-description">
        {description || "Start building, automating, and scaling your business with Atlaga's AI-powered platform. Join thousands of successful businesses worldwide."}
      </p>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a
        href={primaryButtonLink}
        class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-white bg-pink-600 hover:bg-pink-700 rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-pink-500/25 hover:-translate-y-0.5"
        id="content-primaryButtonLink"
      >
        <span id="content-primaryButtonText">{primaryButtonText || "Start Free Trial"}</span>
      </a>
      <a
        href={secondaryButtonLink}
        class="w-full sm:w-auto px-8 py-4 text-base font-semibold text-white rounded-full border border-gray-700 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5" style="background-color: #1a1b3f;"
        id="content-secondaryButtonLink"
      >
        <span id="content-secondaryButtonText">{secondaryButtonText || "Schedule Demo"}</span>
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
      {(stats || defaultStats).map((stat, index) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-white mb-2" id={`content-stat-${index}-value`}>
            {stat.value}
          </div>
          <div class="text-gray-400 text-sm md:text-base" id={`content-stat-${index}-label`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Trust Indicators -->
    {partnerLogos && partnerLogos.length > 0 && (
      <div class="mt-16 text-center">
        <p class="text-gray-400 mb-6" id="content-partnerLogos-title">Trusted by leading companies worldwide</p>
        <div class="flex flex-wrap justify-center items-center gap-8 opacity-70">
          {partnerLogos.map((logo, index) => (
            <img 
              src={logo.src} 
              alt={logo.alt} 
              class="h-8 brightness-0 invert grayscale hover:grayscale-0 transition-all duration-300"
              id={`content-partnerLogo-${index}`}
              data-content-key={`partnerLogos.${index}.src`}
              data-alt-key={`partnerLogos.${index}.alt`}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }
  .bg-navy-700 {
    background-color: #1a1b3f;
  }
  .bg-navy-600 {
    background-color: #232453;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 