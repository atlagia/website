---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const {
  Check,
  X,
  Star,
  Zap,
  Shield,
  Users,
  Globe,
  Clock,
  Database,
  Cpu,
  Brain,
  ChevronRight,
  ArrowRight,
  HelpCircle,
  MessageSquare,
  Phone,
  Building2,
  Stethoscope,
  Factory,
  ShoppingBag,
  GraduationCap,
  Briefcase,
  Home,
  Truck,
  Hotel,
  Building,
  CloudAws,
  CloudGoogle,
  CloudMicrosoft,
  Database2,
  Code,
  Calendar
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language from URL
const currentLang = getLangFromUrl(Astro.url);

// Import language-specific data
const pricingData = await import(`../data/pricing/pricing_${currentLang}.json`).catch(() => {
  // Fallback to English if language file doesn't exist
  return import(`../data/pricing/pricing_en.json`);
});

const {
  pageTitle,
  pageDescription,
  hero,
  benefits,
  industries,
  successMetrics,
  globalFeatures,
  integrations,
  faqs,
  implementation,
  contact,
  cta
} = pricingData;

// Map icon strings to actual icon components
const getIcon = (iconName) => LucideIcons[iconName];

const iconMap = {
  CloudAws,
  CloudGoogle,
  CloudMicrosoft,
  Database2,
  Building2,
  Factory,
  Database,
  Globe,
  Users,
  Star,
  Shield,
  Clock,
  Zap,
  Brain,
  Cpu,
  Code,
  MessageSquare,
  Calendar
};


---

<!doctype html>
<html lang={currentLang} class="scroll-smooth" dir={currentLang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead 
      title={`${pageTitle} | ${siteName}`}
      description={pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-purple-100 shadow-lg mb-8">
            <span class="text-sm font-medium text-purple-700">{hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-900 mb-12 max-w-3xl mx-auto">
            {hero.description}
          </p>

          <a 
            href={hero.cta.href}
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium hover:from-purple-700 hover:to-blue-700 transition-all duration-300"
          >
            {hero.cta.text}
            <ArrowRight class="w-5 h-5" />
          </a>
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{benefits.title}</h2>
          <p class="text-xl text-gray-900">{benefits.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {benefits.items.map((benefit) => {
            const BenefitIcon = getIcon(benefit.icon);
            return (
              <div class="bg-gray-50 rounded-2xl p-6">
                <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center mb-4">
                  <BenefitIcon class="w-6 h-6 text-purple-600" />
                </div>
                <h3 class="text-xl font-bold mb-2 text-gray-900">{benefit.title}</h3>
                <p class="text-gray-900 mb-4">{benefit.description}</p>
                <ul class="space-y-2">
                  {benefit.items.map((item) => (
                    <li class="flex items-start gap-2">
                      <Check class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" />
                      <span class="text-sm text-gray-900">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Industries Grid -->
    <section class="py-24">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{industries.title}</h2>
          <p class="text-xl text-gray-900">{industries.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {industries.items.map((industry) => {
            const IndustryIcon = getIcon(industry.icon);
            return (
              <div class="group p-6 bg-white rounded-2xl hover:shadow-lg transition-all duration-300">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
                    <IndustryIcon class="w-6 h-6 text-purple-600" />
                  </div>
                  <div>
                    <h3 class="font-semibold group-hover:text-purple-600 transition-colors mb-1 text-gray-900">
                      {industry.name}
                    </h3>
                    <p class="text-sm text-gray-900 mb-4">{industry.description}</p>
                    <div class="flex flex-wrap gap-2">
                      {industry.solutions.map((solution) => (
                        <a 
                          href={solution.link}
                          class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 hover:bg-purple-100 hover:text-purple-600 transition-colors"
                        >
                          {solution.name}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Success Metrics -->
    <section class="py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{successMetrics.title}</h2>
          <p class="text-xl text-gray-900">{successMetrics.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {successMetrics.items.map((metric) => {
            const MetricIcon = getIcon(metric.icon);
            return (
              <div class="bg-white rounded-2xl p-6 text-center">
                <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center mx-auto mb-4">
                  <MetricIcon class="w-6 h-6 text-purple-600" />
                </div>
                <div class="text-4xl font-bold text-purple-600 mb-2">{metric.value}</div>
                <h3 class="text-lg font-semibold mb-2 text-gray-900">{metric.title}</h3>
                <p class="text-gray-900">{metric.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Global Features -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{globalFeatures.title}</h2>
          <p class="text-xl text-gray-900">{globalFeatures.description}</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {globalFeatures.features.map((category) => (
            <div class="bg-gray-50 rounded-2xl p-6">
              <h3 class="text-xl font-bold mb-4 text-gray-900">{category.category}</h3>
              <ul class="space-y-3">
                {category.items.map((item) => (
                  <li class="flex items-start gap-3">
                    <Check class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" />
                    <span class="text-gray-900">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Integrations Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{integrations.title}</h2>
          <p class="text-xl text-gray-900">{integrations.description}</p>
        </div>

        <div class="space-y-12">
          {integrations.categories.map((category) => (
            <div>
              <h3 class="text-2xl font-bold mb-8 text-gray-900">{category.category}</h3>
              <div class="grid md:grid-cols-3 gap-8">
                {category.items.map((item) => {
                  const IntegrationIcon = iconMap[item.icon] || iconMap['Globe'];
                  return (
                    <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                      <!-- Card Glow Effect -->
                      <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-500 to-blue-500 rounded-xl blur opacity-0 group-hover:opacity-25 transition duration-500"></div>
                      
                      <!-- Card Content -->
                      <div class="relative bg-white rounded-xl p-6 flex flex-col items-center justify-center gap-3 border border-gray-100 group-hover:border-transparent transition-colors duration-500">
                        <div class="w-16 h-16 flex items-center justify-center bg-purple-50 rounded-lg group-hover:bg-purple-100 transition-colors duration-500">
                          <IntegrationIcon class="w-8 h-8 text-purple-600" />
                        </div>
                        <span class="text-sm font-medium text-gray-900 group-hover:text-purple-600 transition-colors duration-500">{item.name}</span>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{faqs.title}</h2>
          <p class="text-xl text-gray-900">{faqs.description}</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          {faqs.items.map((faq) => (
            <div class="bg-white rounded-2xl p-6">
              <h3 class="text-lg font-semibold mb-3 text-gray-900">{faq.question}</h3>
              <p class="text-gray-900">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Implementation Process -->
    <section class="py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{implementation.title}</h2>
          <p class="text-xl text-gray-900">{implementation.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {implementation.steps.map((step) => (
            <div class="bg-white rounded-2xl p-6">
              <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center mb-4">
                <span class="text-xl font-bold text-purple-600">{step.number}</span>
              </div>
              <h3 class="text-xl font-bold mb-2 text-gray-900">{step.title}</h3>
              <p class="text-gray-900">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{contact.title}</h2>
          <p class="text-xl text-gray-900">{contact.description}</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
          {contact.options.map((option) => {
            const OptionIcon = getIcon(option.icon);
            return (
              <a 
                href={option.link}
                class="group p-6 bg-gray-50 rounded-2xl hover:shadow-lg transition-all duration-300"
              >
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
                    <OptionIcon class="w-6 h-6 text-purple-600" />
                  </div>
                  <div>
                    <h3 class="font-semibold group-hover:text-purple-600 transition-colors mb-1 text-gray-900">
                      {option.title}
                    </h3>
                    <p class="text-sm text-gray-900">{option.description}</p>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cta.title}</h2>
          <p class="text-xl text-white/90 mb-8">
            {cta.description}
          </p>
          <div class="flex items-center justify-center gap-4">
            {cta.buttons.map((button) => {
              const Icon = button.icon ? iconMap[button.icon] : null;
              return (
                <a 
                  href={button.href}
                  class={`inline-flex items-center gap-2 px-8 py-4 rounded-xl ${
                    button.variant === 'primary'
                      ? 'bg-white text-purple-600 hover:bg-gray-100'
                      : 'bg-white/10 text-white hover:bg-white/20'
                  } font-medium transition-all duration-300`}
                >
                  {Icon && <Icon class="w-5 h-5" strokeWidth={2} />}
                  {button.text}
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  /* Hover effects */
  .hover\:scale-105:hover {
    transform: scale(1.05);
  }

  .hover\:-translate-y-1:hover {
    transform: translateY(-0.25rem);
  }

  /* RTL Support */
  [dir="rtl"] .from-blue-600 {
    --tw-gradient-from: theme('colors.purple.600');
    --tw-gradient-to: theme('colors.blue.600');
  }

  [dir="rtl"] .to-purple-600 {
    --tw-gradient-to: theme('colors.blue.600');
  }

  [dir="rtl"] .from-purple-500 {
    --tw-gradient-from: theme('colors.blue.500');
    --tw-gradient-to: theme('colors.purple.500');
  }

  [dir="rtl"] .to-blue-500 {
    --tw-gradient-to: theme('colors.purple.500');
  }
</style>