---
import { Button } from './ui/Button';
import { ArrowRight, Globe, Zap, Users, Brain } from 'lucide-react';

interface Logo {
  src: string;
  alt: string;
}

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  blogLink: string;
  blogLinkText: string;
  heroImage: string;
  partnerLogos: Logo[];
  getStartedText?: string;
  getStartedLink?: string;
  features: Feature[];
}

const { 
  badge, 
  title, 
  description, 
  blogLink, 
  blogLinkText, 
  heroImage, 
  partnerLogos,
  getStartedText = 'Get Started Free',
  getStartedLink = '/discuss-project',
  features
} = Astro.props;
const isRTL = Astro.url.pathname.includes('/ar/');

// Extract language from URL path
const lang = Astro.url.pathname.split('/')[1] || 'en';

// Map icon names to Lucide components
const iconMap = {
  'Globe': Globe,
  'Zap': Zap,
  'Users': Users,
  'Brain': Brain
};

// Process title to ensure proper HTML rendering
const processedTitle = title.replace(
  /<span class='text-gradient'>(.*?)<\/span>/g,
  (_, content) => `<span class="inline-block relative">
    <span class="absolute -inset-1 bg-gradient-to-r from-pink-600/20 via-purple-600/20 to-blue-600/20 blur rounded-lg"></span>
    <span class="relative bg-gradient-to-r from-pink-600 via-purple-600 to-blue-600 bg-clip-text text-transparent animate-gradient">${content}</span>
  </span>`
);

// Process description to ensure proper HTML rendering
const processedDescription = description.replace(
  /<p>(.*?)<\/p>/g,
  (_, content) => `<p class="mb-4">${content}</p>`
);
---

<section class="relative min-h-[90vh] flex items-center justify-center px-4 py-20 overflow-hidden bg-gradient-to-b from-[#f8f9ff] via-white to-[#f8f9ff]">
  <!-- Enhanced Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs with enhanced animations -->
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-full blur-3xl animate-float-delayed-slow"></div>
    <!-- Decorative Grid with fade animation -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-5 animate-fade-in"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="text-center mb-16">
      <!-- Enhanced Badge with slide-in animation -->
      <div class="animate-slide-down">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 border border-purple-100/20 backdrop-blur-sm mb-8 shadow-sm hover:shadow-md transition-all duration-300">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-600 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-pink-600 to-purple-600"></span>
          </span>
          <span class="text-sm font-medium bg-gradient-to-r from-pink-600 to-purple-600 bg-clip-text text-transparent">
            {badge}
          </span>
        </div>
      </div>

      <!-- Enhanced Title with animated border -->
      <div class="relative mb-8 animate-slide-up">
        <!-- Title Background Effect -->
        <div class="absolute -inset-4 bg-gradient-to-r from-pink-600/5 via-purple-600/5 to-blue-600/5 blur-xl rounded-xl"></div>
        
        <div class="relative inline-block">
          <h1 class="relative text-5xl lg:text-7xl font-bold leading-tight tracking-tight pb-4" set:html={processedTitle} />
          
          <!-- Animated Bottom Rule -->
          <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-1/3 h-1">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-pink-500 to-transparent animate-border-slide"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-500 to-transparent animate-border-slide-delayed"></div>
          </div>
        </div>
      </div>

      <!-- Enhanced Description with fade-in animation -->
      <div class="text-xl text-gray-600/90 max-w-3xl mx-auto mb-12 leading-relaxed animate-fade-in" set:html={processedDescription} />
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left Column: Features with staggered animation -->
      <div class="space-y-8 animate-slide-right">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {features.map((feature, index) => {
            const IconComponent = iconMap[feature.icon as keyof typeof iconMap];
            return (
              <div class={`group p-6 rounded-2xl bg-white/70 backdrop-blur-sm border border-purple-100/20 hover:bg-white/90 transition-all duration-500 hover:shadow-lg hover:shadow-purple-500/5 animate-fade-in`} style={`animation-delay: ${index * 150}ms`}>
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 p-3 rounded-xl bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 group-hover:from-purple-500/20 group-hover:via-pink-500/20 group-hover:to-blue-500/20 transition-all duration-500">
                    <IconComponent class="w-6 h-6 text-purple-600 group-hover:scale-110 transition-transform duration-500" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 group-hover:text-purple-600 transition-colors duration-300">{feature.title}</h3>
                    <p class="text-sm text-gray-600 mt-2">{feature.description}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- CTA Buttons with hover animations -->
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a 
            href={getStartedLink}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 via-pink-600 to-blue-600 text-white font-medium hover:opacity-95 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5 group animate-slide-up"
            style="animation-delay: 300ms"
          >
            <span>{getStartedText}</span>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
          </a>
          <a 
            href={blogLink}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white/80 text-gray-900 font-medium hover:bg-white backdrop-blur-sm border border-purple-100/20 hover:border-purple-300/30 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 group animate-slide-up"
            style="animation-delay: 450ms"
          >
            <span>{blogLinkText}</span>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
          </a>
        </div>

        <!-- Partner Logos with fade-in animation -->
        <div class="flex items-center gap-8 mt-12">
          {partnerLogos.map((logo, index) => (
            <div class="relative group animate-fade-in" style={`animation-delay: ${600 + index * 150}ms`}>
              <div class="absolute inset-0 bg-gradient-to-r from-purple-500/5 via-pink-500/5 to-blue-500/5 rounded-lg blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <img 
                src={logo.src} 
                alt={logo.alt} 
                class="h-8 opacity-70 group-hover:opacity-100 transition-all duration-300 group-hover:scale-110 relative"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column: Hero Image with enhanced animations -->
      <div class="relative group animate-slide-left">
        <!-- Enhanced Glow Effect -->
        <div class="absolute -inset-10 bg-gradient-to-r from-purple-500/5 via-pink-500/5 to-blue-500/5 rounded-full blur-3xl opacity-50 group-hover:opacity-75 transition-all duration-1000"></div>
        
        <!-- Floating Elements with enhanced animations -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-full blur-2xl animate-float"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gradient-to-br from-blue-500/10 to-purple-500/10 rounded-full blur-2xl animate-float-delayed"></div>
        
        <!-- Main Image Container with hover effect -->
        <div class="relative transform group-hover:scale-[1.02] transition-all duration-700 ease-out">
          <!-- Subtle Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-tr from-purple-500/5 via-transparent to-pink-500/5 mix-blend-overlay rounded-3xl"></div>
          
          <!-- Image with enhanced shadow -->
          <img 
            src={heroImage}
            alt="AI Automation Illustration"
            class="relative w-full drop-shadow-2xl animate-float-subtle"
            style="filter: drop-shadow(0 25px 25px rgb(139 92 246 / 0.15));"
          />
          
          <!-- Dynamic Particles Effect -->
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-1/4 right-1/4 w-2 h-2 bg-purple-500/30 rounded-full animate-ping"></div>
            <div class="absolute bottom-1/3 left-1/3 w-2 h-2 bg-pink-500/30 rounded-full animate-ping" style="animation-delay: 1s;"></div>
            <div class="absolute top-1/2 right-1/3 w-2 h-2 bg-blue-500/30 rounded-full animate-ping" style="animation-delay: 2s;"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  @keyframes float-subtle {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(0, -10px); }
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes border-slide {
    0%, 100% { transform: translateX(-100%); opacity: 0; }
    25%, 75% { opacity: 1; }
    50% { transform: translateX(100%); opacity: 0; }
  }

  @keyframes slide-up {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes slide-down {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes slide-left {
    from { transform: translateX(50px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slide-right {
    from { transform: translateX(-50px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-slow {
    animation: float 30s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  .animate-float-delayed-slow {
    animation: float 30s ease-in-out infinite;
    animation-delay: -15s;
  }

  .animate-float-subtle {
    animation: float-subtle 6s ease-in-out infinite;
  }

  .animate-gradient {
    background-size: 200% auto;
    animation: gradient 8s linear infinite;
  }

  .animate-border-slide {
    animation: border-slide 3s ease-in-out infinite;
  }

  .animate-border-slide-delayed {
    animation: border-slide 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  .animate-slide-up {
    animation: slide-up 1s ease-out forwards;
  }

  .animate-slide-down {
    animation: slide-down 1s ease-out forwards;
  }

  .animate-slide-left {
    animation: slide-left 1s ease-out forwards;
  }

  .animate-slide-right {
    animation: slide-right 1s ease-out forwards;
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }

  .font-arabic {
    font-family: 'Cairo', sans-serif;
  }

  /* Enhanced text shadow for better readability */
  h1 {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  /* Smooth hover transitions */
  .hover-glow {
    transition: all 0.3s ease-in-out;
  }
  
  .hover-glow:hover {
    text-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
  }
</style>