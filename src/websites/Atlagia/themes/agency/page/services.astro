---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const currentLang = getLangFromUrl(Astro.url);
const siteName = currentLang === 'ar' ? (import.meta.env.PUBLIC_SITE_NAME_ARABIC || 'جيا كونكت') : (import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect');

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import the language-specific services content
const servicesData = await import(`../data/services/services_${currentLang}.json`).catch(() => {
  return import('../data/services/services_en.json');
});

const { 
  Code,
  Brain,
  Database,
  Network,
  Shield,
  Globe,
  Clock,
  Zap,
  Award,
  Star,
  Settings,
  Cpu,
  FileText,
  BarChart,
  Target,
  Rocket,
  Lightbulb,
  Lock,
  Server,
  Cloud,
  Monitor,
  Smartphone,
  Tablet,
  Laptop,
  Desktop,
  Users,
  Building2,
  Briefcase,
  Wrench,
  Tool,
  Cog,
  LineChart,
  PieChart,
  BarChart2,
  LineChart2,
  PieChart2,
  BarChart3,
  LineChart3,
  PieChart3,
  BarChart4,
  LineChart4,
  PieChart4,
  BarChart5,
  LineChart5,
  PieChart5,
  BarChart6,
  LineChart6,
  PieChart6,
  BarChart7,
  LineChart7,
  PieChart7,
  BarChart8,
  LineChart8,
  PieChart8,
  BarChart9,
  LineChart9,
  PieChart9,
  BarChart10,
  LineChart10,
  PieChart10,
  CheckCircle,
  ArrowRight
} = LucideIcons;

const iconMap = {
  code: Code,
  brain: Brain,
  database: Database,
  network: Network,
  shield: Shield,
  globe: Globe,
  clock: Clock,
  zap: Zap,
  award: Award,
  star: Star,
  settings: Settings,
  cpu: Cpu,
  'file-text': FileText,
  'bar-chart': BarChart,
  target: Target,
  rocket: Rocket,
  lightbulb: Lightbulb,
  lock: Lock,
  server: Server,
  cloud: Cloud,
  monitor: Monitor,
  smartphone: Smartphone,
  tablet: Tablet,
  laptop: Laptop,
  desktop: Desktop,
  users: Users,
  building2: Building2,
  briefcase: Briefcase,
  wrench: Wrench,
  tool: Tool,
  cog: Cog,
  'line-chart': LineChart,
  'pie-chart': PieChart,
  'bar-chart2': BarChart2,
  'line-chart2': LineChart2,
  'pie-chart2': PieChart2,
  'bar-chart3': BarChart3,
  'line-chart3': LineChart3,
  'pie-chart3': PieChart3,
  'bar-chart4': BarChart4,
  'line-chart4': LineChart4,
  'pie-chart4': PieChart4,
  'bar-chart5': BarChart5,
  'line-chart5': LineChart5,
  'pie-chart5': PieChart5,
  'bar-chart6': BarChart6,
  'line-chart6': LineChart6,
  'pie-chart6': PieChart6,
  'bar-chart7': BarChart7,
  'line-chart7': LineChart7,
  'pie-chart7': PieChart7,
  'bar-chart8': BarChart8,
  'line-chart8': LineChart8,
  'pie-chart8': PieChart8,
  'bar-chart9': BarChart9,
  'line-chart9': LineChart9,
  'pie-chart9': PieChart9,
  'bar-chart10': BarChart10,
  'line-chart10': LineChart10,
  'pie-chart10': PieChart10
};

const getIcon = (iconName: string) => {
  return iconMap[iconName.toLowerCase()] || Globe;
};

const { pageTitle, pageDescription, hero, stats, services, features, benefits, testimonials, cta } = servicesData;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${pageTitle} | ${siteName}`}
      description={pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[80vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-purple-100 shadow-lg mb-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute h-full w-full rounded-full bg-purple-400 opacity-75"></span>
              <span class="rounded-full h-2 w-2 bg-purple-500"></span>
            </span>
            <span class="text-sm font-medium text-purple-700">{hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
            {hero.description}
          </p>

          <div class="flex items-center justify-center gap-4">
            <a 
              href={hero.cta.primary.href}
              class="px-8 py-4 rounded-xl bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium hover:from-purple-700 hover:to-blue-700 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5"
            >
              {hero.cta.primary.text}
            </a>
            <a 
              href={hero.cta.secondary.href}
              class="px-8 py-4 rounded-xl bg-white text-gray-700 font-medium hover:bg-gray-50 transition-all duration-300 hover:shadow-lg hover:shadow-gray-200/50 hover:-translate-y-0.5"
            >
              {hero.cta.secondary.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Banner -->
    <section class="relative py-12 bg-white border-y border-gray-100">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
                {stat.value}
              </div>
              <div class="text-gray-600 mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section id="services" class="py-32 relative">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        {services.map((category, index) => (
          <div class={`mb-20 ${index !== 0 ? 'mt-32' : ''}`}>
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-6">{category.category}</h2>
              <p class="text-xl text-gray-600">{category.description}</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
              {category.items.map((service) => {
                const Icon = getIcon(service.icon);
                return (
                  <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                    <!-- Card Glow Effect -->
                    <div class={`absolute -inset-0.5 bg-gradient-to-r from-${service.color}-500 to-${service.color}-600 rounded-3xl blur opacity-25 group-hover:opacity-100 transition duration-500`}></div>
                    
                    <!-- Card Content -->
                    <div class="relative h-full bg-white backdrop-blur-sm rounded-3xl p-8 border border-gray-200">
                      <div class="flex items-center gap-4 mb-6">
                        <div class={`w-12 h-12 bg-${service.color}-100 rounded-xl flex items-center justify-center`}>
                          <Icon class={`w-6 h-6 text-${service.color}-600`} />
                        </div>
                        <div>
                          <h3 class="text-xl font-semibold mb-1">{service.name}</h3>
                          <p class="text-gray-600">{service.description}</p>
                        </div>
                      </div>

                      <!-- Features List -->
                      <div class="mt-6 pt-6 border-t border-gray-100">
                        <div class="grid grid-cols-2 gap-4">
                          {service.features.map((feature) => (
                            <div class="flex items-center gap-2">
                              <CheckCircle class="w-4 h-4 text-green-500" />
                              <span class="text-sm text-gray-600">{feature}</span>
                            </div>
                          ))}
                        </div>
                      </div>

                      <!-- CTA -->
                      <div class="mt-6 pt-6 border-t border-gray-100">
                        <a 
                          href={`/services/${service.name.toLowerCase().replace(/\s+/g, '-')}`}
                          class="inline-flex items-center text-purple-600 hover:text-purple-700"
                        >
                          <span class="font-medium mr-2">Learn More</span>
                          <ArrowRight class="w-4 h-4" />
                        </a>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 bg-white relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-blue-50/50"></div>
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-50 border border-purple-100 mb-4">
            <span class="text-sm font-medium text-purple-700">Service Features</span>
          </div>
          <h2 class="text-4xl font-bold mb-6">{features.title}</h2>
          <p class="text-xl text-gray-600">{features.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {features.items.map((feature) => {
            const Icon = getIcon(feature.icon);
            return (
              <div class="bg-white rounded-2xl p-8 shadow-lg shadow-gray-100/50 hover:shadow-xl transition-shadow duration-300">
                <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                  <Icon class="w-6 h-6 text-purple-600" />
                </div>
                <h3 class="text-xl font-semibold mb-4">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-32 relative overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-purple-900 to-blue-900">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-20">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-4">
            <span class="text-sm font-medium text-white">Why Choose Us</span>
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-white">{benefits.title}</h2>
          <p class="text-xl text-gray-300">{benefits.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {benefits.items.map((benefit) => {
            const Icon = getIcon(benefit.icon);
            return (
              <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                <!-- Card Glow Effect -->
                <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-600 to-blue-600 rounded-3xl blur opacity-30 group-hover:opacity-100 transition duration-500"></div>
                
                <!-- Card Content -->
                <div class="relative h-full bg-white/10 backdrop-blur-sm border border-white/20 rounded-3xl p-8">
                  <!-- Icon -->
                  <div class="relative w-16 h-16 mb-6 mx-auto">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-600/20 to-blue-600/20 rounded-2xl blur-sm"></div>
                    <div class="relative h-full flex items-center justify-center">
                      <Icon class="w-8 h-8 text-white" />
                    </div>
                  </div>

                  <!-- Content -->
                  <div class="text-center">
                    <h3 class="text-2xl font-semibold text-white mb-4">{benefit.title}</h3>
                    <p class="text-gray-300 mb-6">{benefit.description}</p>
                    <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-blue-400">
                      {benefit.stats}
                    </div>
                    <div class="text-sm text-gray-400 mt-2">{benefit.label}</div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-24 bg-white relative overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50 via-white to-blue-50 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-50 border border-purple-100 mb-4">
            <Star class="w-4 h-4 text-purple-600" />
            <span class="text-sm font-medium text-purple-700">Client Testimonials</span>
          </div>
          <h2 class="text-4xl font-bold mb-6">{testimonials.title}</h2>
          <p class="text-xl text-gray-600">{testimonials.description}</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {testimonials.items.map((testimonial) => (
            <div class="bg-white rounded-2xl p-8 shadow-lg shadow-purple-100/20">
              <div class="flex gap-4 items-center mb-6">
                <img 
                  src={testimonial.image} 
                  alt={testimonial.author}
                  class="w-16 h-16 rounded-full object-cover"
                />
                <div>
                  <div class="font-semibold text-gray-900">{testimonial.author}</div>
                  <div class="text-gray-600">{testimonial.role}</div>
                </div>
              </div>
              <p class="text-gray-700 text-lg italic">"{testimonial.quote}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cta.title}</h2>
          <p class="text-xl text-white/90 mb-8">
            {cta.description}
          </p>
          <div class="flex items-center justify-center gap-4">
            {cta.buttons.map((button) => (
              <a 
                href={button.href}
                class={`px-8 py-4 rounded-xl font-medium transition-all duration-300 ${
                  button.variant === 'primary'
                    ? 'bg-white text-purple-600 hover:bg-gray-100 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5'
                    : 'bg-white/10 text-white hover:bg-white/20'
                }`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      // Add smooth scrolling for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href')).scrollIntoView({
            behavior: 'smooth'
          });
        });
      });

      // Add intersection observer for fade-in animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('fade-in');
          }
        });
      }, {
        threshold: 0.1
      });

      // Observe all service cards
      document.querySelectorAll('.service-card').forEach(card => {
        observer.observe(card);
      });
    </script>
  </body>
</html>

<style>
  /* Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.4; }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s ease-in-out infinite;
  }

  .fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }

  /* Smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }

  /* Hover effects */
  .hover\:scale-105:hover {
    transform: scale(1.05);
  }

  .hover\:-translate-y-1:hover {
    transform: translateY(-0.25rem);
  }

  /* Additional animations */
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .slide-in {
    animation: slideIn 0.5s ease-out forwards;
  }

  /* Ensure proper section spacing */
  section {
    position: relative;
    overflow: hidden;
  }

  /* Improve card aesthetics */
  .rounded-2xl {
    border-radius: 1rem;
  }

  .shadow-lg {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
</style> 