---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const { 
  Shield, 
  Lock,
  FileText,
  UserCheck,
  Eye,
  Key,
  Database,
  RefreshCw,
  AlertCircle,
  Settings,
  Server,
  Clock,
  Users,
  CheckCircle,
  Cookie,
  ClipboardCheck
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language
const currentLang = getLangFromUrl(Astro.url);

const privacyContent = {
  pageTitle: "Privacy Policy",
  pageDescription: "Learn about how we protect your data and respect your privacy at GiaConnect",
  hero: {
    badge: "Privacy & Security Policy",
    title: "Your Privacy & Data Security",
    description: "We are committed to protecting your privacy and ensuring the security of your personal information. Learn about our comprehensive privacy practices and data protection measures."
  },
  sections: [
    {
      title: "Data Collection",
      icon: "Database",
      description: "Information about the types of data we collect",
      items: [
        {
          title: "Personal Information",
          description: "We collect basic information necessary for service provision, such as name, email, and contact details.",
          icon: "UserCheck"
        },
        {
          title: "Usage Data",
          description: "We gather anonymous usage statistics to improve our services and user experience.",
          icon: "Eye"
        },
        {
          title: "Technical Data",
          description: "System logs and technical details for security and service optimization.",
          icon: "Server"
        }
      ]
    },
    {
      title: "Data Protection",
      icon: "Shield",
      description: "How we protect your information",
      items: [
        {
          title: "Encryption",
          description: "All data is encrypted in transit and at rest using industry-standard protocols.",
          icon: "Lock"
        },
        {
          title: "Access Control",
          description: "Strict access controls and authentication measures protect your information.",
          icon: "Key"
        },
        {
          title: "Regular Updates",
          description: "Continuous security updates and vulnerability assessments.",
          icon: "RefreshCw"
        }
      ]
    },
    {
      title: "Data Processing",
      icon: "Settings",
      description: "How we handle and process your data",
      items: [
        {
          title: "Data Storage",
          description: "Your data is stored securely in certified data centers with redundancy.",
          icon: "Database"
        },
        {
          title: "Data Retention",
          description: "We only keep your data for as long as necessary and legally required.",
          icon: "Clock"
        },
        {
          title: "Third-Party Processing",
          description: "Strict controls on how third-party services can access and process your data.",
          icon: "Users"
        }
      ]
    },
    {
      title: "Your Rights",
      icon: "FileText",
      description: "Understanding your data rights",
      items: [
        {
          title: "Data Access",
          description: "You can request access to your personal data at any time.",
          icon: "Eye"
        },
        {
          title: "Data Control",
          description: "Options to update or delete your personal information.",
          icon: "Settings"
        },
        {
          title: "Transparency",
          description: "Clear information about how your data is used and processed.",
          icon: "AlertCircle"
        }
      ]
    },
    {
      title: "Compliance",
      icon: "CheckCircle",
      description: "Our commitment to legal compliance",
      items: [
        {
          title: "GDPR Compliance",
          description: "We follow strict European data protection regulations.",
          icon: "Shield"
        },
        {
          title: "Cookie Policy",
          description: "Transparent use of cookies and tracking technologies.",
          icon: "Cookie"
        },
        {
          title: "Regular Audits",
          description: "Independent security and compliance audits.",
          icon: "ClipboardCheck"
        }
      ]
    }
  ],
  contact: {
    title: "Privacy Inquiries",
    description: "Have questions about our privacy practices?",
    email: "privacy@giaconnect.com",
    button: {
      text: "Contact Privacy Team",
      href: "/contact"
    }
  }
};

const iconMap = {
  Database,
  UserCheck,
  Eye,
  Server,
  Shield,
  Lock,
  Key,
  RefreshCw,
  FileText,
  Settings,
  AlertCircle,
  Clock,
  Users,
  CheckCircle,
  Cookie,
  ClipboardCheck
};

const getIcon = (iconName: string) => {
  return iconMap[iconName] || Shield;
};
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${privacyContent.pageTitle} | ${siteName}`}
      description={privacyContent.pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-white/90 border border-purple-100 shadow-lg mb-8">
            <Shield class="w-5 h-5 text-purple-600" />
            <span class="text-base font-medium text-purple-700">{privacyContent.hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {privacyContent.hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
            {privacyContent.hero.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Privacy Sections -->
    {privacyContent.sections.map((section) => (
      <section class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-white">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-blue-50/50"></div>
        </div>
        
        <div class="container mx-auto px-4 relative">
          <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-purple-50 border border-purple-100 mb-4">
              {(() => {
                const Icon = getIcon(section.icon);
                return <Icon class="w-5 h-5 text-purple-600" />;
              })()}
              <span class="text-base font-medium text-purple-700">{section.title}</span>
            </div>
            <h2 class="text-4xl font-bold mb-6">{section.title}</h2>
            <p class="text-xl text-gray-600">{section.description}</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            {section.items.map((item) => {
              const Icon = getIcon(item.icon);
              return (
                <div class="bg-white rounded-2xl p-8 shadow-lg shadow-purple-100/20 hover:shadow-xl transition-shadow duration-300">
                  <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                    <Icon class="w-6 h-6 text-purple-600" />
                  </div>
                  <h3 class="text-xl font-semibold mb-4">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    ))}

    <!-- Contact Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{privacyContent.contact.title}</h2>
          <p class="text-xl text-white/90 mb-4">
            {privacyContent.contact.description}
          </p>
          <p class="text-xl text-white/90 mb-8">
            Email us at: <a href={`mailto:${privacyContent.contact.email}`} class="underline hover:text-white">{privacyContent.contact.email}</a>
          </p>
          <div class="flex items-center justify-center">
            <a 
              href={privacyContent.contact.button.href}
              class="px-8 py-4 rounded-xl font-medium bg-white text-purple-600 hover:bg-gray-100 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5"
            >
              {privacyContent.contact.button.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <style>
      /* Animations */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-in {
        animation: fadeIn 0.6s ease-out forwards;
      }

      /* Smooth transitions */
      .transition-all {
        transition-property: all;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 150ms;
      }

      /* Ensure proper section spacing */
      section {
        position: relative;
        overflow: hidden;
      }

      /* Improve card aesthetics */
      .rounded-2xl {
        border-radius: 1rem;
      }

      .shadow-lg {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      }
    </style>
  </body>
</html> 