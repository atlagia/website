---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get the language parameter from the URL
const { lang } = Astro.params;

// Validate language and redirect to /en if invalid
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Racing Culture - ${jsonData.siteTitle}`;
const SITE_DESCRIPTION = 'Explore the rich heritage of racing culture, from Formula 1 legends to street racing icons. Discover authentic racing merchandise and celebrate the true spirit of motorsport.';
---

<!doctype html>
<html lang={lang} class="drivon">
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION}
    />
  </head>
  <body class="bg-[var(--drivon-bg)] text-[var(--drivon-text)] antialiased">
    <Header />
    <main class="min-h-screen bg-[var(--drivon-bg)]">
      <!-- Hero Section -->
      <section class="relative py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
        <div class="relative max-w-6xl mx-auto px-4 text-center">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight mb-6">
            Racing Culture
          </h1>
          <p class="font-body text-xl md:text-2xl text-[var(--drivon-bg)]/90 mb-8 max-w-3xl mx-auto">
            From Formula 1 legends to street racing icons, discover the rich heritage of racing culture that defines the true spirit of motorsport worldwide.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-8">
            <a href={`/${lang}/racing-legends`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">Racing Legends</a>
            <a href={`/${lang}/racing-hoodies`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">Racing Merchandise</a>
          </div>
        </div>
      </section>

      <!-- Racing Heritage Sections -->
      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Racing Heritage & Culture</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Formula 1 -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Formula 1</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                The pinnacle of motorsport, Formula 1 represents the ultimate in racing 
                technology, skill, and passion. Celebrate the legends and moments that define F1.
              </p>
              <a href={`/${lang}/formula1-collection`} class="text-red-600 font-semibold hover:text-red-700">
                Explore F1 Collection →
              </a>
            </div>

            <!-- Le Mans & Endurance -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                  <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1V8a1 1 0 00-1-1h-3z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Le Mans & Endurance</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                The ultimate test of man and machine. Le Mans 24 Hours and endurance racing 
                represent the pinnacle of automotive engineering and driver determination.
              </p>
              <a href={`/${lang}/endurance-racing`} class="text-red-600 font-semibold hover:text-red-700">
                Discover Endurance Racing →
              </a>
            </div>

            <!-- Street Racing -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Street Racing</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                The underground culture that started it all. From illegal street races 
                to organized events, street racing culture defines automotive passion.
              </p>
              <a href={`/${lang}/street-racing`} class="text-red-600 font-semibold hover:text-red-700">
                Explore Street Culture →
              </a>
            </div>

            <!-- Rally Racing -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                  <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1V8a1 1 0 00-1-1h-3z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Rally Racing</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                The ultimate test of driver skill and car performance across all terrains. 
                Rally racing represents the purest form of motorsport competition.
              </p>
              <a href={`/${lang}/rally-racing`} class="text-red-600 font-semibold hover:text-red-700">
                Discover Rally Culture →
              </a>
            </div>

            <!-- Drag Racing -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Drag Racing</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                Pure speed and power. Drag racing culture celebrates the ultimate 
                expression of automotive performance in its most raw form.
              </p>
              <a href={`/${lang}/drag-racing`} class="text-red-600 font-semibold hover:text-red-700">
                Explore Drag Culture →
              </a>
            </div>

            <!-- Drift Racing -->
            <div class="bg-[var(--drivon-bg)] rounded-lg p-8 hover:shadow-lg transition-shadow">
              <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                  <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1V8a1 1 0 00-1-1h-3z"/>
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-4">Drift Racing</h3>
              <p class="text-[var(--drivon-muted)] mb-6">
                The art of controlled chaos. Drift racing culture celebrates the skill 
                and style of maintaining control while pushing the limits of grip.
              </p>
              <a href={`/${lang}/drift-racing`} class="text-red-600 font-semibold hover:text-red-700">
                Discover Drift Culture →
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Racing Legends -->
      <section class="py-16 bg-[var(--drivon-surface)]">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Racing Legends & Icons</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] p-6 shadow-md hover:shadow-lg transition-shadow">
              <div class="h-32 bg-gradient-to-br from-red-500 to-red-700 rounded-lg mb-4 flex items-center justify-center">
                <span class="text-white text-xl font-bold">F1 Legends</span>
              </div>
              <h3 class="font-bold text-lg mb-2">Formula 1 Legends</h3>
              <p class="text-[var(--drivon-muted)] text-sm mb-4">Celebrate the greatest F1 drivers in history</p>
              <a href={`/${lang}/f1-legends`} class="text-red-600 font-semibold text-sm hover:text-red-700">
                Explore F1 Legends →
              </a>
            </div>

            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] p-6 shadow-md hover:shadow-lg transition-shadow">
              <div class="h-32 bg-gradient-to-br from-blue-500 to-blue-700 rounded-lg mb-4 flex items-center justify-center">
                <span class="text-white text-xl font-bold">Le Mans Heroes</span>
              </div>
              <h3 class="font-bold text-lg mb-2">Le Mans Heroes</h3>
              <p class="text-[var(--drivon-muted)] text-sm mb-4">Endurance racing legends and champions</p>
              <a href={`/${lang}/le-mans-heroes`} class="text-red-600 font-semibold text-sm hover:text-red-700">
                Discover Heroes →
              </a>
            </div>

            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] p-6 shadow-md hover:shadow-lg transition-shadow">
              <div class="h-32 bg-gradient-to-br from-green-500 to-green-700 rounded-lg mb-4 flex items-center justify-center">
                <span class="text-white text-xl font-bold">Rally Champions</span>
              </div>
              <h3 class="font-bold text-lg mb-2">Rally Champions</h3>
              <p class="text-[var(--drivon-muted)] text-sm mb-4">Rally racing legends and their iconic cars</p>
              <a href={`/${lang}/rally-champions`} class="text-red-600 font-semibold text-sm hover:text-red-700">
                Meet Champions →
              </a>
            </div>

            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] p-6 shadow-md hover:shadow-lg transition-shadow">
              <div class="h-32 bg-gradient-to-br from-purple-500 to-purple-700 rounded-lg mb-4 flex items-center justify-center">
                <span class="text-white text-xl font-bold">Street Icons</span>
              </div>
              <h3 class="font-bold text-lg mb-2">Street Racing Icons</h3>
              <p class="text-[var(--drivon-muted)] text-sm mb-4">Underground racing legends and culture</p>
              <a href={`/${lang}/street-icons`} class="text-red-600 font-semibold text-sm hover:text-red-700">
                Explore Icons →
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Racing Merchandise -->
      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Racing Culture Merchandise</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <a href={`/${lang}/racing-hoodies`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                  <span class="text-white text-2xl font-bold">Racing Hoodies</span>
                </div>
                <div class="p-6">
                  <h3 class="font-bold text-lg mb-2">Racing Hoodies</h3>
                  <p class="text-[var(--drivon-muted)] text-sm">Authentic racing-inspired hoodies</p>
                </div>
              </div>
            </a>

            <a href={`/${lang}/racing-tees`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                  <span class="text-white text-2xl font-bold">Racing Tees</span>
                </div>
                <div class="p-6">
                  <h3 class="font-bold text-lg mb-2">Racing Tees</h3>
                  <p class="text-[var(--drivon-muted)] text-sm">Classic racing culture shirts</p>
                </div>
              </div>
            </a>

            <a href={`/${lang}/racing-accessories`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                  <span class="text-white text-2xl font-bold">Racing Accessories</span>
                </div>
                <div class="p-6">
                  <h3 class="font-bold text-lg mb-2">Racing Accessories</h3>
                  <p class="text-[var(--drivon-muted)] text-sm">Essential racing gear and accessories</p>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="py-16 bg-red-600 text-white">
        <div class="max-w-4xl mx-auto px-4 text-center">
          <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Join the Racing Culture</h2>
          <p class="text-xl mb-8">
            Celebrate the rich heritage of racing culture with authentic merchandise 
            that honors the legends, moments, and passion that define motorsport.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={`/${lang}/racing-legends`} class="bg-white text-red-600 px-8 py-3 rounded-lg font-semibold hover:bg-[var(--drivon-surface)] transition-colors">
              Explore Racing Legends
            </a>
            <a href={`/${lang}/racing-hoodies`} class="bg-red-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-800 transition-colors">
              Shop Racing Merchandise
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
    <style>
      .font-headline { font-family: var(--font-headline); }
      .font-body { font-family: var(--font-body); }
    </style>
  </body>
</html>
