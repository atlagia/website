---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Clock, Trophy, Star, Award, Crown } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'JacketVerse';

// SEO
const seoTitle = `Le Mans Heroes | ${storeName}`;
const seoDescription = "Celebrate the heroes of Le Mans endurance racing. From 24-hour champions to endurance legends, honor the greatest drivers in motorsport history.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--drivon-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight text-[var(--drivon-bg)] mb-6">
            Le Mans Heroes
          </h1>
          <p class="text-xl md:text-2xl text-[var(--drivon-bg)]/90 mb-8">
            The ultimate test of endurance and determination
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/le-mans-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
              Le Mans Collection
            </a>
            <a href={`/${lang}/endurance-racing`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">
              Endurance Racing
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Le Mans Heroes Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Champions of Endurance</h2>
          <p class="text-xl text-[var(--drivon-muted)] max-w-3xl mx-auto">
            From the legendary 24 Hours of Le Mans to grueling endurance challenges, celebrate the heroes who have conquered the ultimate test of speed and stamina.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Clock class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">24-Hour Champions</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate the legendary drivers who have conquered the grueling 24 Hours of Le Mans and earned their place in endurance racing history.
            </p>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Endurance Legends</h3>
            <p class="text-[var(--drivon-muted)]">
              Honor the legendary drivers who have shaped endurance racing and inspired generations of racing fans worldwide.
            </p>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Star class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Modern Heroes</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate today's endurance racing heroes who continue to push the boundaries of speed and endurance.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Le Mans Heroes Categories -->
    <section class="py-20 bg-[var(--drivon-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Le Mans Heroes Collection</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Celebrate the greatest endurance racing champions</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/le-mans-hoodies`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Clock class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Le Mans Hoodies</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Premium hoodies celebrating Le Mans champions</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Le Mans Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Le Mans Heroes Tees</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Classic tees honoring endurance racing legends</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Le Mans Heroes Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Award class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Le Mans Accessories</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Essential accessories for endurance racing fans</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Le Mans Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Le Mans Heroes Spotlight -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Legendary Le Mans Champions</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Honor the greatest endurance racing heroes</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Clock class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">24-Hour Champions</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Celebrate the drivers who have conquered the grueling 24 Hours of Le Mans and earned their place in endurance racing history.
            </p>
            <a href={`/${lang}/le-mans-hoodies`} class="flex items-center justify-center text-blue-600 font-semibold hover:text-blue-700">
              Shop Champions Collection <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Trophy class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">Endurance Icons</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Honor the legendary drivers who have shaped endurance racing and inspired generations of racing fans.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-green-600 font-semibold hover:text-green-700">
              Shop Icons Collection <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Star class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">Modern Heroes</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Celebrate today's endurance racing heroes who continue to push the boundaries of speed and endurance.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-purple-600 font-semibold hover:text-purple-700">
              Shop Modern Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Le Mans Heritage -->
    <section class="py-20 bg-[var(--drivon-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Le Mans Heritage & Legacy</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Experience the rich history of endurance racing</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Clock class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">24-Hour Records</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate the drivers who have set incredible 24-hour endurance records and achieved legendary status.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Trophy class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Endurance Championships</h3>
            <p class="text-[var(--drivon-muted)]">
              Honor the drivers who have won multiple endurance championships and earned their place in racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Award class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Iconic Moments</h3>
            <p class="text-[var(--drivon-muted)]">
              Remember the legendary moments and achievements that have defined Le Mans and endurance racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Crown class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Racing Legacy</h3>
            <p class="text-[var(--drivon-muted)]">
              Experience the lasting impact and legacy of the greatest endurance racing drivers in motorsport history.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Honor Le Mans Heroes</h2>
        <p class="text-xl text-[var(--drivon-bg)]/90 mb-8">
          Join the global endurance racing community and celebrate the greatest drivers in Le Mans history with our authentic heroes collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/le-mans-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
            Shop Le Mans Heroes Collection
          </a>
          <a href={`/${lang}/endurance-racing`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">
            Explore Endurance Racing
          </a>
        </div>
      </div>
    </section>
  </div>
<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
</Layoutc>
