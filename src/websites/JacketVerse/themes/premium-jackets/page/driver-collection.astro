---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get the language parameter from the URL
const { lang } = Astro.params;

// Validate language and redirect to /en if invalid
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Driver Collection - ${jsonData.siteTitle}`;
const SITE_DESCRIPTION = 'Premium driver merchandise collection featuring racing hoodies, car culture tees, driver accessories, and authentic automotive gear for true car enthusiasts.';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main class="min-h-screen bg-[var(--drivon-bg)]">
      <!-- Hero Section -->
      <section class="relative py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
<div class="relative max-w-6xl mx-auto px-4 text-center">
          <h1 class="text-5xl md:text-7xl font-black mb-6 uppercase tracking-tighter">
            Driver Collection
          </h1>
          <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto font-medium">
            Authentic driver merchandise for automotive culture enthusiasts. 
            From racing legends to street culture icons, celebrate the true spirit of driving passion.
          </p>
          <div class="flex flex-wrap justify-center gap-4 mt-8">
            <a href={`/${lang}/racing-hoodies`} class="bg-red-600 hover:bg-red-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
              Racing Hoodies
            </a>
            <a href={`/${lang}/car-culture-tees`} class="bg-white/20 hover:bg-white/30 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
              Car Culture Tees
            </a>
          </div>
        </div>
      </section>

      <!-- Collection Categories -->
      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Driver Collection Categories</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Racing Hoodies -->
            <a href={`/${lang}/racing-hoodies`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-red-500 to-red-700 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">Racing Hoodies</h3>
                    <p class="text-red-100">Authentic racing-inspired designs</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Premium hoodies featuring legendary racing brands, iconic car models, 
                    and authentic automotive culture designs.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop Racing Hoodies
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>

            <!-- Car Culture Tees -->
            <a href={`/${lang}/car-culture-tees`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-gray-600 to-gray-800 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">Car Culture Tees</h3>
                    <p class="text-[var(--drivon-bg)]/90">Classic automotive culture shirts</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Classic tees celebrating iconic car brands, racing legends, 
                    and the authentic automotive culture that defines car enthusiasts.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop Car Culture Tees
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>

            <!-- Driver Accessories -->
            <a href={`/${lang}/driver-accessories`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-yellow-500 to-orange-600 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">Driver Accessories</h3>
                    <p class="text-orange-100">Essential driver accessories</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Complete your automotive look with essential driver accessories 
                    including caps, bags, and gear that celebrates car culture.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop Driver Accessories
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>

            <!-- Racing Legends -->
            <a href={`/${lang}/racing-legends`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-purple-600 to-purple-800 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">Racing Legends</h3>
                    <p class="text-purple-100">Legendary racing icons</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Celebrate the greatest drivers and racing moments in history 
                    with merchandise honoring racing legends and iconic victories.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop Racing Legends
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>

            <!-- Driver Favorites -->
            <a href={`/${lang}/driver-favorites`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-green-600 to-green-800 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">Driver Favorites</h3>
                    <p class="text-green-100">Most popular driver gear</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Our most popular driver merchandise loved by automotive 
                    enthusiasts worldwide. Best-selling items that define car culture.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop Driver Favorites
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>

            <!-- New Arrivals -->
            <a href={`/${lang}/new-arrivals`} class="group">
              <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
                <div class="h-64 bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute inset-0 bg-black/20"></div>
                  <div class="relative z-10 text-center">
                    <h3 class="text-3xl font-bold text-white mb-2">New Arrivals</h3>
                    <p class="text-[var(--drivon-bg)]/90">Latest driver merchandise</p>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-[var(--drivon-muted)] mb-4">
                    Discover the latest additions to our driver collection. 
                    Fresh designs and new releases celebrating automotive culture.
                  </p>
                  <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                    Shop New Arrivals
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="py-16 bg-[var(--drivon-surface)]">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Why Choose Our Driver Collection?</h2>
          
          <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-4">Authentic Designs</h3>
              <p class="text-[var(--drivon-muted)]">
                Every piece celebrates authentic automotive culture with designs 
                that respect the heritage and community of car enthusiasts.
              </p>
            </div>

            <div class="text-center">
              <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-4">Premium Quality</h3>
              <p class="text-[var(--drivon-muted)]">
                High-quality materials and construction ensure your driver merchandise 
                lasts through every adventure and represents your passion authentically.
              </p>
            </div>

            <div class="text-center">
              <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-4">Global Community</h3>
              <p class="text-[var(--drivon-muted)]">
                Join automotive enthusiasts worldwide who share your passion 
                for authentic car culture and racing heritage.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="py-16 bg-red-600 text-white">
        <div class="max-w-4xl mx-auto px-4 text-center">
          <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Start Your Driver Collection</h2>
          <p class="text-xl mb-8">
            Join thousands of customers who trust JacketVerse for authentic 
            driver merchandise that celebrates the true spirit of car culture.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href={`/${lang}/racing-hoodies`} class="bg-white text-red-600 px-8 py-3 rounded-lg font-semibold hover:bg-[var(--drivon-surface)] transition-colors">
              Shop Racing Hoodies
            </a>
            <a href={`/${lang}/car-culture-tees`} class="bg-red-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-800 transition-colors">
              Shop Car Culture Tees
            </a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
