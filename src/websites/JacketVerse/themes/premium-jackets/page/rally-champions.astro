---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Flag, Trophy, Star, Award, Crown } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'JacketVerse';

// SEO
const seoTitle = `Rally Champions | ${storeName}`;
const seoDescription = "Celebrate the champions of rally racing. From WRC legends to rally heroes, honor the greatest drivers who conquered the world's toughest terrains.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--drivon-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight text-[var(--drivon-bg)] mb-6">
            Rally Champions
          </h1>
          <p class="text-xl md:text-2xl text-[var(--drivon-bg)]/90 mb-8">
            Conquerors of the world's toughest terrains
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/rally-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
              Rally Champions Collection
            </a>
            <a href={`/${lang}/rally-racing`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">
              Rally Racing
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Champions Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Champions of Rally Racing</h2>
          <p class="text-xl text-[var(--drivon-muted)] max-w-3xl mx-auto">
            From the legendary WRC to grueling endurance rallies, celebrate the champions who have conquered the world's toughest terrains and most challenging conditions.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Flag class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">WRC Champions</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate the legendary rally drivers who have conquered the World Rally Championship and earned their place in rally racing history.
            </p>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Legends</h3>
            <p class="text-[var(--drivon-muted)]">
              Honor the legendary drivers who have shaped rally racing and inspired generations of rally enthusiasts worldwide.
            </p>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]">
              <Star class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Modern Heroes</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate today's rally heroes who continue to push the boundaries of speed and skill in the world's toughest conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Champions Categories -->
    <section class="py-20 bg-[var(--drivon-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Champions Collection</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Celebrate the greatest rally racing champions</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/rally-hoodies`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Flag class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Champions Hoodies</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Premium hoodies celebrating rally champions</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Rally Champions Hoodies <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Champions Tees</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Classic tees honoring rally racing legends</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Rally Champions Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/racing-accessories`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
              <Award class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Champions Accessories</h3>
              <p class="text-[var(--drivon-muted)] mb-4">Essential accessories for rally champions fans</p>
              <div class="flex items-center text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Rally Champions Accessories <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Rally Champions Spotlight -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Legendary Rally Champions</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Honor the greatest rally racing champions</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Flag class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">WRC Champions</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Celebrate the drivers who have conquered the World Rally Championship and earned their place in rally racing history.
            </p>
            <a href={`/${lang}/rally-hoodies`} class="flex items-center justify-center text-yellow-600 font-semibold hover:text-yellow-700">
              Shop WRC Champions <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Trophy class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">Rally Icons</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Honor the legendary drivers who have shaped rally racing and inspired generations of rally enthusiasts.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-orange-600 font-semibold hover:text-orange-700">
              Shop Rally Icons <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>

          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Star class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4 text-center">Modern Heroes</h3>
            <p class="text-[var(--drivon-muted)] text-center mb-6">
              Celebrate today's rally heroes who continue to push the boundaries of speed and skill in the world's toughest conditions.
            </p>
            <a href={`/${lang}/collections`} class="flex items-center justify-center text-red-600 font-semibold hover:text-red-700">
              Shop Modern Heroes <ArrowRight class="w-4 h-4 ml-2" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Rally Heritage -->
    <section class="py-20 bg-[var(--drivon-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Heritage & Legacy</h2>
          <p class="text-xl text-[var(--drivon-muted)]">Experience the rich history of rally racing</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Flag class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">WRC Records</h3>
            <p class="text-[var(--drivon-muted)]">
              Celebrate the drivers who have set incredible WRC records and achieved legendary status in rally racing.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Trophy class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Championships</h3>
            <p class="text-[var(--drivon-muted)]">
              Honor the drivers who have won multiple rally championships and earned their place in racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Award class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Iconic Moments</h3>
            <p class="text-[var(--drivon-muted)]">
              Remember the legendary moments and achievements that have defined rally racing history.
            </p>
          </div>

          <div class="text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]">
              <Crown class="w-10 h-10" />
            </div>
            <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Legacy</h3>
            <p class="text-[var(--drivon-muted)]">
              Experience the lasting impact and legacy of the greatest rally racing drivers in motorsport history.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Honor Rally Champions</h2>
        <p class="text-xl text-[var(--drivon-bg)]/90 mb-8">
          Join the global rally racing community and celebrate the greatest drivers in rally history with our authentic champions collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/rally-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">
            Shop Rally Champions Collection
          </a>
          <a href={`/${lang}/rally-racing`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">
            Explore Rally Racing
          </a>
        </div>
      </div>
    </section>
  </div>
<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
</Layoutc>
