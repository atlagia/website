---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Flag, Car, Trophy, Star } from 'lucide-react';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'JacketVerse';

const seoTitle = `Rally Racing | ${storeName}`;
const seoDescription = "Celebrate the champions of rally racing. From WRC legends to iconic rally moments, honor the heroes who conquered the world's toughest terrains.";
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--drivon-bg)]">
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="relative z-10 text-center px-4 py-20">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight mb-6">Rally Racing</h1>
          <p class="font-body text-xl md:text-2xl text-[var(--drivon-bg)]/90 mb-8">Conquer the world's toughest terrains</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/rally-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">Rally Hoodies</a>
            <a href={`/${lang}/rally-champions`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">Rally Champions</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">The Ultimate Rally Challenge</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)] max-w-3xl mx-auto">Rally racing is the ultimate test of skill, courage, and determination. From the legendary WRC to grueling endurance rallies, celebrate the champions who conquered the world's toughest terrains.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Flag class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">WRC Champions</h3>
            <p class="font-body text-[var(--drivon-muted)]">Celebrate the legendary rally drivers who have conquered the World Rally Championship and earned their place in motorsport history.</p>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Car class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Iconic Rally Cars</h3>
            <p class="font-body text-[var(--drivon-muted)]">Honor the legendary rally cars that have shaped the sport and continue to inspire generations of rally enthusiasts worldwide.</p>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Trophy class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Heritage</h3>
            <p class="font-body text-[var(--drivon-muted)]">Experience the rich history of rally racing through authentic designs that capture the spirit of adventure and determination.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--drivon-surface)] border-y border-[var(--drivon-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Racing Collection</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)]">Celebrate the heroes of rally racing</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/rally-hoodies`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]"><Flag class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Hoodies</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Premium hoodies celebrating rally champions</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Shop Rally Hoodies <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
          <a href={`/${lang}/rally-champions`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)]/90 flex items-center justify-center text-[var(--drivon-bg)]"><Trophy class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Champions</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Celebrate the legendary rally champions</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore Rally Champions <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
          <a href={`/${lang}/racing-accessories`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)]/80 flex items-center justify-center text-[var(--drivon-bg)]"><Car class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Rally Accessories</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Essential accessories for rally racing fans</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Shop Rally Accessories <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Champions</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)]">Honor the greatest rally racing champions</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Flag class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">WRC Champions</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Celebrate the drivers who have conquered the World Rally Championship and earned their place in rally racing history.</p>
            <a href={`/${lang}/rally-champions`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore WRC Champions <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Trophy class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Rally Icons</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Honor the legendary rally drivers who have shaped the sport and inspired generations of rally enthusiasts.</p>
            <a href={`/${lang}/rally-champions`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore Rally Icons <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Star class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Modern Heroes</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Celebrate today's rally heroes who continue to push the boundaries of speed and skill in the world's toughest conditions.</p>
            <a href={`/${lang}/rally-champions`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore Modern Heroes <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Experience Rally Racing Heritage</h2>
        <p class="font-body text-xl text-[var(--drivon-bg)]/90 mb-8">Join the global rally racing community and celebrate the ultimate test of skill and determination with our authentic rally collection.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/rally-hoodies`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">Shop Rally Collection</a>
          <a href={`/${lang}/rally-champions`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">Explore Rally Champions</a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
