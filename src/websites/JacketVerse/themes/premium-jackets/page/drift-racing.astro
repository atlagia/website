---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Zap, Car, Trophy, Star } from 'lucide-react';

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'JacketVerse';

let data;
try {
  data = await import(`../data/drift-racing/drift-racing_${lang}.json`);
} catch (error) {
  data = await import(`../data/drift-racing/drift-racing_en.json`);
}

const pageData = data.default;
const seoTitle = `${pageData.title} | ${storeName}`;
const seoDescription = pageData.description;
---

<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--drivon-bg)]">
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="relative z-10 text-center px-4 py-20">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight mb-6">{pageData.hero.title}</h1>
          <p class="font-body text-xl md:text-2xl text-[var(--drivon-bg)]/90 mb-8">{pageData.hero.subtitle}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">Drift Collection</a>
            <a href={`/${lang}/street-culture`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">Street Culture</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">The Art of Drifting</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)] max-w-3xl mx-auto">Drift racing is the ultimate expression of skill, style, and control. From JDM legends to drift champions, celebrate the art of controlled chaos.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Zap class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Champions</h3>
            <p class="font-body text-[var(--drivon-muted)]">Celebrate the legendary drift drivers who have mastered the art of controlled chaos and earned their place in drift racing history.</p>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Car class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">JDM Legends</h3>
            <p class="font-body text-[var(--drivon-muted)]">Honor the legendary JDM cars and drivers who have shaped the drift scene and continue to inspire generations of drift enthusiasts.</p>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)]">
            <div class="w-16 h-16 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--drivon-text)]"><Trophy class="w-8 h-8" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Style</h3>
            <p class="font-body text-[var(--drivon-muted)]">Experience the rich culture of drift racing through authentic designs that capture the style and skill of the sport.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--drivon-surface)] border-y border-[var(--drivon-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Racing Collection</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)]">Celebrate the art of drifting</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/collections`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]"><Zap class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Drift Hoodies</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Premium hoodies celebrating drift culture</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Shop Drift Hoodies <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
          <a href={`/${lang}/collections`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)]/90 flex items-center justify-center text-[var(--drivon-bg)]"><Car class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">JDM Tees</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Classic tees celebrating JDM culture</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Shop JDM Tees <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
          <a href={`/${lang}/racing-accessories`} class="group bg-[var(--drivon-card)] rounded-2xl overflow-hidden border border-[var(--drivon-border)] hover:border-[var(--drivon-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--drivon-text)]/80 flex items-center justify-center text-[var(--drivon-bg)]"><Trophy class="w-16 h-16" /></div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--drivon-text)] uppercase tracking-wide mb-2">Drift Accessories</h3>
              <p class="font-body text-[var(--drivon-muted)] mb-4">Essential accessories for drift fans</p>
              <span class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] group-hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Shop Drift Accessories <ArrowRight class="w-4 h-4 ml-2" /></span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Racing Culture</h2>
          <p class="font-body text-xl text-[var(--drivon-muted)]">Experience the authentic drift lifestyle</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Zap class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Scene</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Experience the raw energy of drift racing with authentic designs that capture the skill and style of the sport.</p>
            <a href={`/${lang}/street-culture`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore Drift Scene <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Car class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">JDM Culture</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Celebrate the legendary JDM cars and culture that have shaped the drift scene and inspired generations.</p>
            <a href={`/${lang}/street-culture`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Explore JDM Culture <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
          <div class="bg-[var(--drivon-card)] rounded-2xl p-8 border border-[var(--drivon-border)] text-center">
            <div class="w-20 h-20 bg-[var(--drivon-surface)] rounded-full flex items-center justify-center mb-6 mx-auto text-[var(--drivon-text)]"><Star class="w-10 h-10" /></div>
            <h3 class="font-headline text-2xl text-[var(--drivon-text)] uppercase tracking-wide mb-4">Drift Community</h3>
            <p class="font-body text-[var(--drivon-muted)] mb-6">Connect with like-minded drift enthusiasts who share your passion for the art of controlled chaos.</p>
            <a href={`/${lang}/car-communities`} class="inline-flex items-center text-[11px] font-medium tracking-[0.2em] uppercase text-[var(--drivon-text)] hover:text-[var(--drivon-accent-hover)] transition-colors font-body">Join Drift Community <ArrowRight class="w-4 h-4 ml-2" /></a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Experience Drift Racing Culture</h2>
        <p class="font-body text-xl text-[var(--drivon-bg)]/90 mb-8">Join the global drift racing community and celebrate the art of controlled chaos with our authentic drift racing collection.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="inline-flex items-center justify-center bg-[var(--drivon-bg)] text-[var(--drivon-text)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:opacity-90 transition-opacity font-body">Shop Drift Racing Collection</a>
          <a href={`/${lang}/street-culture`} class="inline-flex items-center justify-center border-2 border-[var(--drivon-bg)] text-[var(--drivon-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--drivon-bg)]/10 transition-colors font-body">Explore Street Culture</a>
        </div>
      </div>
    </section>
  </div>
</Layoutc>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
