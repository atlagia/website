---
import Layoutc from '@layouts/Layoutc.astro';
import { ArrowRight, Star, Trophy, Crown, Award, Zap } from 'lucide-react';

// Generate static paths for allowed languages from environment
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}

const { lang = 'en' } = Astro.params;
const baseUrl = import.meta.env.DOMAINE || 'https://drivon.store';
const storeName = import.meta.env.PUBLIC_SITE_NAME || 'JacketVerse';

// SEO
const seoTitle = `JDM Culture Tees | ${storeName}`;
const seoDescription = "Premium tees celebrating JDM culture. From Supra to Skyline, wear the passion of Japanese automotive excellence.";
---
<Layoutc title={seoTitle} description={seoDescription} lang={lang}>
  <div class="min-h-screen bg-[var(--jv-bg)]">
    <!-- Hero Section -->
    <section class="relative min-h-[50vh] flex items-center justify-center bg-[var(--jv-text)] text-[var(--jv-bg)]">
      <div class="relative z-10 h-full flex items-center justify-center text-center px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="font-headline text-5xl md:text-7xl uppercase tracking-tight text-[var(--jv-bg)] mb-6">
            JDM Culture Tees
          </h1>
          <p class="text-xl md:text-2xl text-[var(--jv-bg)]/90 mb-8">
            Premium tees celebrating Japanese automotive culture
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`/${lang}/collections`} class="bg-pink-600 hover:bg-pink-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
              Shop JDM Culture
            </a>
            <a href={`/${lang}/supra-tees`} class="inline-flex items-center justify-center border-2 border-[var(--jv-bg)] text-[var(--jv-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--jv-bg)]/10 transition-colors font-body">
              Supra Collection
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- JDM Culture Features -->
    <section class="py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--jv-text)] uppercase tracking-wide mb-4">Premium JDM Culture Tees</h2>
          <p class="text-xl text-[var(--jv-muted)] max-w-3xl mx-auto">
            From Supra to Skyline, our JDM culture tees celebrate the legendary Japanese automotive brands and the culture that surrounds them.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8 mb-16">
          <div class="bg-[var(--jv-card)] rounded-2xl p-8 border border-[var(--jv-border)]">
            <div class="w-16 h-16 bg-[var(--jv-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--jv-text)]">
              <Crown class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--jv-text)] uppercase tracking-wide mb-4">JDM Legends</h3>
            <p class="text-[var(--jv-muted)]">
              Celebrate the most iconic JDM cars that have defined Japanese automotive culture and continue to inspire enthusiasts worldwide.
            </p>
          </div>

          <div class="bg-[var(--jv-card)] rounded-2xl p-8 border border-[var(--jv-border)]">
            <div class="w-16 h-16 bg-[var(--jv-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--jv-text)]">
              <Star class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--jv-text)] uppercase tracking-wide mb-4">Japanese Heritage</h3>
            <p class="text-[var(--jv-muted)]">
              Honor the legendary Japanese cars and the culture that has shaped automotive excellence and inspired generations of car enthusiasts.
            </p>
          </div>

          <div class="bg-[var(--jv-card)] rounded-2xl p-8 border border-[var(--jv-border)]">
            <div class="w-16 h-16 bg-[var(--jv-surface)] rounded-full flex items-center justify-center mb-6 text-[var(--jv-text)]">
              <Trophy class="w-8 h-8" />
            </div>
            <h3 class="font-headline text-2xl text-[var(--jv-text)] uppercase tracking-wide mb-4">Premium Quality</h3>
            <p class="text-[var(--jv-muted)]">
              Every tee is crafted with premium materials and attention to detail, ensuring comfort and durability for the JDM enthusiast.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- JDM Culture Categories -->
    <section class="py-20 bg-[var(--jv-surface)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-16">
          <h2 class="font-headline text-4xl text-[var(--jv-text)] uppercase tracking-wide mb-4">JDM Culture Collection</h2>
          <p class="text-xl text-[var(--jv-muted)]">Celebrate the legendary Japanese automotive culture</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href={`/${lang}/supra-tees`} class="group bg-[var(--jv-card)] rounded-2xl overflow-hidden border border-[var(--jv-border)] hover:border-[var(--jv-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--jv-text)] flex items-center justify-center text-[var(--jv-bg)]">
              <Crown class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--jv-text)] uppercase tracking-wide mb-2">Supra Tees</h3>
              <p class="text-[var(--jv-muted)] mb-4">Premium tees celebrating the legendary Toyota Supra</p>
              <div class="flex items-center text-[var(--jv-text)] group-hover:text-[var(--jv-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Supra Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-[var(--jv-card)] rounded-2xl overflow-hidden border border-[var(--jv-border)] hover:border-[var(--jv-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--jv-text)] flex items-center justify-center text-[var(--jv-bg)]">
              <Star class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--jv-text)] uppercase tracking-wide mb-2">Skyline Tees</h3>
              <p class="text-[var(--jv-muted)] mb-4">Classic tees honoring the legendary Nissan Skyline</p>
              <div class="flex items-center text-[var(--jv-text)] group-hover:text-[var(--jv-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop Skyline Tees <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>

          <a href={`/${lang}/collections`} class="group bg-[var(--jv-card)] rounded-2xl overflow-hidden border border-[var(--jv-border)] hover:border-[var(--jv-text)]/30 transition-colors">
            <div class="h-48 bg-[var(--jv-text)] flex items-center justify-center text-[var(--jv-bg)]">
              <Trophy class="w-16 h-16" />
            </div>
            <div class="p-6">
              <h3 class="font-headline text-xl text-[var(--jv-text)] uppercase tracking-wide mb-2">JDM Legends Tees</h3>
              <p class="text-[var(--jv-muted)] mb-4">Tees celebrating JDM racing legends</p>
              <div class="flex items-center text-[var(--jv-text)] group-hover:text-[var(--jv-accent-hover)] font-body text-[11px] font-medium tracking-[0.2em] uppercase">
                Shop JDM Legends <ArrowRight class="w-4 h-4 ml-2" />
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-20 bg-[var(--jv-text)] text-[var(--jv-bg)]">
      <div class="max-w-4xl mx-auto text-center px-4">
        <h2 class="font-headline text-4xl uppercase tracking-tight mb-6">Wear JDM Culture</h2>
        <p class="text-xl text-[var(--jv-bg)]/90 mb-8">
          Join the global JDM community and celebrate the legendary Japanese automotive culture with our premium JDM culture tees collection.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/${lang}/collections`} class="bg-pink-600 hover:bg-pink-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Shop JDM Culture Collection
          </a>
          <a href={`/${lang}/supra-tees`} class="inline-flex items-center justify-center border-2 border-[var(--jv-bg)] text-[var(--jv-bg)] px-8 py-3.5 text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--jv-bg)]/10 transition-colors font-body">
            Explore Supra Collection
          </a>
        </div>
      </div>
    </section>
  </div>
<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
</Layoutc>
