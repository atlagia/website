---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Cookie Policy - ${jsonData.siteTitle || 'JacketVerse'}`;
const SITE_DESCRIPTION = 'Cookie policy and tracking information for JacketVerse premium jackets website.';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} isHomePage={false} />
  </head>
  <body>
    <Header />
    <main class="min-h-screen bg-[var(--drivon-bg)]">
      <div class="max-w-4xl mx-auto px-4 py-16">
        <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] shadow-sm p-8">
          <h1 class="text-4xl font-bold text-[var(--drivon-text)] mb-8">Cookie Policy</h1>
          
          <div class="prose prose-lg max-w-none">
            <p class="text-[var(--drivon-muted)] mb-6">
              <strong>Last updated:</strong> {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">What Are Cookies?</h2>
              <p class="text-gray-700 mb-4">
                Cookies are small text files that are placed on your computer or mobile device when you visit our website. They help us provide you with a better 
                experience by remembering your preferences and enabling certain website functions.
              </p>
            </section>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">How We Use Cookies</h2>
              <p class="text-gray-700 mb-4">
                We use cookies to enhance your shopping experience on our driver merchandise website:
              </p>
              <ul class="list-disc pl-6 text-gray-700 mb-4">
                <li>Remember your shopping cart contents</li>
                <li>Keep you logged into your account</li>
                <li>Remember your language and region preferences</li>
                <li>Analyze website traffic and usage patterns</li>
                <li>Show you relevant automotive merchandise</li>
              </ul>
            </section>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">Types of Cookies We Use</h2>
              
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
                <h3 class="text-xl font-semibold text-blue-800 mb-3">Essential Cookies</h3>
                <p class="text-blue-700 mb-3">These cookies are necessary for the website to function properly.</p>
                <ul class="list-disc pl-6 text-blue-700">
                  <li>Session management</li>
                  <li>Shopping cart functionality</li>
                  <li>Security features</li>
                  <li>User authentication</li>
                </ul>
              </div>

              <div class="bg-green-50 border border-green-200 rounded-lg p-6 mb-6">
                <h3 class="text-xl font-semibold text-green-800 mb-3">Analytics Cookies</h3>
                <p class="text-green-700 mb-3">These cookies help us understand how visitors use our website.</p>
                <ul class="list-disc pl-6 text-green-700">
                  <li>Google Analytics</li>
                  <li>Page views and user behavior</li>
                  <li>Traffic sources and demographics</li>
                  <li>Website performance metrics</li>
                </ul>
              </div>

              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 mb-6">
                <h3 class="text-xl font-semibold text-yellow-800 mb-3">Marketing Cookies</h3>
                <p class="text-yellow-700 mb-3">These cookies are used to show you relevant automotive merchandise ads.</p>
                <ul class="list-disc pl-6 text-yellow-700">
                  <li>Social media advertising</li>
                  <li>Retargeting campaigns</li>
                  <li>Email marketing preferences</li>
                  <li>Product recommendations</li>
                </ul>
              </div>
            </section>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">Managing Your Cookie Preferences</h2>
              <p class="text-gray-700 mb-4">
                You can control and manage cookies in several ways:
              </p>
              <ul class="list-disc pl-6 text-gray-700 mb-4">
                <li>Use your browser settings to block or delete cookies</li>
                <li>Use our cookie preference center (if available)</li>
                <li>Opt out of marketing cookies through ad networks</li>
                <li>Use browser extensions to manage cookies</li>
              </ul>
            </section>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">Third-Party Cookies</h2>
              <p class="text-gray-700 mb-4">
                We may use third-party services that set their own cookies:
              </p>
              <ul class="list-disc pl-6 text-gray-700 mb-4">
                <li>Payment processors (Stripe, PayPal)</li>
                <li>Analytics services (Google Analytics)</li>
                <li>Social media platforms (Facebook, Instagram)</li>
                <li>Email marketing services</li>
              </ul>
            </section>

            <section class="mb-8">
              <h2 class="text-2xl font-semibold text-[var(--drivon-text)] mb-4">Contact Us</h2>
              <p class="text-gray-700 mb-4">
                If you have questions about our cookie policy, please contact us:
              </p>
              <div class="bg-[var(--drivon-bg)] p-6 rounded-lg">
                <p class="text-gray-700 mb-2"><strong>Email:</strong> privacy@drivon.store</p>
                <p class="text-gray-700">We will respond to your inquiry within 5 business days.</p>
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
