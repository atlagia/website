---
interface Props {
  title: string;
  description?: string;
  subtext?: string;
  backgroundImage?: string;
  formAction?: string;
  buttonText?: string;
}

const { title, description, subtext, formAction = '/api/signup', buttonText = 'Subscribe' } = Astro.props;
const desc = description ?? subtext ?? '';
---

<section class="jv-email-signup relative py-28 lg:py-36 bg-[var(--jv-bg)] border-t border-[var(--jv-border)]">
  <div class="max-w-[560px] mx-auto px-6 sm:px-8 text-center">
    <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-[var(--jv-text)] uppercase tracking-wide mb-4">
      {title}
    </h2>
    {desc && (
      <p class="text-[var(--jv-text)]/60 font-body text-sm mb-10 tracking-wide">
        {desc}
      </p>
    )}
    <form action={formAction} method="POST" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="flex-1 min-w-0 px-5 py-3.5 bg-transparent border-b border-[var(--jv-border)] text-[var(--jv-text)] placeholder:text-[var(--jv-muted)] focus:outline-none focus:border-[var(--jv-text)]/50 transition-colors text-sm font-body"
      />
      <button
        type="submit"
        class="px-6 py-3.5 border border-[var(--jv-text)]/40 text-[var(--jv-text)] text-[11px] font-medium tracking-[0.2em] uppercase hover:bg-[var(--jv-text)] hover:text-[var(--jv-bg)] transition-colors shrink-0"
      >
        {buttonText}
      </button>
    </form>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
