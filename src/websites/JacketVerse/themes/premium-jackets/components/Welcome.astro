---
import { ArrowRight } from 'lucide-react';

interface Props {
  title?: string;
  description?: string;
  blogLink?: string;
  blogLinkText?: string;
  headlineLine1?: string;
  headlineLine2?: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  seasonLabel?: string;
  heroImage?: string;
  /** Featured-snippet–ready: question as H2, 40–60 word definition. */
  snippetQuestion?: string;
  snippetDefinition?: string;
}

const props = Astro.props;
const headlineLine1 = props.headlineLine1 ?? props.title ?? '';
const headlineLine2 = props.headlineLine2 ?? props.description ?? '';
const primaryCtaText = props.primaryCtaText ?? props.blogLinkText ?? 'Shop';
const primaryCtaLink = props.primaryCtaLink ?? props.blogLink ?? '/collections';
const secondaryCtaText = props.secondaryCtaText ?? 'Explore';
const secondaryCtaLink = props.secondaryCtaLink ?? '/collections/styles';
const seasonLabel = props.seasonLabel;
const heroImage = props.heroImage;
const snippetQuestion = props.snippetQuestion;
const snippetDefinition = props.snippetDefinition;

const isShopify = heroImage?.includes('cdn.shopify.com');
const baseUrl = (heroImage?.replace(/[?&]width=\d+/, '') ?? '').replace(/\?$/, '');
const sep = baseUrl?.includes('?') ? '&' : '?';
const heroImageSrc = heroImage
  ? isShopify
    ? `${baseUrl}${sep}width=2880`
    : heroImage
  : '';
const heroImageSrcSet =
  isShopify && heroImage
    ? [
        `${baseUrl}${sep}width=960 960w`,
        `${baseUrl}${sep}width=1440 1440w`,
        `${baseUrl}${sep}width=1920 1920w`,
        `${baseUrl}${sep}width=2880 2880w`,
      ].join(', ')
    : undefined;

const lang = Astro.url.pathname.split('/')[1] || 'en';
const primaryHref = primaryCtaLink.startsWith('/') ? `/${lang}${primaryCtaLink}` : primaryCtaLink;
const secondaryHref = secondaryCtaLink.startsWith('/') ? `/${lang}${secondaryCtaLink}` : secondaryCtaLink;
---

<section
  class="jv-hero relative min-h-[100vh] min-h-[100dvh] flex items-end justify-start overflow-hidden bg-[var(--jv-bg)] grain-overlay"
  itemScope
  itemType="https://schema.org/WebPageElement"
>
  {heroImage && (
    <div class="hero-bg-image absolute inset-0 z-0" aria-hidden="true">
      <img
        src={heroImageSrc || heroImage}
        srcset={heroImageSrcSet}
        sizes="100vw"
        alt="JacketVerse hero: premium jackets for every style and season"
        class="hero-img w-full h-full object-cover"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
      <div class="hero-overlay absolute inset-0" aria-hidden="true" />
    </div>
  )}
  {heroImage && <div class="hero-gradient" aria-hidden="true"></div>}
  {heroImage && <div class="hero-text-backing" aria-hidden="true" />}

  <div class={`relative z-20 w-full max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12 pb-32 pt-36 sm:pt-40 lg:pb-44 lg:pt-48 jv-hero-content ${heroImage ? 'hero-has-bg' : ''}`}>
    {seasonLabel && (
      <p class="font-body text-[10px] tracking-[0.4em] uppercase text-[var(--jv-text)] mb-6 hero-label inline-block px-3 py-1.5 rounded-sm bg-[var(--jv-surface)]/95 backdrop-blur-sm border border-[var(--jv-border)]/60">
        {seasonLabel}
      </p>
    )}
    <h1
      class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[7rem] xl:text-[8rem] 2xl:text-[9rem] uppercase leading-[0.9] tracking-tight max-w-full md:max-w-[50vw] mb-8 hero-title"
      itemProp="headline"
      role="heading"
      aria-level="1"
    >
      {headlineLine1}
    </h1>
    {headlineLine2 && (
      <p class="text-base md:text-lg lg:text-xl text-[var(--jv-muted)] max-w-xl mb-12 font-body tracking-wide leading-relaxed hero-desc">
        {headlineLine2}
      </p>
    )}
    <div class="flex flex-wrap gap-4 sm:gap-5 hero-ctas">
      <a
        href={primaryHref}
        class="group inline-flex items-center gap-3 bg-[var(--jv-text)] text-[var(--jv-bg)] px-8 sm:px-10 py-3.5 sm:py-4 text-[11px] font-medium tracking-[0.3em] uppercase hover:bg-[var(--jv-accent)] hover:text-white transition-all duration-300 hover:shadow-xl"
      >
        <span>{primaryCtaText}</span>
        <ArrowRight className="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" />
      </a>
      <a
        href={secondaryHref}
        class="hero-cta-secondary group inline-flex items-center gap-3 border-2 border-[var(--jv-text)] text-[var(--jv-text)] bg-[var(--jv-surface)]/90 backdrop-blur-sm px-8 sm:px-10 py-3.5 sm:py-4 text-[11px] font-medium tracking-[0.3em] uppercase hover:bg-[var(--jv-text)] hover:text-[var(--jv-bg)] transition-all duration-300"
      >
        <span>{secondaryCtaText}</span>
        <ArrowRight className="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" />
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-3 scroll-indicator">
    <span class="text-[10px] tracking-[0.35em] uppercase text-[var(--jv-text)]/70 font-body">Scroll</span>
    <div class="w-px h-14 bg-[var(--jv-text)]/40 rounded-full"></div>
  </div>

  {snippetQuestion && snippetDefinition && (
    <div class="relative z-20 max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12 -mt-8 pb-8">
      <div class="bg-[var(--jv-surface)]/95 backdrop-blur-sm border border-[var(--jv-border)]/60 rounded-lg p-6 md:p-8">
        <h2 class="font-display text-xl md:text-2xl text-[var(--jv-text)] mb-3">{snippetQuestion}</h2>
        <p class="font-body text-[var(--jv-muted)] leading-relaxed max-w-3xl">{snippetDefinition}</p>
      </div>
    </div>
  )}
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }

  .hero-overlay {
    background: linear-gradient(
      to right,
      rgba(252, 252, 252, 0.92) 0%,
      rgba(250, 250, 250, 0.75) 35%,
      rgba(250, 250, 250, 0.35) 52%,
      transparent 65%
    );
    pointer-events: none;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.08) 40%,
      transparent 55%
    );
    pointer-events: none;
  }

  .hero-text-backing {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    top: 0;
    z-index: 3;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0.88) 0%,
      rgba(250, 250, 250, 0.6) 38%,
      rgba(250, 250, 250, 0.2) 50%,
      transparent 58%
    );
    pointer-events: none;
  }

  .hero-title {
    letter-spacing: -0.03em;
    color: var(--jv-text);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  .hero-has-bg .hero-title {
    color: #0a0a0a;
    text-shadow: 0 1px 0 rgb(255 255 255 / 0.9), 0 2px 8px rgb(0 0 0 / 0.06);
  }
  .hero-has-bg .hero-desc {
    color: var(--jv-muted);
    text-shadow: 0 1px 1px rgba(255, 255, 255, 0.8);
    font-weight: 450;
  }
  .hero-has-bg .hero-label {
    color: var(--jv-text);
    text-shadow: none;
  }

  .hero-has-bg .hero-cta-secondary {
    border-color: #0a0a0a;
    color: #0a0a0a;
    background: rgba(255, 255, 255, 0.95);
  }
  .hero-has-bg .hero-cta-secondary:hover {
    background: #0a0a0a;
    color: #fff;
    border-color: #0a0a0a;
  }

  .hero-bg-image .hero-img {
    transform: scale(1.02);
    backface-visibility: hidden;
  }
</style>
