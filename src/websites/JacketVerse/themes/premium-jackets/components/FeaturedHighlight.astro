---
interface Props {
  title: string;
  description?: string;
  ctaText: string;
  ctaLink: string;
  backgroundImage?: string;
  imageAlt?: string;
  lang?: string;
}

const { title, description = '', ctaText, ctaLink, backgroundImage, imageAlt = '', lang = 'en' } = Astro.props;
const base = lang ? `/${lang}` : '';
const resolvedLink = ctaLink.startsWith('/') ? base + ctaLink : ctaLink;
---

<section class="jv-featured-highlight relative min-h-[60vh] flex items-center justify-center overflow-hidden bg-[var(--jv-bg)]">
  {backgroundImage ? (
    <div class="absolute inset-0">
      <img
        src={backgroundImage}
        alt={imageAlt || title}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-[var(--jv-bg)]/70" />
    </div>
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--jv-surface)] to-[var(--jv-bg)]" />
  )}
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center py-24 lg:py-32">
    <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold text-[var(--jv-text)] tracking-tight mb-6">
      {title}
    </h2>
    {description && (
      <p class="font-body text-lg md:text-xl text-[var(--jv-muted)] mb-10 max-w-2xl mx-auto">{description}</p>
    )}
    <a
      href={resolvedLink}
      class="inline-flex items-center justify-center px-8 py-4 bg-[var(--jv-accent)] text-[var(--jv-bg)] font-body text-sm font-medium tracking-[0.2em] uppercase hover:opacity-95 transition-opacity"
    >
      {ctaText}
    </a>
  </div>
</section>

<style>
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
</style>
