---
import { getCollectionProducts, getAllProducts } from '@libs/shopify';

interface Props {
  title: string;
  description: string;
  viewAllLink: string;
  lang: string;
  collectionHandle?: string;
}

const { title, description, viewAllLink, lang, collectionHandle } = Astro.props;

let productsData;
try {
  if (collectionHandle && collectionHandle !== 'all') {
    productsData = await getCollectionProducts(collectionHandle);
  } else {
    productsData = await getAllProducts();
  }
} catch {
  productsData = await getAllProducts();
}

const products = productsData
  .slice(0, 6)
  .map(({ node }) => ({
    id: node.id,
    name: node.title,
    handle: node.handle,
    price: new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: node.priceRange.minVariantPrice.currencyCode
    }).format(node.priceRange.minVariantPrice.amount),
    image: node.images.edges[0]?.node.url || '/placeholder-image.jpg',
  }));
---

<section class="f1-collection bg-[var(--drivon-bg)] py-24 lg:py-36">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-8 lg:px-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14">
      <div>
        <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl text-[var(--drivon-text)] uppercase tracking-wide mb-3">{title}</h2>
        <p class="text-[var(--drivon-text)]/60 font-body text-sm max-w-md tracking-wide">{description}</p>
      </div>
      <a href={viewAllLink} class="text-[10px] font-medium tracking-[0.3em] uppercase text-[var(--drivon-muted)] hover:text-[var(--drivon-text)] transition-colors w-fit">
        View all
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {products.map((product) => (
        <a href={`/${lang}/products/${product.handle}`} class="group block">
          <div class="relative aspect-[3/4] overflow-hidden bg-[var(--drivon-card)] mb-4 transition-all duration-500 ease-out group-hover:shadow-2xl group-hover:-translate-y-1">
            <img
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
          </div>
          <p class="font-body text-[11px] tracking-[0.15em] uppercase text-[var(--drivon-text)]/90">{product.name}</p>
          <span class="text-[10px] text-[var(--drivon-muted)] mt-0.5 font-body tracking-wider">{product.price}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .font-headline { font-family: var(--font-headline); }
  .font-body { font-family: var(--font-body); }
</style>
