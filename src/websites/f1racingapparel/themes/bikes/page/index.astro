---
import { fetchBlogPosts } from '@utils/shopifyAPI';
import { useTranslations, isValidLanguage } from '@utils/i18n';

const theme = import.meta.env.THEME || 'default';

const lang = Astro.props?.lang ?? Astro.params?.lang ?? 'en';

if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

// Properly handle dynamic imports with default exports
const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);
const { default: Welcome } = await import(`../components/Welcome.astro`);
const { default: Banner } = await import(`../components/Banner.astro`);
const { default: FeaturedPosts } = await import(`../components/FeaturedPosts.astro`);
const { default: EmailSignup } = await import(`../components/EmailSignup.astro`);
const { default: CategoryGrid } = await import(`../components/CategoryGrid.astro`);
const { default: ProductShowcase } = await import(`../components/ProductShowcase.astro`);
const { default: TestimonialSlider } = await import(`../components/TestimonialSlider.astro`);
const { default: FAQ } = await import(`../components/FaqSection.astro`);
const { default: Video } = await import(`../components/Video.astro`);
const { default: FeaturesSection } = await import(`../components/FeaturesSection.astro`);
const { default: BestSellers } = await import(`../components/BestSellers.astro`);
const { default: SpecialOffers } = await import(`../components/SpecialOffers.astro`);
const { default: Marquee } = await import(`../components/Marquee.astro`);
const { default: StatsBar } = await import(`../components/StatsBar.astro`);
const { default: ManifestoSection } = await import(`../components/ManifestoSection.astro`);
const { default: RacingArchive } = await import(`../components/RacingArchive.astro`);
const { default: CategoryHighlightBlocks } = await import(`../components/CategoryHighlightBlocks.astro`);
const { default: LifestyleSection } = await import(`../components/LifestyleSection.astro`);
const { default: TrustBadges } = await import(`../components/TrustBadges.astro`);
const { default: SocialProof } = await import(`../components/SocialProof.astro`);
const { default: EditorialQuote } = await import(`../components/EditorialQuote.astro`);
const { default: PressStrip } = await import(`../components/PressStrip.astro`);
const { default: CarBrandsStrip } = await import(`../components/CarBrandsStrip.astro`);
const { default: SeasonDrop } = await import(`../components/SeasonDrop.astro`);
const { default: FollowStrip } = await import(`../components/FollowStrip.astro`);

const translations = await useTranslations(lang);
const jsonData = translations.default;

// Get site title and description from language-specific data
const SITE_TITLE = jsonData.siteTitle || 'Bikes';
const SITE_DESCRIPTION = jsonData.siteDescription || 'Your ultimate cosplay destination';

const blogId = '82152357935';
let posts = [];

try {
  posts = await fetchBlogPosts();
} catch (error) {
  console.error('Error fetching blog posts:', error);
}

// Generate static paths for all supported languages
export async function getStaticPaths() {
  const allowedLanguages = import.meta.env.ALLOWED_LANGUAGES || 'en';
  const languages = allowedLanguages.split(',').map(lang => lang.trim()).filter(lang => lang.length > 0);
  
  return languages.map(lang => ({ params: { lang } }));
}
---

<!doctype html>
<html lang={lang} class="drivon">
  <head>
    <BaseHead 
      title={SITE_TITLE} 
      description={SITE_DESCRIPTION} 
      isHomePage={true}
      currentLang={lang}
    />
  </head>
  <body class="bg-[var(--drivon-bg)] text-[var(--drivon-text)] antialiased">
    <Header />
    <main>
      {jsonData.sections?.map((section) => {
        return (
          <>
            {section.type === 'marqueeSection' && (
              <Marquee items={section.items} />
            )}
            {section.type === 'welcomeSection' && (
              <Welcome
                title={section.title}
                description={section.description}
                blogLink={`/${lang}${section.blogLink}`}
                blogLinkText={section.blogLinkText}
                seasonLabel={section.seasonLabel}
                heroImage={section.heroImage}
                backgroundVideo={section.backgroundVideo}
              />
            )}
            
            {section.type === 'statsSection' && (
              <StatsBar stats={section.stats} />
            )}
            {section.type === 'manifestoSection' && (
              <ManifestoSection headline={section.headline} body={section.body} image={section.image} imageAlt={section.imageAlt} />
            )}
            {section.type === 'bannerSection' && (
              <Banner
                headline={section.headline}
                description={section.description}
                backgroundImage={section.backgroundImage}
                button1Text={section.button1Text}
                button1Link={`/${lang}${section.button1Link}`}
                button2Text={section.button2Text}
                button2Link={`/${lang}${section.button2Link}`}
              />
            )}
            
            {section.type === 'categoryGrid' && (
              <CategoryGrid
                title={section.title}
                description={section.description}
                categories={section.categories}
              />
            )}
            
            {section.type === 'productShowcase' && (
              <ProductShowcase
                title={section.title}
                description={section.description}
                products={section.products}
                viewAllLink={`/${lang}${section.viewAllLink}`}
                lang={lang}
              />
            )}
            
            {section.type === 'testimonialSlider' && (
              <TestimonialSlider
                title={section.title}
                testimonials={section.testimonials}
              />
            )}
            
            {section.type === 'featuredPostsSection' && (
              <FeaturedPosts
                title={section.title}
                posts={posts}
                exploreMoreLink={`/${lang}${section.exploreMoreLink}`}
                exploreMoreText={section.exploreMoreText}
              />
            )}
            
            {section.type === 'emailSignupSection' && (
              <EmailSignup
                title={section.title}
                description={section.description}
                backgroundImage={section.backgroundImage}
                formAction={section.formAction}
                buttonText={section.submitText}
              />
            )}

            {section.type === 'faqSection' && (
              <FAQ
                title={section.title}
                description={section.description}
                faqs={section.faqs}
              />
            )}

            {section.type === 'videoSection' && (
              <Video
                headline={section.headline}
                description={section.description}
                videoUrl={section.videoUrl}
                buttonText={section.buttonText}
                buttonLink={`/${lang}${section.buttonLink}`}
                headlinePosition={section.headlinePosition}
                textPosition={section.textPosition}
              />
            )}
            
            {section.type === 'featuresSection' && (
              <FeaturesSection
                title={section.title}
                features={section.features}
              />
            )}
            
            {section.type === 'bestSellers' && (
              <BestSellers
                title={section.title}
                description={section.description}
                viewAllLink={`/${lang}${section.viewAllLink}`}
                lang={lang}
                collectionHandle={section.collectionHandle}
              />
            )}
            
            {section.type === 'racingArchiveSection' && (
              <RacingArchive headline={section.headline} body={section.body} image={section.image} imageAlt={section.imageAlt} />
            )}
            {section.type === 'categoryHighlightSection' && (
              <CategoryHighlightBlocks categories={section.categories.map((c: { id: string; name: string; link: string; image: string }) => ({ ...c, link: `/${lang}${c.link}` }))} />
            )}
            {section.type === 'lifestyleSection' && (
              <LifestyleSection image={section.image} imageAlt={section.imageAlt} caption={section.caption} />
            )}
            {section.type === 'specialOffers' && (
              <SpecialOffers
                title={section.title}
                offers={section.offers.map((o: { buttonLink?: string; [key: string]: unknown }) => ({ ...o, buttonLink: o.buttonLink ? `/${lang}${o.buttonLink}` : '#' }))}
              />
            )}
            
            {section.type === 'trustBadges' && (
              <TrustBadges
                title={section.title}
                badges={section.badges}
                paymentMethods={section.paymentMethods}
                guaranteeText={section.guaranteeText}
              />
            )}
            
            {section.type === 'socialProof' && (
              <SocialProof
                title={section.title}
                stats={section.stats}
                recentActivities={section.recentActivities}
                overallRating={section.overallRating}
                totalReviews={section.totalReviews}
              />
            )}
            {section.type === 'editorialQuoteSection' && (
              <EditorialQuote quote={section.quote} attribution={section.attribution} role={section.role} />
            )}
            {section.type === 'pressStripSection' && (
              <PressStrip title={section.title} items={section.items} />
            )}
            {section.type === 'carBrandsSection' && (
              <CarBrandsStrip title={section.title} items={section.items} lang={lang} />
            )}
            {section.type === 'seasonDropSection' && (
              <SeasonDrop
                headline={section.headline}
                description={section.description}
                ctaText={section.ctaText}
                ctaLink={`/${lang}${section.ctaLink}`}
                image={section.image}
                imageAlt={section.imageAlt}
              />
            )}
            {section.type === 'followStripSection' && (
              <FollowStrip headline={section.headline} ctaText={section.ctaText} ctaLink={section.ctaLink} />
            )}
          </>
        );
      })}
    </main>
    <Footer />
  </body>
</html>