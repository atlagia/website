---
import { getLangFromUrl, useTranslations, isValidLanguage } from '@utils/i18n';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/en');
}

const translations = await useTranslations(lang);
const jsonData = translations.default;

const SITE_TITLE = `Driver Accessories - ${jsonData.siteTitle}`;
const SITE_DESCRIPTION = 'Essential driver accessories to complete your automotive culture look. From caps to bags, celebrate car culture with authentic driver gear.';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="min-h-screen bg-[var(--drivon-bg)]">
      <section class="relative py-20 bg-[var(--drivon-text)] text-[var(--drivon-bg)]">
<div class="relative max-w-6xl mx-auto px-4 text-center">
          <h1 class="text-5xl md:text-7xl font-black mb-6 uppercase tracking-tighter">
            Driver Accessories
          </h1>
          <p class="text-xl md:text-2xl mb-8 max-w-3xl mx-auto font-medium">
            Essential accessories to complete your automotive culture look and style. 
            From caps to bags, celebrate car culture with authentic driver gear.
          </p>
        </div>
      </section>

      <section class="py-16 bg-white">
        <div class="max-w-6xl mx-auto px-4">
          <h2 class="text-4xl font-bold text-center mb-12">Driver Accessory Collections</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg">
              <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                <span class="text-white text-2xl font-bold">Driver Caps</span>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2">Driver Caps</h3>
                <p class="text-[var(--drivon-muted)] text-sm">Authentic racing and car culture caps</p>
              </div>
            </div>
            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg">
              <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                <span class="text-white text-2xl font-bold">Driver Bags</span>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2">Driver Bags</h3>
                <p class="text-[var(--drivon-muted)] text-sm">Essential bags for car enthusiasts</p>
              </div>
            </div>
            <div class="bg-[var(--drivon-card)] rounded-lg border border-[var(--drivon-border)] overflow-hidden shadow-lg">
              <div class="h-48 bg-[var(--drivon-text)] flex items-center justify-center text-[var(--drivon-bg)]">
                <span class="text-white text-2xl font-bold">Racing Gear</span>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2">Racing Gear</h3>
                <p class="text-[var(--drivon-muted)] text-sm">Professional racing accessories</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
