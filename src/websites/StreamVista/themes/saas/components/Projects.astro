---
interface ProjectStats {
  [key: string]: string;
}

interface Project {
  title: string;
  category: string;
  description: string;
  image: string;
  stats: ProjectStats;
  technologies: string[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  projects: Project[];
  buttonText: string;
  buttonLink: string;
}

const { subtitle, title, description, projects, buttonText, buttonLink } = Astro.props;
---

<section class="relative py-32 overflow-hidden" style="background-color: #060818;">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-purple-500/10 via-pink-500/10 to-blue-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <!-- Badge - Now as a separate block -->
      <div class="mb-6">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-purple-500/20 backdrop-blur-sm shadow-lg shadow-purple-500/5 hover:shadow-purple-500/10 transition-all duration-300" style="background-color: rgba(10, 11, 30, 0.5);">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-pink-600 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-pink-600 to-purple-600"></span>
          </span>
          <span class="text-sm font-medium bg-gradient-to-r from-pink-500 to-purple-500 text-transparent bg-clip-text">
            {subtitle}
          </span>
        </div>
      </div>
      
      <!-- Title with animated border - Now as a separate block -->
      <div class="mb-8">
        <div class="relative inline-block">
          <h2 class="text-4xl lg:text-5xl font-bold text-white pb-4">
            {title}
            <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-purple-500 to-transparent opacity-0 animate-shine"></div>
          </h2>
          <!-- Animated Border -->
          <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-1/4 h-1">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-pink-500 to-transparent animate-border-slide"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-purple-500 to-transparent animate-border-slide-delayed"></div>
          </div>
        </div>
      </div>
      
      <!-- Description -->
      <p class="text-lg text-gray-300 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      {projects.map((project) => (
        <div class="group relative transform transition-all duration-500 hover:translate-y-[-5px]">
          <!-- Card Background with Gradient Border -->
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-2xl opacity-0 group-hover:opacity-100 blur-xl transition-all duration-700"></div>
          
          <!-- Main Card -->
          <div class="relative rounded-2xl backdrop-blur-sm border border-purple-500/10 p-8 transition-all duration-500 group-hover:border-purple-500/20" style="background-color: rgba(10, 11, 30, 0.5);">
            <!-- Category Badge -->
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 mb-6 transform transition-transform duration-500 group-hover:scale-105">
              <span class="text-sm text-purple-300">{project.category}</span>
            </div>

            <!-- Project Title -->
            <h3 class="text-2xl font-bold text-white mb-4 transition-all duration-300 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-pink-500 group-hover:to-purple-500">
              {project.title}
            </h3>

            <!-- Description -->
            <p class="text-gray-300 mb-6">
              {project.description}
            </p>

            <!-- Stats Grid -->
            <div class="grid grid-cols-3 gap-4 mb-6">
              {Object.entries(project.stats).map(([key, value]) => (
                <div class="text-center transform transition-transform duration-500 group-hover:translate-y-[-2px]">
                  <div class="text-xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">{value}</div>
                  <div class="text-sm text-gray-400 capitalize">{key}</div>
                </div>
              ))}
            </div>

            <!-- Technologies -->
            <div class="flex flex-wrap gap-2">
              {project.technologies.map((tech) => (
                <span class="px-3 py-1 text-sm font-medium rounded-full bg-white/5 text-white/80 border border-white/10 transition-all duration-300 hover:border-purple-500/20 hover:bg-white/10">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <div class="text-center">
      <a 
        href={buttonLink}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white font-medium shadow-lg shadow-purple-500/25 hover:shadow-purple-500/50 transform hover:-translate-y-1 transition-all duration-300"
      >
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-bounce-x" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bg-navy-950 {
    background-color: #060818;
  }
  
  .bg-navy-900 {
    background-color: #0a0b1e;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes bounce-x {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(3px); }
  }

  .animate-bounce-x {
    animation: bounce-x 1s ease-in-out infinite;
  }

  @keyframes border-slide {
    0%, 100% { transform: translateX(-100%); opacity: 0; }
    25%, 75% { opacity: 1; }
    50% { transform: translateX(100%); opacity: 0; }
  }

  .animate-border-slide {
    animation: border-slide 3s ease-in-out infinite;
  }

  .animate-border-slide-delayed {
    animation: border-slide 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  @keyframes shine {
    0% { opacity: 0; transform: translateX(-100%); }
    50% { opacity: 1; }
    100% { opacity: 0; transform: translateX(100%); }
  }

  .animate-shine {
    animation: shine 3s ease-in-out infinite;
  }
</style> 