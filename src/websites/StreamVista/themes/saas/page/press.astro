---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const { 
  Newspaper,
  Image,
  FileText,
  Download,
  Mail,
  Phone,
  MessageSquare,
  Award,
  TrendingUp,
  Users,
  Building,
  Calendar,
  Globe,
  Share2,
  Megaphone
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language
const currentLang = getLangFromUrl(Astro.url);

const pressContent = {
  pageTitle: "Press & Media",
  pageDescription: "Access GiaConnect's press releases, media resources, and contact information for press inquiries",
  hero: {
    badge: "Press Room",
    title: "Press & Media Center",
    description: "Welcome to GiaConnect's press room. Find the latest news, press releases, media resources, and contact information for media inquiries."
  },
  sections: [
    {
      title: "Latest News",
      icon: "Newspaper",
      description: "Recent announcements and press releases",
      items: [
        {
          title: "Press Releases",
          description: "Access our latest press releases and company announcements.",
          icon: "FileText"
        },
        {
          title: "News Coverage",
          description: "Recent media coverage and featured articles about GiaConnect.",
          icon: "Globe"
        },
        {
          title: "Company Updates",
          description: "Important updates about our products, services, and initiatives.",
          icon: "Megaphone"
        }
      ]
    },
    {
      title: "Media Resources",
      icon: "Image",
      description: "Download official media assets",
      items: [
        {
          title: "Brand Assets",
          description: "Download our logo, brand guidelines, and official imagery.",
          icon: "Download"
        },
        {
          title: "Media Kit",
          description: "Comprehensive information pack about GiaConnect for journalists.",
          icon: "FileText"
        },
        {
          title: "Image Gallery",
          description: "High-resolution images and graphics for media use.",
          icon: "Image"
        }
      ]
    },
    {
      title: "Company Facts",
      icon: "Building",
      description: "Key information about GiaConnect",
      items: [
        {
          title: "Company Overview",
          description: "Learn about our history, mission, and leadership team.",
          icon: "Users"
        },
        {
          title: "Key Metrics",
          description: "Important statistics and growth metrics about our company.",
          icon: "TrendingUp"
        },
        {
          title: "Awards",
          description: "Industry recognition and accolades received by GiaConnect.",
          icon: "Award"
        }
      ]
    },
    {
      title: "Events",
      icon: "Calendar",
      description: "Upcoming and past company events",
      items: [
        {
          title: "Conferences",
          description: "Industry events where you can meet our team.",
          icon: "Users"
        },
        {
          title: "Webinars",
          description: "Online events and educational sessions.",
          icon: "Globe"
        },
        {
          title: "Speaking Engagements",
          description: "Upcoming speaking appearances by our leadership team.",
          icon: "MessageSquare"
        }
      ]
    },
    {
      title: "Social Media",
      icon: "Share2",
      description: "Follow us on social media",
      items: [
        {
          title: "Social Channels",
          description: "Find and follow us on various social media platforms.",
          icon: "Share2"
        },
        {
          title: "Social Updates",
          description: "Latest posts and announcements from our social channels.",
          icon: "MessageSquare"
        },
        {
          title: "Media Mentions",
          description: "See what others are saying about us on social media.",
          icon: "Globe"
        }
      ]
    }
  ],
  contact: {
    title: "Press Contact",
    description: "For press and media inquiries",
    email: "press@giaconnect.com",
    button: {
      text: "Contact Press Team",
      href: "/contact"
    }
  }
};

const iconMap = {
  Newspaper,
  Image,
  FileText,
  Download,
  Mail,
  Phone,
  MessageSquare,
  Award,
  TrendingUp,
  Users,
  Building,
  Calendar,
  Globe,
  Share2,
  Megaphone
};

const getIcon = (iconName: string) => {
  return iconMap[iconName] || Newspaper;
};
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${pressContent.pageTitle} | ${siteName}`}
      description={pressContent.pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-white/90 border border-purple-100 shadow-lg mb-8">
            <Newspaper class="w-5 h-5 text-purple-600" />
            <span class="text-base font-medium text-purple-700">{pressContent.hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {pressContent.hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
            {pressContent.hero.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Press Sections -->
    {pressContent.sections.map((section) => (
      <section class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-white">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-blue-50/50"></div>
        </div>
        
        <div class="container mx-auto px-4 relative">
          <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-purple-50 border border-purple-100 mb-4">
              {(() => {
                const Icon = getIcon(section.icon);
                return <Icon class="w-5 h-5 text-purple-600" />;
              })()}
              <span class="text-base font-medium text-purple-700">{section.title}</span>
            </div>
            <h2 class="text-4xl font-bold mb-6">{section.title}</h2>
            <p class="text-xl text-gray-600">{section.description}</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            {section.items.map((item) => {
              const Icon = getIcon(item.icon);
              return (
                <div class="bg-white rounded-2xl p-8 shadow-lg shadow-purple-100/20 hover:shadow-xl transition-shadow duration-300">
                  <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                    <Icon class="w-6 h-6 text-purple-600" />
                  </div>
                  <h3 class="text-xl font-semibold mb-4">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    ))}

    <!-- Contact Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{pressContent.contact.title}</h2>
          <p class="text-xl text-white/90 mb-4">
            {pressContent.contact.description}
          </p>
          <p class="text-xl text-white/90 mb-8">
            Email us at: <a href={`mailto:${pressContent.contact.email}`} class="underline hover:text-white">{pressContent.contact.email}</a>
          </p>
          <div class="flex items-center justify-center">
            <a 
              href={pressContent.contact.button.href}
              class="px-8 py-4 rounded-xl font-medium bg-white text-purple-600 hover:bg-gray-100 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5"
            >
              {pressContent.contact.button.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <style>
      /* Animations */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-in {
        animation: fadeIn 0.6s ease-out forwards;
      }

      /* Smooth transitions */
      .transition-all {
        transition-property: all;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 150ms;
      }

      /* Ensure proper section spacing */
      section {
        position: relative;
        overflow: hidden;
      }

      /* Improve card aesthetics */
      .rounded-2xl {
        border-radius: 1rem;
      }

      .shadow-lg {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      }
    </style>
  </body>
</html> 