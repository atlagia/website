---
import { getLangFromUrl } from '@utils/i18n';

const currentLang = getLangFromUrl(Astro.url);
const isRTL = currentLang === 'ar';
const siteName = currentLang === 'ar' ? (import.meta.env.PUBLIC_SITE_NAME_ARABIC || 'جيا كونكت') : (import.meta.env.PUBLIC_SITE_NAME || 'Atlagia');

// Import the language-specific footer content
const footerData = await import(`../data/footer/footer_${currentLang}.json`).catch(() => {
  return import('../data/footer/footer_en.json');
});

const { company, product, resources, legal, social, newsletter, copyright, contact } = footerData;

// Get API base URL from environment (server-side)
const apiBaseUrl = import.meta.env.PUBLIC_FORM_API_BASE_URL || import.meta.env.FormApiBaseUrl || 'https://api.atlagia.com/atlagia/api/datavault';
// Get Atlagia access token from environment (simplified API - works for all schemas)
const atlagiaAccessToken = import.meta.env.PUBLIC_ATLAGIA_ACCESS_TOKEN || import.meta.env.ATLAGIA_ACCESS_TOKEN;
// Newsletter schema config
const newsletterSchemaId = 1;
---

<footer class="bg-gradient-to-br from-emerald-950 via-slate-950 to-emerald-900 text-slate-200">
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <!-- Newsletter Section -->
      <div class="space-y-8">
        <span class:list={[
          "text-xl font-bold bg-gradient-to-r from-emerald-400 to-cyan-300 bg-clip-text text-transparent",
          isRTL && "font-arabic-primary"
        ]}>
          {siteName}
        </span>
        <div class="mt-6">
          <h3 class:list={[
            "text-sm font-semibold leading-6 text-emerald-100",
            isRTL && "font-arabic-primary"
          ]}>
            {newsletter.title}
          </h3>
          <p class:list={[
            "mt-2 text-sm leading-6 text-slate-300",
            isRTL && "font-arabic-secondary"
          ]}>
            {newsletter.description}
          </p>
          <form id="footer-newsletter-form" method="POST" action="javascript:void(0)" class="mt-6 sm:flex sm:max-w-md">
            <label for="email-address" class="sr-only">{newsletter.placeholderText}</label>
            <input
              type="email"
              name="email"
              id="email-address"
              autocomplete="email"
              required
              class:list={[
                "w-full min-w-0 appearance-none rounded-md border border-white/10 bg-white/5 px-3 py-1.5 text-base text-white shadow-sm ring-1 ring-inset ring-white/10 placeholder:text-slate-400 focus:border-emerald-400 focus:ring-2 focus:ring-inset focus:ring-emerald-400 sm:w-64 sm:text-sm sm:leading-6",
                isRTL && "font-arabic-secondary"
              ]}
              placeholder={newsletter.placeholderText}
            />
            <div class={`mt-4 sm:mt-0 ${isRTL ? 'sm:mr-4' : 'sm:ml-4'} sm:flex-shrink-0`}>
              <button
                type="submit"
                class:list={[
                  "flex w-full items-center justify-center rounded-md bg-gradient-to-r from-emerald-500 to-cyan-500 px-3 py-2 text-sm font-semibold text-white shadow-sm shadow-emerald-700/30 hover:brightness-110 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400",
                  isRTL && "font-arabic-primary"
                ]}
              >
                {newsletter.buttonText}
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Navigation Links -->
      <div class={`mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0 ${isRTL ? 'xl:mr-32' : 'xl:ml-32'}`}>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Company Links -->
          <div>
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100",
              isRTL && "font-arabic-primary"
            ]}>
              {company.title}
            </h3>
            <ul role="list" class="mt-6 space-y-4">
              {company.links.map((link) => (
                <li>
                  <a 
                    href={`/${currentLang}${link.href}`}
                    class:list={[
                      "text-sm leading-6 text-slate-300 transition hover:text-emerald-200",
                      isRTL && "font-arabic-secondary"
                    ]}
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Product Links -->
          <div class="mt-10 md:mt-0">
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100",
              isRTL && "font-arabic-primary"
            ]}>
              {product.title}
            </h3>
            <ul role="list" class="mt-6 space-y-4">
              {product.links.map((link) => (
                <li>
                  <a 
                    href={`/${currentLang}${link.href}`}
                    class:list={[
                      "text-sm leading-6 text-slate-300 transition hover:text-emerald-200",
                      isRTL && "font-arabic-secondary"
                    ]}
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <!-- Resources Links -->
          <div>
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100",
              isRTL && "font-arabic-primary"
            ]}>
              {resources.title}
            </h3>
            <ul role="list" class="mt-6 space-y-4">
              {resources.links.map((link) => (
                <li>
                  <a 
                    href={`/${currentLang}${link.href}`}
                    class:list={[
                      "text-sm leading-6 text-slate-300 transition hover:text-emerald-200",
                      isRTL && "font-arabic-secondary"
                    ]}
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Legal Links -->
          <div class="mt-10 md:mt-0">
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100",
              isRTL && "font-arabic-primary"
            ]}>
              {legal.title}
            </h3>
            <ul role="list" class="mt-6 space-y-4">
              {legal.links.map((link) => (
                <li>
                  <a 
                    href={`/${currentLang}${link.href}`}
                    class:list={[
                      "text-sm leading-6 text-slate-300 transition hover:text-emerald-200",
                      isRTL && "font-arabic-secondary"
                    ]}
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Information Section -->
    {contact && (
      <div class="mt-16 border-t border-white/10 pt-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div>
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100 mb-4",
              isRTL && "font-arabic-primary"
            ]}>
              {contact.title}
            </h3>
            <p class:list={[
              "text-sm text-slate-200 font-medium",
              isRTL && "font-arabic-secondary"
            ]}>
              {contact.company}
            </p>
          </div>
          <div>
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100 mb-4",
              isRTL && "font-arabic-primary"
            ]}>
              {contact.addressTitle || 'Address'}
            </h3>
            <p class:list={[
              "text-sm text-slate-200",
              isRTL && "font-arabic-secondary"
            ]}>
              {contact.address}<br />
              {contact.city}, {contact.postalCode}<br />
              {contact.country}
            </p>
          </div>
          <div>
            <h3 class:list={[
              "text-sm font-semibold leading-6 text-emerald-100 mb-4",
              isRTL && "font-arabic-primary"
            ]}>
              {contact.contactTitle || 'Contact'}
            </h3>
            <p class:list={[
              "text-sm text-slate-200",
              isRTL && "font-arabic-secondary"
            ]}>
              <a href={`mailto:${contact.email}`} class="hover:text-emerald-300 transition-colors">{contact.email}</a><br />
              <a href={`tel:${contact.phone}`} class="hover:text-emerald-300 transition-colors">{contact.phone}</a>
            </p>
          </div>
        </div>
      </div>
    )}

    <!-- Footer Bottom -->
    <div class="mt-16 border-t border-white/10 pt-8 sm:mt-20 lg:mt-24">
      <div class="flex flex-col-reverse justify-between gap-y-4 sm:flex-row">
        <p class:list={[
          "text-xs leading-5 text-slate-400",
          isRTL && "font-arabic-secondary"
        ]}>
          {copyright.text}
        </p>
        <div class="flex gap-x-4">
          {social.links.map((link) => (
            <a
              href={link.href}
              class="text-slate-400 transition hover:text-emerald-200"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="sr-only">{link.name}</span>
              {link.icon === 'instagram' && (
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.805.249 2.227.419.562.217.96.477 1.382.896.419.42.679.819.896 1.381.17.422.365 1.057.419 2.227.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.054 1.17-.249 1.805-.419 2.227-.217.562-.477.96-.896 1.382-.419.419-.819.679-1.381.896-.422.17-1.057.365-2.227.419-1.266.058-1.646.07-4.85-.07M12 0C8.741 0 8.332.014 7.052.072 5.775.131 4.902.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.902.131 5.775.072 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.059 1.277.261 2.15.558 2.912.306.788.717 1.459 1.384 2.126.667.667 1.338 1.078 2.126 1.384.762.297 1.635.499 2.912.558C8.332 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 1.277-.059 2.15-.261 2.912-.558.788-.306 1.459-.717 2.126-1.384.667-.667 1.078-1.338 1.384-2.126.297-.762.499-1.635.558-2.912.058-1.28.072-1.689.072-4.948 0-3.259-.014-3.668-.072-4.948-.059-1.277-.261-2.15-.558-2.912-.306-.789-.717-1.459-1.384-2.126C21.319 1.347 20.648.935 19.86.63c-.762-.297-1.635-.499-2.912-.558C15.668.014 15.259 0 12 0z"/>
                  <path d="M12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8z"/>
                  <circle cx="18.406" cy="5.594" r="1.44"/>
                </svg>
              )}
              {link.icon === 'twitter' && (
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                </svg>
              )}
              {link.icon === 'linkedin' && (
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              )}
              {link.icon === 'github' && (
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              )}
              {link.icon === 'youtube' && (
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<script define:vars={{ apiBaseUrl, newsletterSchemaId, atlagiaAccessToken }}>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('footer-newsletter-form');
  if (!form) return;
  
  const submitButton = form.querySelector('button[type="submit"]');
  let isSubmitting = false;
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    
    // Prevent multiple submissions
    if (isSubmitting) {
      return false;
    }
    
    isSubmitting = true;
    const originalButtonText = submitButton?.textContent;
    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Subscribing...';
    }
    
    const formData = new FormData(form);
    const email = formData.get('email');
    
    // Use the same API endpoint as EmailSignup component
    const schemaId = newsletterSchemaId; // Newsletter schema ID
    const today = new Date().toISOString().split('T')[0];
    
    const subscriberData = {
      name: email?.split('@')[0] || 'Subscriber',
      email: email,
      subscriptionDate: today,
      subscriptionStatus: 'Subscribed'
    };
    
    try {
      const response = await fetch(
        `${apiBaseUrl}/builder/entities/${schemaId}/entries/create/`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Atlagia-Access-Token': atlagiaAccessToken
          },
          body: JSON.stringify({
            data: subscriberData
          })
        }
      );
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      
      const result = await response.json();
      
      if (result.id) {
        // Success
        form.reset();
        alert('Thank you for subscribing to our newsletter!');
      } else {
        throw new Error(result.error || 'Failed to subscribe');
      }
    } catch (error) {
      console.error('Newsletter subscription error:', error);
      alert('Sorry, there was an error processing your subscription. Please try again.');
    } finally {
      isSubmitting = false;
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
      }
    }
    return false;
  }, { passive: false });
});
</script>
