---
interface Message {
  text: string;
  sender: 'user' | 'ai';
  timestamp?: string;
  type?: 'text' | 'appointment' | 'confirmation';
  appointmentData?: {
    date: string;
    time: string;
    service: string;
    duration: string;
  };
}

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  messages: Message[];
  phoneNumber?: string;
  aiName?: string;
}

const { 
  title = "AI-Powered Patient Communication",
  subtitle = "See how our AI assistant handles appointment scheduling automatically",
  description = "Experience seamless appointment scheduling with our intelligent AI assistant that understands natural language and automatically books your preferred time slots.",
  messages = [],
  phoneNumber = "+1 (555) 123-4567",
  aiName = "Dentagia AI Assistant"
} = Astro.props;

// Default conversation if no messages provided
const defaultMessages: Message[] = [
  {
    text: "Hi, I need to schedule a dental cleaning appointment",
    sender: 'user',
    timestamp: '10:30 AM'
  },
  {
    text: "Hello! I'd be happy to help you schedule a dental cleaning. Let me check our available slots for you.",
    sender: 'ai',
    timestamp: '10:31 AM'
  },
  {
    text: "I have availability this week. Would you prefer:\n\n📅 Tuesday, March 15th at 2:00 PM\n📅 Thursday, March 17th at 10:00 AM\n📅 Friday, March 18th at 3:30 PM",
    sender: 'ai',
    timestamp: '10:31 AM'
  },
  {
    text: "Thursday at 10 AM works for me",
    sender: 'user',
    timestamp: '10:32 AM'
  },
  {
    text: "Perfect! I've scheduled your dental cleaning appointment for Thursday, March 17th at 10:00 AM. The appointment will take approximately 45 minutes.",
    sender: 'ai',
    timestamp: '10:32 AM',
    type: 'appointment',
    appointmentData: {
      date: "Thursday, March 17th",
      time: "10:00 AM",
      service: "Dental Cleaning",
      duration: "45 minutes"
    }
  },
  {
    text: "Great! I'll send you a confirmation message and a reminder 24 hours before your appointment. Is there anything else I can help you with?",
    sender: 'ai',
    timestamp: '10:33 AM'
  },
  {
    text: "No, that's all. Thank you!",
    sender: 'user',
    timestamp: '10:33 AM'
  },
  {
    text: "You're welcome! We look forward to seeing you on March 17th. Have a great day! 😊",
    sender: 'ai',
    timestamp: '10:33 AM'
  }
];

const conversationMessages = messages.length > 0 ? messages : defaultMessages;
---

<section id="whatsapp-section" class="relative py-24 px-4 overflow-hidden bg-white">
  <!-- Textured Background with WhatsApp Icons -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <!-- Base white -->
    <div class="absolute inset-0 bg-white"></div>
    
    <!-- Scattered WhatsApp Icons as Texture -->
    <div class="absolute inset-0 opacity-15">
      <!-- Message Icons -->
      <svg class="absolute top-20 left-10 w-16 h-16 text-[#25D366] animate-float-icon" style="animation-delay: 0s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      <svg class="absolute top-40 left-32 w-12 h-12 text-[#25D366] animate-float-icon" style="animation-delay: 0.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      <svg class="absolute top-60 right-20 w-14 h-14 text-[#25D366] animate-float-icon" style="animation-delay: 1s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      
      <!-- Speed/Lightning Icons -->
      <svg class="absolute top-32 right-40 w-16 h-16 text-[#25D366] animate-float-icon" style="animation-delay: 1.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
      <svg class="absolute bottom-40 left-20 w-14 h-14 text-[#25D366] animate-float-icon" style="animation-delay: 2s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
      <svg class="absolute bottom-60 right-32 w-12 h-12 text-[#25D366] animate-float-icon" style="animation-delay: 2.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
      
      <!-- AI/Brain Icons -->
      <svg class="absolute top-80 left-24 w-18 h-18 text-[#25D366] animate-float-icon" style="animation-delay: 3s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
      </svg>
      <svg class="absolute bottom-32 left-40 w-16 h-16 text-[#25D366] animate-float-icon" style="animation-delay: 3.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
      </svg>
      <svg class="absolute top-48 right-60 w-14 h-14 text-[#25D366] animate-float-icon" style="animation-delay: 4s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
      </svg>
      
      <!-- Checkmark Icons -->
      <svg class="absolute top-28 right-16 w-12 h-12 text-[#25D366] animate-float-icon" style="animation-delay: 4.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <svg class="absolute bottom-80 left-60 w-16 h-16 text-[#25D366] animate-float-icon" style="animation-delay: 5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <svg class="absolute bottom-20 right-16 w-14 h-14 text-[#25D366] animate-float-icon" style="animation-delay: 5.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      
      <!-- Clock/Time Icons -->
      <svg class="absolute top-64 left-52 w-12 h-12 text-[#25D366] animate-float-icon" style="animation-delay: 6s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <svg class="absolute bottom-52 right-48 w-16 h-16 text-[#25D366] animate-float-icon" style="animation-delay: 6.5s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    
    <!-- Subtle gradient overlays -->
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-50/40 via-white to-emerald-50/30"></div>
    <div class="absolute inset-0 bg-gradient-to-tl from-transparent via-emerald-100/20 to-transparent"></div>
    
    <!-- Animated blobs with WhatsApp green -->
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-emerald-100/20 to-emerald-200/10 rounded-full blur-3xl animate-blob"></div>
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-emerald-100/15 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-emerald-100/15 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      {subtitle && (
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-emerald-100 text-emerald-700 backdrop-blur-sm border border-emerald-200">
          {subtitle}
        </span>
      )}
      <h2 class="mt-4 text-3xl font-extrabold text-gray-900 sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      {description && (
        <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-600 leading-relaxed">
          {description}
        </p>
      )}
    </div>

    <!-- WhatsApp Conversation Container -->
    <div class="relative max-w-6xl mx-auto flex items-center justify-center gap-8 lg:gap-16">
      <!-- Decorative Elements - Left Side -->
      <div class="hidden lg:flex flex-col items-center gap-8 flex-1 max-w-xs">
        <!-- Floating Icon Cards -->
        <div class="w-24 h-24 bg-gradient-to-br from-emerald-400/30 to-emerald-600/20 rounded-2xl backdrop-blur-md border border-emerald-300/40 shadow-lg shadow-emerald-500/20 flex items-center justify-center animate-float-left">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </div>
        <div class="w-20 h-20 bg-gradient-to-br from-cyan-400/30 to-cyan-600/20 rounded-xl backdrop-blur-md border border-cyan-300/40 shadow-lg shadow-cyan-500/20 flex items-center justify-center animate-float-left-delay">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="w-28 h-28 bg-gradient-to-br from-emerald-500/30 to-cyan-500/20 rounded-2xl backdrop-blur-md border border-emerald-400/40 shadow-lg shadow-emerald-500/20 flex items-center justify-center animate-float-left-delay-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <!-- Connecting Lines -->
        <div class="absolute left-1/2 top-12 w-0.5 h-16 bg-gradient-to-b from-emerald-400/40 to-transparent"></div>
        <div class="absolute left-1/2 bottom-12 w-0.5 h-16 bg-gradient-to-t from-cyan-400/40 to-transparent"></div>
      </div>

      <!-- WhatsApp Phone Frame with Texture Background -->
      <div class="relative max-w-md mx-auto flex-shrink-0">
        <!-- Texture Background Around Panel -->
        <div class="absolute -inset-12 -z-10 overflow-visible">
          <!-- Gradient Orbs -->
          <div class="absolute -top-16 -left-16 w-40 h-40 bg-gradient-to-br from-emerald-300/50 to-emerald-500/30 rounded-full blur-3xl animate-pulse-slow"></div>
          <div class="absolute -bottom-16 -right-16 w-40 h-40 bg-gradient-to-br from-cyan-300/50 to-cyan-500/30 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
          <div class="absolute top-1/2 -left-12 -translate-y-1/2 w-32 h-32 bg-emerald-200/40 rounded-full blur-2xl animate-pulse-slow" style="animation-delay: 0.5s;"></div>
          <div class="absolute top-1/2 -right-12 -translate-y-1/2 w-32 h-32 bg-cyan-200/40 rounded-full blur-2xl animate-pulse-slow" style="animation-delay: 1.5s;"></div>
          
          <!-- Pattern Overlay -->
          <div class="absolute inset-0 opacity-25">
            <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%2310b981\" fill-opacity=\"0.4\"%3E%3Ccircle cx=\"30\" cy=\"30\" r=\"2\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] animate-texture-drift"></div>
          </div>
          
          <!-- Glow Border -->
          <div class="absolute inset-0 rounded-3xl border-2 border-emerald-300/30 animate-glow-pulse"></div>
          <div class="absolute inset-[-2px] rounded-3xl border border-cyan-300/20 animate-glow-pulse-delay"></div>
        </div>

        <!-- WhatsApp Phone Frame -->
        <div class="relative bg-[#0b141a] rounded-3xl shadow-2xl overflow-hidden border border-emerald-500/20 backdrop-blur-sm z-10">
        <!-- WhatsApp Header -->
        <div class="bg-[#202c33] px-4 py-3 flex items-center gap-3 border-b border-emerald-500/10">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-cyan-500 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.487 5.235 3.487 8.413 0 6.557-5.338 11.892-11.894 11.892-1.99 0-3.875-.527-5.547-1.478l-6.313 1.701zm5.626-4.825l.32.185c1.479.851 3.162 1.302 4.891 1.302 5.449 0 9.888-4.434 9.889-9.888.001-5.454-4.434-9.889-9.889-9.889-5.452 0-9.887 4.434-9.887 9.888 0 1.791.48 3.515 1.348 5.021l.204.354-1.016 3.71z"/>
            </svg>
          </div>
          <div class="flex-1">
            <div class="text-white font-semibold">{aiName}</div>
            <div class="text-xs text-emerald-400">Online • Typically replies instantly</div>
          </div>
          <div class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
            </svg>
          </div>
        </div>

        <!-- Chat Messages -->
        <div id="whatsapp-messages" class="bg-[#0b141a] px-4 py-6 space-y-4 min-h-[500px] max-h-[600px] overflow-y-auto whatsapp-scroll" style="scroll-behavior: smooth;">
          {conversationMessages.map((message, index) => (
            <>
              <!-- Typing Indicator (shown before message) -->
              <div 
                id={`typing-${index}`}
                class:list={[
                  "flex gap-2 typing-indicator",
                  message.sender === 'user' ? 'justify-end' : 'justify-start'
                ]}
                style="display: none;"
              >
                {message.sender === 'ai' && (
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-cyan-500 flex items-center justify-center flex-shrink-0 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.487 5.235 3.487 8.413 0 6.557-5.338 11.892-11.894 11.892-1.99 0-3.875-.527-5.547-1.478l-6.313 1.701zm5.626-4.825l.32.185c1.479.851 3.162 1.302 4.891 1.302 5.449 0 9.888-4.434 9.889-9.888.001-5.454-4.434-9.889-9.889-9.889-5.452 0-9.887 4.434-9.887 9.888 0 1.791.48 3.515 1.348 5.021l.204.354-1.016 3.71z"/>
                    </svg>
                  </div>
                )}
                <div 
                  class:list={[
                    "rounded-lg px-4 py-2 shadow-md typing-bubble",
                    message.sender === 'user' 
                      ? 'bg-emerald-500/20 text-emerald-400 rounded-tr-none' 
                      : 'bg-[#202c33] text-[#8696a0] rounded-tl-none'
                  ]}
                >
                  <div class="flex items-center gap-1 typing-dots-container">
                    <span class="typing-dot"></span>
                    <span class="typing-dot"></span>
                    <span class="typing-dot"></span>
                  </div>
                </div>
                {message.sender === 'user' && (
                  <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
