<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('whatsapp-section');
    const messagesContainer = document.getElementById('whatsapp-messages');
    if (!section || !messagesContainer) return;

    // Initialize scroll to top
    messagesContainer.scrollTop = 0;

    const messages = messagesContainer.querySelectorAll('.message-item');
    const typingIndicators = messagesContainer.querySelectorAll('.typing-indicator');
    let currentIndex = 0; // Start from beginning - all messages hidden initially
    let hasStarted = false;
    let animationRunning = false;

    // Smart scroll function - scrolls down gradually to show new messages
    const scrollToShowMessage = (messageElement) => {
      const containerRect = messagesContainer.getBoundingClientRect();
      const messageRect = messageElement.getBoundingClientRect();
      const messageBottom = messageRect.bottom - containerRect.top;
      const containerHeight = containerRect.height;
      
      // Only scroll if message is below the visible area (with some padding)
      if (messageBottom > containerHeight - 80) {
        const scrollAmount = messageBottom - containerHeight + 120; // Add padding to show old and new
        messagesContainer.scrollBy({
          top: scrollAmount,
          behavior: 'smooth'
        });
      }
    };

    // Show messages one by one with delays
    const showNextMessage = () => {
      if (currentIndex >= messages.length) {
        // All messages shown, stop animation
        animationRunning = false;
        return;
      }

      const message = messages[currentIndex];
      const typingIndicator = typingIndicators[currentIndex];
      const isAIMessage = message.classList.contains('justify-start');
      
      // Show typing indicator for 1 second (same for all messages)
      if (typingIndicator) {
        typingIndicator.style.display = 'flex';
        setTimeout(() => {
          typingIndicator.classList.add('show');
        }, 50);
      }
      
      // Typing duration - 1 second for all messages
      const typingDuration = 1000;
      
      setTimeout(() => {
        // Hide typing indicator
        if (typingIndicator) {
          typingIndicator.classList.remove('show');
          setTimeout(() => {
            typingIndicator.style.display = 'none';
          }, 300);
        }
        
        // Show actual message
        message.classList.add('visible');
        
        // Smart scroll - only scroll if needed to show the message
        setTimeout(() => {
          scrollToShowMessage(message);
        }, 300);
        
        // Calculate delay based on message length
        const textElement = message.querySelector('p, div');
        const textLength = textElement ? textElement.textContent.length : 100;
        const delay = isAIMessage 
          ? Math.max(1200, Math.min(2500, textLength * 25))
          : Math.max(1000, Math.min(2000, textLength * 20));
        
        currentIndex++;
        setTimeout(showNextMessage, delay);
      }, typingDuration);
    };

    // Start animation when section comes into view
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasStarted && !animationRunning) {
          hasStarted = true;
          animationRunning = true;
          
          // Start showing messages after a short delay
          setTimeout(showNextMessage, 1000);
        }
      });
    }, {
      threshold: 0.5, // Start when 50% of section is visible (more strict)
      rootMargin: '100px 0px' // Add margin to ensure section is really in view
    });

    observer.observe(section);
  });
</script>

