---
interface Feature {
  title: string;
  description: string;
  icon: string; // "scheduling", "analytics", "communication", "automation"
  metric?: {
    value: string;
    label: string;
  };
}

interface Benefit {
  title: string;
  description: string;
}

interface CtaButton {
  text: string;
  link: string;
}

export interface Props {
  subtitle?: string;
  title: string;
  description: string;
  features: Feature[];
  benefits?: Benefit[];
  ctaButton?: CtaButton;
}

const { subtitle, title, description, features, benefits, ctaButton } = Astro.props;

const icons = {
  scheduling: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <line x1="16" y1="2" x2="16" y2="6"></line>
      <line x1="8" y1="2" x2="8" y2="6"></line>
      <line x1="3" y1="10" x2="21" y2="10"></line>
      <path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01M16 18h.01"></path>
    </svg>
  `,
  analytics: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
    </svg>
  `,
  communication: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
  `,
  automation: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M13 10V3L4 14h7v7l9-11h-7z"></path>
    </svg>
  `,
  patient: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
    </svg>
  `,
  security: `
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
    </svg>
  `
};
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-gray-900 via-emerald-950 to-gray-900" id="ai-agent-section">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-bl from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-cyan-500/5 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      {subtitle && (
        <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium rounded-full bg-emerald-500/20 text-emerald-300 backdrop-blur-sm border border-emerald-500/30">
          {subtitle}
        </span>
      )}
      <h2 class="mt-4 text-4xl font-extrabold text-white sm:text-5xl lg:text-6xl mb-6" set:html={title}></h2>
      <p class="max-w-3xl mx-auto mt-6 text-lg text-gray-300 leading-relaxed">{description}</p>
    </div>

    <!-- AI Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-16 mb-20">
      {features.map((feature, index) => (
        <div class="group relative">
          <!-- Card Glow Effect -->
          <div class="absolute -inset-0.5 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-2xl blur opacity-0 group-hover:opacity-30 transition duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative h-full bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-emerald-500/20 group-hover:border-emerald-500/40 transition-all duration-300 group-hover:bg-white/8">
            <!-- Icon -->
            <div class="flex items-center justify-center w-16 h-16 rounded-xl bg-gradient-to-br from-emerald-500 to-cyan-500 shadow-lg shadow-emerald-500/30 mb-6 group-hover:scale-110 transition-transform duration-300">
              <Fragment set:html={icons[feature.icon] || icons.scheduling} />
            </div>

            <!-- Content -->
            <h3 class="text-xl font-bold text-white mb-3">{feature.title}</h3>
            <p class="text-gray-300 leading-relaxed mb-6">{feature.description}</p>

            <!-- Metric -->
            {feature.metric && (
              <div class="pt-6 border-t border-emerald-500/20">
                <div class="flex items-baseline gap-2">
                  <div class="text-3xl font-bold text-emerald-400">{feature.metric.value}</div>
                  <div class="text-sm text-gray-400">{feature.metric.label}</div>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Benefits Section -->
    {benefits && benefits.length > 0 && (
      <div class="mt-20 pt-20 border-t border-emerald-500/20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {benefits.map((benefit, index) => (
            <div class="group relative">
              <div class="relative bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-emerald-500/10 group-hover:border-emerald-500/30 transition-all duration-300 group-hover:bg-white/8">
                <div class="flex items-start gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500/30 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-lg font-semibold text-white mb-2">{benefit.title}</h4>
                    <p class="text-gray-300 text-sm leading-relaxed">{benefit.description}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
    
    <!-- CTA Button -->
    {ctaButton && (
      <div class="mt-16 text-center">
        <a 
          href={ctaButton.link} 
          class="inline-flex items-center gap-2 px-8 py-4 font-semibold text-white transition-all duration-300 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-xl hover:from-emerald-600 hover:to-cyan-600 hover:shadow-xl hover:shadow-emerald-500/50 transform hover:scale-105"
        >
          {ctaButton.text}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }
  .animate-blob {
    animation: blob 20s infinite linear;
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
  
  .bg-grid-pattern {
    background-image: 
      linear-gradient(to right, rgba(16, 185, 129, 0.1) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(16, 185, 129, 0.1) 1px, transparent 1px);
    background-size: 30px 30px;
  }

  .text-gradient {
    background: linear-gradient(135deg, #10b981 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
