---
import { Button } from './ui/Button';
import { ArrowRight } from 'lucide-react';
import * as LucideIcons from 'lucide-react';

interface Logo {
  src: string;
  alt: string;
}

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  badge: string;
  title: string;
  description: string;
  blogLink: string;
  blogLinkText: string;
  heroImage?: string;
  heroVideo?: string;
  heroVideoThumbnail?: string;
  partnerLogos: Logo[];
  getStartedText?: string;
  getStartedLink?: string;
  features: Feature[];
  trustedBy?: string;
}

const { 
  badge, 
  title, 
  description, 
  blogLink, 
  blogLinkText, 
  heroImage, 
  heroVideo,
  heroVideoThumbnail,
  partnerLogos,
  getStartedText = 'Get Started Free',
  getStartedLink = '/discuss-project',
  features,
  trustedBy = 'Trusted by dental practices'
} = Astro.props;

// Extract YouTube video ID from URL
function getYouTubeVideoId(url: string): string | null {
  if (!url) return null;
  // Handle youtu.be format
  if (url.includes('youtu.be/')) {
    const match = url.match(/youtu\.be\/([^#&?]*)/);
    return match && match[1] ? match[1] : null;
  }
  // Handle youtube.com/watch?v= format
  const regExp = /^.*(?:youtube\.com\/watch\?v=|youtube\.com\/embed\/|youtube\.com\/v\/)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[1] && match[1].length === 11) ? match[1] : null;
}

const videoId = heroVideo ? getYouTubeVideoId(heroVideo) : null;
if (videoId) {
  console.log('Video ID extracted:', videoId, 'from URL:', heroVideo);
}

// Extract language from URL path - handle both root and /lang paths
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const lang = pathParts.length > 0 && pathParts[0].length === 2 ? pathParts[0] : 'en';
const isRTL = lang === 'ar';
const dir = isRTL ? 'rtl' : 'ltr';
const textAlign = isRTL ? 'text-right' : 'text-left';
const flexDirection = isRTL ? 'flex-row-reverse' : 'flex-row';
const gridOrder = isRTL ? 'lg:grid-cols-2' : 'lg:grid-cols-2';

// Helper function to get icon component from Lucide
function getIconComponent(iconName: string) {
  // Handle different icon name formats
  const normalizedName = iconName
    .replace(/-/g, '') // Remove hyphens
    .replace(/([A-Z])/g, '$1') // Preserve camelCase
    .split('')
    .map((char, index) => {
      if (index === 0) return char.toUpperCase();
      return char;
    })
    .join('');
  
  // Try exact match first
  if (LucideIcons[iconName as keyof typeof LucideIcons]) {
    return LucideIcons[iconName as keyof typeof LucideIcons];
  }
  
  // Try normalized name
  if (LucideIcons[normalizedName as keyof typeof LucideIcons]) {
    return LucideIcons[normalizedName as keyof typeof LucideIcons];
  }
  
  // Try with common variations
  const variations = [
    iconName,
    normalizedName,
    iconName.charAt(0).toUpperCase() + iconName.slice(1),
    iconName.toLowerCase(),
    iconName.toUpperCase()
  ];
  
  for (const variation of variations) {
    if (LucideIcons[variation as keyof typeof LucideIcons]) {
      return LucideIcons[variation as keyof typeof LucideIcons];
    }
  }
  
  // Fallback to a default icon
  return LucideIcons.Circle;
}

// Process title to ensure proper HTML rendering
const processedTitle = title.replace(
  /<span class='text-gradient'>(.*?)<\/span>/g,
  (_, content) => `<span class="inline-block relative">
    <span class="absolute -inset-1 bg-gradient-to-r from-teal-600/20 via-cyan-600/20 to-blue-600/20 blur rounded-lg"></span>
    <span class="relative bg-gradient-to-r from-teal-600 via-cyan-600 to-blue-600 bg-clip-text text-transparent animate-gradient">${content}</span>
  </span>`
);

// Process description to ensure proper HTML rendering
const processedDescription = description.replace(
  /<p>(.*?)<\/p>/g,
  (_, content) => `<p class="mb-4">${content}</p>`
);
---

<section class="relative min-h-[80vh] flex items-center justify-center px-4 py-12 md:py-16 overflow-hidden bg-gradient-to-b from-teal-50/30 via-white to-cyan-50/30" dir={dir}>
  <!-- Enhanced Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs with enhanced animations -->
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-gradient-to-br from-teal-500/8 via-cyan-500/8 to-blue-500/8 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-gradient-to-tr from-blue-500/8 via-teal-500/8 to-cyan-500/8 rounded-full blur-3xl animate-float-delayed-slow"></div>
    <!-- Decorative Grid with fade animation -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-5 animate-fade-in"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Top Row: Badge, Title, and Image aligned -->
    <div class={`grid ${gridOrder} gap-6 lg:gap-10 items-start mb-3`}>
      <!-- Badge and Title (Always Left) -->
      <div class={`lg:order-1 ${textAlign}`}>
        <!-- Enhanced Badge with slide-in animation -->
        <div class="animate-slide-down mb-4">
          <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/80 border border-teal-200/50 backdrop-blur-sm shadow-sm hover:shadow-md hover:border-teal-300/50 transition-all duration-300">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-gradient-to-r from-teal-500 to-cyan-500"></span>
            </span>
            <span class="text-sm font-semibold bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent">
              {badge}
            </span>
          </div>
        </div>

        <!-- Enhanced Title with animated border - Left Aligned -->
        <div class="relative animate-slide-up">
          <!-- Title Background Effect -->
          <div class="absolute -inset-2 bg-gradient-to-r from-teal-600/5 via-cyan-600/5 to-blue-600/5 blur-xl rounded-xl"></div>
          
          <div class="relative">
            <h1 class={`relative text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight tracking-tight pb-1 text-gray-900 ${textAlign}`} set:html={processedTitle} />
            
            <!-- Animated Bottom Rule - Direction Aligned -->
            <div class={`absolute -bottom-1 ${isRTL ? 'right-0' : 'left-0'} w-24 md:w-32 h-1`}>
              <div class={`absolute inset-0 ${isRTL ? 'bg-gradient-to-l' : 'bg-gradient-to-r'} from-teal-500 via-cyan-500 to-transparent ${isRTL ? 'animate-border-slide-rtl' : 'animate-border-slide'}`}></div>
              <div class={`absolute inset-0 ${isRTL ? 'bg-gradient-to-l' : 'bg-gradient-to-r'} from-cyan-500 via-blue-500 to-transparent ${isRTL ? 'animate-border-slide-rtl-delayed' : 'animate-border-slide-delayed'}`}></div>
            </div>
          </div>
        </div>

        <!-- Enhanced Description with fade-in animation - Direction Aligned -->
        <div class={`text-base md:text-lg text-gray-600/90 max-w-2xl leading-relaxed animate-fade-in ${textAlign} mt-2`} set:html={processedDescription} />
      </div>

      <!-- Hero Video/Image (Always Right) -->
      <div class="relative group lg:order-2 animate-slide-left">
        <!-- Enhanced Glow Effect -->
        <div class="absolute -inset-10 bg-gradient-to-r from-teal-500/5 via-cyan-500/5 to-blue-500/5 rounded-full blur-3xl opacity-50 group-hover:opacity-75 transition-all duration-1000"></div>
        
        <!-- Floating Elements with enhanced animations -->
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-gradient-to-br from-teal-500/10 to-cyan-500/10 rounded-full blur-2xl animate-float"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gradient-to-br from-blue-500/10 to-teal-500/10 rounded-full blur-2xl animate-float-delayed"></div>
        
        <!-- Main Video/Image Container with hover effect -->
        <div class="relative transform group-hover:scale-[1.02] transition-all duration-700 ease-out">
          <!-- Subtle Gradient Overlay -->
          <div class="absolute inset-0 bg-gradient-to-tr from-teal-500/5 via-transparent to-cyan-500/5 mix-blend-overlay rounded-3xl z-10 pointer-events-none"></div>
          
          {videoId ? (
            <div 
              id="video-container" 
              class="relative w-full rounded-3xl shadow-2xl border border-white/50 overflow-hidden animate-float-subtle cursor-pointer" 
              style="filter: drop-shadow(0 25px 25px rgba(20, 184, 166, 0.15)); aspect-ratio: 16/10; position: relative;"
            >
              <!-- Video Thumbnail (shown initially) -->
              <div id="video-thumbnail" class="relative w-full h-full">
                <img 
                  src={heroVideoThumbnail || heroImage || `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
                  alt="Dental Practice Management Software"
                  class="w-full h-full object-cover"
                />
                <!-- Play Button Overlay -->
                <div class="absolute inset-0 flex items-center justify-center bg-black/20 hover:bg-black/30 transition-all duration-300">
                  <div class="relative">
                    <div class="absolute inset-0 bg-white/20 rounded-full blur-xl"></div>
                    <div class="relative w-20 h-20 md:w-24 md:h-24 bg-red-600 rounded-full flex items-center justify-center shadow-2xl hover:bg-red-700 transition-all duration-300 hover:scale-110">
                      <svg class="w-8 h-8 md:w-10 md:h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Video Iframe (hidden initially) -->
              <iframe
                id="video-iframe"
                src=""
                data-src={`https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1&autoplay=1&enablejsapi=1`}
                title="Dental Practice Management Software"
                class="absolute inset-0 w-full h-full z-30"
                style="display: none; width: 100%; height: 100%; border: none; position: absolute; top: 0; left: 0;"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          ) : heroImage ? (
            <img 
              src={heroImage}
              alt="Dental Practice Management Software"
              class="relative w-full rounded-3xl shadow-2xl border border-white/50 animate-float-subtle"
              style="filter: drop-shadow(0 25px 25px rgba(20, 184, 166, 0.15)); aspect-ratio: 16/10;"
            />
          ) : null}
          
          <!-- Dynamic Particles Effect -->
          <div class="absolute inset-0 pointer-events-none z-20">
            <div class="absolute top-1/4 right-1/4 w-2 h-2 bg-teal-500/30 rounded-full animate-ping"></div>
            <div class="absolute bottom-1/3 left-1/3 w-2 h-2 bg-cyan-500/30 rounded-full animate-ping" style="animation-delay: 1s;"></div>
            <div class="absolute top-1/2 right-1/3 w-2 h-2 bg-blue-500/30 rounded-full animate-ping" style="animation-delay: 2s;"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section: Features, CTAs, Trust Indicators - Left Column Only -->
    <div class="grid lg:grid-cols-2 gap-6 lg:gap-10">
      <!-- Left Column: Features, CTAs, Trust -->
      <div class="space-y-6 lg:space-y-8 animate-slide-right">
        <!-- Features Grid with better spacing -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
          {features.map((feature, index) => {
            const IconComponent = getIconComponent(feature.icon);
            return (
              <div class={`group relative p-4 rounded-2xl bg-white/80 backdrop-blur-sm border border-teal-100/30 hover:border-teal-300/50 hover:bg-white transition-all duration-500 hover:shadow-xl hover:shadow-teal-500/10 hover:-translate-y-1 animate-fade-in`} style={`animation-delay: ${index * 150}ms`}>
                <!-- Hover glow effect -->
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-teal-500/0 via-cyan-500/0 to-blue-500/0 group-hover:from-teal-500/5 group-hover:via-cyan-500/5 group-hover:to-blue-500/5 transition-all duration-500 -z-10"></div>
                
                <div class="flex items-start gap-3 relative z-10">
                  <div class="flex-shrink-0 p-2 rounded-lg bg-gradient-to-br from-teal-500/10 via-cyan-500/10 to-blue-500/10 group-hover:from-teal-500/20 group-hover:via-cyan-500/20 group-hover:to-blue-500/20 transition-all duration-500 shadow-sm group-hover:shadow-md">
                    <IconComponent class="w-5 h-5 text-teal-600 group-hover:text-teal-700 group-hover:scale-110 transition-all duration-500" />
                  </div>
                  <div class="flex-1">
                    <h3 class={`font-semibold text-base text-gray-900 group-hover:text-teal-600 transition-colors duration-300 mb-1 ${textAlign}`}>{feature.title}</h3>
                    <p class={`text-xs text-gray-600 leading-relaxed ${textAlign}`}>{feature.description}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- CTA Buttons with improved design -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a 
            href={getStartedLink}
            class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-gradient-to-r from-teal-600 via-cyan-600 to-blue-600 text-white font-semibold hover:opacity-95 transition-all duration-300 hover:shadow-xl hover:shadow-teal-500/30 hover:-translate-y-1 animate-slide-up overflow-hidden"
            style="animation-delay: 300ms"
          >
            <!-- Shimmer effect -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
            <span class="relative z-10">{getStartedText}</span>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300 relative z-10" />
          </a>
          <a 
            href={blogLink}
            class="group relative inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white text-gray-900 font-semibold hover:bg-gray-50 border-2 border-teal-200 hover:border-teal-300 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 animate-slide-up"
            style="animation-delay: 450ms"
          >
            <span>{blogLinkText}</span>
            <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
          </a>
        </div>

        <!-- Trust Indicators Section -->
        <div class="pt-6 border-t border-teal-100/50">
          <p class={`text-xs text-gray-500 uppercase tracking-wider mb-4 ${textAlign}`}>
            {trustedBy}
          </p>
          <div class="flex flex-wrap items-center justify-start gap-4 md:gap-6">
            {partnerLogos.map((logo, index) => (
              <div class="relative group animate-fade-in" style={`animation-delay: ${600 + index * 150}ms`}>
                <div class="absolute inset-0 bg-gradient-to-r from-teal-500/5 via-cyan-500/5 to-blue-500/5 rounded-lg blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <img 
                  src={logo.src} 
                  alt={logo.alt} 
                  class="h-6 md:h-8 opacity-60 group-hover:opacity-100 transition-all duration-300 group-hover:scale-105 relative filter grayscale group-hover:grayscale-0"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
      <!-- Right Column: Empty (image stays in top row) -->
      <div></div>
    </div>
    </div>
  </div>
</section>

<script>
  // Ensure animations work on both direct load and dynamic content insertion
  document.addEventListener('DOMContentLoaded', initAnimations);
  window.addEventListener('contentLoaded', initAnimations);
  
  function initAnimations() {
    const section = document.querySelector('section');
    if (section && section.classList.contains('min-h-[90vh]')) {
      // Force reflow to trigger CSS animations
      void section.offsetWidth;
      
      // Add a loaded class to trigger animations
      section.classList.add('loaded');
    }
  }
  
  // Run immediately in case DOMContentLoaded already fired
  if (document.readyState === 'loading') {
    // Still loading
  } else {
    initAnimations();
  }

  // Video thumbnail click handler
  function initVideoPlayer() {
    const videoContainer = document.getElementById('video-container');
    const videoThumbnail = document.getElementById('video-thumbnail');
    const videoIframe = document.getElementById('video-iframe');
    
    if (!videoContainer || !videoThumbnail || !videoIframe) {
      console.log('Video elements not found', { videoContainer: !!videoContainer, videoThumbnail: !!videoThumbnail, videoIframe: !!videoIframe });
      return;
    }
    
    // Check if already initialized
    if (videoContainer.dataset.initialized === 'true') {
      return;
    }
    
    videoContainer.dataset.initialized = 'true';
    
    videoContainer.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      console.log('Video clicked, loading...');
      
      // Hide thumbnail
      videoThumbnail.style.display = 'none';
      
      // Show and load iframe
      const dataSrc = videoIframe.getAttribute('data-src');
      console.log('Video src:', dataSrc);
      
      if (dataSrc) {
        videoIframe.src = dataSrc;
        videoIframe.style.display = 'block';
        videoIframe.style.width = '100%';
        videoIframe.style.height = '100%';
        videoIframe.style.position = 'absolute';
        videoIframe.style.top = '0';
        videoIframe.style.left = '0';
        videoIframe.style.zIndex = '30';
      } else {
        console.error('No data-src found for video iframe');
      }
    }, { once: false });
  }

  // Initialize video player on load
  function setupVideoPlayer() {
    setTimeout(() => {
      initVideoPlayer();
    }, 100);
  }

  document.addEventListener('DOMContentLoaded', setupVideoPlayer);
  document.addEventListener('astro:page-load', setupVideoPlayer);
  
  // Run immediately if DOM is ready
  if (document.readyState !== 'loading') {
    setupVideoPlayer();
  }
</script>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  @keyframes float-subtle {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(0, -10px); }
  }

  @keyframes gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes border-slide {
    0%, 100% { transform: translateX(-100%); opacity: 0; }
    25%, 75% { opacity: 1; }
    50% { transform: translateX(100%); opacity: 0; }
  }

  @keyframes border-slide-rtl {
    0%, 100% { transform: translateX(100%); opacity: 0; }
    25%, 75% { opacity: 1; }
    50% { transform: translateX(-100%); opacity: 0; }
  }

  @keyframes slide-up {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes slide-down {
    from { transform: translateY(-20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes slide-left {
    from { transform: translateX(50px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slide-right {
    from { transform: translateX(-50px); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-slow {
    animation: float 30s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  .animate-float-delayed-slow {
    animation: float 30s ease-in-out infinite;
    animation-delay: -15s;
  }

  .animate-float-subtle {
    animation: float-subtle 6s ease-in-out infinite;
  }

  .animate-gradient {
    background-size: 200% auto;
    animation: gradient 8s linear infinite;
  }

  .animate-border-slide {
    animation: border-slide 3s ease-in-out infinite;
  }

  .animate-border-slide-delayed {
    animation: border-slide 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  .animate-border-slide-rtl {
    animation: border-slide-rtl 3s ease-in-out infinite;
  }

  .animate-border-slide-rtl-delayed {
    animation: border-slide-rtl 3s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  .animate-slide-up {
    animation: slide-up 1s ease-out forwards;
  }

  .animate-slide-down {
    animation: slide-down 1s ease-out forwards;
  }

  .animate-slide-left {
    animation: slide-left 1s ease-out forwards;
  }

  .animate-slide-right {
    animation: slide-right 1s ease-out forwards;
  }

  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }

  .font-arabic {
    font-family: 'Cairo', sans-serif;
  }

  /* Enhanced text shadow for better readability */
  h1 {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    color: #111827 !important; /* Force dark text color */
  }
  
  /* Ensure gradient only applies to specific spans, not the whole title */
  h1 .text-transparent {
    color: transparent !important;
  }

  /* Smooth hover transitions */
  .hover-glow {
    transition: all 0.3s ease-in-out;
  }
  
  .hover-glow:hover {
    text-shadow: 0 0 8px rgba(139, 92, 246, 0.3);
  }
</style>