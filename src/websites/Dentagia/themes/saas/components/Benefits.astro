---
interface Benefit {
  title: string;
  description: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  benefits: Benefit[];
}

const { subtitle, title, description, benefits } = Astro.props;
---

<section class="relative py-24 px-4 overflow-hidden bg-gradient-to-b from-teal-50/30 via-white to-cyan-50/30">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-gradient-to-br from-teal-500/8 via-cyan-500/8 to-blue-500/8 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/3 left-1/4 w-[400px] h-[400px] bg-gradient-to-tr from-blue-500/8 via-teal-500/8 to-cyan-500/8 rounded-full blur-3xl animate-float-delayed"></div>
    <!-- Decorative Grid -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-5"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 border border-teal-200/50 backdrop-blur-sm shadow-sm hover:shadow-md transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-teal-500 to-cyan-500"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-teal-600 to-cyan-600 bg-clip-text text-transparent">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight max-w-4xl mx-auto mb-8 pb-4">
        {title}
      </h2>
      
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit, index) => (
        <div class="group relative">
          <!-- Card Background -->
          <div class="absolute inset-0 bg-white/80 backdrop-blur-sm rounded-2xl border border-teal-100/30 shadow-sm transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1 group-hover:border-teal-300/50"></div>
          <!-- Card Content -->
          <div class="relative p-8 rounded-2xl">
            <div class="mb-6">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal-500/10 via-cyan-500/10 to-blue-500/10 flex items-center justify-center group-hover:from-teal-500/20 group-hover:via-cyan-500/20 group-hover:to-blue-500/20 transition-all duration-300">
                <div class="w-6 h-6 text-teal-600">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 group-hover:text-teal-600 transition-colors duration-300">
              {benefit.title}
            </h3>
            <p class="text-gray-600 leading-relaxed">
              {benefit.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }
</style> 