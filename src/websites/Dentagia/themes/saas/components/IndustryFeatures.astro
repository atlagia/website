---
import { ArrowRight } from 'lucide-react';
import * as LucideIcons from 'lucide-react';

interface Industry {
  icon: string;
  title: string;
  description: string;
  features: string[];
  processIcons: string[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  industries: Industry[];
}

const { subtitle, title, description, industries } = Astro.props;

// Helper function to get icon component from Lucide
function getIconComponent(iconName: string) {
  // Handle different icon name formats
  const normalizedName = iconName
    .replace(/-/g, '') // Remove hyphens
    .replace(/([A-Z])/g, '$1') // Preserve camelCase
    .split('')
    .map((char, index) => {
      if (index === 0) return char.toUpperCase();
      return char;
    })
    .join('');
  
  // Try exact match first
  if (LucideIcons[iconName as keyof typeof LucideIcons]) {
    return LucideIcons[iconName as keyof typeof LucideIcons];
  }
  
  // Try normalized name
  if (LucideIcons[normalizedName as keyof typeof LucideIcons]) {
    return LucideIcons[normalizedName as keyof typeof LucideIcons];
  }
  
  // Try with common variations
  const variations = [
    iconName,
    normalizedName,
    iconName.charAt(0).toUpperCase() + iconName.slice(1),
    iconName.toLowerCase(),
    iconName.toUpperCase()
  ];
  
  for (const variation of variations) {
    if (LucideIcons[variation as keyof typeof LucideIcons]) {
      return LucideIcons[variation as keyof typeof LucideIcons];
    }
  }
  
  // Fallback to a default icon
  return LucideIcons.Circle;
}
---

<section class="relative py-32 overflow-hidden bg-gradient-to-b from-white via-emerald-50/30 to-gray-50">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-emerald-200/40 via-cyan-200/40 to-blue-200/40 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-200/40 via-emerald-200/40 to-cyan-200/40 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-5"></div>
    
    <!-- Slow pulse overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-200/20 via-transparent to-cyan-200/20 animate-pulse-slow"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-200 backdrop-blur-sm shadow-lg shadow-emerald-500/10 hover:shadow-emerald-500/20 transition-all duration-300 mb-8 bg-emerald-50">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-emerald-500 to-cyan-500"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-emerald-600 to-cyan-600 text-transparent bg-clip-text">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
        {title}
      </h2>
      
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Industry Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {industries.map((industry, index) => {
        const IconComponent = getIconComponent(industry.icon);
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 bg-white rounded-2xl border border-gray-200 shadow-sm transition-all duration-500 group-hover:border-emerald-300 group-hover:shadow-xl"></div>
            
            <div class="relative p-8">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-gradient-to-br from-emerald-100 to-cyan-100 group-hover:from-emerald-200 group-hover:to-cyan-200 transition-colors duration-300">
                  <IconComponent className="w-8 h-8 text-emerald-600" />
                </div>
                <h3 class="text-2xl font-bold text-gray-900">
                  {industry.title}
                </h3>
              </div>

              <p class="text-gray-600 mb-6">
                {industry.description}
              </p>

              <ul class="space-y-3 mb-8">
                {industry.features.map((feature) => (
                  <li class="flex items-center gap-2">
                    <div class="w-5 h-5 rounded-full bg-gradient-to-br from-emerald-100 to-cyan-100 flex items-center justify-center">
                      <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                    <span class="text-gray-600">{feature}</span>
                  </li>
                ))}
              </ul>

              <!-- Process Flow -->
              <div class="relative h-24 mt-6 bg-gradient-to-br from-emerald-50 to-cyan-50 rounded-xl p-4 border border-emerald-200">
                <div class="flex items-center justify-between">
                  {industry.processIcons.map((iconName, iconIndex) => {
                    const ProcessIcon = getIconComponent(iconName);
                    return (
                      <div class="flex items-center">
                        <div class={`w-12 h-12 rounded-full bg-white border border-emerald-200 shadow-sm flex items-center justify-center ${iconIndex === 0 ? 'animate-pulse-first' : iconIndex === 1 ? 'animate-pulse-second' : iconIndex === 2 ? 'animate-pulse-third' : 'animate-pulse-fourth'}`}>
                          <ProcessIcon className="w-6 h-6 text-emerald-600" />
                        </div>
                        {iconIndex < industry.processIcons.length - 1 && (
                          <ArrowRight className="w-6 h-6 text-emerald-500 mx-2" />
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }

  @keyframes pulse-scale {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.1);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
  }

  .animate-pulse-first {
    animation: pulse-scale 2s infinite;
  }

  .animate-pulse-second {
    animation: pulse-scale 2s infinite;
    animation-delay: 0.5s;
  }

  .animate-pulse-third {
    animation: pulse-scale 2s infinite;
    animation-delay: 1s;
  }

  .animate-pulse-fourth {
    animation: pulse-scale 2s infinite;
    animation-delay: 1.5s;
  }
</style> 