---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  image: string;
  stats: Stat[];
}

const { subtitle, title, description, image, stats } = Astro.props;
---

<section class="relative py-28 px-4 overflow-hidden bg-gradient-to-b from-[#F6FFFD] via-white to-[#E8F6FF]">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs in dental palette -->
    <div class="absolute top-1/3 right-1/4 w-[520px] h-[520px] bg-gradient-to-br from-[#0EA5E91A] via-[#14B8A61A] to-[#22D3EE1A] rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/3 left-1/4 w-[420px] h-[420px] bg-gradient-to-tr from-[#22D3EE1A] via-[#0EA5E91A] to-[#14B8A61A] rounded-full blur-3xl animate-float-delayed"></div>
    <!-- Decorative Grid -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
    <!-- Decorative Dots -->
    <div class="absolute top-20 right-20 w-20 h-20 bg-gradient-to-r from-[#0EA5E91A] to-[#14B8A61A] rounded-full filter blur-sm animate-pulse"></div>
    <div class="absolute bottom-20 left-20 w-16 h-16 bg-gradient-to-r from-[#14B8A61A] to-[#22D3EE1A] rounded-full filter blur-sm animate-pulse delay-300"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- Title Section -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/70 border border-[#0EA5E926] backdrop-blur-sm shadow-sm hover:shadow-md transition-all duration-300 mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#0EA5E9] opacity-70"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-[#0EA5E9] to-[#14B8A6]"></span>
        </span>
        <span class="text-sm font-medium text-[#0EA5E9]">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-3xl lg:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#0EA5E9] via-[#14B8A6] to-[#22D3EE] leading-tight max-w-4xl mx-auto mb-10 pt-3 pb-2">
        {title}
      </h2>
      
      <p class="text-lg text-slate-600 leading-relaxed max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <div class="flex flex-col lg:flex-row items-center gap-16">
      <!-- Image Section -->
      <div class="flex-1 relative group perspective-1000">
        <!-- Decorative Elements -->
        <div class="absolute -top-6 -right-6 w-12 h-12 bg-gradient-to-br from-[#0EA5E91A] to-[#22D3EE1A] rounded-lg transform rotate-45 animate-float-slow"></div>
        <div class="absolute -bottom-6 -left-6 w-12 h-12 bg-gradient-to-br from-[#14B8A61A] to-[#0EA5E91A] rounded-full animate-float-delayed"></div>
        
        <div class="absolute inset-0 bg-gradient-to-br from-[#0EA5E914] via-[#14B8A614] to-[#22D3EE14] rounded-3xl blur-2xl transform rotate-6 group-hover:rotate-12 transition-transform duration-500"></div>
        <div class="relative transform group-hover:translate-z-10 transition-transform duration-500">
          <div class="absolute inset-0 bg-gradient-to-r from-[#0EA5E91A] to-[#14B8A61A] rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <img 
            src={image}
            alt="AI Agency Illustration"
            class="relative w-full max-w-[600px] mx-auto rounded-2xl shadow-2xl transform group-hover:scale-[1.02] transition-all duration-500"
          />
          <!-- Image Overlay Effects -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-t from-[#0EA5E90D] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="flex-1">
        <div class="grid grid-cols-2 md:grid-cols-2 gap-6 md:gap-8">
          {stats.map((stat) => (
            <div class="relative group">
              <!-- Decorative Background -->
              <div class="absolute inset-0 bg-white/80 rounded-2xl transform transition-transform group-hover:scale-105 duration-300 border border-[#0EA5E91A]"></div>
              <!-- Stat Content -->
              <div class="relative p-6 text-center">
                <div class="text-4xl xl:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#0EA5E9] via-[#14B8A6] to-[#22D3EE] mb-3">
                  {stat.value}
                </div>
                <div class="text-sm text-slate-600 font-medium">
                  {stat.label}
                </div>
                <!-- Hover Effect -->
                <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-[#0EA5E90F] to-[#14B8A60F] opacity-0 group-hover:opacity-100 transition-all duration-300"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) rotate(45deg); }
    50% { transform: translate(0, -10px) rotate(45deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  .animate-float-slow {
    animation: float-slow 10s ease-in-out infinite;
  }

  .perspective-1000 {
    perspective: 1000px;
  }

  .translate-z-10 {
    transform: translateZ(10px);
  }

  .delay-300 {
    animation-delay: 300ms;
  }
</style> 