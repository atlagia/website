---
import * as LucideIcons from 'lucide-react';

interface AutomationFeature {
  icon: string;
  title: string;
  description: string;
  metrics: {
    value: string;
    label: string;
  }[];
}

interface Props {
  subtitle: string;
  title: string;
  description: string;
  features: AutomationFeature[];
}

const { subtitle, title, description, features } = Astro.props;

// Helper function to get icon component from Lucide
function getIconComponent(iconName: string) {
  // Handle different icon name formats
  const normalizedName = iconName
    .replace(/-/g, '') // Remove hyphens
    .replace(/([A-Z])/g, '$1') // Preserve camelCase
    .split('')
    .map((char, index) => {
      if (index === 0) return char.toUpperCase();
      return char;
    })
    .join('');
  
  // Try exact match first
  if (LucideIcons[iconName as keyof typeof LucideIcons]) {
    return LucideIcons[iconName as keyof typeof LucideIcons];
  }
  
  // Try normalized name
  if (LucideIcons[normalizedName as keyof typeof LucideIcons]) {
    return LucideIcons[normalizedName as keyof typeof LucideIcons];
  }
  
  // Try with common variations
  const variations = [
    iconName,
    normalizedName,
    iconName.charAt(0).toUpperCase() + iconName.slice(1),
    iconName.toLowerCase(),
    iconName.toUpperCase()
  ];
  
  for (const variation of variations) {
    if (LucideIcons[variation as keyof typeof LucideIcons]) {
      return LucideIcons[variation as keyof typeof LucideIcons];
    }
  }
  
  // Fallback to a default icon
  return LucideIcons.Circle;
}
---

<section class="relative py-32 overflow-hidden bg-gradient-to-b from-gray-900 via-emerald-950 to-gray-900">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-emerald-500/10 via-cyan-500/10 to-blue-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/10 via-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-[0.03]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/20 border border-emerald-500/30 backdrop-blur-sm shadow-lg shadow-emerald-500/5 hover:shadow-emerald-500/10 transition-all duration-300 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-emerald-500 to-cyan-500"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
      
      <p class="text-lg text-gray-300 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {features.map((feature) => {
        const IconComponent = getIconComponent(feature.icon);
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 bg-white/5 backdrop-blur-sm rounded-2xl border border-emerald-500/20 transition-all duration-500 group-hover:border-emerald-500/40 group-hover:shadow-xl group-hover:bg-white/8"></div>
            
            <div class="relative p-8">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-gradient-to-br from-emerald-500/20 via-cyan-500/20 to-blue-500/20 group-hover:from-emerald-500/30 group-hover:via-cyan-500/30 group-hover:to-blue-500/30 transition-colors duration-300">
                  <IconComponent className="w-8 h-8 text-emerald-400" />
                </div>
                <h3 class="text-2xl font-bold text-white group-hover:text-emerald-400 transition-colors duration-300">
                  {feature.title}
                </h3>
              </div>

              <p class="text-gray-300 mb-8">
                {feature.description}
              </p>

              <!-- Metrics Grid -->
              <div class="grid grid-cols-2 gap-4">
                {feature.metrics.map((metric) => (
                  <div class="relative group/metric">
                    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/20 to-cyan-500/20 rounded-xl opacity-0 group-hover/metric:opacity-100 transition-opacity duration-300"></div>
                    <div class="relative p-4 rounded-xl bg-white/5 backdrop-blur-sm border border-emerald-500/20">
                      <div class="text-2xl font-bold bg-gradient-to-r from-emerald-400 to-cyan-400 text-transparent bg-clip-text mb-1">
                        {metric.value}
                      </div>
                      <div class="text-sm text-gray-400">
                        {metric.label}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }
</style> 