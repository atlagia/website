---
import { FaUser } from 'react-icons/fa';

interface Review {
  name: string;
  role: string;
  company: string;
  image: string;
  content: string;
  rating: number;
}

interface Props {
  reviews: Review[];
  subtitle?: string;
  title?: string;
  description?: string;
}

const { reviews, subtitle = "CLIENT TESTIMONIALS", title = "What Our Clients Say", description = "Discover why leading businesses trust us to deliver exceptional AI-powered solutions that drive their success." } = Astro.props;

// Function to get initials from name
const getInitials = (name: string) => {
  return name.charAt(0).toUpperCase();
};
---

<section class="relative py-32 overflow-hidden bg-gradient-to-b from-slate-900 via-teal-950 to-slate-900">
  <!-- Background Effects -->
  <div class="absolute inset-0 z-0">
    <!-- Animated Gradient Orbs -->
    <div class="absolute top-1/4 right-1/3 w-[800px] h-[800px] bg-gradient-to-br from-teal-500/10 via-cyan-500/10 to-blue-500/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[600px] h-[600px] bg-gradient-to-tr from-blue-500/10 via-teal-500/10 to-cyan-500/10 rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
    
    <!-- Slow pulse overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-teal-500/5 via-transparent to-cyan-500/5 animate-pulse-slow"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-teal-500/20 backdrop-blur-sm shadow-lg shadow-teal-500/5 hover:shadow-teal-500/10 transition-all duration-300 mb-8 bg-white/5">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-teal-500 to-cyan-500"></span>
        </span>
        <span class="text-sm font-medium bg-gradient-to-r from-teal-400 to-cyan-400 text-transparent bg-clip-text text-white">
          {subtitle}
        </span>
      </div>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-white mb-6 drop-shadow-lg">
        {title}
      </h2>
      
      <p class="text-lg text-gray-300 max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Reviews Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <div class="group relative">
          <!-- Card Background -->
          <div class="absolute inset-0 bg-white/5 backdrop-blur-sm rounded-2xl border border-teal-500/10 transition-all duration-500 group-hover:border-teal-500/20 group-hover:shadow-xl group-hover:bg-white/10"></div>
          
          <!-- Content -->
          <div class="relative p-8">
            <!-- Rating Stars -->
            <div class="flex gap-1 mb-6">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Review Content -->
            <p class="text-gray-300 mb-8 italic">
              "{review.content}"
            </p>

            <!-- Author Info -->
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-teal-500/20 to-cyan-500/20 flex items-center justify-center">
                <div class="relative">
                  <FaUser class="w-6 h-6 text-teal-400" />
                  <span class="absolute inset-0 flex items-center justify-center text-sm font-semibold text-white">
                    {getInitials(review.name)}
                  </span>
                </div>
              </div>
              <div>
                <h4 class="text-white font-medium">
                  {review.name}
                </h4>
                <p class="text-sm text-gray-400">
                  {review.role} at {review.company}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.5; }
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
</style> 