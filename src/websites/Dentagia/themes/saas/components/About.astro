---
import { Brain, Code, Cpu, Layers } from 'lucide-react';

interface Feature {
  icon: string;
  title: string;
  description: string;
  keywords: string[];
  bullets: string[];
  backgroundSvg: string;
}

interface Props {
  subtitle: string;
  title: string;
  features: Feature[];
  ctaText: string;
  ctaLink: string;
}

const { subtitle, title, features, ctaText, ctaLink } = Astro.props;

// Map icon names to Lucide components
const iconMap = {
  'ai-development': Brain,
  'software-solutions': Code,
  'digital-transformation': Cpu,
  'industry-solutions': Layers
};

// Simplified position function for single keyword
function getKeywordPosition(): string {
  return 'absolute -top-2 right-0 translate-x-1/3 -translate-y-full'; // Position above and slightly to the right
}
---

<section class="relative py-24 md:py-28 overflow-hidden bg-gradient-to-b from-[#04252B] via-[#052F37] to-[#04252B]">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <!-- Soft Gradient Orbs in dental palette -->
    <div class="absolute top-1/4 right-1/3 w-[620px] h-[620px] bg-gradient-to-br from-[#0EA5E933] via-[#14B8A633] to-[#22D3EE33] rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/3 w-[500px] h-[500px] bg-gradient-to-tr from-[#0EA5E926] via-[#14B8A626] to-[#0EA5E933] rounded-full blur-3xl animate-float-delayed"></div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10 [mask-image:linear-gradient(to_bottom,transparent,black,transparent)]"></div>
    
    <!-- Animated gradient sweep -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(34,211,238,0.08),transparent_40%),radial-gradient(circle_at_80%_30%,rgba(20,184,166,0.08),transparent_35%),radial-gradient(circle_at_50%_80%,rgba(14,165,233,0.06),transparent_45%)] animate-pulse-slow"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <!-- Header Section -->
    <div class="text-center mb-10 flex flex-col items-center gap-4">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[#0EA5E94D] backdrop-blur-sm shadow-sm hover:shadow-md transition-all duration-300 bg-white/10 text-white">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#0EA5E9] opacity-60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gradient-to-r from-[#0EA5E9] to-[#14B8A6]"></span>
        </span>
        <span class="text-sm font-medium text-white">
          {subtitle}
        </span>
      </div>
      
      <div class="relative inline-block">
        <h2 class="text-3xl lg:text-4xl font-bold text-white pb-3 mb-3 drop-shadow-sm">
          {title}
        </h2>
        <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#14B8A6] to-transparent"></div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-12">
      {features.map((feature) => {
        const Icon = iconMap[feature.icon];
        return (
          <div class="group relative">
            <!-- Card Background -->
            <div class="absolute inset-0 rounded-2xl backdrop-blur-sm border border-[#0EA5E933] transition-all duration-500 group-hover:border-[#22D3EE66] bg-[#08343C]/70 group-hover:bg-[#0B3F48]/80"></div>
            
            <!-- Content -->
            <div class="relative p-6 md:p-7">
              <div class="flex items-start gap-5">
                <!-- Icon -->
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-[#0EA5E926] via-[#14B8A626] to-[#22D3EE26] flex items-center justify-center group-hover:scale-110 transition-transform duration-300 border border-[#0EA5E94D] shadow-[0_10px_30px_-12px_rgba(14,165,233,0.6)]">
                  <Icon strokeWidth={2} color="#7CE8DF" className="w-7 h-7" />
                </div>
                
                <!-- Text Content -->
                <div class="flex-1">
                  <h3 class="text-lg md:text-xl font-semibold text-white mb-2 group-hover:text-[#7CE8DF] transition-all duration-300">
                    {feature.title}
                  </h3>
                  
                  <!-- Keywords -->
                  <div class="flex flex-wrap gap-2 mb-3">
                    {feature.keywords.map((keyword) => (
                      <span class="px-2 py-1 text-xs font-medium rounded-full bg-white/10 text-[#7CE8DF] border border-[#22D3EE66]">
                        {keyword}
                      </span>
                    ))}
                  </div>
                  
                  <p class="text-slate-200/90 mb-4">
                    {feature.description}
                  </p>
                  
                  <!-- Bullets -->
                  <ul class="space-y-2">
                    {feature.bullets.map((bullet) => (
                      <li class="flex items-center gap-2 text-sm text-slate-100/90">
                        <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-r from-[#7CE8DF] to-[#22D3EE]"></span>
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>

    <!-- CTA Button -->
    <div class="text-center">
      <a 
        href={ctaLink}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-[#0EA5E9] via-[#14B8A6] to-[#22D3EE] text-white font-medium shadow-lg shadow-[#0EA5E94D] hover:shadow-[#22D3EE80] transform hover:-translate-y-1 transition-all duration-300"
      >
        {ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 animate-bounce-x" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bg-navy-950 {
    background-color: #060818;
  }
  
  .bg-navy-900 {
    background-color: #0a0b1e;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(10px, -10px) rotate(1deg); }
    50% { transform: translate(0, -15px) rotate(-1deg); }
    75% { transform: translate(-10px, -5px) rotate(1deg); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes gradient-border {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .animate-gradient-border {
    animation: gradient-border 8s linear infinite;
    background-size: 200% 200%;
  }

  @keyframes bounce-x {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(3px); }
  }

  .animate-bounce-x {
    animation: bounce-x 1s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.6; }
  }

  .animate-pulse-slow {
    animation: pulse-slow 6s ease-in-out infinite;
  }

  .delay-150 {
    animation-delay: 150ms;
  }

  .delay-300 {
    animation-delay: 300ms;
  }
</style> 