---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const { 
  Cookie,
  Shield,
  Eye,
  Settings,
  Toggle,
  Clock,
  Database,
  AlertCircle,
  CheckCircle,
  XCircle,
  Lock,
  Trash,
  HelpCircle,
  FileText,
  Globe
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language
const currentLang = getLangFromUrl(Astro.url);

const cookieContent = {
  pageTitle: "Cookie Policy",
  pageDescription: "Learn about how we use cookies and similar technologies on GiaConnect",
  hero: {
    badge: "Cookie Policy",
    title: "Our Cookie Policy",
    description: "We use cookies and similar technologies to provide, protect, and improve our services. This policy explains how and why we use these technologies and the choices you have."
  },
  sections: [
    {
      title: "What Are Cookies",
      icon: "Cookie",
      description: "Understanding cookies and how they work",
      items: [
        {
          title: "Definition",
          description: "Small text files stored on your device that help us provide and improve our services.",
          icon: "FileText"
        },
        {
          title: "Purpose",
          description: "Cookies help us remember your preferences and understand how you use our service.",
          icon: "Eye"
        },
        {
          title: "Types",
          description: "We use different types of cookies including essential, functional, and analytical cookies.",
          icon: "Database"
        }
      ]
    },
    {
      title: "Cookie Usage",
      icon: "Settings",
      description: "How we use cookies on our platform",
      items: [
        {
          title: "Essential Cookies",
          description: "Required for basic site functionality and security features.",
          icon: "Lock"
        },
        {
          title: "Functional Cookies",
          description: "Remember your preferences and personalize your experience.",
          icon: "Toggle"
        },
        {
          title: "Analytics Cookies",
          description: "Help us understand site usage and improve our services.",
          icon: "Eye"
        }
      ]
    },
    {
      title: "Your Choices",
      icon: "Settings",
      description: "Managing your cookie preferences",
      items: [
        {
          title: "Cookie Settings",
          description: "You can customize your cookie preferences through our cookie settings panel.",
          icon: "Settings"
        },
        {
          title: "Browser Controls",
          description: "Most browsers allow you to manage cookies through their settings.",
          icon: "Globe"
        },
        {
          title: "Opt-Out Options",
          description: "You can choose to opt-out of non-essential cookies at any time.",
          icon: "XCircle"
        }
      ]
    },
    {
      title: "Data Protection",
      icon: "Shield",
      description: "How we protect information collected through cookies",
      items: [
        {
          title: "Security",
          description: "We use encryption and security measures to protect cookie data.",
          icon: "Shield"
        },
        {
          title: "Retention",
          description: "Cookies expire after specific periods based on their purpose.",
          icon: "Clock"
        },
        {
          title: "Data Deletion",
          description: "You can clear cookies from your browser at any time.",
          icon: "Trash"
        }
      ]
    },
    {
      title: "Compliance",
      icon: "CheckCircle",
      description: "Our commitment to privacy regulations",
      items: [
        {
          title: "GDPR Compliance",
          description: "We follow EU regulations regarding cookie consent and transparency.",
          icon: "CheckCircle"
        },
        {
          title: "Cookie Consent",
          description: "We obtain your consent before setting non-essential cookies.",
          icon: "AlertCircle"
        },
        {
          title: "Policy Updates",
          description: "We regularly update our cookie policy to reflect changes in our practices.",
          icon: "FileText"
        }
      ]
    }
  ],
  contact: {
    title: "Cookie Questions?",
    description: "Have questions about our cookie practices?",
    email: "privacy@giaconnect.com",
    button: {
      text: "Contact Privacy Team",
      href: "/contact"
    }
  }
};

const iconMap = {
  Cookie,
  Shield,
  Eye,
  Settings,
  Toggle,
  Clock,
  Database,
  AlertCircle,
  CheckCircle,
  XCircle,
  Lock,
  Trash,
  HelpCircle,
  FileText,
  Globe
};

const getIcon = (iconName: string) => {
  return iconMap[iconName] || Cookie;
};
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${cookieContent.pageTitle} | ${siteName}`}
      description={cookieContent.pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center py-20 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-20"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-white/90 border border-purple-100 shadow-lg mb-8">
            <Cookie class="w-5 h-5 text-purple-600" />
            <span class="text-base font-medium text-purple-700">{cookieContent.hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8">
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600">
              {cookieContent.hero.title}
            </span>
          </h1>

          <p class="text-xl text-gray-600 mb-12 max-w-3xl mx-auto">
            {cookieContent.hero.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Cookie Policy Sections -->
    {cookieContent.sections.map((section) => (
      <section class="py-24 relative overflow-hidden">
        <div class="absolute inset-0 bg-white">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-blue-50/50"></div>
        </div>
        
        <div class="container mx-auto px-4 relative">
          <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-purple-50 border border-purple-100 mb-4">
              {(() => {
                const Icon = getIcon(section.icon);
                return <Icon class="w-5 h-5 text-purple-600" />;
              })()}
              <span class="text-base font-medium text-purple-700">{section.title}</span>
            </div>
            <h2 class="text-4xl font-bold mb-6">{section.title}</h2>
            <p class="text-xl text-gray-600">{section.description}</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            {section.items.map((item) => {
              const Icon = getIcon(item.icon);
              return (
                <div class="bg-white rounded-2xl p-8 shadow-lg shadow-purple-100/20 hover:shadow-xl transition-shadow duration-300">
                  <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-6">
                    <Icon class="w-6 h-6 text-purple-600" />
                  </div>
                  <h3 class="text-xl font-semibold mb-4">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    ))}

    <!-- Contact Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-blue-600">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-10"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cookieContent.contact.title}</h2>
          <p class="text-xl text-white/90 mb-4">
            {cookieContent.contact.description}
          </p>
          <p class="text-xl text-white/90 mb-8">
            Email us at: <a href={`mailto:${cookieContent.contact.email}`} class="underline hover:text-white">{cookieContent.contact.email}</a>
          </p>
          <div class="flex items-center justify-center">
            <a 
              href={cookieContent.contact.button.href}
              class="px-8 py-4 rounded-xl font-medium bg-white text-purple-600 hover:bg-gray-100 transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5"
            >
              {cookieContent.contact.button.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <style>
      /* Animations */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-in {
        animation: fadeIn 0.6s ease-out forwards;
      }

      /* Smooth transitions */
      .transition-all {
        transition-property: all;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 150ms;
      }

      /* Ensure proper section spacing */
      section {
        position: relative;
        overflow: hidden;
      }

      /* Improve card aesthetics */
      .rounded-2xl {
        border-radius: 1rem;
      }

      .shadow-lg {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      }
    </style>
  </body>
</html> 