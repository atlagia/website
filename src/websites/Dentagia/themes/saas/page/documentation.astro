---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const {
  Rocket,
  Code,
  BookOpen,
  Map,
  Zap,
  Download,
  Settings,
  FileText,
  Lock,
  Server,
  Database,
  Webhook,
  Brain,
  Workflow,
  Puzzle,
  Shield,
  Gauge,
  Upload,
  BarChart,
  Activity,
  Users,
  Github,
  Video,
  HelpCircle,
  MessageSquare,
  Calendar,
  Search,
  ArrowRight,
  ExternalLink,
  Terminal,
  Copy,
  Check
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Atlagia';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language from URL
const currentLang = getLangFromUrl(Astro.url);

// Import language-specific data
const docsData = await import(`../data/documentation/documentation_${currentLang}.json`).catch(() => {
  return import(`../data/documentation/documentation_en.json`);
});

const {
  pageTitle,
  pageDescription,
  hero,
  categories,
  sdks,
  resources,
  cta
} = docsData;

// Icon map
const iconMap = {
  Rocket,
  Code,
  BookOpen,
  Map,
  Zap,
  Download,
  Settings,
  FileText,
  Lock,
  Server,
  Database,
  Webhook,
  Brain,
  Workflow,
  Puzzle,
  Shield,
  Gauge,
  Upload,
  BarChart,
  Activity,
  Users,
  Github,
  Video,
  HelpCircle,
  MessageSquare,
  Calendar
};

const getIcon = (iconName) => iconMap[iconName] || Code;
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth" dir={currentLang === 'ar' ? 'rtl' : 'ltr'}>
  <head>
    <BaseHead 
      title={`${pageTitle} | ${SITE_TITLE}`} 
      description={pageDescription} 
    />
  </head>
  <body class={`bg-[#04252B] ${currentLang === 'ar' ? 'rtl' : 'ltr'}`}>
    <Header />

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden bg-gradient-to-br from-[#04252B] via-[#052F37] to-[#04252B]">
      <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
      
      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/20 text-emerald-300 font-medium mb-6 border border-emerald-500/30">
            <Code class="w-4 h-4" />
            {hero.badge}
          </div>
          
          <h1 class="text-5xl lg:text-6xl font-bold mb-6 text-white">
            {hero.title}
          </h1>
          
          <p class="text-xl text-slate-300 mb-12 max-w-3xl mx-auto">
            {hero.description}
          </p>

          <!-- Search Bar -->
          <div class="max-w-2xl mx-auto mb-8">
            <div class="relative flex items-center">
              <div class="absolute left-4 pointer-events-none">
                <Search class="w-5 h-5 text-slate-400" />
              </div>
              <input 
                type="text" 
                placeholder={hero.searchPlaceholder}
                class="w-full pl-12 pr-4 py-4 rounded-xl border-2 border-emerald-900 focus:border-emerald-500 focus:outline-none text-white bg-[#08343C]/70 shadow-sm placeholder-slate-400"
              />
            </div>
          </div>

          <!-- Quick Links -->
          <div class="flex flex-wrap items-center justify-center gap-4">
            {hero.quickLinks.map((link) => (
              <a 
                href={link.href}
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#08343C]/70 text-white hover:bg-emerald-600 border border-emerald-900 hover:border-emerald-500 transition-all duration-300"
              >
                {link.text}
                <ArrowRight class="w-4 h-4" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Grid -->
    {categories.map((category) => {
      const CategoryIcon = getIcon(category.icon);
      return (
        <section id={category.id} class="py-20 bg-[#052F37]">
          <div class="container mx-auto px-4">
            <div class="max-w-3xl mx-auto text-center mb-16">
              <div class="w-16 h-16 rounded-2xl bg-emerald-500/20 flex items-center justify-center mx-auto mb-6">
                <CategoryIcon class="w-8 h-8 text-emerald-400" />
              </div>
              <h2 class="text-4xl font-bold mb-4 text-white">{category.title}</h2>
              <p class="text-xl text-slate-300">{category.description}</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
              {category.items.map((item) => {
                const ItemIcon = getIcon(item.icon);
                return (
                  <a 
                    href={item.link}
                    class="group p-6 bg-[#08343C]/70 rounded-2xl hover:shadow-xl hover:bg-[#08343C] border border-emerald-900 hover:border-emerald-500 transition-all duration-300"
                  >
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center mb-4 group-hover:bg-emerald-600 transition-colors">
                      <ItemIcon class="w-6 h-6 text-emerald-400 group-hover:text-white transition-colors" />
                    </div>
                    <h3 class="text-lg font-bold mb-2 text-white group-hover:text-emerald-400 transition-colors">
                      {item.title}
                    </h3>
                    <p class="text-sm text-slate-300">
                      {item.description}
                    </p>
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      );
    })}

    <!-- SDKs Section -->
    <section class="py-20 bg-[#04252B]">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-white">{sdks.title}</h2>
          <p class="text-xl text-slate-300">{sdks.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sdks.items.map((sdk) => (
            <div class="bg-[#08343C]/70 rounded-2xl p-6 border border-emerald-900 hover:border-emerald-500 hover:shadow-lg transition-all duration-300">
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center">
                    <Code class="w-6 h-6 text-emerald-400" />
                  </div>
                  <div>
                    <h3 class="text-xl font-bold text-white">{sdk.name}</h3>
                    <span class="text-sm text-emerald-400">{sdk.version}</span>
                  </div>
                </div>
              </div>
              
              <p class="text-slate-300 mb-4">{sdk.description}</p>
              
              <!-- Install Command -->
              <div class="bg-gray-900 rounded-lg p-3 mb-4 relative group">
                <code class="text-sm text-green-400 font-mono">{sdk.installCommand}</code>
                <button class="absolute right-2 top-2 p-1.5 rounded bg-gray-800 hover:bg-gray-700 transition-colors opacity-0 group-hover:opacity-100">
                  <Copy class="w-4 h-4 text-gray-400" />
                </button>
              </div>

              <a 
                href={sdk.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-emerald-400 hover:text-emerald-300 font-medium"
              >
                View on GitHub
                <ExternalLink class="w-4 h-4" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Resources Section -->
    <section class="py-20 bg-[#052F37]">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-white">{resources.title}</h2>
          <p class="text-xl text-slate-300">{resources.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {resources.items.map((resource) => {
            const ResourceIcon = getIcon(resource.icon);
            return (
              <a 
                href={resource.link}
                target={resource.external ? "_blank" : "_self"}
                rel={resource.external ? "noopener noreferrer" : ""}
                class="group p-6 bg-[#08343C]/70 rounded-2xl hover:shadow-xl hover:bg-[#08343C] border border-emerald-900 hover:border-emerald-500 transition-all duration-300"
              >
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-emerald-600 transition-colors">
                    <ResourceIcon class="w-6 h-6 text-emerald-400 group-hover:text-white transition-colors" />
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <h3 class="text-lg font-bold text-white group-hover:text-emerald-400 transition-colors">
                        {resource.title}
                      </h3>
                      {resource.external && <ExternalLink class="w-4 h-4 text-slate-400" />}
                    </div>
                    <p class="text-sm text-slate-300">
                      {resource.description}
                    </p>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20 overflow-hidden bg-gradient-to-br from-[#04252B] via-[#052F37] to-[#04252B]">
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cta.title}</h2>
          <p class="text-xl text-slate-300 mb-8">
            {cta.description}
          </p>
          <div class="flex items-center justify-center gap-4">
            {cta.buttons.map((button) => {
              const Icon = button.icon ? iconMap[button.icon] : null;
              return (
                <a 
                  href={button.href}
                  class={`inline-flex items-center gap-2 px-8 py-4 rounded-xl ${
                    button.variant === 'primary'
                      ? 'bg-white text-emerald-600 hover:bg-gray-100'
                      : 'bg-white/10 text-white hover:bg-white/20 backdrop-blur-sm border border-white/20'
                  } font-medium transition-all duration-300`}
                >
                  {Icon && <Icon class="w-5 h-5" strokeWidth={2} />}
                  {button.text}
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Search input styling */
  input[type="text"]:focus {
    box-shadow: 0 0 0 3px rgba(147, 51, 234, 0.1);
  }

  /* Code block styling */
  code {
    font-family: 'Monaco', 'Courier New', monospace;
  }
</style>
