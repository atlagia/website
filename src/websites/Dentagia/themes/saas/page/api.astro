---
import { SITE_TITLE } from '../consts';
import { Search, Code, Box, Zap, BarChart, Settings, MessageCircle, Mail, ChevronRight, Terminal, Database, Shield } from 'lucide-react';

const theme = import.meta.env.THEME || 'default';
const lang = Astro.params.lang || 'en';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Import language-specific API documentation data
const apiData = await import(`../data/api/api_${lang}.json`);

const businessInfo = {
  name: import.meta.env.PUBLIC_BUSINESS_NAME || 'Atalsia'
};

// Map icon strings to actual components
const iconMap = {
  Code,
  Box,
  Terminal,
  Database,
  Shield,
  Zap,
  BarChart,
  Settings,
  MessageCircle,
  Mail
};

// Map sidebar categories with actual icon components
const sidebarCategories = apiData.sidebar.categories.map(category => ({
  ...category,
  icon: iconMap[category.icon]
}));

// Map featured guides with actual icon components
const featuredGuides = apiData.featured.guides.map(guide => ({
  ...guide,
  icon: iconMap[guide.icon]
}));

// Map help options with actual icon components
const helpOptions = apiData.help.options.map(option => ({
  ...option,
  icon: iconMap[option.icon]
}));

// Generate schema markup for API documentation
const apiSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  name: `API Documentation | ${businessInfo.name}`,
  description: apiData.hero?.description || "API documentation and guides",
  publisher: {
    "@type": "Organization",
    name: businessInfo.name,
    logo: {
      "@type": "ImageObject",
      url: new URL("/logo.png", Astro.url)
    }
  },
  datePublished: new Date().toISOString(),
  dateModified: new Date().toISOString()
};

// Generate schema for API categories
const categoriesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "API Documentation Categories",
  itemListElement: sidebarCategories.map((category, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "CreativeWork",
      name: category.title,
      description: category.description
    }
  }))
};

// Generate schema for featured guides if they exist
const guidesSchema = apiData.featured?.guides ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Featured API Guides",
  itemListElement: apiData.featured.guides.map((guide, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "HowTo",
      name: guide.title,
      description: guide.description,
      step: guide.steps?.map((step, stepIndex) => ({
        "@type": "HowToStep",
        position: stepIndex + 1,
        name: step.title,
        text: step.description
      })) || []
    }
  }))
} : null;

// Generate schema for help options
const helpSchema = apiData.help?.options ? {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "API Support",
  description: "Various support options for API assistance",
  offers: apiData.help.options.map(option => ({
    "@type": "Offer",
    name: option.title,
    description: option.description
  }))
} : null;

// Generate search action schema
const searchSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: Astro.url.origin,
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${Astro.url.origin}/api/search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

// Combine all schemas
const schemaMarkup = [
  apiSchema,
  categoriesSchema,
  guidesSchema,
  helpSchema,
  searchSchema
].filter(Boolean);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead 
      title={`API Documentation | ${businessInfo.name}`}
      description={apiData.hero?.description || "API documentation and guides"}
      type="article"
      schemaMarkup={schemaMarkup}
    />
  </head>
  <body class="bg-[#04252B]">
    <Header />
    <main class="pt-10">
      <!-- Hero Section -->
      <section class="relative py-20 px-4 bg-gradient-to-b from-[#04252B] via-[#052F37] to-[#04252B] overflow-hidden">
        <div class="absolute inset-0">
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-bl from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
          <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-tr from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl animate-blob"></div>
        </div>
        <div class="relative max-w-7xl mx-auto text-center">
          <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold rounded-full bg-emerald-500/20 text-emerald-300 border border-emerald-500/30">{apiData.hero.subtitle}</span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white">{apiData.hero.title}</h1>
          <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-8">
            {apiData.hero.description}
          </p>
          <div class="max-w-2xl mx-auto relative">
            <input
              type="search"
              placeholder={apiData.hero.searchPlaceholder}
              class="w-full px-6 py-4 bg-[#08343C]/70 border border-emerald-900 rounded-xl shadow-sm pl-12 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 text-white placeholder-slate-400"
            />
            <Search className="w-5 h-5 text-slate-400 absolute left-4 top-1/2 transform -translate-y-1/2" />
          </div>
        </div>
      </section>

      <!-- Main API Documentation Content -->
      <section class="relative py-16 px-4 bg-[#052F37]">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-4 gap-8">
          <!-- Sidebar -->
          <div class="lg:col-span-1">
            <nav class="space-y-8">
              {sidebarCategories.map(category => (
                <div>
                  <div class="flex items-center gap-2 mb-4">
                    <category.icon className="w-5 h-5 text-emerald-400" />
                    <h3 class="font-semibold text-white">{category.title}</h3>
                  </div>
                  <ul class="space-y-2">
                    {category.items.map(item => (
                      <li>
                        <a
                          href={item.link}
                          class="flex items-center text-slate-300 hover:text-emerald-400 py-1 transition-colors"
                        >
                          <ChevronRight className="w-4 h-4 mr-2" />
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </div>

          <!-- Main Content -->
          <div class="lg:col-span-3 space-y-12">
            <!-- Featured Guides -->
            <div>
              <h2 class="text-2xl font-bold mb-6 text-white">{apiData.featured.title}</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {featuredGuides.map(guide => (
                  <a
                    href={guide.link}
                    class="group p-6 bg-[#08343C]/70 rounded-xl hover:bg-emerald-600 transition-all duration-300 border border-emerald-900 hover:border-emerald-500"
                  >
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/20 group-hover:bg-emerald-500/40 flex items-center justify-center mb-4">
                      <guide.icon className="w-6 h-6 text-emerald-400 group-hover:text-white" />
                    </div>
                    <h3 class="font-semibold mb-2 text-white group-hover:text-white">{guide.title}</h3>
                    <p class="text-sm text-slate-300 group-hover:text-gray-200">{guide.description}</p>
                  </a>
                ))}
              </div>
            </div>

            <!-- API Endpoints -->
            <div>
              <h2 class="text-2xl font-bold mb-4 text-white">{apiData.endpoints.title}</h2>
              <p class="text-slate-300 mb-6">{apiData.endpoints.description}</p>
              <div class="space-y-6">
                {apiData.endpoints.items.map(item => (
                  <div class="flex items-start gap-4 p-6 bg-[#08343C]/70 rounded-xl border border-emerald-900">
                    <div class="flex-1">
                      <div class="flex items-center gap-3 mb-2">
                        <span class={`px-2 py-1 text-xs font-medium rounded-full ${
                          item.method === 'GET' ? 'bg-green-500/20 text-green-400' : 
                          item.method === 'POST' ? 'bg-blue-500/20 text-blue-400' : 
                          item.method === 'PUT' ? 'bg-yellow-500/20 text-yellow-400' : 
                          item.method === 'DELETE' ? 'bg-red-500/20 text-red-400' : 
                          'bg-slate-500/20 text-slate-400'
                        }`}>{item.method}</span>
                        <span class="font-mono text-sm text-slate-300">{item.path}</span>
                      </div>
                      <h3 class="font-semibold mb-1 text-white">{item.title}</h3>
                      <p class="text-sm text-slate-300">{item.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Latest Updates -->
            <div>
              <h2 class="text-2xl font-bold mb-4 text-white">{apiData.updates.title}</h2>
              <p class="text-slate-300 mb-6">{apiData.updates.description}</p>
              <div class="space-y-6">
                {apiData.updates.items.map(item => (
                  <div class="flex items-start gap-4 p-6 bg-[#08343C]/70 rounded-xl border border-emerald-900">
                    <div class="flex-1">
                      <div class="flex items-center gap-3 mb-2">
                        <span class="text-sm text-slate-400">{item.date}</span>
                        <span class="px-2 py-1 text-xs font-medium bg-emerald-500/20 text-emerald-300 rounded-full">{item.tag}</span>
                      </div>
                      <h3 class="font-semibold mb-1 text-white">{item.title}</h3>
                      <p class="text-sm text-slate-300">{item.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Need Help -->
            <div class="bg-[#08343C]/70 rounded-2xl p-8 border border-emerald-900">
              <h2 class="text-2xl font-bold mb-4 text-white">{apiData.help.title}</h2>
              <p class="text-slate-300 mb-6">{apiData.help.description}</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {helpOptions.map(option => (
                  <a
                    href={option.link}
                    class="flex items-start p-6 bg-[#04252B] rounded-xl hover:shadow-md transition-shadow border border-emerald-900"
                  >
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center mr-4">
                      <option.icon className="w-6 h-6 text-emerald-400" />
                    </div>
                    <div>
                      <h3 class="font-semibold mb-1 text-white">{option.title}</h3>
                      <p class="text-sm text-slate-300">{option.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .bg-navy-900 {
    background-color: #0a0b1e;
  }
  .bg-navy-800 {
    background-color: #12132d;
  }

  @keyframes blob {
    0% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(-50%, -50%) scale(1.1) rotate(120deg);
    }
    66% {
      transform: translate(-50%, -50%) scale(0.9) rotate(240deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(360deg);
    }
  }

  .animate-blob {
    animation: blob 20s infinite linear;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style> 