---
import { SITE_TITLE } from '../consts';
import * as LucideIcons from 'lucide-react';
import { getLangFromUrl } from '@utils/i18n';

const { 
  Stethoscope,
  Building2,
  Pill,
  Hospital,
  Flask,
  RadioTower,
  Dog,
  Tooth,
  ChevronRight,
  ArrowRight,
  Brain,
  Shield,
  TrendingUp,
  Users,
  CheckCircle,
  Globe,
  Clock,
  Zap,
  Award,
  Star,
  ShoppingBag,
  Factory,
  GraduationCap,
  Building,
  Truck,
  Store,
  Warehouse,
  Hotel,
  CloudAws,
  CloudGoogle,
  CloudMicrosoft,
  Database2,
  Cloud
} = LucideIcons;

const theme = import.meta.env.THEME || 'default';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'GiaConnect';

const { default: BaseHead } = await import(`../components/BaseHead.astro`);
const { default: Header } = await import(`../components/Header.astro`);
const { default: Footer } = await import(`../components/Footer.astro`);

// Get current language and load appropriate content
const currentLang = getLangFromUrl(Astro.url);
const solutionsData = await import(`../data/solutions/solutions_${currentLang}.json`).catch(() => 
  import(`../data/solutions/solutions_en.json`)
);

const {
  pageTitle,
  pageDescription,
  hero,
  stats,
  solutions,
  features,
  benefits,
  testimonials,
  integrations,
  faq,
  cta
} = solutionsData;

const iconMap = {
  stethoscope: Stethoscope,
  hospital: Hospital,
  building2: Building2,
  pill: Pill,
  tooth: Tooth,
  'radio-tower': RadioTower,
  flask: Flask,
  dog: Dog,
  brain: Brain,
  shield: Shield,
  'trending-up': TrendingUp,
  users: Users,
  globe: Globe,
  clock: Clock,
  zap: Zap,
  'shopping-bag': ShoppingBag,
  factory: Factory,
  'graduation-cap': GraduationCap,
  building: Building,
  truck: Truck,
  store: Store,
  warehouse: Warehouse,
  hotel: Hotel,
  CloudAws: CloudAws,
  CloudGoogle: CloudGoogle,
  CloudMicrosoft: CloudMicrosoft,
  Building2: Building2,
  Factory: Factory,
  Database2: Database2,
  Cloud: Cloud
};

const getIcon = (iconName: string) => {
  return iconMap[iconName.toLowerCase()] || Globe;
};


---

<!doctype html>
<html lang={currentLang} class="scroll-smooth">
  <head>
    <BaseHead 
      title={`${pageTitle} | ${siteName}`}
      description={pageDescription}
    />
  </head>
  <body class="bg-gray-50">
    <Header />
    
    <!-- Hero Section -->
    <section class="relative min-h-[80vh] flex items-center py-20 overflow-hidden bg-gradient-to-br from-emerald-950 via-slate-950 to-emerald-900">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
        <div class="absolute top-1/4 right-1/3 w-[620px] h-[620px] bg-gradient-to-br from-teal-500/20 via-cyan-500/20 to-emerald-500/20 rounded-full blur-3xl animate-float"></div>
        <div class="absolute bottom-1/4 left-1/3 w-[500px] h-[500px] bg-gradient-to-tr from-emerald-500/20 via-teal-500/20 to-cyan-500/20 rounded-full blur-3xl animate-float-delayed"></div>
      </div>

      <div class="relative container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/20 border border-emerald-500/30 shadow-lg mb-8 backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-sm font-medium text-emerald-300">{hero.badge}</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-bold leading-tight mb-8 text-white">
            {hero.title}
          </h1>

          <p class="text-xl text-slate-300 mb-12 max-w-3xl mx-auto">
            {hero.description}
          </p>

          <div class="flex items-center justify-center gap-4">
            <a 
              href={hero.cta.primary.href}
              class="px-8 py-4 rounded-xl bg-gradient-to-r from-emerald-600 via-teal-600 to-cyan-600 text-white font-medium hover:opacity-90 transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/25 hover:-translate-y-0.5"
            >
              {hero.cta.primary.text}
            </a>
            <a 
              href={hero.cta.secondary.href}
              class="px-8 py-4 rounded-xl bg-white/10 text-white border border-white/20 font-medium hover:bg-white/20 transition-all duration-300 hover:shadow-lg hover:shadow-white/10 hover:-translate-y-0.5 backdrop-blur-sm"
            >
              {hero.cta.secondary.text}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Banner -->
    <section class="relative py-12 bg-slate-50 border-y border-slate-200">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-4xl font-bold bg-gradient-to-r from-emerald-600 via-teal-600 to-cyan-600 bg-clip-text text-transparent">
                {stat.value}
              </div>
              <div class="text-gray-700 mt-2 font-medium">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Solutions Grid -->
    <section id="solutions" class="py-32 relative bg-white">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-emerald-50/30 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-5"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        {solutions.map((category, index) => (
          <div class={`mb-20 ${index !== 0 ? 'mt-32' : ''}`}>
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-4xl font-bold mb-6">{category.category}</h2>
              <p class="text-xl text-gray-600">{category.description}</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
              {category.items.map((solution) => {
                const Icon = getIcon(solution.icon);
                return (
                  <a 
                    href={solution.href}
                    class="group relative transform hover:-translate-y-2 transition-all duration-500"
                  >
                    <!-- Card Glow Effect -->
                    <div class={`absolute -inset-0.5 bg-gradient-to-r from-${solution.color}-500 to-${solution.color}-600 rounded-3xl blur opacity-25 group-hover:opacity-100 transition duration-500`}></div>
                    
                    <!-- Card Content -->
                    <div class="relative h-full bg-white backdrop-blur-sm rounded-3xl p-8 border border-slate-200 hover:border-emerald-300 transition-colors">
                      <div class="relative w-16 h-16 mb-6">
                        <div class="absolute inset-0 bg-emerald-100 rounded-2xl transform group-hover:scale-110 transition-transform duration-500"></div>
                        <div class="relative h-full flex items-center justify-center">
                          <Icon class="w-8 h-8 text-emerald-600" />
                        </div>
                      </div>

                      <h3 class="text-xl font-semibold mb-4 group-hover:text-emerald-600 transition-colors text-gray-900">
                        {solution.name}
                      </h3>
                      
                      <p class="text-gray-600 mb-6">
                        {solution.description}
                      </p>

                      <div class="flex items-center text-emerald-600 group-hover:translate-x-2 transition-transform duration-500">
                        <span class="font-medium mr-2">Learn More</span>
                        <ArrowRight class="w-4 h-4" />
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 bg-slate-50 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-50/30 to-slate-50"></div>
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-4">
            <span class="text-sm font-medium text-emerald-700">{features.title}</span>
          </div>
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{features.title}</h2>
          <p class="text-xl text-gray-700">{features.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {features.items.map((feature) => {
            const Icon = getIcon(feature.icon);
            return (
              <div class="bg-white rounded-2xl p-8 shadow-lg shadow-slate-100/50 hover:shadow-xl transition-shadow duration-300 border border-slate-200">
                <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mb-6">
                  <Icon class="w-6 h-6 text-emerald-600" />
                </div>
                <h3 class="text-xl font-semibold mb-4 text-gray-900">{feature.title}</h3>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-32 relative overflow-hidden bg-gradient-to-br from-emerald-950 via-slate-950 to-emerald-900">
      <!-- Background Effects -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
        <div class="absolute top-1/4 right-1/3 w-[620px] h-[620px] bg-gradient-to-br from-teal-500/20 via-cyan-500/20 to-emerald-500/20 rounded-full blur-3xl animate-float"></div>
      </div>

      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-20">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/20 backdrop-blur-sm border border-emerald-500/30 mb-4">
            <span class="text-sm font-medium text-emerald-300">Why Choose Us</span>
          </div>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-white">{benefits.title}</h2>
          <p class="text-xl text-slate-300">{benefits.description}</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {benefits.items.map((benefit) => {
            const Icon = getIcon(benefit.icon);
            return (
              <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                <!-- Card Glow Effect -->
                <div class="absolute -inset-0.5 bg-gradient-to-r from-emerald-600 via-teal-600 to-cyan-600 rounded-3xl blur opacity-30 group-hover:opacity-100 transition duration-500"></div>
                
                <!-- Card Content -->
                <div class="relative h-full bg-white/10 backdrop-blur-sm border border-emerald-500/20 rounded-3xl p-8">
                  <!-- Icon -->
                  <div class="relative w-16 h-16 mb-6 mx-auto">
                    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/20 to-teal-500/20 rounded-2xl blur-sm"></div>
                    <div class="relative h-full flex items-center justify-center">
                      <Icon class="w-8 h-8 text-white" />
                    </div>
                  </div>

                  <!-- Content -->
                  <div class="text-center">
                    <h3 class="text-2xl font-semibold text-white mb-4">{benefit.title}</h3>
                    <p class="text-slate-300 mb-6">{benefit.description}</p>
                    <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400">
                      {benefit.stats}
                    </div>
                    <div class="text-sm text-slate-400 mt-2">{benefit.label}</div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-24 bg-white relative overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-slate-50 via-white to-emerald-50/30 opacity-90"></div>
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(to_bottom,transparent,black,transparent)] opacity-5"></div>
      </div>
      
      <div class="container mx-auto px-4 relative">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-4">
            <Star class="w-4 h-4 text-emerald-600" />
            <span class="text-sm font-medium text-emerald-700">{testimonials.title}</span>
          </div>
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{testimonials.title}</h2>
          <p class="text-xl text-gray-700">{testimonials.description}</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {testimonials.items.map((testimonial) => (
            <div class="bg-white rounded-2xl p-8 shadow-lg shadow-slate-100/20 border border-slate-200">
              <div class="flex gap-4 items-center mb-6">
                <img 
                  src={testimonial.image} 
                  alt={testimonial.author}
                  class="w-16 h-16 rounded-full object-cover"
                />
                <div>
                  <div class="font-semibold text-gray-900">{testimonial.author}</div>
                  <div class="text-gray-600">{testimonial.role}</div>
                </div>
              </div>
              <p class="text-gray-700 text-lg italic">"{testimonial.quote}"</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Integration Partners -->
    <section class="py-24 bg-slate-50 border-t border-slate-200">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 border border-emerald-100 mb-4">
            <Globe class="w-4 h-4 text-emerald-600" />
            <span class="text-sm font-medium text-emerald-700">{integrations.title}</span>
          </div>
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{integrations.title}</h2>
          <p class="text-xl text-gray-700">{integrations.description}</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8">
          {[
            { icon: 'CloudAws', name: 'AWS' },
            { icon: 'CloudGoogle', name: 'Google Cloud' },
            { icon: 'CloudMicrosoft', name: 'Azure' },
            { icon: 'Building2', name: 'Salesforce' },
            { icon: 'Factory', name: 'SAP' },
            { icon: 'Database2', name: 'Oracle' }
          ].map((partner) => {
            const PartnerIcon = iconMap[partner.icon] || iconMap['Cloud'];
            return (
              <div class="group relative transform hover:-translate-y-2 transition-all duration-500">
                <!-- Card Glow Effect -->
                <div class="absolute -inset-0.5 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-xl blur opacity-0 group-hover:opacity-25 transition duration-500"></div>
                
                <!-- Card Content -->
                <div class="relative bg-white rounded-xl p-6 flex flex-col items-center justify-center gap-3 border border-slate-200 group-hover:border-emerald-300 transition-colors duration-500">
                  <div class="w-16 h-16 flex items-center justify-center bg-emerald-50 rounded-lg group-hover:bg-emerald-100 transition-colors duration-500">
                    <PartnerIcon class="w-8 h-8 text-emerald-600" />
                  </div>
                  <span class="text-sm font-medium text-gray-700 group-hover:text-emerald-600 transition-colors duration-500">{partner.name}</span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 text-gray-900">{faq.title}</h2>
          <p class="text-xl text-gray-700">{faq.description}</p>
        </div>

        <div class="max-w-3xl mx-auto space-y-6">
          {faq.items.map((item) => (
            <div class="bg-slate-50 rounded-xl p-6 shadow-sm border border-slate-200">
              <h3 class="text-lg font-semibold mb-3 text-gray-900">{item.question}</h3>
              <p class="text-gray-700">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative py-20 overflow-hidden bg-gradient-to-br from-emerald-950 via-slate-950 to-emerald-900">
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-10"></div>
        <div class="absolute top-1/4 right-1/3 w-[620px] h-[620px] bg-gradient-to-br from-teal-500/20 via-cyan-500/20 to-emerald-500/20 rounded-full blur-3xl animate-float"></div>
      </div>
      
      <div class="relative container mx-auto px-4 text-center">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-4xl font-bold text-white mb-6">{cta.title}</h2>
          <p class="text-xl text-slate-300 mb-8">
            {cta.description}
          </p>
          <div class="flex items-center justify-center gap-4">
            {cta.buttons.map((button) => (
              <a 
                href={button.href}
                class={`px-8 py-4 rounded-xl font-medium transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/25 hover:-translate-y-0.5 ${
                  button.variant === 'primary' 
                    ? 'bg-white text-emerald-600 hover:bg-gray-100' 
                    : 'bg-white/10 text-white hover:bg-white/20 backdrop-blur-sm border border-white/20'
                }`}
              >
                {button.text}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />

    <script>
      // Add smooth scrolling for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href')).scrollIntoView({
            behavior: 'smooth'
          });
        });
      });
    </script>
  </body>
</html>

<style>
  /* Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.4; }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s ease-in-out infinite;
  }

  /* Smooth transitions */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
  }

  /* Hover effects */
  .hover\:scale-105:hover {
    transform: scale(1.05);
  }

  .hover\:-translate-y-1:hover {
    transform: translateY(-0.25rem);
  }

  /* Additional animations */
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .slide-in {
    animation: slideIn 0.5s ease-out forwards;
  }

  /* Ensure proper section spacing */
  section {
    position: relative;
    overflow: hidden;
  }

  /* Improve card aesthetics */
  .rounded-2xl {
    border-radius: 1rem;
  }

  .shadow-lg {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
</style> 